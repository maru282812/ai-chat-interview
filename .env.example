# ============================================================
# アプリケーション設定
# ============================================================
PORT=3000

# 公開URL（HTTPS必須。LIFFはHTTPSでないと動作しない）
APP_BASE_URL=https://your-app.example.com

NODE_ENV=development

# ============================================================
# Supabase (データベース)
# ============================================================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# LINE Messaging API
# （LINE Developers > Messaging API チャネル で確認）
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# Webhook URL: LINE Developers で設定する値は
#   ${APP_BASE_URL}/webhooks/line
# 例: https://your-app.example.com/webhooks/line
# LINE Developers 側で "Use Webhook" を ON にすること

# ============================================================
# LIFF (LINE Front-end Framework)
# （LINE Developers > LIFF タブ で確認）
# ============================================================

# LIFF を使うチャネルの Channel ID（Messaging API チャネルと同一か、別途 Login チャネルを作成）
# ID token 検証 (liffAuthService) に使用する
# 未設定の場合: /liff/survey の本人確認が無効になる（回答は可能だが別人でも開ける）
LINE_LIFF_CHANNEL_ID=

# 汎用 LIFF ID（個別設定がない場合のフォールバック）
LINE_LIFF_ID=

# 機能別 LIFF App ID
# LINE Developers でそれぞれ LIFF App を作成し、エンドポイントURLを設定する
LINE_LIFF_ID_RANT=       # /liff/rant
LINE_LIFF_ID_DIARY=      # /liff/diary
LINE_LIFF_ID_PERSONALITY= # /liff/personality

# survey 用 LIFF ID（未設定時は LINE_LIFF_ID にフォールバック）
# エンドポイントURL: ${APP_BASE_URL}/liff/survey
# scope: openid, profile が必要
LINE_LIFF_ID_SURVEY=

# mypage 用 LIFF ID（未設定時は LINE_LIFF_ID にフォールバック）
# エンドポイントURL: ${APP_BASE_URL}/liff/mypage
LINE_LIFF_ID_MYPAGE=

# ============================================================
# アプリケーション設定
# ============================================================
DEFAULT_PROJECT_ID=your-default-project-uuid
SESSION_SUMMARY_INTERVAL=5
MAX_AI_PROBES_PER_ANSWER=1
MAX_AI_PROBES_PER_SESSION=2

# 管理画面 Basic 認証
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=change-me

# デバッグ用（本番では false に）
MENU_ACTION_DEBUG_FORCE_PROJECT_LIST=false

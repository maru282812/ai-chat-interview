<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>フロー設計 - <%= project.name %></title>
  <link rel="stylesheet" href="/public/styles.css" />
  <link rel="stylesheet" href="/public/flowDesigner.css" />
</head>
<body>
<div class="flow-page-root">

  <!-- ============================================================ -->
  <!-- Toolbar (Excel ribbon-style)                                  -->
  <!-- ============================================================ -->
  <div class="flow-toolbar">

    <!-- ナビ -->
    <div class="tb-group">
      <button class="tb-btn" id="tb-back" title="質問一覧へ戻る">
        <span class="tb-icon">←</span>
        <span class="tb-label">一覧へ</span>
      </button>
    </div>

    <!-- プロジェクト名 -->
    <div class="tb-group">
      <span class="tb-project-name" title="<%= project.name %>"><%= project.name %></span>
    </div>

    <!-- 保存 / プレビュー -->
    <div class="tb-group">
      <span class="tb-group-label">ファイル</span>
      <button class="tb-btn" id="tb-save" disabled title="選択中ノードを保存">
        <span class="tb-icon">💾</span>
        <span class="tb-label">保存</span>
      </button>
      <button class="tb-btn" id="tb-preview" title="質問一覧を別タブで開く">
        <span class="tb-icon">👁</span>
        <span class="tb-label">プレビュー</span>
      </button>
    </div>

    <!-- 表示 -->
    <div class="tb-group">
      <span class="tb-group-label">表示</span>
      <button class="tb-btn" id="tb-fit" title="全体表示">
        <span class="tb-icon">⊞</span>
        <span class="tb-label">全体</span>
      </button>
      <button class="tb-btn" id="tb-zoom-in" title="拡大">
        <span class="tb-icon">＋</span>
        <span class="tb-label">拡大</span>
      </button>
      <button class="tb-btn" id="tb-zoom-out" title="縮小">
        <span class="tb-icon">－</span>
        <span class="tb-label">縮小</span>
      </button>
    </div>

    <!-- 追加 -->
    <div class="tb-group">
      <span class="tb-group-label">追加</span>
      <button class="tb-btn" id="tb-add-question" title="質問ノード追加">
        <span class="tb-icon">📝</span>
        <span class="tb-label">質問</span>
      </button>
      <button class="tb-btn" id="tb-add-ai" title="AI深掘りノード追加">
        <span class="tb-icon">🤖</span>
        <span class="tb-label">AI深掘</span>
      </button>
      <button class="tb-btn" id="tb-add-end" title="ENDノードへスクロール">
        <span class="tb-icon">🏁</span>
        <span class="tb-label">END</span>
      </button>
    </div>

    <!-- フロー生成 -->
    <div class="tb-group">
      <span class="tb-group-label">生成</span>
      <button class="tb-btn" id="tb-import-flow" title="過去案件からフローを流用">
        <span class="tb-icon">📂</span>
        <span class="tb-label">流用</span>
      </button>
      <button class="tb-btn" id="tb-generate-flow" title="プロジェクト情報からAIがフローを自動生成">
        <span class="tb-icon">✨</span>
        <span class="tb-label">AI生成</span>
      </button>
    </div>

    <!-- モード表示 -->
    <div class="tb-group">
      <span class="tb-group-label">モード</span>
      <span style="font-size:11px;color:#4d6b66;padding:0 6px;">
        <%
          const dmLabel = project.display_mode === 'interview_chat'
            ? '🗣 インタビュー'
            : project.display_mode === 'survey_page'
            ? '📄 アンケート（ページ）'
            : '📋 アンケート（1問ずつ）';
        %>
        <%= dmLabel %>
      </span>
    </div>

    <!-- ステータス -->
    <div style="flex:1;"></div>
    <span id="flowStatusText" class=""></span>
  </div>

  <!-- ============================================================ -->
  <!-- Main: left + canvas + right                                   -->
  <!-- ============================================================ -->
  <div class="flow-main">

    <!-- ── Left panel (parts palette) ── -->
    <div class="flow-left">
      <div class="flow-left-title">部品</div>

      <div class="part-item" data-type="question">
        <span class="part-icon">📝</span>
        <span class="part-label">質問</span>
      </div>
      <div class="part-item" data-type="ai">
        <span class="part-icon">🤖</span>
        <span class="part-label">AI深掘り</span>
      </div>
      <div class="part-item" data-type="end">
        <span class="part-icon">🏁</span>
        <span class="part-label">END</span>
      </div>

      <div class="flow-left-title" style="margin-top:16px">凡例</div>
      <div style="font-size:10px;color:#60726f;line-height:1.9;padding:0 4px;">
        <span style="color:#2ca87a">━</span> 順番通り<br>
        <span style="color:#dda020">╌</span> 条件分岐<br>
        <span style="color:#6abfa0">━</span> START<br>
        <span style="background:#ede8ff;border-radius:3px;padding:0 3px">紫枠</span> AI深掘<br>
        <span style="background:#fcd8c8;border-radius:3px;padding:0 3px">橙枠</span> END<br>
        <span style="background:#fffaf0;border:2px solid #dda020;border-radius:3px;padding:0 3px">◇</span> 条件分岐<br>
        <span style="background:#eef2ff;border:1.5px dashed #b0c8e0;border-radius:3px;padding:0 3px">□</span> セクション<br>
      </div>
      <div style="font-size:10px;color:#60726f;margin-top:10px;padding:0 4px;line-height:1.6;">
        <strong>操作</strong><br>
        ○ドラッグ→接続<br>
        接続線クリック→選択<br>
        Delete→接続削除<br>
        ノードドラッグ→移動
      </div>

      <% if (questions.length > 0) { %>
      <div class="flow-left-title" style="margin-top:16px">質問一覧</div>
      <div style="font-size:10px;color:#4d6b66;line-height:1.8;">
        <% const sortedQ = questions.slice().sort((a,b) => a.sort_order - b.sort_order); %>
        <% for (const q of sortedQ) { %>
          <div style="padding:1px 4px;cursor:pointer;border-radius:4px;"
               onclick="document.getElementById('node-<%= q.id %>')?.scrollIntoView({behavior:'smooth',block:'center'})"
               title="<%= q.question_text %>">
            <span style="color:#8aacaa">#<%= q.sort_order %></span>
            <%= q.question_code %>
          </div>
        <% } %>
      </div>
      <% } %>
    </div>

    <!-- ── Canvas ── -->
    <div class="flow-canvas-wrapper" id="canvasWrapper">
      <div class="flow-canvas" id="flowCanvas">
        <svg class="flow-svg" id="flowSvg"></svg>
        <!-- Nodes are injected by flowCanvas.js -->
      </div>
    </div>

    <!-- ── Right panel ── -->
    <div class="flow-right" id="rightPanel">
      <!-- Filled by flowCanvas.js -->
    </div>

  </div><!-- /.flow-main -->

  <!-- ─── Status bar ─── -->
  <div class="flow-status-bar">
    <span style="color:#8aacaa;font-size:10px">
      <%= questions.length %> 質問 ·
      <%= project.display_mode || 'survey_question' %> モード ·
      クリックでノード選択 / ハンドル(○)ドラッグで接続 / 接続線クリック→Deleteで削除
    </span>
  </div>

</div><!-- /.flow-page-root -->

<!-- ============================================================ -->
<!-- モーダル: 過去案件流用                                         -->
<!-- ============================================================ -->
<div id="importFlowModal" class="fd-modal-overlay" style="display:none">
  <div class="fd-modal">
    <div class="fd-modal-header">
      <h3>過去案件からフローを流用</h3>
      <button class="fd-modal-close" id="importModalClose">✕</button>
    </div>
    <div class="fd-modal-body">

      <!-- Step 1: 案件選択 -->
      <div id="importStep1">
        <p class="fd-modal-desc">流用元の過去案件を選択してください。選択肢テキストはAIが新規案件向けに自動調整します。</p>
        <input type="text" id="importProjectSearch" class="fd-modal-search" placeholder="案件名で絞り込み…" />
        <div id="importProjectList" class="fd-project-list">
          <div class="fd-loading">読み込み中…</div>
        </div>
        <div class="fd-modal-footer">
          <button class="fd-btn-secondary" id="importModalCancel">キャンセル</button>
          <button class="fd-btn-primary" id="importStep1Next" disabled>プレビュー →</button>
        </div>
      </div>

      <!-- Step 2: プレビュー -->
      <div id="importStep2" style="display:none">
        <p class="fd-modal-desc" id="importPreviewDesc"></p>
        <div id="importPreviewList" class="fd-preview-list"></div>
        <div class="fd-modal-footer">
          <button class="fd-btn-secondary" id="importStep2Back">← 戻る</button>
          <button class="fd-btn-primary" id="importStep2Execute">AIで調整して流用する</button>
        </div>
      </div>

      <!-- Step 3: 処理中 -->
      <div id="importStep3" style="display:none">
        <div class="fd-working">
          <div class="fd-spinner"></div>
          <p>AIがテキストを調整中です。しばらくお待ちください…</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ============================================================ -->
<!-- モーダル: AIフロー自動生成                                     -->
<!-- ============================================================ -->
<div id="generateFlowModal" class="fd-modal-overlay" style="display:none">
  <div class="fd-modal">
    <div class="fd-modal-header">
      <h3>AIフロー自動生成</h3>
      <button class="fd-modal-close" id="generateModalClose">✕</button>
    </div>
    <div class="fd-modal-body">

      <!-- 確認画面 -->
      <div id="generateStep1">
        <p class="fd-modal-desc">以下のプロジェクト情報をもとに、AIが調査フローを自動生成します。生成後は各設問を自由に編集できます。</p>
        <div class="fd-info-box">
          <div class="fd-info-row">
            <span class="fd-info-label">プロジェクト名</span>
            <span class="fd-info-value" id="genProjectName">—</span>
          </div>
          <div class="fd-info-row">
            <span class="fd-info-label">調査目的</span>
            <span class="fd-info-value" id="genProjectObjective">—</span>
          </div>
        </div>
        <p style="font-size:11px;color:#8aacaa;margin-top:8px">※生成には10〜30秒かかる場合があります。既存の質問に追加されます。</p>
        <div class="fd-modal-footer">
          <button class="fd-btn-secondary" id="generateModalCancel">キャンセル</button>
          <button class="fd-btn-primary" id="generateExecute">AIでフローを生成する</button>
        </div>
      </div>

      <!-- 処理中 -->
      <div id="generateStep2" style="display:none">
        <div class="fd-working">
          <div class="fd-spinner"></div>
          <p>AIがフロー構成を生成中です。しばらくお待ちください…</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ============================================================ -->
<!-- モーダル: 選択肢流用                                          -->
<!-- ============================================================ -->
<div id="optionReuseModal" class="fd-modal-overlay" style="display:none">
  <div class="fd-modal fd-modal-sm">
    <div class="fd-modal-header">
      <h3>選択肢を流用</h3>
      <button class="fd-modal-close" id="optionReuseModalClose">✕</button>
    </div>
    <div class="fd-modal-body">
      <p class="fd-modal-desc">流用元の設問を選択してください。選択肢が現在の設問にコピーされます（保存は別途必要）。</p>
      <input type="text" id="optionReuseSearch" class="fd-modal-search" placeholder="設問コード・設問文で絞り込み…" />
      <div id="optionReuseList" class="fd-project-list">
        <div class="fd-loading">読み込み中…</div>
      </div>
      <div class="fd-modal-footer">
        <button class="fd-btn-secondary" id="optionReuseCancel">キャンセル</button>
      </div>
    </div>
  </div>
</div>

<!-- Initial data for JS -->
<script>
window.FLOW_DESIGNER_DATA = <%- JSON.stringify(initialData) %>;
</script>
<script src="/public/flowCanvas.js"></script>
</body>
</html>

<%- include("../../partials/header", { title }) %>

<div class="question-header-nav" style="position:sticky;top:0;z-index:10;background:#fff;padding:8px 0;border-bottom:1px solid #e0e0e0;">
  <div class="actions-row" style="justify-content: space-between;">
    <div class="actions-row">
      <a class="button-link secondary" href="/admin/projects">一覧へ戻る</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/edit">基本設定</a>
      <a class="button-link" href="/admin/projects/<%= project.id %>/questions/flow" style="background:#0b7a75">🗂 フロー設計</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/page-groups">🧩 ブロック/ページ</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/concepts">🔁 コンセプト</a>
      <a class="button-link" href="/admin/projects/<%= project.id %>/questions/new">質問を追加</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/edit#screening-section">スクリーニング設定</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/preview">プレビュー</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/respondents">回答者</a>
    </div>
    <span class="muted"><%= project.name %></span>
  </div>
</div>

<% if (rawdataIndex) { %>
  <p class="muted" style="margin-top:12px;font-size:0.85em;">
    ロウデータ列（q番号）:
    <% if (rawdataIndex.snapshotConfirmed) { %>
      <span class="tag" style="background:#0b7a75;color:#fff;">✓ 調査票確定済み（q番号は固定）</span>
    <% } else { %>
      <span class="tag" style="background:#8a5b00;color:#fff;">暫定（設問の追加・並べ替えで変わります。分析ページで「調査票を確定」すると固定されます）</span>
    <% } %>
  </p>
<% } %>

<table style="margin-top: 16px;">
  <thead>
    <tr>
      <th>Order</th>
      <th>Code</th>
      <th>ロウデータ列</th>
      <th>Type</th>
      <th>Role</th>
      <th>AI Probe</th>
      <th>Extraction</th>
      <th>Branch</th>
      <th>Next</th>
      <th>Text</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% for (const row of questions) { %>
      <tr>
        <td><%= row.question.sort_order %></td>
        <td><strong><%= row.question.question_code %></strong></td>
        <td>
          <% const rd = rawdataIndex ? rawdataIndex.byQuestionId[row.question.id] : null; %>
          <% if (rd) { %>
            <span style="font-family:monospace;font-size:0.9em;"><%= rd.summary %></span>
          <% } else { %>
            <span class="muted">-</span>
          <% } %>
        </td>
        <td><%= row.question.question_type %></td>
        <td><span class="tag"><%= row.question.question_role %></span></td>
        <td><%= row.question.ai_probe_enabled ? "ON" : "OFF" %></td>
        <td><%= row.question.question_config?.extraction?.mode && row.question.question_config.extraction.mode !== "none" ? row.question.question_config.extraction.mode : "-" %></td>
        <td>
          <% if (row.hasBranches) { %>
            <span class="tag"><%= row.branchCount %> branches</span>
          <% } else { %>
            <span class="muted">なし</span>
          <% } %>
        </td>
        <td><%= row.nextSummary || "-" %></td>
        <td><strong><%= row.question.question_text %></strong></td>
        <td><a href="/admin/questions/<%= row.question.id %>/edit">Edit</a></td>
      </tr>
    <% } %>
  </tbody>
</table>

<%- include("../../partials/footer") %>

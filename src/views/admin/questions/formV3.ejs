    d.className = 'row-card ans-row';
    d.innerHTML = `
      <div class="form-grid">
        <label>参照元質問コード<select name="ans_source"><option value="">選択</option>${optHtml}</select></label>
        <label>差し込み先<select name="ans_target">
          <option value="question_text">設問文</option>
          <option value="comment_top">コメント上</option>
          <option value="comment_bottom">コメント下</option>
        </select></label>
      </div>
      <div class="inline-actions"><button type="button" class="button-link danger remove-row">削除</button></div>`;
    return d;
  }

  const addTo = (containerId, makeRow) => {
    const c = document.getElementById(containerId);
    const row = makeRow();
    c.appendChild(row);
    attachRemoveRow(c);
  };

  ['optionRows','extractionRows','branchRows','visCondRows','ansRows'].forEach(id => {
    const el = document.getElementById(id);
    if (el) attachRemoveRow(el);
  });

  // 既存の選択肢行の画像ハンドラを初期化
  const optionRowsEl = document.getElementById('optionRows');
  if (optionRowsEl) attachImageHandlers(optionRowsEl);

  // URL直入力の既存行にも syncImagePreview を紐付け
  optionRowsEl && optionRowsEl.querySelectorAll('.option-image-url').forEach(inp => {
    inp.addEventListener('input', () => syncImagePreview(inp));
  });

  document.getElementById('addOptionRow').onclick      = () => addTo('optionRows', makeOptionRow);
  document.getElementById('addExtractionRow').onclick  = () => addTo('extractionRows', makeExtractionRow);
  document.getElementById('addBranchRow').onclick      = () => addTo('branchRows', makeBranchRow);
  document.getElementById('addVisCondRow').onclick     = () => addTo('visCondRows', makeVisCondRow);
  document.getElementById('addAnsRow').onclick         = () => addTo('ansRows', makeAnsRow);

  // ----------------------------------------------------------------
  // 保存前にタグを自動生成して hidden フィールドへセット
  // ----------------------------------------------------------------
  document.getElementById('mainForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget;
    const formData = collectTagFormData();
    const hasTagInput = Object.values(formData).some(v => v === true || (typeof v === 'string' && v.trim() !== ''));
    if (hasTagInput) {
      try {
        const res = await fetch('/admin/api/generate-tags', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData),
        });
        if (res.ok) {
          const data = await res.json();
          if (data.rawGenerated) {
            document.getElementById('tagsRaw').value = data.rawGenerated;
          }
          if (data.parsed) {
            document.getElementById('displayTagsParsedJson').value = JSON.stringify(data.parsed);
          }
        }
      } catch(err) {
        console.warn('tag auto-generate on submit failed', err);
      }
    }
    // スクリーニング通過対象バリデーション
    const isScreeningOn = document.getElementById('screeningCheck')?.checked ?? false;
    const currentQType = document.getElementById('questionType')?.value ?? '';
    if (isScreeningOn && SCREENING_CHOICE_TYPES_JS.includes(currentQType)) {
      const passCount = [...document.querySelectorAll('.screening-pass-check')].filter(cb => cb.checked).length;
      if (passCount === 0) {
        alert('スクリーニング設問には、最低1つ以上の通過対象回答を設定してください。');
        return;
      }
    }

    form.submit();
  });

  // ----------------------------------------------------------------
  // タグ解析（クライアントサイド簡易版）
  // ----------------------------------------------------------------
  document.getElementById('parseTagsBtn').onclick = async () => {
    const raw = document.getElementById('tagsRaw').value;
    const res = await fetch('/admin/api/parse-tags', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ raw, question_type: document.getElementById('questionType').value }),
    });
    if (!res.ok) { alert('タグ解析に失敗しました'); return; }
    const data = await res.json();
    showTagResult(data);
  };

  document.getElementById('generateTagsBtn').onclick = async () => {
    const formData = collectTagFormData();
    const res = await fetch('/admin/api/generate-tags', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData),
    });
    if (!res.ok) { alert('タグ生成に失敗しました'); return; }
    const data = await res.json();
    document.getElementById('tagsRaw').value = data.rawGenerated || '';
    showTagResult(data);
  };

  document.getElementById('clearTagsBtn').onclick = () => {
    document.getElementById('tagsRaw').value = '';
    document.getElementById('tagParseResult').classList.add('hidden');
    document.getElementById('displayTagsParsedJson').value = '';
  };

  function showTagResult(data) {
    const resultEl = document.getElementById('tagParseResult');
    resultEl.classList.remove('hidden');

    const errorList = document.getElementById('tagErrorItems');
    const errorContainer = document.getElementById('tagErrorList');
    const allIssues = [...(data.errors || []), ...(data.warnings || [])];
    if (allIssues.length > 0) {
      errorContainer.classList.remove('hidden');
      errorList.innerHTML = allIssues.map(e =>
        `<li class="${e.severity}">[${e.severity}] ${escHtml(e.message)}</li>`
      ).join('');
    } else {
      errorContainer.classList.add('hidden');
      errorList.innerHTML = '';
    }

    document.getElementById('tagParsedPreview').textContent =
      JSON.stringify(data.parsed, null, 2);
    document.getElementById('tagGeneratedPreview').textContent =
      data.rawGenerated || '';
    document.getElementById('displayTagsParsedJson').value =
      JSON.stringify(data.parsed);
  }

  function collectTagFormData() {
    const f = name => {
      const el = document.querySelector(`[name="${name}"]`);
      return el ? el.value : '';
    };
    const cb = name => {
      const el = document.querySelector(`[name="${name}"]`);
      return el ? el.checked : false;
    };
    return {
      tag_size: f('tag_size'), tag_min: f('tag_min'), tag_max: f('tag_max'),
      tag_rows: f('tag_rows'), tag_cols: f('tag_cols'), tag_code: f('tag_code'),
      tag_numeric: cb('tag_numeric'), tag_numeric_decimal: f('tag_numeric_decimal'),
      tag_al: cb('tag_al'),
      tag_type_year: cb('tag_type_year'), tag_type_jyear: cb('tag_type_jyear'),
      tag_type_month: cb('tag_type_month'), tag_type_day: cb('tag_type_day'),
      tag_norep: cb('tag_norep'), tag_fix: cb('tag_fix'), tag_br: cb('tag_br'),
      tag_must: cb('tag_must'), tag_ex: cb('tag_ex'),
      tag_len_op: f('tag_len_op'), tag_len_val: f('tag_len_val'),
      tag_bf: f('tag_bf'), tag_af: f('tag_af'),
    };
  }

  // ----------------------------------------------------------------
  // プレビュー
  // ----------------------------------------------------------------
  const previewModal = document.getElementById('previewModal');
  document.getElementById('previewBtn').onclick = () => {
    const qText = document.querySelector('[name="question_text"]').value;
    const qType = document.getElementById('questionType').value;
    const mode  = document.getElementById('previewMode').value;
    const opts  = Array.from(document.querySelectorAll('[name="option_labels"]')).map(el => el.value).filter(Boolean);
    const commentTop    = document.querySelector('[name="comment_top"]')?.value || '';
    const commentBottom = document.querySelector('[name="comment_bottom"]')?.value || '';
    const matrixRows    = (document.querySelector('[name="matrix_rows"]')?.value || '').split('\n').filter(Boolean);
    const matrixCols    = (document.querySelector('[name="matrix_cols"]')?.value || '').split('\n').filter(Boolean);

    let html = buildPreviewHtml(qText, qType, mode, opts, commentTop, commentBottom, matrixRows, matrixCols);
    document.getElementById('previewContent').innerHTML = html;
    previewModal.style.display = 'flex';
  };
  document.getElementById('closePreview').onclick  = () => { previewModal.style.display = 'none'; };
  document.getElementById('previewMode').onchange  = () => document.getElementById('previewBtn').click();

  function buildPreviewHtml(qText, qType, mode, opts, commentTop, commentBottom, matrixRows, matrixCols) {
    const wrapStyle = mode === 'interview_chat'
      ? 'font-family:sans-serif;background:#f0f0f0;padding:16px;border-radius:12px;'
      : 'font-family:sans-serif;padding:8px;';
    let inner = '';

    if (commentTop) inner += `<p style="font-size:12px;color:#60726f;margin:0 0 6px">${escHtml(commentTop)}</p>`;

    const bubble = mode === 'interview_chat'
      ? `<div style="background:#fff;border-radius:12px;padding:12px;margin-bottom:10px;box-shadow:0 1px 4px rgba(0,0,0,.1);">${escHtml(qText)}</div>`
      : `<p style="font-weight:600;margin:0 0 10px">${escHtml(qText)}</p>`;
    inner += bubble;

    if (commentBottom) inner += `<p style="font-size:12px;color:#60726f;margin:0 0 8px">${escHtml(commentBottom)}</p>`;

    if (['single_choice','text_with_image'].includes(qType) && opts.length > 0) {
      inner += opts.map(o => `<label style="display:block;margin:4px 0;"><input type="radio" /> ${escHtml(o)}</label>`).join('');
    } else if (qType === 'multi_choice' && opts.length > 0) {
      inner += opts.map(o => `<label style="display:block;margin:4px 0;"><input type="checkbox" /> ${escHtml(o)}</label>`).join('');
    } else if (['text','free_text_short','numeric'].includes(qType)) {
      inner += `<input type="text" style="width:100%;padding:8px;border:1px solid #ccc;border-radius:6px;" placeholder="回答を入力..." />`;
    } else if (['free_text_long'].includes(qType)) {
      inner += `<textarea rows="4" style="width:100%;padding:8px;border:1px solid #ccc;border-radius:6px;" placeholder="回答を入力..."></textarea>`;
    } else if (['scale'].includes(qType)) {
      inner += `<input type="range" min="1" max="5" style="width:100%" />`;
    } else if (['matrix_single','matrix_multi','matrix_mixed'].includes(qType)) {
      if (matrixRows.length > 0 && matrixCols.length > 0) {
        const isMulti = qType === 'matrix_multi';
        inner += `<table style="width:100%;border-collapse:collapse;font-size:13px;">
          <tr><th style="padding:6px;border-bottom:1px solid #eee;text-align:left;"></th>`;
        for (const col of matrixCols) {
          inner += `<th style="padding:6px;border-bottom:1px solid #eee;text-align:center;">${escHtml(col)}</th>`;
        }
        inner += `</tr>`;
        for (const row of matrixRows) {
          inner += `<tr><td style="padding:6px;border-bottom:1px solid #eee;">${escHtml(row)}</td>`;
          for (let ci = 0; ci < matrixCols.length; ci++) {
            inner += `<td style="padding:6px;border-bottom:1px solid #eee;text-align:center;">
              <input type="${isMulti ? 'checkbox' : 'radio'}" name="prev_row_${escHtml(row)}" />
            </td>`;
          }
          inner += `</tr>`;
        }
        inner += `</table>`;
      } else {
        inner += `<p style="font-size:12px;color:#888;">[マトリクス - 行・列を「2. 回答形式」タブで設定してください]</p>`;
      }
    }

    if (mode === 'interview_chat') {
      inner += `<div style="margin-top:8px;">
        <input type="text" placeholder="返信する..." style="width:calc(100% - 60px);padding:8px;border:1px solid #ccc;border-radius:20px;" />
        <button style="padding:8px 12px;background:#2ca87a;color:#fff;border:none;border-radius:20px;margin-left:4px;">送信</button>
      </div>`;
    } else {
      inner += `<div style="margin-top:16px;text-align:right;">
        <button style="padding:8px 24px;background:#2ca87a;color:#fff;border:none;border-radius:8px;">次へ</button>
      </div>`;
    }

    return `<div style="${wrapStyle}">${inner}</div>`;
  }

  // ----------------------------------------------------------------
  // util
  // ----------------------------------------------------------------
  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  syncTypeVisibility();

  // ----------------------------------------------------------------
  // 未保存変更検知 + 設問ナビゲーション
  // ----------------------------------------------------------------
  let isDirty = false;
  const mainForm = document.getElementById('mainForm');
  mainForm.addEventListener('change', () => { isDirty = true; });
  mainForm.addEventListener('input', () => { isDirty = true; });
  mainForm.addEventListener('submit', () => { isDirty = false; });

  function navigateTo(href) {
    if (isDirty) {
      if (!confirm('未保存の変更があります。保存せずに移動しますか？')) return;
      isDirty = false;
    }
    window.location.href = href;
  }

  document.querySelectorAll('.nav-question-btn').forEach(btn => {
    btn.addEventListener('click', () => navigateTo(btn.dataset.href));
  });

  // キーボードナビゲーション（←→キー、テキスト入力中は無効）
  document.addEventListener('keydown', (e) => {
    const tag = document.activeElement ? document.activeElement.tagName : '';
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
    if (e.key === 'ArrowLeft') {
      const btn = document.querySelector('.nav-question-btn[data-nav-key="prev"]');
      if (btn) btn.click();
    } else if (e.key === 'ArrowRight') {
      const btn = document.querySelector('.nav-question-btn[data-nav-key="next"]');
      if (btn) btn.click();
    }
  });
})();
</script>


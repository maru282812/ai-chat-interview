<%- include("../../partials/header", { title }) %>
<%
  const safeForm = form || {};
  const branchRows = Array.isArray(safeForm.branch_rows) && safeForm.branch_rows.length > 0
    ? safeForm.branch_rows
    : [{ source: "answer", field_label: "", operator: "equals", value: "", next: "" }];
  const optionLabels = Array.isArray(safeForm.option_labels) && safeForm.option_labels.length > 0
    ? safeForm.option_labels
    : [""];
  const optionImageUrls = Array.isArray(safeForm.option_image_urls)
    ? safeForm.option_image_urls
    : [];
  const optionExtraImageUrls = Array.isArray(safeForm.option_extra_image_urls)
    ? safeForm.option_extra_image_urls
    : [];
  const optionDescriptions = Array.isArray(safeForm.option_descriptions)
    ? safeForm.option_descriptions
    : [];
  const extractionItems = Array.isArray(safeForm.extraction_items) && safeForm.extraction_items.length > 0
    ? safeForm.extraction_items : [""];
  const nextQuestionOptions = (availableQuestions || [])
    .filter((item) => item.id !== question?.id)
    .map((item) => ({ code: item.question_code, text: item.question_text }));
  const qType = safeForm.question_type || "free_text_short";
  const ALL_TYPES = [
    { value: "single_choice",  label: "単一選択" },
    { value: "multi_choice",   label: "複数選択" },
    { value: "free_text_short","label": "短文自由記述" },
    { value: "free_text_long", "label": "長文自由記述" },
    { value: "numeric",        label: "数値入力" },
    { value: "matrix_single",  label: "マトリクス（単一）" },
    { value: "matrix_multi",   label: "マトリクス（複数）" },
    { value: "matrix_mixed",   label: "マトリクス（混合）" },
    { value: "image_upload",   label: "画像アップロード" },
    { value: "hidden_single",  label: "隠し項目（単一）" },
    { value: "hidden_multi",   label: "隠し項目（複数）" },
    { value: "text_with_image","label": "テキスト+画像選択肢" },
    { value: "sd",             label: "SD法" },
  ];
  const MATRIX_TYPES = ["matrix_single","matrix_multi","matrix_mixed"];
  const CHOICE_TYPES  = ["single_choice","multi_choice",
                         "hidden_single","hidden_multi","text_with_image","sd"];
  const SCALE_TYPES   = [];
  // スクリーニング通過対象チェックを表示できる設問タイプ
  const SCREENING_CHOICE_TYPES = ["single_choice","multi_choice"];
  const optionScreeningPass = Array.isArray(safeForm.option_screening_pass)
    ? safeForm.option_screening_pass : [];
  const DISPLAY_MODES = [
    { value: "survey_question", label: "1問ずつ表示 (survey_question)" },
    { value: "survey_page",     label: "ページ単位表示 (survey_page)" },
    { value: "interview_chat",  label: "チャット形式 (interview_chat)" },
  ];
  // 質問側display_mode（project優先、個別上書き用）
  const qDisplayMode = safeForm.question_display_mode || "";
%>

<style>
  .tab-nav { display:flex; gap:4px; border-bottom:2px solid #d8e3e0; margin-bottom:18px; flex-wrap:wrap; }
  .tab-btn {
    padding:8px 16px; border:none; background:none; cursor:pointer;
    border-bottom:3px solid transparent; font-weight:600; color:#60726f;
    border-radius:6px 6px 0 0; position:relative;
  }
  .tab-btn.active { border-bottom-color:#2ca87a; color:#1a7a57; background:#f0faf6; }
  .tab-btn.has-error { color:#8a0000; }
  .tab-btn .err-badge {
    display:inline-block; background:#e55; color:#fff;
    border-radius:10px; font-size:10px; padding:1px 5px; margin-left:4px;
  }
  .tab-pane { display:none; }
  .tab-pane.active { display:block; }
  .authoring-section {
    border:1px solid #d8e3e0; border-radius:14px; padding:18px; background:#f8fbfa;
  }
  .helper-text { margin:0; font-size:12px; color:#60726f; }
  .stack-sm { display:flex; flex-direction:column; gap:10px; }
  .row-card {
    display:grid; gap:10px; padding:12px;
    border:1px solid #d8e3e0; border-radius:12px; background:#fff;
  }
  .inline-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .hidden { display:none; }
  .warning-card { border:1px solid #f2cf88; background:#fff7e8; color:#8a5b00; }
  .error-card   { border:1px solid #f2a8a8; background:#fff4f4; color:#8a0000; }
  .tag-preview  {
    font-family:monospace; font-size:12px; background:#f4f4f4;
    border:1px solid #ccc; border-radius:6px; padding:8px; white-space:pre-wrap;
  }
  .tag-error-list { margin:0; padding:0 0 0 18px; }
  .tag-error-list li.error   { color:#8a0000; }
  .tag-error-list li.warning { color:#8a5b00; }
  .form-3col { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
  .display-mode-cards { display:flex; gap:10px; flex-wrap:wrap; }
  .display-mode-card {
    flex:1; min-width:140px; padding:12px 14px;
    border:2px solid #d8e3e0; border-radius:12px; cursor:pointer;
    text-align:center; transition:all 0.15s; background:#fff;
  }
  .display-mode-card.selected { border-color:#2ca87a; background:#f0faf6; }
  .display-mode-card input[type=radio] { display:none; }
  .display-mode-card .dm-icon { font-size:24px; margin-bottom:4px; }
  .display-mode-card .dm-label { font-size:13px; font-weight:600; }
  .display-mode-card .dm-sub   { font-size:11px; color:#60726f; }
</style>

<form class="card stack" method="post" action="<%= action %>" id="mainForm">
  <input type="hidden" name="question_code" value="<%= safeForm.question_code || '' %>" />

  <div class="actions-row" style="justify-content:space-between;">
    <p class="muted" style="margin:0;">プロジェクト: <%= project.name %></p>
    <div class="inline-actions">
      <button type="button" id="previewBtn" class="button-link secondary">プレビュー</button>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/page-groups">🧩 ブロック/ページ</a>
      <a class="button-link secondary" href="/admin/projects/<%= project.id %>/questions">一覧へ戻る</a>
    </div>
  </div>

  <% if (question) { %>
  <div style="display:flex;gap:8px;align-items:center;border-top:1px solid #e0ece8;border-bottom:1px solid #e0ece8;padding:8px 0;">
    <% if (prevQuestion) { %>
      <button type="button" class="button-link secondary nav-question-btn" data-nav-key="prev" data-href="/admin/questions/<%= prevQuestion.id %>/edit" style="font-size:13px;">
        ← 前の質問 (<%= prevQuestion.question_code %>)
      </button>
    <% } else { %>
      <button type="button" class="button-link secondary" disabled style="font-size:13px;opacity:0.4;cursor:not-allowed;">← 前の質問</button>
    <% } %>
    <span style="flex:1;text-align:center;font-size:12px;color:#60726f;font-weight:600;"><%= question.question_code %></span>
    <% if (nextQuestion) { %>
      <button type="button" class="button-link secondary nav-question-btn" data-nav-key="next" data-href="/admin/questions/<%= nextQuestion.id %>/edit" style="font-size:13px;">
        次の質問 (<%= nextQuestion.question_code %>) →
      </button>
    <% } else { %>
      <button type="button" class="button-link secondary" disabled style="font-size:13px;opacity:0.4;cursor:not-allowed;">次の質問 →</button>
    <% } %>
  </div>
  <% } %>

  <% if (errorMessage) { %>
    <section class="card subtle-card error-card"><strong><%= errorMessage %></strong></section>
  <% } %>
  <% if (successMessage) { %>
    <section class="card subtle-card success-card">
      <strong class="success-text"><%= successMessage %></strong>
    </section>
  <% } %>

  <% if (typeof rawdataInfo !== "undefined" && rawdataInfo) { %>
  <section style="background:#f6f9f8;border:1px solid #d8e3e0;border-radius:10px;padding:10px 14px;font-size:12.5px;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
      <strong>ロウデータ列:</strong>
      <span style="font-family:monospace;"><%= rawdataInfo.summary %></span>
      <% if (rawdataInfo.snapshotConfirmed) { %>
        <span class="tag" style="background:#0b7a75;color:#fff;">✓ 確定済み（q<%= rawdataInfo.q_number %> 固定）</span>
      <% } else { %>
        <span class="tag" style="background:#8a5b00;color:#fff;">暫定 q<%= rawdataInfo.q_number %>（調査票確定まで変わる可能性）</span>
      <% } %>
      <% if (rawdataInfo.columns.length > 1) { %>
        <button type="button" id="rd-cols-toggle" class="button-link secondary" style="font-size:11px;padding:2px 8px;">列の対応を表示</button>
      <% } %>
    </div>
    <% if (rawdataInfo.columns.length > 1) { %>
    <div id="rd-cols" style="display:none;margin-top:8px;">
      <table style="font-size:12px;">
        <thead><tr><th>列名</th><th>対応</th></tr></thead>
        <tbody>
          <% for (const col of rawdataInfo.columns) { %>
            <tr><td style="font-family:monospace;"><%= col.name %></td><td><%= col.label %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <script>
      document.getElementById("rd-cols-toggle")?.addEventListener("click", function () {
        const box = document.getElementById("rd-cols");
        const open = box.style.display !== "none";
        box.style.display = open ? "none" : "";
        this.textContent = open ? "列の対応を表示" : "列の対応を隠す";
      });
    </script>
    <% } %>
  </section>
  <% } %>

  <!-- ============================================================ -->
  <!-- タブナビ                                                      -->
  <!-- ============================================================ -->
  <nav class="tab-nav" id="tabNav">
    <button type="button" class="tab-btn active" data-tab="basic">1. 基本設定</button>
    <button type="button" class="tab-btn" data-tab="answer">2. 回答形式</button>
    <button type="button" class="tab-btn" data-tab="branch">3. 分岐・表示制御</button>
    <button type="button" class="tab-btn" data-tab="display">4. 表示モード・装飾</button>
    <button type="button" class="tab-btn" data-tab="tags">5. タグ詳細</button>
  </nav>

  <!-- ============================================================ -->
  <!-- Tab 1: 基本設定                                               -->
  <!-- ============================================================ -->
  <div class="tab-pane active" id="tab-basic">
    <section class="authoring-section stack">
      <h2>1. 基本設定</h2>
      <p class="helper-text">設問文・種別・AI深掘り設定を行います。</p>

      <label>
        設問文 <span style="color:red">*</span>
        <textarea name="question_text" required rows="3"><%= safeForm.question_text || '' %></textarea>
      </label>

      <!-- 設問文画像（省略可） -->
      <%
        const qtImgUrl = safeForm.question_text_image_url || '';
        const qtExtraImgs = safeForm.question_text_extra_image_urls || '';
        const qtCaption = safeForm.question_text_caption || '';
      %>
      <div style="padding:10px 12px;border:1px solid #d8e3e0;border-radius:10px;background:#fafcfb;">
        <label style="font-weight:600;font-size:13px;color:#60726f;display:block;margin-bottom:8px;">設問文の画像（省略可）</label>
        <div class="row-card question-text-image-card" style="padding:10px;">
          <div style="display:flex;gap:8px;align-items:flex-start;flex-wrap:wrap;">
            <div style="flex:2;min-width:200px;">
              <label>メイン画像URL</label>
              <div style="display:flex;gap:4px;align-items:center;">
                <input type="url" name="question_text_image_url" class="option-image-url"
                  value="<%= qtImgUrl %>" placeholder="https://..."
                  style="flex:1;" oninput="syncImagePreview(this)" />
                <label class="button-link secondary" style="white-space:nowrap;cursor:pointer;">
                  ファイル選択
                  <input type="file" accept="image/png,image/jpeg,image/webp" class="option-file-input" hidden />
                </label>
              </div>
              <div class="option-image-preview" style="margin-top:4px;<%= qtImgUrl ? '' : 'display:none;' %>">
                <img src="<%= qtImgUrl %>" alt="preview"
                  style="max-width:160px;max-height:100px;border-radius:4px;border:1px solid #ddd;"
                  onerror="this.parentElement.style.display='none'" />
                <button type="button" class="button-link danger remove-image" style="font-size:12px;">削除</button>
              </div>
              <label style="margin-top:6px;font-size:12px;color:#60726f;">
                追加画像URL（改行区切り・複数枚表示）
                <textarea name="question_text_extra_image_urls" rows="2"
                  placeholder="https://...&#10;https://..."
                  style="font-size:12px;"><%= qtExtraImgs %></textarea>
              </label>
            </div>
            <label style="flex:2;min-width:160px;">
              画像の説明（caption・省略可）
              <input type="text" name="question_text_caption"
                value="<%= qtCaption %>" placeholder="例: 図1. 商品パッケージ" />
            </label>
          </div>
        </div>
      </div>

      <% const pageGroups = locals.pageGroups || []; %>
      <% if (pageGroups.length > 0) { %>
      <label>
        ページグループ（survey_page モード用）
        <select name="page_group_id">
          <option value="">未割当（ページなし）</option>
          <% for (const pg of pageGroups) { %>
            <option value="<%= pg.id %>" <%= safeForm.page_group_id === pg.id ? 'selected' : '' %>>
              P<%= pg.page_number %> <%= pg.title ? '| ' + pg.title : '' %>
            </option>
          <% } %>
        </select>
      </label>
      <% } %>

      <div class="form-grid">
        <label>
          回答形式 <span style="color:red">*</span>
          <select name="question_type" id="questionType">
            <% for (const t of ALL_TYPES) { %>
              <option value="<%= t.value %>" <%= qType === t.value ? 'selected' : '' %>><%= t.label %></option>
            <% } %>
          </select>
        </label>
        <label>
          質問ロール
          <select name="question_role" id="questionRole">
            <% for (const role of ["screening","main","probe_trigger","attribute","comparison_core","free_comment"]) { %>
              <option value="<%= role %>" <%= safeForm.question_role === role ? 'selected' : '' %>><%= role %></option>
            <% } %>
          </select>
          <%# is_screening_question: hidden+checkbox ペアで確実に値を送る %>
          <input type="hidden" name="is_screening_question" value="0" />
          <label style="margin-top:4px;display:flex;align-items:center;gap:6px;font-weight:normal;cursor:pointer" id="screeningCheckLabel">
            <input type="checkbox" id="screeningCheck" name="is_screening_question" value="1"
              <%= safeForm.is_screening_question ? 'checked' : '' %>
              onchange="onScreeningCheckChange(this)" />
            この設問をスクリーニングに使用する
          </label>
          <p id="screeningUnsupportedNote" class="helper-text" style="color:#e08c00;display:none;">
            このタイプの設問はスクリーニング通過判定に対応していません（条件なし＝全員通過）
          </p>
        </label>
        <label>
          表示順
          <input type="number" name="sort_order" min="1" value="<%= safeForm.sort_order_text || '1' %>" />
        </label>
      </div>

      <div class="form-grid">
        <label>
          <input type="checkbox" name="is_required" <%= safeForm.is_required ? 'checked' : '' %> />
          必須にする
        </label>
        <label>
          <input type="checkbox" name="ai_probe_enabled" id="aiProbeEnabled"
            <%= safeForm.ai_probe_enabled ? 'checked' : '' %> />
          AI深掘りを有効にする
        </label>
      </div>

      <div id="aiProbeOptions" class="stack-sm">
        <label>
          深掘りガイドライン（任意）
          <input type="text" name="probe_guideline" value="<%= safeForm.probe_guideline || '' %>"
            placeholder="例: 理由・具体例・感情・利用シーンを引き出す" />
        </label>
        <div class="form-grid">
          <label>
            深掘り上限回数
            <input type="number" name="max_probe_count" value="<%= safeForm.max_probe_count_text || '' %>"
              min="0" max="5" placeholder="未入力=既定値" />
          </label>
          <label>
            質問文キャッシュ
            <select name="render_strategy">
              <option value="static"  <%= safeForm.render_strategy === 'static'  ? 'selected' : '' %>>static</option>
              <option value="dynamic" <%= safeForm.render_strategy === 'dynamic' ? 'selected' : '' %>>dynamic</option>
            </select>
          </label>
        </div>
      </div>

      <label>
        この質問で知りたいこと <span id="questionGoalRequired" style="color:red;display:none">*</span>
        <textarea name="question_goal" id="questionGoalInput" rows="2"
          placeholder="例: なぜその選択をしたのか"><%= safeForm.question_goal || '' %></textarea>
      </label>

      <!-- 共通指標（複数アンケート横断の合算キー）。任意。 -->
      <%
        const metricCatalogList = (typeof metricCatalog !== 'undefined' && metricCatalog) ? metricCatalog : [];
        const metricDirList = (typeof metricDirections !== 'undefined' && metricDirections) ? metricDirections : [];
        const currentMetric = safeForm.metric_code || '';
        const isCatalogMetric = metricCatalogList.some(function (m) { return m.code === currentMetric; });
        const metricDirection = safeForm.metric_direction || '';
      %>
      <label>
        共通指標（横断集計キー・任意）
        <select name="metric_code" id="metricCodeSelect" onchange="onMetricCodeChange()">
          <option value="">（なし）</option>
          <% for (const m of metricCatalogList) { %>
            <option value="<%= m.code %>" <%= currentMetric === m.code ? 'selected' : '' %>><%= m.label %>（<%= m.code %>）</option>
          <% } %>
          <option value="__custom__" <%= (currentMetric && !isCatalogMetric) ? 'selected' : '' %>>その他（自由入力）</option>
        </select>
        <small class="muted">複数アンケートを企業単位で合算・比較するための共通キーです。満足度など同じ意味の設問に同じ指標を付けてください。</small>
      </label>
      <label id="metricCustomWrap" style="<%= (currentMetric && !isCatalogMetric) ? '' : 'display:none' %>">
        共通指標コード（自由入力・英数と _ のみ）
        <input type="text" name="metric_code_custom" id="metricCodeCustom"
          value="<%= (currentMetric && !isCatalogMetric) ? currentMetric : '' %>"
          placeholder="例: waiting_time_eval" />
      </label>
      <label>
        指標の集計方向
        <select name="metric_direction" id="metricDirectionSelect">
          <option value="">（自動）</option>
          <% for (const d of metricDirList) { %>
            <option value="<%= d.value %>" <%= metricDirection === d.value ? 'selected' : '' %>><%= d.label %></option>
          <% } %>
        </select>
      </label>
      <script>
        // 「その他」選択時に自由入力欄を出し、送信時は自由入力値を metric_code に採用する。
        function onMetricCodeChange() {
          var sel = document.getElementById('metricCodeSelect');
          var wrap = document.getElementById('metricCustomWrap');
          wrap.style.display = (sel.value === '__custom__') ? '' : 'none';
        }
        // 送信直前に __custom__ を自由入力値へ差し替え（サーバ側 normalizeMetricCode で最終正規化）。
        (function () {
          var form = document.getElementById('metricCodeSelect').closest('form');
          if (form) {
            form.addEventListener('submit', function () {
              var sel = document.getElementById('metricCodeSelect');
              if (sel.value === '__custom__') {
                var custom = document.getElementById('metricCodeCustom').value || '';
                sel.value = custom.trim();
                if (!sel.querySelector('option[value="' + CSS.escape(sel.value) + '"]')) {
                  var opt = document.createElement('option');
                  opt.value = sel.value; opt.selected = true;
                  sel.appendChild(opt);
                }
              }
            });
          }
        })();
      </script>
    </section>
  </div>

  <!-- ============================================================ -->
  <!-- Tab 2: 回答形式設定                                           -->
  <!-- ============================================================ -->
  <div class="tab-pane" id="tab-answer">
    <section class="authoring-section stack">
      <h2>2. 回答形式設定</h2>

      <!-- コメント上下 -->
      <label>
        コメント（設問文の上）
        <textarea name="comment_top" rows="2" placeholder="設問文の上に表示するコメント（任意）"><%= safeForm.comment_top || '' %></textarea>
      </label>
      <label>
        コメント（設問文の下・選択肢の上）
        <textarea name="comment_bottom" rows="2" placeholder="選択肢の上に表示するコメント（任意）"><%= safeForm.comment_bottom || '' %></textarea>
      </label>

      <!-- 選択肢系 -->
      <div id="typeChoiceFields" class="stack-sm <%= !CHOICE_TYPES.includes(qType) ? 'hidden' : '' %>">
        <h3>選択肢</h3>
        <div id="optionRows" class="stack-sm">
          <% for (let i = 0; i < optionLabels.length; i++) { %>
            <% const label = optionLabels[i]; %>
            <% const imgUrl = optionImageUrls[i] || ''; %>
            <% const extraImgs = optionExtraImageUrls[i] || ''; %>
            <% const optDesc = optionDescriptions[i] || ''; %>
            <% const isScreeningPass = optionScreeningPass[i] === true; %>
            <div class="row-card option-row">
              <div style="display:flex;gap:8px;align-items:flex-start;flex-wrap:wrap;">
                <label style="flex:1;min-width:160px;">
                  選択肢テキスト
                  <input type="text" name="option_labels" value="<%= label %>" placeholder="例: 毎日" />
                  <%# is_screening_question=true かつ SCREENING_CHOICE_TYPES のとき表示 %>
                  <%# hiddenが実際の値を保持。checkboxはUIのみで送信しない %>
                  <input type="hidden" name="option_screening_pass" value="<%= isScreeningPass ? '1' : '0' %>" class="screening-pass-hidden" />
                  <label class="screening-pass-label" style="margin-top:4px;display:flex;align-items:center;gap:5px;font-size:12px;font-weight:normal;">
                    <input type="checkbox" class="screening-pass-check"
                      <%= isScreeningPass ? 'checked' : '' %>
                      onchange="this.closest('.option-row').querySelector('.screening-pass-hidden').value = this.checked ? '1' : '0'" />
                    スクリーニング通過対象
                  </label>
                </label>
                <div style="flex:2;min-width:200px;">
                  <label>メイン画像URL（省略可）</label>
                  <div style="display:flex;gap:4px;align-items:center;">
                    <input type="url" name="option_image_urls" class="option-image-url"
                      value="<%= imgUrl %>" placeholder="https://... または空欄"
                      style="flex:1;" oninput="syncImagePreview(this)" />
                    <label class="button-link secondary" style="white-space:nowrap;cursor:pointer;">
                      ファイル選択
                      <input type="file" accept="image/png,image/jpeg,image/webp" class="option-file-input" hidden />
                    </label>
                  </div>
                  <div class="option-image-preview" style="margin-top:4px;<%= imgUrl ? '' : 'display:none;' %>">
                    <img src="<%= imgUrl %>" alt="preview"
                      style="max-width:120px;max-height:80px;border-radius:4px;border:1px solid #ddd;"
                      onerror="this.parentElement.style.display='none'" />
                    <button type="button" class="button-link danger remove-image" style="font-size:12px;">削除</button>
                  </div>
                  <label style="margin-top:6px;font-size:12px;color:#60726f;">
                    追加画像URL（改行区切り・複数枚表示）
                    <textarea name="option_extra_image_urls" rows="2"
                      placeholder="https://...&#10;https://..."
                      style="font-size:12px;"><%= extraImgs %></textarea>
                  </label>
                </div>
                <label style="flex:2;min-width:160px;">
                  補足説明（省略可）
                  <input type="text" name="option_descriptions"
                    value="<%= optDesc %>" placeholder="例: 商品名・説明" />
                </label>
              </div>
              <div class="inline-actions">
                <button type="button" class="button-link danger remove-row">削除</button>
              </div>
            </div>
          <% } %>
        </div>
        <div class="inline-actions">
          <button type="button" class="button-link secondary" id="addOptionRow">選択肢を追加</button>
        </div>
        <p id="screeningPassOffNote" class="helper-text" style="color:#60726f;display:none;">
          この設問をスクリーニングに使用する場合のみ「スクリーニング通過対象」を設定できます。
        </p>
        <p id="screeningPassOnNote" class="helper-text" style="color:#1a7a57;display:none;">
          通過対象にしたい回答へチェックを入れてください。この回答を選んだ回答者のみ、本案件へ進みます。
        </p>

        <!-- 選択肢ランダム化 (L3) -->
        <% const optRand = (question && question.question_config && question.question_config.option_randomization) || {}; %>
        <% const optFreeText = (question && question.question_config && Array.isArray(question.question_config.options)) ? question.question_config.options.filter(o => o.allow_free_text).map(o => o.label).join("\n") : ""; %>
        <% const optGroupsText = (optRand.groups || []).map(g => `${g.label || ''}: ${(g.values||[]).join(', ')}`).join("\n"); %>
        <fieldset style="margin-top:12px;border:1px solid #d8e3e0;border-radius:10px;padding:12px;background:#fafcfb;">
          <legend style="font-size:13px;color:#2c4a46;">選択肢ランダム化（L3・回答者ごとに適用）</legend>
          <label style="display:block;"><input type="checkbox" name="option_randomize_enabled" value="1" <%= optRand.enabled ? 'checked' : '' %> /> 選択肢の順番をランダム表示する</label>
          <label style="display:block;"><input type="checkbox" name="option_randomize_groups" value="1" <%= optRand.randomize_groups ? 'checked' : '' %> /> 群（グループ）の順番もランダム化する</label>
          <label style="display:block;margin-top:6px;">固定する選択肢（アンカー・改行/カンマ区切り。「その他」「特になし」等はここに入れると位置が固定されます）
            <textarea name="option_anchors" rows="2" placeholder="その他&#10;特になし"><%= (optRand.anchored_values || []).join("\n") %></textarea>
          </label>
          <label style="display:block;margin-top:6px;">群の定義（1行＝「群名: 選択肢1, 選択肢2」。群順＋群内をランダム化）
            <textarea name="option_groups_text" rows="3" placeholder="果物: りんご, バナナ&#10;服: Tシャツ, ズボン"><%= optGroupsText %></textarea>
          </label>
          <label style="display:block;margin-top:6px;">自由記述を出す選択肢（「その他」など・改行/カンマ区切り）
            <textarea name="option_freetext_labels" rows="2" placeholder="その他"><%= optFreeText %></textarea>
          </label>
          <p class="helper-text" style="font-size:11px;margin:4px 0 0;">選択肢は「ラベル名」で指定します。アンカー・群・記述に書いた名前は、上の選択肢のテキストと一致させてください。</p>
        </fieldset>
      </div>

      <!-- 選択肢表示形式 -->
      <div id="typeChoiceDisplayFields" class="stack-sm <%= !CHOICE_TYPES.includes(qType) ? 'hidden' : '' %>"
           style="padding:12px;border:1px solid #d8e3e0;border-radius:10px;background:#fafcfb;">
        <h4 style="margin:0 0 10px 0;font-size:14px;">選択肢の表示形式</h4>
        <div style="display:flex;gap:16px;flex-wrap:wrap;">
          <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
            <input type="radio" name="display_format" value="list"
              <%= (safeForm.display_format || 'list') === 'list' ? 'checked' : '' %> />
            リスト表示（従来）
          </label>
          <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
            <input type="radio" name="display_format" value="card"
              <%= safeForm.display_format === 'card' ? 'checked' : '' %> />
            画像カードグリッド表示
          </label>
        </div>
        <div id="gridColsField" style="margin-top:8px;<%= safeForm.display_format === 'card' ? '' : 'display:none;' %>">
          <label style="font-size:13px;">
            グリッド列数
            <input type="number" name="grid_cols" min="1" max="4"
              value="<%= safeForm.grid_cols || '2' %>" style="width:60px;" />
          </label>
        </div>

        <!-- 回答UI表示パターンの上書き（migration 075・survey_question モードのみ適用） -->
        <div style="margin-top:12px;padding-top:10px;border-top:1px dashed #d8e3e0;">
          <label style="font-size:13px;display:block;">
            表示パターンの上書き（空＝プロジェクトのプリセット準拠）
            <select name="presentation_pattern" style="margin-top:4px;">
              <option value="" <%= !safeForm.presentation_pattern ? 'selected' : '' %>>プリセットに従う</option>
              <option value="swipe_card"  <%= safeForm.presentation_pattern === 'swipe_card'  ? 'selected' : '' %>>swipe_card（2択スワイプ）</option>
              <option value="split_swipe" <%= safeForm.presentation_pattern === 'split_swipe' ? 'selected' : '' %>>split_swipe（2択スワイプ・仕切り2分割）</option>
              <option value="big_split"   <%= safeForm.presentation_pattern === 'big_split'   ? 'selected' : '' %>>big_split（2分割ビッグタップ）</option>
              <option value="carousel"    <%= safeForm.presentation_pattern === 'carousel'    ? 'selected' : '' %>>carousel（カードカルーセル）</option>
              <option value="tap_cards"   <%= safeForm.presentation_pattern === 'tap_cards'   ? 'selected' : '' %>>tap_cards（大型タップカード）</option>
              <option value="face_scale"  <%= safeForm.presentation_pattern === 'face_scale'  ? 'selected' : '' %>>face_scale（絵文字フェイス）</option>
              <option value="big_slider"  <%= safeForm.presentation_pattern === 'big_slider'  ? 'selected' : '' %>>big_slider（ビッグスライダー）</option>
              <option value="sort_swipe"  <%= safeForm.presentation_pattern === 'sort_swipe'  ? 'selected' : '' %>>sort_swipe（スワイプ振り分け・複数選択）</option>
              <option value="chip_select" <%= safeForm.presentation_pattern === 'chip_select' ? 'selected' : '' %>>chip_select（チップ選択・複数選択）</option>
            </select>
          </label>
          <label style="display:block;margin-top:6px;font-size:13px;">
            <input type="checkbox" name="presentation_scale" value="true" <%= safeForm.presentation_scale ? 'checked' : '' %> />
            順序尺度として扱う（casual=絵文字フェイス / standard=スライダー）
          </label>
          <label style="display:block;margin-top:4px;font-size:13px;">
            <input type="checkbox" name="presentation_slider" value="true" <%= safeForm.presentation_slider ? 'checked' : '' %> />
            スライダーで回答（single_choice の順序選択）
          </label>
          <p class="helper-text" style="font-size:11px;margin:6px 0 0;">保存形式はパターンに関わらず不変です。survey_page / チャット型には影響しません。</p>
        </div>
      </div>

      <!-- 複数選択制約 -->
      <div id="typeMultiFields" class="form-grid <%= qType !== 'multi_choice' ? 'hidden' : '' %>">
        <label>最小選択数 <input type="number" name="min_select" min="0" value="<%= safeForm.min_select_text || '' %>" /></label>
        <label>最大選択数 <input type="number" name="max_select" min="1" value="<%= safeForm.max_select_text || '' %>" /></label>
      </div>

      <!-- 排他制御プレビュー（multi_choice のみ・回答画面と同じ挙動で試せる） -->
      <div id="exclusivePreviewBlock" class="stack-sm <%= qType !== 'multi_choice' ? 'hidden' : '' %>"
           style="padding:12px;border:1px solid #d8b98a;border-radius:10px;background:#fffdf7;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;">
          <h4 style="margin:0;font-size:14px;">🔍 排他制御プレビュー</h4>
          <button type="button" id="exclusivePreviewRefresh" class="button-link secondary" style="font-size:12px;">最新の選択肢で更新</button>
        </div>
        <p class="helper-text">回答画面と同じ挙動です。下のチェックを実際に押して、排他が効くか確認できます（保存はされません）。</p>
        <!-- ルール要約 -->
        <div id="exclusivePreviewSummary" style="font-size:12px;color:#5a4a2a;"></div>
        <!-- インタラクティブ・チェック -->
        <div id="exclusivePreviewChecks" style="display:flex;flex-direction:column;gap:6px;margin-top:4px;"></div>
        <div id="exclusivePreviewNote" style="font-size:12px;color:#1a7a57;min-height:16px;"></div>
      </div>

      <!-- スケール設定（未使用） -->
      <div id="typeScaleFields" class="form-grid hidden">
        <label>最小値 <input type="number" name="scale_min" value="<%= safeForm.scale_min_text || '1' %>" /></label>
        <label>最小ラベル <input type="text" name="scale_min_label" value="<%= safeForm.scale_min_label || '' %>" /></label>
        <label>最大値 <input type="number" name="scale_max" value="<%= safeForm.scale_max_text || '5' %>" /></label>
        <label>最大ラベル <input type="text" name="scale_max_label" value="<%= safeForm.scale_max_label || '' %>" /></label>
      </div>

      <!-- テキスト入力補助 -->
      <div id="typeTextFields" class="stack-sm <%= (CHOICE_TYPES.includes(qType) || SCALE_TYPES.includes(qType) || MATRIX_TYPES.includes(qType)) ? 'hidden' : '' %>">
        <label>
          入力補助テキスト
          <input type="text" name="placeholder" value="<%= safeForm.placeholder || '' %>"
            placeholder="例: できるだけ具体的に入力してください" />
        </label>
      </div>

      <!-- マトリクス設定 -->
      <div id="typeMatrixFields" class="stack-sm <%= !MATRIX_TYPES.includes(qType) ? 'hidden' : '' %>">
        <h3>マトリクス設定</h3>

        <!-- 行設定（画像・説明付き） -->
        <div>
          <label style="font-weight:600;">行設定 <span style="color:red">*</span></label>
          <p class="helper-text">行ラベルは必須。画像URL・説明は省略可（未設定時はテキストのみ表示）。</p>
          <div id="matrixRowCards" class="stack-sm" style="margin-top:8px;">
            <%
              const matrixRowLabels = (safeForm.matrix_rows || '').split('\n').filter(s => s.trim());
              const matrixRowImgs = Array.isArray(safeForm.matrix_row_image_urls) ? safeForm.matrix_row_image_urls : [];
              const matrixRowExtraImgs = Array.isArray(safeForm.matrix_row_extra_image_urls) ? safeForm.matrix_row_extra_image_urls : [];
              const matrixRowDescs = Array.isArray(safeForm.matrix_row_descriptions) ? safeForm.matrix_row_descriptions : [];
              const matrixRowCount = Math.max(matrixRowLabels.length, 1);
              const matrixColLabels = (safeForm.matrix_cols || '').split('\n').filter(s => s.trim());
              const matrixColImgs = Array.isArray(safeForm.matrix_col_image_urls) ? safeForm.matrix_col_image_urls : [];
              const matrixColExtraImgs = Array.isArray(safeForm.matrix_col_extra_image_urls) ? safeForm.matrix_col_extra_image_urls : [];
              const matrixColDescs = Array.isArray(safeForm.matrix_col_descriptions) ? safeForm.matrix_col_descriptions : [];
              const matrixColCount = Math.max(matrixColLabels.length, 1);
            %>
            <% for (let ri = 0; ri < matrixRowCount; ri++) { %>
              <% const rowImg = matrixRowImgs[ri] || ''; %>
              <% const rowExtraImgs = matrixRowExtraImgs[ri] || ''; %>
              <div class="row-card matrix-row-card">
                <div style="display:flex;gap:8px;align-items:flex-start;flex-wrap:wrap;">
                  <label style="flex:1;min-width:140px;">
                    行ラベル
                    <input type="text" name="matrix_row_labels"
                      value="<%= matrixRowLabels[ri] || '' %>" placeholder="例: 満足度" />
                  </label>
                  <div style="flex:2;min-width:200px;">
                    <label>メイン画像URL（省略可）</label>
                    <div style="display:flex;gap:4px;align-items:center;">
                      <input type="url" name="matrix_row_image_urls" class="option-image-url"
                        value="<%= rowImg %>" placeholder="https://..."
                        style="flex:1;" oninput="syncImagePreview(this)" />
                      <label class="button-link secondary" style="white-space:nowrap;cursor:pointer;">
                        ファイル選択
                        <input type="file" accept="image/png,image/jpeg,image/webp" class="option-file-input" hidden />
                      </label>
                    </div>
                    <div class="option-image-preview" style="margin-top:4px;<%= rowImg ? '' : 'display:none;' %>">
                      <img src="<%= rowImg %>" alt="preview"
                        style="max-width:120px;max-height:80px;border-radius:4px;border:1px solid #ddd;"
                        onerror="this.parentElement.style.display='none'" />
                      <button type="button" class="button-link danger remove-image" style="font-size:12px;">削除</button>
                    </div>
                    <label style="margin-top:6px;font-size:12px;color:#60726f;">
                      追加画像URL（改行区切り・複数枚表示）
                      <textarea name="matrix_row_extra_image_urls" rows="2"
                        placeholder="https://...&#10;https://..."
                        style="font-size:12px;"><%= rowExtraImgs %></textarea>
                    </label>
                  </div>
                  <label style="flex:2;min-width:160px;">
                    補足説明（省略可）
                    <input type="text" name="matrix_row_descriptions"
                      value="<%= matrixRowDescs[ri] || '' %>" placeholder="例: ブランド名・商品説明" />
                  </label>
                </div>
                <div class="inline-actions">
                  <button type="button" class="button-link danger remove-matrix-row">削除</button>
                </div>
              </div>
            <% } %>
          </div>
          <div class="inline-actions" style="margin-top:8px;">
            <button type="button" class="button-link secondary" id="addMatrixRow">行を追加</button>
          </div>
          <!-- 旧フォーマット互換用（送信時に JS が同期する） -->
          <input type="hidden" name="matrix_rows" id="matrixRowsHidden" value="<%= safeForm.matrix_rows || '' %>" />
        </div>

        <!-- 列設定（画像付き） -->
        <div>
          <label style="font-weight:600;">列設定 <span style="color:red">*</span></label>
          <p class="helper-text">列ラベルは必須。画像URLは省略可（未設定時はテキストのみ表示）。</p>
          <div id="matrixColCards" class="stack-sm" style="margin-top:8px;">
            <% for (let ci = 0; ci < matrixColCount; ci++) { %>
              <% const colImg = matrixColImgs[ci] || ''; %>
              <% const colExtraImgs = matrixColExtraImgs[ci] || ''; %>
              <% const colDesc = matrixColDescs[ci] || ''; %>
              <div class="row-card matrix-col-card">
                <div style="display:flex;gap:8px;align-items:flex-start;flex-wrap:wrap;">
                  <label style="flex:1;min-width:140px;">
                    列ラベル
                    <input type="text" name="matrix_col_labels"
                      value="<%= matrixColLabels[ci] || '' %>" placeholder="例: そう思う" />
                  </label>
                  <div style="flex:2;min-width:200px;">
                    <label>メイン画像URL（省略可）</label>
                    <div style="display:flex;gap:4px;align-items:center;">
                      <input type="url" name="matrix_col_image_urls" class="option-image-url"
                        value="<%= colImg %>" placeholder="https://..."
                        style="flex:1;" oninput="syncImagePreview(this)" />
                      <label class="button-link secondary" style="white-space:nowrap;cursor:pointer;">
                        ファイル選択
                        <input type="file" accept="image/png,image/jpeg,image/webp" class="option-file-input" hidden />
                      </label>
                    </div>
                    <div class="option-image-preview" style="margin-top:4px;<%= colImg ? '' : 'display:none;' %>">
                      <img src="<%= colImg %>" alt="preview"
                        style="max-width:120px;max-height:80px;border-radius:4px;border:1px solid #ddd;"
                        onerror="this.parentElement.style.display='none'" />
                      <button type="button" class="button-link danger remove-image" style="font-size:12px;">削除</button>
                    </div>
                    <label style="margin-top:6px;font-size:12px;color:#60726f;">
                      追加画像URL（改行区切り・複数枚表示）
                      <textarea name="matrix_col_extra_image_urls" rows="2"
                        placeholder="https://...&#10;https://..."
                        style="font-size:12px;"><%= colExtraImgs %></textarea>
                    </label>
                  </div>
                  <label style="flex:2;min-width:160px;">
                    補足説明（省略可）
                    <input type="text" name="matrix_col_descriptions"
                      value="<%= colDesc %>" placeholder="例: ブランド名・商品説明" />
                  </label>
                </div>
                <div class="inline-actions">
                  <button type="button" class="button-link danger remove-matrix-col">削除</button>
                </div>
              </div>
            <% } %>
          </div>
          <div class="inline-actions" style="margin-top:8px;">
            <button type="button" class="button-link secondary" id="addMatrixCol">列を追加</button>
          </div>
          <!-- 旧フォーマット互換用（送信時に JS が同期する） -->
          <input type="hidden" name="matrix_cols" id="matrixColsHidden" value="<%= safeForm.matrix_cols || '' %>" />
        </div>

        <!-- 列見出し表示モード -->
        <div>
          <label style="font-weight:600;">列見出し表示モード</label>
          <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:4px;">
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
              <input type="radio" name="matrix_header_mode" value="normal"
                <%= (safeForm.matrix_header_mode || 'normal') === 'normal' ? 'checked' : '' %> />
              通常（横書き）
            </label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
              <input type="radio" name="matrix_header_mode" value="vertical"
                <%= safeForm.matrix_header_mode === 'vertical' ? 'checked' : '' %> />
              縦書き
            </label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
              <input type="radio" name="matrix_header_mode" value="rotated"
                <%= safeForm.matrix_header_mode === 'rotated' ? 'checked' : '' %> />
              90°回転
            </label>
          </div>
        </div>

        <p class="helper-text">マトリクス（複数）の場合、各行で複数選択できます。（混合）は行ごとに列タイプ設定が必要です。</p>
      </div>

      <!-- image_upload 設定 -->
      <div id="typeImageUploadFields" class="stack-sm <%= qType !== 'image_upload' ? 'hidden' : '' %>"
           style="padding:12px;border:1px solid #d8e3e0;border-radius:10px;background:#fafcfb;">
        <h3 style="margin:0 0 12px 0;">画像アップロード設定</h3>
        <div class="form-grid">
          <label>
            最大アップロード枚数
            <input type="number" name="image_upload_max_count" min="1" max="20"
              value="<%= safeForm.image_upload_max_count || '1' %>" />
          </label>
          <label>
            最大ファイルサイズ (MB)
            <input type="number" name="image_upload_max_size_mb" min="1" max="50"
              value="<%= safeForm.image_upload_max_size_mb || '10' %>" />
          </label>
        </div>
        <label>
          許可ファイル形式（カンマ区切り）
          <input type="text" name="image_upload_allowed_types"
            value="<%= safeForm.image_upload_allowed_types || 'image/jpeg,image/png,image/webp' %>"
            placeholder="image/jpeg,image/png,image/webp" />
          <span class="helper-text">例: image/jpeg,image/png,image/webp,image/heic</span>
        </label>
        <label>
          回答者への注意書き（省略可）
          <textarea name="image_upload_instructions" rows="2"
            placeholder="例: 商品のパッケージが写るように撮影してください"><%= safeForm.image_upload_instructions || '' %></textarea>
        </label>
        <label>
          補足テキスト入力
          <select name="image_upload_text_mode">
            <option value="hidden" <%= (safeForm.image_upload_text_mode || 'hidden') === 'hidden' ? 'selected' : '' %>>非表示（画像のみ）</option>
            <option value="optional" <%= safeForm.image_upload_text_mode === 'optional' ? 'selected' : '' %>>任意（画像＋テキスト）</option>
            <option value="required" <%= safeForm.image_upload_text_mode === 'required' ? 'selected' : '' %>>必須（テキスト未入力で次へ進めない）</option>
          </select>
          <span class="helper-text">任意・必須にすると画像アップロード欄の下にテキスト入力欄が表示されます</span>
        </label>
      </div>

      <!-- 抽出設定 -->
      <div class="stack-sm" style="margin-top:8px;">
        <label>
          <input type="checkbox" id="extractionEnabled" name="extraction_enabled"
            <%= safeForm.extraction_enabled ? 'checked' : '' %> />
          回答を構造化抽出する（AI深掘り連携）
        </label>
        <div id="extractionArea" class="stack-sm <%= safeForm.extraction_enabled ? '' : 'hidden' %>">
          <div id="extractionRows" class="stack-sm">
            <% for (const item of extractionItems) { %>
              <div class="row-card extraction-row">
                <label>抽出したい項目
                  <input type="text" name="extraction_items" value="<%= item %>" placeholder="例: 理由 / 年齢 / 価格帯" />
                </label>
                <div class="inline-actions">
                  <button type="button" class="button-link danger remove-row">削除</button>
                </div>
              </div>
            <% } %>
          </div>
          <button type="button" class="button-link secondary" id="addExtractionRow">項目を追加</button>
        </div>
      </div>

      <!-- 回答出力タイプ -->
      <label>
        回答出力タイプ
        <select name="answer_output_type">
          <option value="">自動（設問タイプから推定）</option>
          <% for (const t of ["text","number","boolean","array","object","none"]) { %>
            <option value="<%= t %>" <%= safeForm.answer_output_type === t ? 'selected' : '' %>><%= t %></option>
          <% } %>
        </select>
      </label>
    </section>
  </div>

  <!-- ============================================================ -->
  <!-- Tab 3: 分岐・表示制御                                         -->
  <!-- ============================================================ -->
  <div class="tab-pane" id="tab-branch">
    <section class="authoring-section stack">
      <h2>3. 分岐・表示制御</h2>

      <div class="form-grid">
        <label>
          デフォルト遷移先
          <select name="default_next">
            <option value="">次の設問へ（順番通り）</option>
            <% for (const option of nextQuestionOptions) { %>
              <option value="<%= option.code %>"
                <%= safeForm.default_next === option.code ? 'selected' : '' %>>
                <%= option.code %> | <%= option.text %>
              </option>
            <% } %>
          </select>
        </label>
      </div>

      <h3>条件分岐（遷移先の上書き）</h3>
      <p class="helper-text">
        「回答が〇〇なら △△ へ遷移」の形式で設定します。
        ここは<strong>進行遷移</strong>の設定です（表示条件は下の「設問表示条件」で設定）。
      </p>

      <div id="branchRows" class="stack-sm">
        <% for (const row of branchRows) { %>
          <div class="row-card branch-row">
            <div class="form-grid">
              <label>判定元
                <select name="branch_source" class="branch-source">
                  <option value="answer"    <%= row.source === 'answer'    ? 'selected' : '' %>>回答そのもの</option>
                  <option value="extracted" <%= row.source === 'extracted' ? 'selected' : '' %>>抽出項目</option>
                </select>
              </label>
              <label>項目
                <select name="branch_field_label" class="branch-field" data-selected="<%= row.field_label || '' %>">
                  <option value="">回答そのもの</option>
                </select>
              </label>
              <label>条件
                <select name="branch_operator">
                  <% for (const op of ["equals","includes","any_of","gte","lte"]) { %>
                    <option value="<%= op %>" <%= row.operator === op ? 'selected' : '' %>><%= op %></option>
                  <% } %>
                </select>
              </label>
              <label>値 <input type="text" name="branch_value" value="<%= row.value || '' %>" placeholder="例: 1" /></label>
            </div>
            <div class="form-grid">
              <label>遷移先
                <select name="branch_next">
                  <option value="">選択</option>
                  <% for (const option of nextQuestionOptions) { %>
                    <option value="<%= option.code %>"
                      <%= row.next === option.code ? 'selected' : '' %>>
                      <%= option.code %> | <%= option.text %>
                    </option>
                  <% } %>
                </select>
              </label>
            </div>
            <div class="inline-actions">
              <button type="button" class="button-link danger remove-row">削除</button>
            </div>
          </div>
        <% } %>
      </div>
      <button type="button" class="button-link secondary" id="addBranchRow">分岐を追加</button>

      <hr style="border:none;border-top:1px solid #d8e3e0;margin:12px 0;" />

      <h3>設問表示条件 &lt;pipe&gt;</h3>
      <p class="helper-text">
        この設問を表示する条件を設定します（空欄 = 常に表示）。<br />
        複数指定した場合はすべて満たした場合に表示（AND）。<br />
        例: <code>( q1=1 and q2=2 ) or q3=3</code>
      </p>
      <div id="visCondRows" class="stack-sm">
        <% const visConds = Array.isArray(safeForm.visibility_conditions) ? safeForm.visibility_conditions : []; %>
        <% for (const cond of visConds) { %>
          <div class="row-card vis-cond-row">
            <label>条件式
              <input type="text" name="vis_condition_expr" value="<%= cond.expression || '' %>"
                placeholder="例: q1=1 and q2=2" class="font-mono" />
            </label>
            <div class="inline-actions">
              <button type="button" class="button-link danger remove-row">削除</button>
            </div>
          </div>
        <% } %>
        <% if (!visConds.length) { %>
          <div class="row-card vis-cond-row">
            <label>条件式
              <input type="text" name="vis_condition_expr" value=""
                placeholder="例: q1=1 and q2=2" class="font-mono" />
            </label>
            <div class="inline-actions">
              <button type="button" class="button-link danger remove-row">削除</button>
            </div>
          </div>
        <% } %>
      </div>
      <button type="button" class="button-link secondary" id="addVisCondRow">表示条件を追加</button>
    </section>
  </div>

  <!-- ============================================================ -->
  <!-- Tab 4: 表示モード・装飾                                       -->
  <!-- ============================================================ -->
  <div class="tab-pane" id="tab-display">
    <section class="authoring-section stack">
      <h2>4. 表示モード・装飾</h2>

      <h3>表示モード（プロジェクト設定を上書きする場合のみ）</h3>
      <p class="helper-text">
        通常はプロジェクトの表示モード（<strong><%= project.display_mode || 'survey_question' %></strong>）が適用されます。
        この設問だけ別モードにしたい場合のみ選択してください。
      </p>
      <div class="display-mode-cards" id="displayModeCards">
        <label class="display-mode-card <%= !qDisplayMode ? 'selected' : '' %>">
          <input type="radio" name="question_display_mode" value="" <%= !qDisplayMode ? 'checked' : '' %> />
          <div class="dm-icon">🔗</div>
          <div class="dm-label">プロジェクト設定に従う</div>
          <div class="dm-sub">推奨</div>
        </label>
        <label class="display-mode-card <%= qDisplayMode === 'survey_question' ? 'selected' : '' %>">
          <input type="radio" name="question_display_mode" value="survey_question" <%= qDisplayMode === 'survey_question' ? 'checked' : '' %> />
          <div class="dm-icon">📋</div>
          <div class="dm-label">1問ずつ表示</div>
          <div class="dm-sub">survey_question</div>
        </label>
        <label class="display-mode-card <%= qDisplayMode === 'survey_page' ? 'selected' : '' %>">
          <input type="radio" name="question_display_mode" value="survey_page" <%= qDisplayMode === 'survey_page' ? 'checked' : '' %> />
          <div class="dm-icon">📄</div>
          <div class="dm-label">ページ単位</div>
          <div class="dm-sub">survey_page</div>
        </label>
        <label class="display-mode-card <%= qDisplayMode === 'interview_chat' ? 'selected' : '' %>">
          <input type="radio" name="question_display_mode" value="interview_chat" <%= qDisplayMode === 'interview_chat' ? 'checked' : '' %> />
          <div class="dm-icon">💬</div>
          <div class="dm-label">チャット形式</div>
          <div class="dm-sub">interview_chat</div>
        </label>
      </div>

      <hr style="border:none;border-top:1px solid #d8e3e0;margin:12px 0;" />

      <h3>入力サイズ・制約</h3>
      <div class="form-3col">
        <label>入力桁数 <code>&lt;size=n&gt;</code>
          <input type="number" name="tag_size" value="<%= safeForm.tag_size || '' %>" placeholder="例: 20" />
        </label>
        <label>最小値 <code>&lt;min=n&gt;</code>
          <input type="number" name="tag_min" value="<%= safeForm.tag_min || '' %>" placeholder="" />
        </label>
        <label>最大値 <code>&lt;max=n&gt;</code>
          <input type="number" name="tag_max" value="<%= safeForm.tag_max || '' %>" placeholder="" />
        </label>
      </div>
      <div class="form-3col">
        <label>行数 <code>&lt;rows=n&gt;</code>
          <input type="number" name="tag_rows" value="<%= safeForm.tag_rows || '' %>" placeholder="例: 5" />
        </label>
        <label>桁数 <code>&lt;cols=n&gt;</code>
          <input type="number" name="tag_cols" value="<%= safeForm.tag_cols || '' %>" placeholder="例: 40" />
        </label>
        <label>コード番号 <code>&lt;code=n&gt;</code>
          <input type="number" name="tag_code" value="<%= safeForm.tag_code || '' %>" placeholder="" />
        </label>
      </div>

      <h3>入力種別</h3>
      <div class="form-grid">
        <label><input type="checkbox" name="tag_numeric" value="1" <%= safeForm.tag_numeric ? 'checked' : '' %> /> 数値のみ <code>&lt;n&gt;</code></label>
        <label>小数桁数 <code>&lt;n,X&gt;</code>
          <input type="number" name="tag_numeric_decimal" value="<%= safeForm.tag_numeric_decimal || '' %>" placeholder="例: 2" min="0" />
        </label>
        <label><input type="checkbox" name="tag_al" value="1" <%= safeForm.tag_al ? 'checked' : '' %> /> 英数字のみ <code>&lt;al&gt;</code></label>
      </div>
      <div class="form-grid">
        <label><input type="checkbox" name="tag_type_year"  value="1" <%= safeForm.tag_type_year  ? 'checked' : '' %> /> 西暦年 <code>&lt;type(year)&gt;</code></label>
        <label><input type="checkbox" name="tag_type_jyear" value="1" <%= safeForm.tag_type_jyear ? 'checked' : '' %> /> 和暦年 <code>&lt;type(jyear)&gt;</code></label>
        <label><input type="checkbox" name="tag_type_month" value="1" <%= safeForm.tag_type_month ? 'checked' : '' %> /> 月 <code>&lt;type(month)&gt;</code></label>
        <label><input type="checkbox" name="tag_type_day"   value="1" <%= safeForm.tag_type_day   ? 'checked' : '' %> /> 日 <code>&lt;type(day)&gt;</code></label>
      </div>

      <h3>表示制御</h3>
      <div class="form-grid">
        <label><input type="checkbox" name="tag_norep"  value="1" <%= safeForm.tag_norep  ? 'checked' : '' %> /> 繰り返し表示なし <code>&lt;norep&gt;</code></label>
        <label><input type="checkbox" name="tag_fix"    value="1" <%= safeForm.tag_fix    ? 'checked' : '' %> /> 固定選択肢 <code>&lt;fix&gt;</code></label>
        <label><input type="checkbox" name="tag_br"     value="1" <%= safeForm.tag_br     ? 'checked' : '' %> /> 改行 <code>&lt;br&gt;</code></label>
        <label><input type="checkbox" name="tag_must"   value="1" <%= safeForm.tag_must   ? 'checked' : '' %> /> 入力必須表示 <code>&lt;must&gt;</code></label>
        <label><input type="checkbox" name="tag_ex"     value="1" <%= safeForm.tag_ex     ? 'checked' : '' %> /> 入力例表示 <code>&lt;ex&gt;</code></label>
      </div>

      <h3>文字長制約 <code>&lt;len=...&gt;</code></h3>
      <div class="form-grid">
        <label>演算子
          <select name="tag_len_op">
            <option value="">なし</option>
            <% for (const op of [">=","<=","=",">","<"]) { %>
              <option value="<%= op %>" <%= safeForm.tag_len_op === op ? 'selected' : '' %>><%= op %></option>
            <% } %>
          </select>
        </label>
        <label>文字数
          <input type="number" name="tag_len_val" value="<%= safeForm.tag_len_val || '' %>" min="0" placeholder="例: 50" />
        </label>
      </div>

      <h3>前置文字 / 後置文字（マトリクス）</h3>
      <div class="form-grid">
        <label>前置文字 <code>&lt;bf=text&gt;</code>
          <input type="text" name="tag_bf" value="<%= safeForm.tag_bf || '' %>" placeholder="例: 円" />
        </label>
        <label>後置文字 <code>&lt;af=text&gt;</code>
          <input type="text" name="tag_af" value="<%= safeForm.tag_af || '' %>" placeholder="例: 円" />
        </label>
      </div>

      <h3>前問回答の差し込み <code>&lt;ans q●●&gt;</code></h3>
      <p class="helper-text">設問文やコメントに他の質問の回答を差し込みます。設問文内に直接 <code>&lt;ans q1&gt;</code> と書くか、下で管理できます。</p>
      <div id="ansRows" class="stack-sm">
        <% const ansInsertions = Array.isArray(safeForm.ans_insertions) ? safeForm.ans_insertions : []; %>
        <% for (const ins of ansInsertions) { %>
          <div class="row-card ans-row">
            <div class="form-grid">
              <label>参照元質問コード
                <select name="ans_source">
                  <option value="">選択</option>
                  <% for (const option of nextQuestionOptions) { %>
                    <option value="<%= option.code %>"
                      <%= ins.source === option.code ? 'selected' : '' %>>
                      <%= option.code %> | <%= option.text %>
                    </option>
                  <% } %>
                </select>
              </label>
              <label>差し込み先
                <select name="ans_target">
                  <option value="question_text" <%= ins.target === 'question_text' ? 'selected' : '' %>>設問文</option>
                  <option value="comment_top"   <%= ins.target === 'comment_top'   ? 'selected' : '' %>>コメント上</option>
                  <option value="comment_bottom" <%= ins.target === 'comment_bottom' ? 'selected' : '' %>>コメント下</option>
                </select>
              </label>
            </div>
            <div class="inline-actions">
              <button type="button" class="button-link danger remove-row">削除</button>
            </div>
          </div>
        <% } %>
      </div>
      <button type="button" class="button-link secondary" id="addAnsRow">差し込みを追加</button>

    </section>
  </div>

  <!-- ============================================================ -->
  <!-- Tab 5: タグ詳細（上級者向け）                                  -->
  <!-- ============================================================ -->
  <div class="tab-pane" id="tab-tags">
    <section class="authoring-section stack">
      <h2>5. タグ詳細（上級者向け）</h2>
      <p class="helper-text">
        raw タグ文字列を直接編集できます。
        <strong>「4. 表示・装飾」のフォームから生成したタグ</strong>を確認・上書きできます。<br/>
        保存時は「4. 表示・装飾」のフォーム入力を優先してタグが自動生成されます。
      </p>

      <label>
        タグ文字列（raw）
        <textarea name="display_tags_raw" id="tagsRaw" rows="4"
          placeholder="例: &lt;size=20&gt;&lt;must&gt;&lt;pipe q1=1&gt;"><%= safeForm.display_tags_raw || '' %></textarea>
      </label>

      <div class="inline-actions">
        <button type="button" id="parseTagsBtn" class="button-link secondary">タグを解析</button>
        <button type="button" id="generateTagsBtn" class="button-link secondary">フォームからタグを生成</button>
        <button type="button" id="clearTagsBtn" class="button-link danger">タグをクリア</button>
      </div>

      <!-- 解析結果 -->
      <div id="tagParseResult" class="hidden">
        <h3>解析結果</h3>
        <div id="tagErrorList" class="hidden">
          <p style="font-weight:600;color:#8a0000;">エラー・警告:</p>
          <ul class="tag-error-list" id="tagErrorItems"></ul>
        </div>
        <p style="font-size:12px;color:#60726f;">構造化データ:</p>
        <pre id="tagParsedPreview" class="tag-preview"></pre>
        <p style="font-size:12px;color:#60726f;margin-top:8px;">構造から再生成した raw タグ:</p>
        <pre id="tagGeneratedPreview" class="tag-preview"></pre>
      </div>

      <!-- display_tags_parsed を hidden フィールドで送信 -->
      <input type="hidden" name="display_tags_parsed_json" id="displayTagsParsedJson"
        value="<%= safeForm.display_tags_parsed_json || '' %>" />
    </section>
  </div>

  <!-- ============================================================ -->
  <!-- Submit                                                        -->
  <!-- ============================================================ -->
  <div style="display:flex;gap:12px;align-items:center;justify-content:space-between;">
    <% if (question) { %>
    <div style="display:flex;gap:8px;">
      <% if (prevQuestion) { %>
        <button type="button" class="button-link secondary nav-question-btn" data-nav-key="prev" data-href="/admin/questions/<%= prevQuestion.id %>/edit" style="font-size:13px;">
          ← 前の質問
        </button>
      <% } else { %>
        <button type="button" class="button-link secondary" disabled style="font-size:13px;opacity:0.4;cursor:not-allowed;">← 前の質問</button>
      <% } %>
      <% if (nextQuestion) { %>
        <button type="button" class="button-link secondary nav-question-btn" data-nav-key="next" data-href="/admin/questions/<%= nextQuestion.id %>/edit" style="font-size:13px;">
          次の質問 →
        </button>
      <% } else { %>
        <button type="button" class="button-link secondary" disabled style="font-size:13px;opacity:0.4;cursor:not-allowed;">次の質問 →</button>
      <% } %>
    </div>
    <% } else { %>
    <div></div>
    <% } %>
    <button type="submit" class="button-link primary" style="font-size:16px;padding:12px 32px;">
      <%= question ? '更新する' : '作成する' %>
    </button>
  </div>
</form>

<!-- ============================================================ -->
<!-- プレビューモーダル                                             -->
<!-- ============================================================ -->
<div id="previewModal" style="
  display:none; position:fixed; inset:0; background:rgba(0,0,0,.5);
  z-index:1000; align-items:center; justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:24px;max-width:480px;width:90%;max-height:80vh;overflow-y:auto;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <h2 style="margin:0;">プレビュー</h2>
      <div style="display:flex;gap:8px;">
        <select id="previewMode" style="border:1px solid #ccc;border-radius:6px;padding:4px 8px;">
          <option value="survey_question">survey_question (1問ずつ)</option>
          <option value="survey_page">survey_page (ページ)</option>
          <option value="interview_chat">interview_chat (チャット)</option>
        </select>
        <button id="closePreview" style="border:none;background:none;font-size:20px;cursor:pointer;">✕</button>
      </div>
    </div>
    <div id="previewContent"></div>
  </div>
</div>

<script>
(() => {
  // ----------------------------------------------------------------
  // タブ切り替え
  // ----------------------------------------------------------------
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
  });

  // ----------------------------------------------------------------
  // 設問タイプ切り替えで回答形式セクションを表示/非表示
  // ----------------------------------------------------------------
  const CHOICE_TYPES  = <%- JSON.stringify(CHOICE_TYPES) %>;
  const MATRIX_TYPES  = <%- JSON.stringify(MATRIX_TYPES) %>;
  const SCALE_TYPES   = ["scale"];

  function syncTypeVisibility() {
    const type = document.getElementById('questionType').value;
    document.getElementById('typeChoiceFields').classList.toggle('hidden',
      !CHOICE_TYPES.includes(type));
    document.getElementById('typeChoiceDisplayFields').classList.toggle('hidden',
      !CHOICE_TYPES.includes(type));
    document.getElementById('typeMultiFields').classList.toggle('hidden',
      type !== 'multi_choice');
    document.getElementById('typeScaleFields').classList.toggle('hidden', true);
    document.getElementById('typeMatrixFields').classList.toggle('hidden',
      !MATRIX_TYPES.includes(type));
    document.getElementById('typeImageUploadFields').classList.toggle('hidden',
      type !== 'image_upload');
    document.getElementById('typeTextFields').classList.toggle('hidden',
      CHOICE_TYPES.includes(type) || SCALE_TYPES.includes(type) || MATRIX_TYPES.includes(type) || type === 'image_upload');
  }
  document.getElementById('questionType').addEventListener('change', syncTypeVisibility);

  // ----------------------------------------------------------------
  // display_format 切り替え（カードグリッド設定の表示/非表示）
  // ----------------------------------------------------------------
  document.querySelectorAll('[name="display_format"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const isCard = document.querySelector('[name="display_format"]:checked')?.value === 'card';
      document.getElementById('gridColsField').style.display = isCard ? '' : 'none';
    });
  });

  // ----------------------------------------------------------------
  // 表示モードカード選択
  // ----------------------------------------------------------------
  document.querySelectorAll('.display-mode-card input[type=radio]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.display-mode-card').forEach(c => c.classList.remove('selected'));
      radio.closest('.display-mode-card')?.classList.add('selected');
    });
  });

  // ----------------------------------------------------------------
  // スクリーニング設問チェックと通過対象UI の同期
  // ----------------------------------------------------------------
  const SCREENING_CHOICE_TYPES_JS = ['single_choice', 'multi_choice'];

  function syncScreeningPassUI() {
    const isScreening = document.getElementById('screeningCheck')?.checked ?? false;
    const qType = document.getElementById('questionType')?.value ?? '';
    const isChoiceType = SCREENING_CHOICE_TYPES_JS.includes(qType);
    const note = document.getElementById('screeningUnsupportedNote');
    const canPass = isScreening && isChoiceType;

    // 通過対象チェックボックスの enabled/disabled 切り替え（常時表示）
    document.querySelectorAll('.screening-pass-label').forEach(el => {
      const cb = el.querySelector('.screening-pass-check');
      if (cb) cb.disabled = !canPass;
      el.style.color = canPass ? '#1a7a57' : '#60726f';
      el.style.cursor = canPass ? 'pointer' : 'default';
    });

    // スクリーニング非対応タイプの警告
    if (note) note.style.display = (isScreening && !isChoiceType) ? '' : 'none';

    // 通過対象ノートの表示切り替え
    const passOffNote = document.getElementById('screeningPassOffNote');
    const passOnNote = document.getElementById('screeningPassOnNote');
    if (passOffNote) passOffNote.style.display = (!canPass && isChoiceType) ? '' : 'none';
    if (passOnNote) passOnNote.style.display = canPass ? '' : 'none';

    // question_role を自動同期
    const roleSelect = document.getElementById('questionRole');
    if (roleSelect) {
      if (isScreening && roleSelect.value !== 'screening') roleSelect.value = 'screening';
      if (!isScreening && roleSelect.value === 'screening') roleSelect.value = 'main';
    }
  }

  function onScreeningCheckChange(cb) {
    syncScreeningPassUI();
  }

  // 質問タイプ変更時にもスクリーニングUIを同期
  document.getElementById('questionType')?.addEventListener('change', syncScreeningPassUI);

  // 初期表示
  syncScreeningPassUI();

  // ----------------------------------------------------------------
  // 排他制御（手動UIは廃止）: ラベルが「特になし/わからない/該当なし/その他」の
  // 選択肢は、保存時にサーバ側で自動的に全排他(exclusive)になる。
  // ここではプレビュー表示のためだけにラベルから同じ判定を行う。
  // ----------------------------------------------------------------
  const EXCLUSIVE_DEFAULT_RE = /特になし|わからない|分からない|該当なし|その他/;

  function isMultiChoice() {
    return (document.getElementById('questionType')?.value ?? '') === 'multi_choice';
  }

  // ----------------------------------------------------------------
  // 排他制御プレビュー（回答画面と同じ挙動で試せる）
  // ----------------------------------------------------------------
  // 現在のフォーム状態から選択肢モデルを読む（exclusive はラベルから自動判定）
  function readOptionModel() {
    return [...document.querySelectorAll('#optionRows .option-row')].map(row => {
      const label = (row.querySelector('input[name="option_labels"]')?.value ?? '').trim();
      const exclusive = EXCLUSIVE_DEFAULT_RE.test(label);
      return { label, exclusive, exclusive_with: [] };
    }).filter(o => o.label !== '');
  }

  // 無向の排他判定（survey.ejs applyExclusion と同一ルール）
  function conflictsModel(a, b) {
    if (a.label === b.label) return false;
    if (a.exclusive || b.exclusive) return true;
    if (a.exclusive_with.includes(b.label)) return true;
    if (b.exclusive_with.includes(a.label)) return true;
    return false;
  }

  function renderExclusivePreview() {
    const model = readOptionModel();
    const summaryEl = document.getElementById('exclusivePreviewSummary');
    const checksEl  = document.getElementById('exclusivePreviewChecks');
    const noteEl    = document.getElementById('exclusivePreviewNote');
    if (!summaryEl || !checksEl) return;
    noteEl && (noteEl.textContent = '');

    // --- ルール要約 ---
    const lines = [];
    model.forEach(o => {
      if (o.exclusive) {
        lines.push(`<div>🚫 <strong>${escHtml(o.label)}</strong> … 他すべてと排他（選ぶと他が全部外れる）</div>`);
      } else if (o.exclusive_with.length > 0) {
        lines.push(`<div>⇔ <strong>${escHtml(o.label)}</strong> … ${o.exclusive_with.map(escHtml).join('・')} と排他</div>`);
      }
    });
    summaryEl.innerHTML = lines.length
      ? lines.join('')
      : '<span style="color:#8a7a5a;">排他ルールは未設定です。上の各選択肢「排他設定」で設定できます。</span>';

    // --- インタラクティブ・チェック（回答画面の再現） ---
    checksEl.innerHTML = '';
    if (model.length === 0) {
      checksEl.innerHTML = '<span style="color:#8a7a5a;font-size:12px;">選択肢を入力するとプレビューできます。</span>';
      return;
    }
    model.forEach((o, i) => {
      const id = 'exprev_' + i;
      const wrap = document.createElement('label');
      wrap.style.cssText = 'display:flex;align-items:center;gap:8px;font-weight:normal;font-size:13px;padding:6px 10px;border:1px solid #e2d6bd;border-radius:8px;background:#fff;cursor:pointer;';
      const badge = o.exclusive
        ? '<span style="margin-left:auto;font-size:11px;color:#b45309;">全排他</span>'
        : (o.exclusive_with.length ? `<span style="margin-left:auto;font-size:11px;color:#b45309;">排他${o.exclusive_with.length}</span>` : '');
      wrap.innerHTML = `<input type="checkbox" data-label="${escHtml(o.label)}" style="width:auto;flex:0 0 auto;padding:0;margin:0;border:none;" /><span>${escHtml(o.label)}</span>${badge}`;
      checksEl.appendChild(wrap);
    });

    // クリックで排他挙動（回答画面と同じ：ONにしたら衝突相手を自動OFF）
    const boxes = [...checksEl.querySelectorAll('input[type=checkbox]')];
    const modelByLabel = new Map(model.map(o => [o.label, o]));
    boxes.forEach(box => {
      box.addEventListener('change', () => {
        if (!box.checked) { paintPreviewRows(); return; }
        const me = modelByLabel.get(box.getAttribute('data-label'));
        const removed = [];
        boxes.forEach(other => {
          if (other === box || !other.checked) return;
          const o2 = modelByLabel.get(other.getAttribute('data-label'));
          if (me && o2 && conflictsModel(me, o2)) {
            other.checked = false;
            removed.push(o2.label);
          }
        });
        paintPreviewRows();
        if (noteEl) {
          noteEl.textContent = removed.length
            ? `「${me.label}」を選んだので、排他の「${removed.join('」「')}」を自動で外しました。`
            : `「${me.label}」を選択（排他相手なし）。`;
        }
      });
    });

    function paintPreviewRows() {
      boxes.forEach(b => {
        const lbl = b.closest('label');
        if (lbl) lbl.style.background = b.checked ? '#e8f7f0' : '#fff';
        if (lbl) lbl.style.borderColor = b.checked ? '#2ca87a' : '#e2d6bd';
      });
    }
  }


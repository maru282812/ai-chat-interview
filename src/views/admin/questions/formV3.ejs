  function syncImagePreview(urlInput) {
    // urlInput は display:flex の内側 div にある。.option-image-preview は外側 div の直下なので parentElement を経由する
    const outerDiv = urlInput.closest('div[style]').parentElement;
    const preview = outerDiv ? outerDiv.querySelector('.option-image-preview') : null;
    const img = preview ? preview.querySelector('img') : null;
    const url = urlInput.value.trim();
    if (url && preview) {
      if (img) img.src = url;
      preview.style.display = '';
    } else if (preview) {
      preview.style.display = 'none';
    }
  }

  function attachImageHandlers(container) {
    container.querySelectorAll('.option-file-input').forEach(fileInput => {
      // fileInput → <label> → <div style="display:flex"> → outerDiv (style="flex:2")
      // outerDiv に .option-image-url と .option-image-preview の両方がある
      const getOuterDiv = (el) => {
        const inner = el.closest('div[style]');
        return inner ? inner.parentElement : null;
      };

      const uploadFile = async (file) => {
        const ALLOWED_TYPES = ['image/png', 'image/jpeg', 'image/jpg', 'image/webp'];
        const MAX_BYTES = 5 * 1024 * 1024;
        if (!ALLOWED_TYPES.includes(file.type)) {
          alert('対応形式はPNG・JPEG・WebPのみです（選択: ' + (file.type || '不明') + '）');
          return;
        }
        if (file.size > MAX_BYTES) {
          alert('画像サイズは5MB以下にしてください（現在: ' + (file.size / 1024 / 1024).toFixed(1) + 'MB）');
          return;
        }
        const outerDiv = getOuterDiv(fileInput);
        if (!outerDiv) return;
        const urlInput = outerDiv.querySelector('.option-image-url');
        const preview  = outerDiv.querySelector('.option-image-preview');
        const img      = preview ? preview.querySelector('img') : null;
        const label    = fileInput.closest('label');
        if (!urlInput) return;
        if (label) label.textContent = '送信中...';
        try {
          const base64 = await new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = reject;
            reader.readAsDataURL(file);
          });
          const resp = await fetch('/admin/api/upload/image', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: base64, filename: file.name, mimeType: file.type }),
          });
          const json = await resp.json().catch(() => ({ error: 'サーバーエラー (HTTP ' + resp.status + ')' }));
          if (!resp.ok || !json.url) throw new Error(json.error || 'Upload failed');
          urlInput.value = json.url;
          urlInput.dispatchEvent(new Event('input'));
          if (img) img.src = json.url;
          if (preview) preview.style.display = '';
        } catch (err) {
          alert('画像アップロード失敗: ' + err.message);
        } finally {
          if (label) {
            label.innerHTML = 'ファイル選択<input type="file" accept="image/png,image/jpeg,image/webp" class="option-file-input" hidden />';
            const card = label.closest('.option-row') || label.closest('.matrix-row-card') || label.closest('.matrix-col-card') || label.closest('.question-text-image-card');
            if (card) attachImageHandlers(card);
          }
        }
      };

      fileInput.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (file) await uploadFile(file);
      });

      // ドラッグ＆ドロップ（外側 div への drag を受け付ける）
      const outerDiv = getOuterDiv(fileInput);
      if (outerDiv && !outerDiv.dataset.dropBound) {
        outerDiv.dataset.dropBound = '1';
        outerDiv.title = '画像をここにドロップできます';
        outerDiv.addEventListener('dragenter', (e) => { e.preventDefault(); });
        outerDiv.addEventListener('dragover', (e) => {
          e.preventDefault();
          outerDiv.style.outline = '2px dashed #2ca87a';
          outerDiv.style.borderRadius = '6px';
          outerDiv.style.background = 'rgba(44,168,122,0.06)';
        });
        outerDiv.addEventListener('dragleave', (e) => {
          if (!outerDiv.contains(e.relatedTarget)) {
            outerDiv.style.outline = '';
            outerDiv.style.background = '';
          }
        });
        outerDiv.addEventListener('drop', async (e) => {
          e.preventDefault();
          outerDiv.style.outline = '';
          outerDiv.style.background = '';
          const file = e.dataTransfer?.files?.[0];
          if (file) await uploadFile(file);
        });
      }
    });
    container.querySelectorAll('.remove-image').forEach(btn => {
      btn.addEventListener('click', () => {
        const row = btn.closest('.option-row') || btn.closest('.matrix-row-card') || btn.closest('.matrix-col-card') || btn.closest('div');
        const urlInput = row ? row.querySelector('.option-image-url') : null;
        const preview = btn.closest('.option-image-preview');
        if (urlInput) urlInput.value = '';
        if (preview) preview.style.display = 'none';
      });
    });
  }

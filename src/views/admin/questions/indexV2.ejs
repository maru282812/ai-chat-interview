<%- include("../../partials/header", { title }) %>

<div class="actions-row">
  <a class="button-link" href="/admin/projects/<%= project.id %>/questions/new">質問を追加</a>
  <span class="muted"><%= project.name %></span>
</div>

<table style="margin-top: 16px;">
  <thead>
    <tr>
      <th>順番</th>
      <th>コード</th>
      <th>役割</th>
      <th>質問文</th>
      <th>形式</th>
      <th>深掘り</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% for (const question of questions) { %>
      <tr>
        <td><%= question.sort_order %></td>
        <td><%= question.question_code %></td>
        <td><span class="tag"><%= question.question_role %></span></td>
        <td><strong><%= question.question_text %></strong></td>
        <td><%= question.question_type %></td>
        <td><%= question.ai_probe_enabled ? "有効" : "無効" %></td>
        <td><a href="/admin/questions/<%= question.id %>/edit">編集</a></td>
      </tr>
    <% } %>
  </tbody>
</table>

<%- include("../../partials/footer") %>

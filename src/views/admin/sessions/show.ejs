<%
function formatAnswerAdmin(answer, question) {
  if (!answer || !answer.answer_text) return '-';
  const text = answer.answer_text;
  if (!question) return text;
  const qType = question.question_type;
  const cfg = question.question_config || {};

  if (['matrix_single', 'matrix_multi', 'matrix_mixed'].includes(qType)) {
    try {
      const val = JSON.parse(text);
      if (typeof val !== 'object' || val === null || Array.isArray(val)) return text;
      const rows = cfg.matrix_rows || cfg.options || [];
      const cols = (cfg.matrix_cols || []).map(c => typeof c === 'string' ? { label: c } : c);
      return Object.keys(val).sort((a, b) => parseInt(a) - parseInt(b)).map(ri => {
        const row = rows[parseInt(ri)];
        const rowLabel = row ? (row.label || ('行' + (parseInt(ri)+1))) : ('行' + (parseInt(ri)+1));
        const colVal = val[ri];
        if (Array.isArray(colVal)) {
          const colLabels = colVal.map(ci => { const col = cols[parseInt(ci)]; return col ? (col.label || String(parseInt(ci)+1)) : String(parseInt(ci)+1); });
          return rowLabel + '：' + colLabels.join('・');
        }
        const ci = parseInt(colVal);
        const col = cols[ci];
        return rowLabel + '：' + (col ? (col.label || String(ci+1)) : String(ci+1));
      }).join(' / ');
    } catch(e) { return text; }
  }

  if (['single_choice', 'text_with_image'].includes(qType)) {
    const opts = cfg.options || [];
    const o = opts.find(o => String(o.value) === String(text));
    return o ? o.label : text;
  }

  if (qType === 'multi_choice') {
    const opts = cfg.options || [];
    return text.split(',').map(v => { const o = opts.find(o => String(o.value) === v.trim()); return o ? o.label : v.trim(); }).join('、');
  }

  if (['sd', 'numeric'].includes(qType) && (cfg.options || []).length) {
    const o = (cfg.options || []).find(o => String(o.value) === String(text));
    return o ? o.label : text;
  }

  return text;
}
%>
<%- include("../../partials/header", { title }) %>
<section class="grid">
  <div class="card">
    <h2>Session</h2>
    <p><strong><%= respondent.display_name || respondent.line_user_id %></strong></p>
    <p class="muted">Project: <%= project.name %></p>
    <p>Status: <span class="tag"><%= session.status %></span></p>
    <p>Phase: <%= session.current_phase %></p>
    <p>Started: <%= session.started_at %></p>
    <p>Completed: <%= session.completed_at || "-" %></p>
  </div>
  <div class="card">
    <h2>Project Context</h2>
    <p class="muted">Research mode: <%= project.research_mode %></p>
    <p><strong>Primary objectives</strong><br /><%= (project.primary_objectives || []).join(" / ") || "-" %></p>
    <p><strong>Secondary objectives</strong><br /><%= (project.secondary_objectives || []).join(" / ") || "-" %></p>
  </div>
</section>

<section class="stack" style="margin-top: 16px;">
  <div class="card">
    <h2>Answers by Question</h2>
    <table>
      <thead>
        <tr>
          <th>Order</th>
          <th>Code</th>
          <th>Role</th>
          <th>Question</th>
          <th>Answer</th>
          <th>normalized_answer</th>
          <th>extracted_json</th>
          <th>AI Probe</th>
        </tr>
      </thead>
      <tbody>
        <% for (const group of answerGroups) { %>
          <tr>
            <td><%= group.question.sort_order %></td>
            <td><%= group.question.question_code %></td>
            <td><span class="tag"><%= group.question.question_role %></span></td>
            <td><strong><%= group.question.question_text %></strong></td>
            <td>
              <%= formatAnswerAdmin(group.primaryAnswer, group.question) %>
              <% if (group.primaryAnswer?.answer_text && group.primaryAnswer.answer_text !== formatAnswerAdmin(group.primaryAnswer, group.question)) { %>
                <div class="muted" style="margin-top:4px;font-size:11px;">raw: <%= group.primaryAnswer.answer_text %></div>
              <% } %>
              <% if (group.primaryAnswer?.free_text_answer) { %>
                <div class="muted" style="margin-top: 6px; font-size: 12px;">自由記述:</div>
                <div class="prelike" style="white-space: pre-wrap;"><%= group.primaryAnswer.free_text_answer %></div>
              <% } %>
              <% if (group.probeAnswers.length > 0) { %>
                <div class="muted" style="margin-top: 8px;">Probe answers:</div>
                <% for (const probe of group.probeAnswers) { %>
                  <div class="prelike"><%= probe.answer_text %></div>
                <% } %>
              <% } %>
            </td>
            <td><pre class="prelike"><%= group.primaryAnswer?.normalized_answer ? JSON.stringify(group.primaryAnswer.normalized_answer, null, 2) : "-" %></pre></td>
            <td><pre class="prelike"><%= group.extraction?.extracted_json ? JSON.stringify(group.extraction.extracted_json, null, 2) : "-" %></pre></td>
            <td><%= group.hasAiProbe ? "Yes" : "No" %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Conversation Log</h2>
    <table>
      <thead>
        <tr>
          <th>At</th>
          <th>Sender</th>
          <th>Message</th>
        </tr>
      </thead>
      <tbody>
        <% for (const message of messages) { %>
          <tr>
            <td><%= message.created_at %></td>
            <td><span class="tag"><%= message.sender_type %></span></td>
            <td><div class="prelike"><%= message.message_text %></div></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>AI Analysis</h2>
    <% if (analysis) { %>
      <p><strong>Summary:</strong> <%= analysis.summary || "-" %></p>
      <p><strong>Usage Scene:</strong> <%= analysis.usage_scene || "-" %></p>
      <p><strong>Motive:</strong> <%= analysis.motive || "-" %></p>
      <p><strong>Pain Points:</strong> <%= analysis.pain_points || "-" %></p>
      <p><strong>Alternatives:</strong> <%= analysis.alternatives || "-" %></p>
      <p><strong>Insights:</strong> <%= analysis.insight_candidates || "-" %></p>
    <% } else { %>
      <p class="muted">No session analysis yet.</p>
    <% } %>
  </div>
</section>
<%- include("../../partials/footer") %>

<%- include("../../partials/header", { title }) %>
<h2>セッション</h2>
<p class="muted" style="margin-top:4px">
  回答セッションを横断的に確認できます。ダッシュボードの「進行中セッション」からもここへ遷移します。
</p>

<form class="card" method="get" action="/admin/sessions">
  <div class="form-grid">
    <label>
      プロジェクト
      <select name="project_id">
        <option value="">すべて</option>
        <% for (const project of projects) { %>
          <option value="<%= project.id %>" <%= filters.projectId === project.id ? "selected" : "" %>>
            <%= project.name %>
          </option>
        <% } %>
      </select>
    </label>
    <label>
      ステータス
      <select name="status">
        <option value="">すべて</option>
        <% for (const value of ["pending", "active", "completed", "abandoned"]) { %>
          <option value="<%= value %>" <%= filters.status === value ? "selected" : "" %>>
            <%= statusLabel("sessionStatus", value) %>
          </option>
        <% } %>
      </select>
    </label>
  </div>
  <div class="actions-row">
    <button type="submit">絞り込む</button>
    <a class="button-link secondary" href="/admin/sessions">条件をリセット</a>
  </div>
</form>

<div class="table-scroll" style="margin-top:16px">
  <table>
    <thead>
      <tr>
        <th>プロジェクト</th>
        <th>回答者</th>
        <th>ステータス</th>
        <th>フェーズ</th>
        <th>開始</th>
        <th>最終アクティビティ</th>
        <th>完了</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% if (sessions.length === 0) { %>
        <tr>
          <td colspan="8">
            <p class="muted" style="margin:8px 0">
              条件に一致するセッションがありません。
              <% if (filters.projectId || filters.status) { %>
                <a href="/admin/sessions">条件をリセット</a>して再検索してください。
              <% } %>
            </p>
          </td>
        </tr>
      <% } %>
      <% for (const session of sessions) { %>
        <tr>
          <td>
            <% if (session.project) { %>
              <strong><%= session.project.name %></strong>
            <% } else { %>
              <span class="muted">-</span>
            <% } %>
          </td>
          <td>
            <% if (session.respondent) { %>
              <a href="/admin/respondents/<%= session.respondent.id %>">
                <%= session.respondent.display_name || shortId(session.respondent.line_user_id) %>
              </a>
            <% } else { %>
              <span class="muted">-</span>
            <% } %>
          </td>
          <td><span class="tag"><%= statusLabel("sessionStatus", session.status) %></span></td>
          <td><%= statusLabel("sessionPhase", session.current_phase) %></td>
          <td><%= fmtDateTime(session.started_at) %></td>
          <td>
            <span title="<%= fmtDateTime(session.last_activity_at) %>">
              <%= fmtRelative(session.last_activity_at) %>
            </span>
          </td>
          <td><%= fmtDateTime(session.completed_at) %></td>
          <td><a href="/admin/sessions/<%= session.id %>">詳細</a></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../../partials/admin-pagination", {
  page,
  totalPages,
  total,
  basePath: "/admin/sessions",
  query: { project_id: filters.projectId, status: filters.status }
}) %>
<%- include("../../partials/footer") %>

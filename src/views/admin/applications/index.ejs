<%- include("../../partials/header", { title }) %>

<%
const APP_STATUS = {
  applied:   { label: '選考中',   color: '#c8851b' },
  accepted:  { label: '当選',     color: '#2ca87a' },
  rejected:  { label: '落選',     color: '#999' },
  withdrawn: { label: '取り消し', color: '#999' },
  expired:   { label: '期限切れ', color: '#b14' }
};
function appBadge(status) {
  const s = APP_STATUS[status] || { label: status, color: '#999' };
  return '<span style="display:inline-block;background:' + s.color + ';color:#fff;font-size:11px;padding:1px 7px;border-radius:3px">' + s.label + '</span>';
}
function fmt(dt) {
  if (!dt) return '-';
  const d = new Date(dt);
  return (d.getMonth()+1) + '/' + d.getDate() + ' ' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
}
%>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
  <h2>応募管理</h2>
</div>

<% if (msg) { %>
  <div class="card" style="background:#e9f7f0;border:1px solid #2ca87a;color:#1c6e4f;padding:10px 14px;margin-bottom:1rem"><%= msg %></div>
<% } %>
<% if (err) { %>
  <div class="card" style="background:#fdeaea;border:1px solid #b14;color:#902a2a;padding:10px 14px;margin-bottom:1rem"><%= err %></div>
<% } %>

<p class="muted" style="margin-bottom:1rem">
  「探す」からの応募一覧です。<strong>応募方式が手動選考（manual）の案件</strong>はここで当選/落選を決めます。
  当選にすると回答用の assignment が発行され、LINEで当選通知（回答URL付き）が送られます。
  自動承認（auto）案件の応募は最初から「当選」として記録されます。
</p>

<form method="get" action="/admin/applications" style="margin-bottom:1rem">
  <label>案件で絞り込み:
    <select name="project_id" onchange="this.form.submit()">
      <option value="">すべて</option>
      <% projects.forEach(function(p) { %>
        <option value="<%= p.id %>" <%= projectIdFilter === p.id ? 'selected' : '' %>><%= p.user_display_title || p.name %></option>
      <% }); %>
    </select>
  </label>
</form>

<%#
  一括当選/落選。行内の単体フォームとネストしないよう、チェックボックスは
  form 属性でこのフォームに参加させる（対象は「選考中」の行のみ）。
%>
<form id="bulk-decide-form" method="post" action="/admin/applications/bulk-decide"
      class="card" style="margin-bottom:1rem;padding:10px 14px;display:flex;gap:12px;align-items:center;flex-wrap:wrap">
  <input type="hidden" name="back" value="<%= projectIdFilter || '' %>">
  <strong style="font-size:13px">一括操作:</strong>
  <span class="muted" style="font-size:12px">選択中 <span id="bulk-count">0</span> 件</span>
  <button type="submit" name="decision" value="accept" id="bulk-accept-btn"
          style="background:#2ca87a;color:#fff;border:none;border-radius:4px;padding:5px 12px;cursor:pointer">
    選択を当選にする
  </button>
  <span style="display:inline-flex;gap:6px;align-items:center">
    <button type="submit" name="decision" value="reject" id="bulk-reject-btn"
            style="background:#fff;color:#b14;border:1px solid #b14;border-radius:4px;padding:4px 12px;cursor:pointer">
      選択を落選にする
    </button>
    <label style="font-size:11px"><input type="checkbox" name="notify" value="1"> 落選を通知する</label>
    <input type="text" name="note" placeholder="落選理由メモ（任意・記録用）"
           style="font-size:12px;padding:4px 6px;border:1px solid #ccc;border-radius:4px;width:200px">
  </span>
</form>

<table class="table" style="width:100%;border-collapse:collapse">
  <thead>
    <tr style="text-align:left;border-bottom:2px solid #ddd">
      <th style="padding:8px 6px"><input type="checkbox" id="bulk-check-all" title="選考中の応募をすべて選択"></th>
      <th style="padding:8px 6px">応募日時</th>
      <th style="padding:8px 6px">案件</th>
      <th style="padding:8px 6px">応募者（LINE ID）</th>
      <th style="padding:8px 6px">状態</th>
      <th style="padding:8px 6px">決定日時</th>
      <th style="padding:8px 6px">操作</th>
    </tr>
  </thead>
  <tbody>
    <% if (rows.length === 0) { %>
      <tr><td colspan="7" style="padding:16px 6px;color:#888">応募はまだありません</td></tr>
    <% } %>
    <% rows.forEach(function(row) { const a = row.application; %>
      <tr style="border-bottom:1px solid #eee">
        <td style="padding:8px 6px">
          <% if (a.status === 'applied') { %>
            <input type="checkbox" class="bulk-check" name="application_ids" value="<%= a.id %>" form="bulk-decide-form">
          <% } %>
        </td>
        <td style="padding:8px 6px;white-space:nowrap"><%= fmt(a.applied_at) %></td>
        <td style="padding:8px 6px">
          <% if (row.project) { %>
            <a href="/admin/projects/<%= row.project.id %>"><%= row.project.user_display_title || row.project.name %></a>
            <span class="muted" style="font-size:11px">（<%= (row.project.apply_mode || 'manual') === 'auto' ? '自動承認' : '手動選考' %>）</span>
          <% } else { %>-<% } %>
        </td>
        <td style="padding:8px 6px;font-family:monospace;font-size:11.5px"><%= a.line_user_id %></td>
        <td style="padding:8px 6px"><%- appBadge(a.status) %></td>
        <td style="padding:8px 6px;white-space:nowrap"><%= fmt(a.decided_at) %></td>
        <td style="padding:8px 6px;white-space:nowrap">
          <% if (a.status === 'applied') { %>
            <form method="post" action="/admin/applications/<%= a.id %>/accept" style="display:inline" onsubmit="return confirm('この応募を当選にして、回答URL付きのLINE通知を送りますか？')">
              <input type="hidden" name="back" value="<%= projectIdFilter || '' %>">
              <button type="submit" style="background:#2ca87a;color:#fff;border:none;border-radius:4px;padding:5px 12px;cursor:pointer">当選</button>
            </form>
            <form method="post" action="/admin/applications/<%= a.id %>/reject" style="display:inline;margin-left:6px" onsubmit="return confirm('この応募を落選にしますか？')">
              <input type="hidden" name="back" value="<%= projectIdFilter || '' %>">
              <label style="font-size:11px"><input type="checkbox" name="notify" value="1"> 通知する</label>
              <button type="submit" style="background:#fff;color:#b14;border:1px solid #b14;border-radius:4px;padding:4px 12px;cursor:pointer;margin-left:4px">落選</button>
            </form>
          <% } else if (a.status === 'accepted' && a.assignment_id) { %>
            <span class="muted" style="font-size:11px">assignment: <%= a.assignment_id.slice(0, 8) %>…</span>
          <% } else { %>
            <span class="muted">-</span>
          <% } %>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>

<script>
  (function () {
    var checkAll = document.getElementById('bulk-check-all');
    var countEl = document.getElementById('bulk-count');
    var form = document.getElementById('bulk-decide-form');
    function checks() { return Array.prototype.slice.call(document.querySelectorAll('.bulk-check')); }
    function updateCount() {
      countEl.textContent = String(checks().filter(function (c) { return c.checked; }).length);
    }
    if (checkAll) {
      checkAll.addEventListener('change', function () {
        checks().forEach(function (c) { c.checked = checkAll.checked; });
        updateCount();
      });
    }
    document.addEventListener('change', function (e) {
      if (e.target && e.target.classList && e.target.classList.contains('bulk-check')) updateCount();
    });
    form.addEventListener('submit', function (e) {
      var selected = checks().filter(function (c) { return c.checked; }).length;
      if (selected === 0) {
        e.preventDefault();
        alert('応募が1件も選択されていません。');
        return;
      }
      var decision = e.submitter && e.submitter.value;
      var message = decision === 'accept'
        ? '選択した ' + selected + ' 件を当選にして、回答URL付きのLINE通知を送りますか？'
        : '選択した ' + selected + ' 件を落選にしますか？';
      if (!confirm(message)) {
        e.preventDefault();
        return;
      }
      // 二重送信防止
      document.getElementById('bulk-accept-btn').disabled = true;
      document.getElementById('bulk-reject-btn').disabled = true;
    });
    updateCount();
  })();
</script>

<%- include("../../partials/footer") %>

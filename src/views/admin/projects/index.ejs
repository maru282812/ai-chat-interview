<%- include("../../partials/header", { title }) %>
<p><a class="button-link" href="/admin/projects/new">新規プロジェクト</a></p>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Client</th>
      <th>Status</th>
      <th>Reward</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% for (const project of projects) { %>
      <tr>
        <td><strong><%= project.name %></strong><br /><span class="muted"><%= project.objective || "" %></span></td>
        <td><%= project.client_name || "-" %></td>
        <td><span class="tag"><%= project.status %></span></td>
        <td><%= project.reward_points %> pt</td>
        <td>
          <a href="/admin/projects/<%= project.id %>/edit">編集</a> |
          <a href="/admin/projects/<%= project.id %>/questions">質問管理</a>
        </td>
      </tr>
    <% } %>
  </tbody>
</table>
<%- include("../../partials/footer") %>

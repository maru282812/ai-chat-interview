<%- include("../../partials/header", { title }) %>
<%
  const form = projectForm || {};
  const aiState = aiStateDisplay || form.ai_state_summary || {};
  const requiredSlots = Array.isArray(aiState.required_slots) ? aiState.required_slots : [];
  const optionalSlots = Array.isArray(aiState.optional_slots) ? aiState.optional_slots : [];
  const modeOptions = [
    { value: "survey_interview", label: "サーベイ＋インタビュー" },
    { value: "interview", label: "インタビュー" }
  ];
  const statusOptions = [
    { value: "draft", label: "下書き" },
    { value: "ready", label: "配信待ち" },
    { value: "published", label: "LIFF掲載中" },
    { value: "paused", label: "一時停止" },
    { value: "closed", label: "募集終了" },
    { value: "archived", label: "アーカイブ" }
  ];
%>

<style>
  .editor-section {
    border: 1px solid #d8e3e0;
    border-radius: 14px;
    padding: 18px;
    background: #f8fbfa;
  }
  .editor-section h2,
  .editor-section h3 {
    margin: 0 0 10px;
  }
  .helper-text {
    margin: 0;
    font-size: 12px;
    color: #60726f;
  }
  .summary-toggle {
    cursor: pointer;
    font-weight: 600;
  }
  .preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }
  .preview-card {
    border: 1px solid #d8e3e0;
    border-radius: 12px;
    padding: 12px;
    background: #fff;
  }
  .slot-list {
    display: grid;
    gap: 8px;
  }
  .slot-item {
    border: 1px solid #d8e3e0;
    border-radius: 10px;
    padding: 10px;
    background: #fff;
  }
  .sc-cond-block {
    border: 1px solid #e0e8e4;
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 6px;
    background: #fff;
  }
  .sc-cond-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    cursor: pointer;
    margin: 0;
  }
  .sc-cond-fields {
    margin-top: 8px;
    padding-left: 24px;
  }
  .sc-cond-checks {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }
  .sc-cond-checks label {
    display: flex;
    align-items: center;
    gap: 4px;
    margin: 0;
    font-weight: normal;
  }
  .sc-pref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
    gap: 4px;
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid #d8e3e0;
    border-radius: 6px;
    padding: 8px;
    background: #f8fbfa;
  }
  .sc-pref-grid label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    white-space: nowrap;
    font-weight: normal;
    margin: 0;
  }
</style>

<form class="card stack" method="post" action="<%= action %>">
  <% if (successMessage) { %>
    <section class="card subtle-card success-card">
      <strong class="success-text"><%= successMessage %></strong>
    </section>
  <% } %>

  <% if (errorMessage) { %>
    <section class="card subtle-card">
      <strong class="danger-text">入力内容を確認してください</strong>
      <p class="danger-text"><%= errorMessage %></p>
    </section>
  <% } %>

  <section class="editor-section stack">
    <h2>1. 基本設定</h2>
    <p class="helper-text">まずはこの3項目だけで、使える調査プロジェクトを作れます。</p>

    <div class="form-grid">
      <label>
        管理用プロジェクト名
        <small class="helper-text">管理画面で使用する内部管理用の名前です。USERには表示されません。</small>
        <input type="text" name="name" value="<%= form.name || '' %>" required />
      </label>
      <label>
        USER表示タイトル
        <small class="helper-text">LINE送付時や回答画面でUSERに表示されるタイトルです。空白の場合は管理用プロジェクト名が使われます。</small>
        <input type="text" name="user_display_title" value="<%= form.user_display_title || '' %>" placeholder="例: 飲食店の利用体験に関するアンケート" />
      </label>
      <label>
        調査モード
        <select name="research_mode">
          <% for (const mode of modeOptions) { %>
            <option value="<%= mode.value %>" <%= form.research_mode === mode.value ? "selected" : "" %>><%= mode.label %></option>
          <% } %>
        </select>
      </label>
    </div>

    <label>
      調査目的
      <textarea name="objective" required placeholder="例: どの利用シーンで不満が出るのか把握したい"><%= form.objective || '' %></textarea>
    </label>
  </section>

  <details class="editor-section">
    <summary class="summary-toggle">2. 詳細設定</summary>
    <div class="stack" style="margin-top: 14px;">
      <div class="form-grid">
        <label>
          <input type="checkbox" name="deep_probe_enabled" <%= form.deep_probe_enabled ? "checked" : "" %> />
          深掘りを有効にする
        </label>
        <label>
          最大深掘り回数
          <input type="number" name="max_probe_depth" min="0" value="<%= form.max_probe_depth_text || '1' %>" />
        </label>
        <label>
          表示スタイル
          <select name="display_style">
            <option value="survey" <%= form.display_style === "survey" ? "selected" : "" %>>survey</option>
            <option value="interview" <%= form.display_style === "interview" ? "selected" : "" %>>interview</option>
          </select>
        </label>
      </div>

      <label>
        比較条件
        <textarea name="comparison_constraints" rows="4" placeholder="1行に1件ずつ入力"><%= form.comparison_constraints_text || '' %></textarea>
      </label>

      <div class="form-grid">
        <label>
          クライアント名
          <input type="text" name="client_name" value="<%= form.client_name || '' %>" />
        </label>
        <label>
          報酬ポイント
          <input type="number" name="reward_points" value="<%= form.reward_points_text || '30' %>" />
        </label>
        <label>
          ステータス
          <select name="status">
            <% for (const status of statusOptions) { %>
              <option value="<%= status.value %>" <%= form.status === status.value ? "selected" : "" %>><%= status.label %></option>
            <% } %>
          </select>
        </label>
        <label>
          カテゴリ（LIFF案件一覧）
          <select name="category">
            <option value="">未設定</option>
            <% for (const cat of ["生活系","仕事系","子育て","健康","趣味","その他"]) { %>
              <option value="<%= cat %>" <%= (project?.category === cat) ? "selected" : "" %>><%= cat %></option>
            <% } %>
          </select>
        </label>
        <label>
          所要時間（分）
          <input type="number" name="estimated_minutes" value="<%= project?.estimated_minutes || '' %>" placeholder="例: 10" min="1" />
        </label>
        <label>
          最大応募人数
          <input type="number" name="max_respondents" value="<%= project?.max_respondents || '' %>" placeholder="未設定で無制限" min="1" />
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" name="is_discoverable" value="true" <%= project?.is_discoverable ? "checked" : "" %> />
          LIFF案件一覧に公開する
        </label>
      </div>
    </div>
  </details>

  <section class="editor-section stack">
    <h2>3. 内部プレビュー</h2>
    <p class="helper-text">JSONは表示しません。下の内容は、現在の入力から内部で自動生成される AI 実行コンテキストです。</p>

    <div class="preview-grid">
      <div class="preview-card">
        <div class="muted">調査ゴール</div>
        <div><%= aiState.project_goal || "未設定" %></div>
      </div>
      <div class="preview-card">
        <div class="muted">理解したいこと</div>
        <div><%= aiState.user_understanding_goal || "未設定" %></div>
      </div>
      <div class="preview-card">
        <div class="muted">深掘り</div>
        <div>有効: <%= form.deep_probe_enabled ? "ON" : "OFF" %></div>
        <div>最大回数: <%= form.max_probe_depth_text || "0" %></div>
      </div>
      <div class="preview-card">
        <div class="muted">生成日時</div>
        <div><%= form.ai_state_generated_at || "保存時に更新" %></div>
      </div>
    </div>

    <div class="form-grid">
      <div>
        <h3>必須スロット</h3>
        <div class="slot-list">
          <% if (requiredSlots.length === 0) { %>
            <div class="slot-item muted">内部テンプレートから自動設定されます。</div>
          <% } %>
          <% for (const slot of requiredSlots) { %>
            <div class="slot-item">
              <strong><%= slot.label %></strong>
              <div class="muted"><%= slot.key %></div>
              <div><%= slot.description || "説明なし" %></div>
            </div>
          <% } %>
        </div>
      </div>
      <div>
        <h3>任意スロット</h3>
        <div class="slot-list">
          <% if (optionalSlots.length === 0) { %>
            <div class="slot-item muted">必要に応じて内部テンプレートから補完されます。</div>
          <% } %>
          <% for (const slot of optionalSlots) { %>
            <div class="slot-item">
              <strong><%= slot.label %></strong>
              <div class="muted"><%= slot.key %></div>
              <div><%= slot.description || "説明なし" %></div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <%
    const sc = project?.screening_config || {};
    const screeningEnabled = sc.enabled === true;
    const pcState = locals.profileConditionsState || {
      age: { enabled: false, min: null, max: null },
      gender: { enabled: false, allowed: [] },
      occupation: { enabled: false, allowed: [] },
      industry: { enabled: false, allowed: [] },
      marital_status: { enabled: false, allowed: [] },
      has_children: { enabled: false, allowed: [] },
      prefecture: { enabled: false, allowed: [] }
    };
    const sqList = typeof screeningQuestions !== 'undefined' ? screeningQuestions : [];
    const GENDER_OPTIONS = [
      { value: 'male', label: '男性' },
      { value: 'female', label: '女性' },
      { value: 'other', label: 'その他・回答しない' }
    ];
    const OCCUPATION_OPTIONS = [
      '会社員', '公務員', '自営業・経営者', 'フリーランス', '学生',
      '主婦・主夫', 'パート・アルバイト', '無職', 'その他'
    ];
    const INDUSTRY_OPTIONS = [
      'IT・テクノロジー', '医療・福祉', '教育', '金融・保険', '製造業',
      '流通・小売', 'サービス業', '建設・不動産', '農業・漁業', 'その他'
    ];
    const MARITAL_OPTIONS = [
      { value: 'single', label: '未婚' },
      { value: 'married', label: '既婚' },
      { value: 'divorced', label: '離婚・死別' }
    ];
    const PREFECTURES = [
      '北海道','青森県','岩手県','宮城県','秋田県','山形県','福島県',
      '茨城県','栃木県','群馬県','埼玉県','千葉県','東京都','神奈川県',
      '新潟県','富山県','石川県','福井県','山梨県','長野県','岐阜県',
      '静岡県','愛知県','三重県','滋賀県','京都府','大阪府','兵庫県',
      '奈良県','和歌山県','鳥取県','島根県','岡山県','広島県','山口県',
      '徳島県','香川県','愛媛県','高知県','福岡県','佐賀県','長崎県',
      '熊本県','大分県','宮崎県','鹿児島県','沖縄県'
    ];
  %>
  <section class="editor-section stack" id="screening-section">
    <h2>4. スクリーニング設定</h2>
    <p class="helper-text">スクリーニングを使用すると、本編の前に条件判定を行います。マイページ条件とスクリーニング設問の回答結果をもとに、対象者のみ本編へ進めます。</p>

    <label style="display:flex;align-items:center;gap:8px;font-weight:600;cursor:pointer">
      <input type="checkbox" name="screening_enabled" value="1"
        id="screening-enabled-toggle"
        <%= screeningEnabled ? "checked" : "" %>
        onchange="toggleScreeningDetails(this.checked)" />
      このプロジェクトでスクリーニングを使用する
    </label>

    <div id="screening-details" style="<%= screeningEnabled ? '' : 'display:none' %>">

      <h3 style="margin:16px 0 8px">■ マイページ条件</h3>
      <p style="font-size:12px;color:#60726f;margin:0 0 10px">チェックした項目のみ判定に使用されます。条件が1つもない場合は全員通過です。</p>

      <!-- 年齢 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_age_enabled" value="1"
            <%= pcState.age.enabled ? "checked" : "" %>
            onchange="toggleCondFields('age-fields', this.checked)" />
          年齢を条件にする
        </label>
        <div id="age-fields" class="sc-cond-fields" style="<%= pcState.age.enabled ? '' : 'display:none' %>">
          <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center">
            <label style="margin:0;display:flex;align-items:center;gap:6px">
              最小（歳以上）
              <input type="number" name="profile_cond_age_min" min="0" max="120"
                value="<%= pcState.age.min !== null ? pcState.age.min : '' %>"
                placeholder="未設定" style="width:72px" />
            </label>
            <label style="margin:0;display:flex;align-items:center;gap:6px">
              最大（歳以下）
              <input type="number" name="profile_cond_age_max" min="0" max="120"
                value="<%= pcState.age.max !== null ? pcState.age.max : '' %>"
                placeholder="未設定" style="width:72px" />
            </label>
          </div>
        </div>
      </div>

      <!-- 性別 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_gender_enabled" value="1"
            <%= pcState.gender.enabled ? "checked" : "" %>
            onchange="toggleCondFields('gender-fields', this.checked)" />
          性別を条件にする
        </label>
        <div id="gender-fields" class="sc-cond-fields" style="<%= pcState.gender.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of GENDER_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_gender_values" value="<%= opt.value %>"
                  <%= pcState.gender.allowed.includes(opt.value) ? "checked" : "" %> />
                <%= opt.label %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 職業 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_occupation_enabled" value="1"
            <%= pcState.occupation.enabled ? "checked" : "" %>
            onchange="toggleCondFields('occupation-fields', this.checked)" />
          職業を条件にする
        </label>
        <div id="occupation-fields" class="sc-cond-fields" style="<%= pcState.occupation.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of OCCUPATION_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_occupation_values" value="<%= opt %>"
                  <%= pcState.occupation.allowed.includes(opt) ? "checked" : "" %> />
                <%= opt %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 業種 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_industry_enabled" value="1"
            <%= pcState.industry.enabled ? "checked" : "" %>
            onchange="toggleCondFields('industry-fields', this.checked)" />
          業種を条件にする
        </label>
        <div id="industry-fields" class="sc-cond-fields" style="<%= pcState.industry.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of INDUSTRY_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_industry_values" value="<%= opt %>"
                  <%= pcState.industry.allowed.includes(opt) ? "checked" : "" %> />
                <%= opt %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 婚姻状況 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_marital_status_enabled" value="1"
            <%= pcState.marital_status.enabled ? "checked" : "" %>
            onchange="toggleCondFields('marital-fields', this.checked)" />
          婚姻状況を条件にする
        </label>
        <div id="marital-fields" class="sc-cond-fields" style="<%= pcState.marital_status.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of MARITAL_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_marital_status_values" value="<%= opt.value %>"
                  <%= pcState.marital_status.allowed.includes(opt.value) ? "checked" : "" %> />
                <%= opt.label %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 子どもの有無 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_has_children_enabled" value="1"
            <%= pcState.has_children.enabled ? "checked" : "" %>
            onchange="toggleCondFields('children-fields', this.checked)" />
          子どもの有無を条件にする
        </label>
        <div id="children-fields" class="sc-cond-fields" style="<%= pcState.has_children.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <label>
              <input type="checkbox" name="profile_cond_has_children_values" value="true"
                <%= pcState.has_children.allowed.includes('true') ? "checked" : "" %> />
              あり
            </label>
            <label>
              <input type="checkbox" name="profile_cond_has_children_values" value="false"
                <%= pcState.has_children.allowed.includes('false') ? "checked" : "" %> />
              なし
            </label>
          </div>
        </div>
      </div>

      <!-- 都道府県 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_prefecture_enabled" value="1"
            <%= pcState.prefecture.enabled ? "checked" : "" %>
            onchange="toggleCondFields('prefecture-fields', this.checked)" />
          都道府県を条件にする
        </label>
        <div id="prefecture-fields" class="sc-cond-fields" style="<%= pcState.prefecture.enabled ? '' : 'display:none' %>">
          <div class="sc-pref-grid">
            <% for (const pref of PREFECTURES) { %>
              <label>
                <input type="checkbox" name="profile_cond_prefecture_values" value="<%= pref %>"
                  <%= pcState.prefecture.allowed.includes(pref) ? "checked" : "" %> />
                <%= pref %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <h3 style="margin:16px 0 8px">■ 設問によるスクリーニング</h3>
      <div style="background:#f0faf5;border:1px solid #b2dcc8;border-radius:8px;padding:12px;font-size:13px;color:#444;line-height:1.7">
        各設問の「スクリーニング設問にする」チェックをONにすることで、その設問がスクリーニング設問として扱われます。<br>
        スクリーニング設問への回答後、上記マイページ条件と合わせて pass / fail を判定します。
        <% if (project?.id) { %>
          <br>&rarr; <a href="/admin/projects/<%= project.id %>/questions">設問管理画面で設定する</a>
        <% } %>
        <% if (sqList.length > 0) { %>
          <br><strong>現在のスクリーニング設問: <%= sqList.length %>件</strong>（<%= sqList.map(q => q.question_code).join('、') %>）
        <% } else { %>
          <br><span class="muted">現在スクリーニング設問はありません。</span>
        <% } %>
      </div>

      <h3 style="margin:16px 0 8px">■ メッセージ</h3>
      <label>
        通過時メッセージ
        <textarea name="screening_pass_message" placeholder="省略時：スクリーニングを通過しました。次のステップへお進みください。"><%= sc.pass_message || "" %></textarea>
      </label>
      <label>
        非通過時メッセージ
        <textarea name="screening_fail_message" placeholder="省略時：今回はご参加いただけませんでした。またの機会にご協力をお願いします。"><%= sc.fail_message || "" %></textarea>
      </label>

    </div>
  </section>

  <button type="submit"><%= project ? "更新する" : "作成する" %></button>
</form>

<script>
function toggleScreeningDetails(enabled) {
  var el = document.getElementById('screening-details');
  if (el) el.style.display = enabled ? '' : 'none';
}
function toggleCondFields(id, enabled) {
  var el = document.getElementById(id);
  if (el) el.style.display = enabled ? '' : 'none';
}
</script>

<%- include("../../partials/footer") %>

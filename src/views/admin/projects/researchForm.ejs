<%- include("../../partials/header", { title }) %>
<%
  const form = projectForm || {};
  const aiState = aiStateDisplay || form.ai_state_summary || {};
  const requiredSlots = Array.isArray(aiState.required_slots) ? aiState.required_slots : [];
  const optionalSlots = Array.isArray(aiState.optional_slots) ? aiState.optional_slots : [];
  const modeOptions = [
    { value: "survey_interview", label: "サーベイ＋インタビュー" },
    { value: "interview", label: "インタビュー" }
  ];
  const statusOptions = [
    { value: "draft", label: "下書き" },
    { value: "ready", label: "配信待ち" },
    { value: "published", label: "LIFF掲載中" },
    { value: "paused", label: "一時停止" },
    { value: "closed", label: "募集終了" },
    { value: "archived", label: "アーカイブ" }
  ];
  const safeTemplateErrors = typeof templateErrors !== "undefined" ? templateErrors : [];
  const safeTemplateWarnings = typeof templateWarnings !== "undefined" ? templateWarnings : [];
  const safePromptKeyDefs = typeof promptKeyDefs !== "undefined" ? promptKeyDefs : [];
%>

<style>
  .editor-section {
    border: 1px solid #d8e3e0;
    border-radius: 14px;
    padding: 18px;
    background: #f8fbfa;
  }
  .editor-section h2,
  .editor-section h3 {
    margin: 0 0 10px;
  }
  .helper-text {
    margin: 0;
    font-size: 12px;
    color: #60726f;
  }
  .summary-toggle {
    cursor: pointer;
    font-weight: 600;
  }
  .preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }
  .preview-card {
    border: 1px solid #d8e3e0;
    border-radius: 12px;
    padding: 12px;
    background: #fff;
  }
  .slot-list {
    display: grid;
    gap: 8px;
  }
  .slot-item {
    border: 1px solid #d8e3e0;
    border-radius: 10px;
    padding: 10px;
    background: #fff;
  }
  .sc-cond-block {
    border: 1px solid #e0e8e4;
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 6px;
    background: #fff;
  }
  .sc-cond-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    cursor: pointer;
    margin: 0;
  }
  .sc-cond-fields {
    margin-top: 8px;
    padding-left: 24px;
  }
  .sc-cond-checks {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }
  .sc-cond-checks label {
    display: flex;
    align-items: center;
    gap: 4px;
    margin: 0;
    font-weight: normal;
  }
  .sc-pref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
    gap: 4px;
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid #d8e3e0;
    border-radius: 6px;
    padding: 8px;
    background: #f8fbfa;
  }
  .sc-pref-grid label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    white-space: nowrap;
    font-weight: normal;
    margin: 0;
  }
</style>

<form class="card stack" method="post" action="<%= action %>" onsubmit="return confirmPromptPackageSelection();">
  <% if (successMessage) { %>
    <section class="card subtle-card success-card">
      <strong class="success-text"><%= successMessage %></strong>
    </section>
  <% } %>

  <% if (errorMessage) { %>
    <section class="card subtle-card">
      <strong class="danger-text">入力内容を確認してください</strong>
      <p class="danger-text"><%= errorMessage %></p>
    </section>
  <% } %>

  <% if (safeTemplateWarnings.length > 0) { %>
    <section class="card subtle-card" style="border-left:4px solid #f5a623">
      <strong style="color:#b36000">⚠ テンプレートに使用できないプレースホルダーがあります</strong>
      <ul style="margin:6px 0 0;padding-left:18px;font-size:13px;color:#b36000">
        <% for (const w of safeTemplateWarnings) { %>
          <li><%= w %></li>
        <% } %>
      </ul>
      <p class="helper-text" style="margin-top:6px">保存は完了しています。プロンプト実行時に該当プレースホルダーは空文字に置換されます。</p>
    </section>
  <% } %>

  <section class="editor-section stack">
    <h2>1. 基本設定</h2>
    <p class="helper-text">まずはこの3項目だけで、使える調査プロジェクトを作れます。</p>

    <div class="form-grid">
      <label>
        管理用プロジェクト名
        <small class="helper-text">管理画面で使用する内部管理用の名前です。USERには表示されません。</small>
        <input type="text" name="name" value="<%= form.name || '' %>" required />
      </label>
      <label>
        USER表示タイトル
        <small class="helper-text">LINE送付時や回答画面でUSERに表示されるタイトルです。空白の場合は管理用プロジェクト名が使われます。</small>
        <input type="text" name="user_display_title" value="<%= form.user_display_title || '' %>" placeholder="例: 飲食店の利用体験に関するアンケート" />
      </label>
      <label>
        調査モード
        <select name="research_mode">
          <% for (const mode of modeOptions) { %>
            <option value="<%= mode.value %>" <%= form.research_mode === mode.value ? "selected" : "" %>><%= mode.label %></option>
          <% } %>
        </select>
      </label>
    </div>

    <label>
      調査目的
      <textarea name="objective" required placeholder="例: どの利用シーンで不満が出るのか把握したい"><%= form.objective || '' %></textarea>
    </label>
  </section>

  <details class="editor-section">
    <summary class="summary-toggle">2. 詳細設定</summary>
    <div class="stack" style="margin-top: 14px;">
      <div class="form-grid">
        <label>
          <input type="checkbox" name="deep_probe_enabled" <%= form.deep_probe_enabled ? "checked" : "" %> />
          深掘りを有効にする
        </label>
        <label>
          最大深掘り回数
          <input type="number" name="max_probe_depth" min="0" value="<%= form.max_probe_depth_text || '1' %>" />
        </label>
        <label>
          表示スタイル
          <select name="display_style">
            <option value="survey" <%= form.display_style === "survey" ? "selected" : "" %>>survey</option>
            <option value="interview" <%= form.display_style === "interview" ? "selected" : "" %>>interview</option>
          </select>
        </label>
      </div>

      <label>
        比較条件
        <textarea name="comparison_constraints" rows="4" placeholder="1行に1件ずつ入力"><%= form.comparison_constraints_text || '' %></textarea>
      </label>

      <div class="form-grid">
        <label>
          クライアント名
          <input type="text" name="client_name" value="<%= form.client_name || '' %>" />
        </label>
        <label>
          報酬ポイント
          <input type="number" name="reward_points" value="<%= form.reward_points_text || '30' %>" />
        </label>
        <label>
          ステータス
          <select name="status">
            <% for (const status of statusOptions) { %>
              <option value="<%= status.value %>" <%= form.status === status.value ? "selected" : "" %>><%= status.label %></option>
            <% } %>
          </select>
        </label>
        <label>
          カテゴリ（LIFF案件一覧）
          <select name="category">
            <option value="">未設定</option>
            <% for (const cat of ["生活系","仕事系","子育て","健康","趣味","その他"]) { %>
              <option value="<%= cat %>" <%= (project?.category === cat) ? "selected" : "" %>><%= cat %></option>
            <% } %>
          </select>
        </label>
        <label>
          所要時間（分）
          <input type="number" name="estimated_minutes" value="<%= project?.estimated_minutes || '' %>" placeholder="例: 10" min="1" />
        </label>
        <label>
          最大応募人数
          <input type="number" name="max_respondents" value="<%= project?.max_respondents || '' %>" placeholder="未設定で無制限" min="1" />
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" name="is_discoverable" value="true" <%= project?.is_discoverable ? "checked" : "" %> />
          LIFF案件一覧に公開する
        </label>
        <label>
          公開区分（店舗専用アンケート）
          <select name="visibility_type" id="visibility_type_select">
            <option value="public" <%= (project?.visibility_type ?? 'public') === 'public' ? "selected" : "" %>>通常案件（探す一覧に表示）</option>
            <option value="private_store" <%= project?.visibility_type === 'private_store' ? "selected" : "" %>>店舗専用（専用URL/QRからのみ・一覧に出さない）</option>
          </select>
        </label>
        <label>
          店舗コード（entry_code）
          <input type="text" name="entry_code" id="entry_code_input" value="<%= project?.entry_code || '' %>" placeholder="例: abc（店舗専用時に必須・一意）" autocomplete="off" />
        </label>
        <div id="store_url_preview" style="display:none;background:#f6f8f7;border:1px solid #d8e3e0;border-radius:8px;padding:10px 12px;font-size:13px;color:#445">
          専用URL：<code id="store_url_text"></code>
          <p style="margin:6px 0 0;color:#789">このURLをQRコード化して店舗に配布してください。</p>
        </div>
        <script>
          (function () {
            const sel = document.getElementById('visibility_type_select');
            const codeInput = document.getElementById('entry_code_input');
            const preview = document.getElementById('store_url_preview');
            const urlText = document.getElementById('store_url_text');
            if (!sel || !codeInput) return;
            function refresh() {
              const isStore = sel.value === 'private_store';
              const code = (codeInput.value || '').trim();
              if (isStore && code) {
                urlText.textContent = location.origin + '/liff/store?entry_code=' + encodeURIComponent(code);
                preview.style.display = '';
              } else {
                preview.style.display = 'none';
              }
            }
            sel.addEventListener('change', refresh);
            codeInput.addEventListener('input', refresh);
            refresh();
          })();
        </script>
      </div>
    </div>
  </details>

  <section class="editor-section stack">
    <h2>3. 内部プレビュー</h2>
    <p class="helper-text">JSONは表示しません。下の内容は、現在の入力から内部で自動生成される AI 実行コンテキストです。</p>

    <div class="preview-grid">
      <div class="preview-card">
        <div class="muted">調査ゴール</div>
        <div><%= aiState.project_goal || "未設定" %></div>
      </div>
      <div class="preview-card">
        <div class="muted">理解したいこと</div>
        <div><%= aiState.user_understanding_goal || "未設定" %></div>
      </div>
      <div class="preview-card">
        <div class="muted">深掘り</div>
        <div>有効: <%= form.deep_probe_enabled ? "ON" : "OFF" %></div>
        <div>最大回数: <%= form.max_probe_depth_text || "0" %></div>
      </div>
      <div class="preview-card">
        <div class="muted">生成日時</div>
        <div><%= form.ai_state_generated_at || "保存時に更新" %></div>
      </div>
    </div>

    <div class="form-grid">
      <div>
        <h3>必須スロット</h3>
        <div class="slot-list">
          <% if (requiredSlots.length === 0) { %>
            <div class="slot-item muted">内部テンプレートから自動設定されます。</div>
          <% } %>
          <% for (const slot of requiredSlots) { %>
            <div class="slot-item">
              <strong><%= slot.label %></strong>
              <div class="muted"><%= slot.key %></div>
              <div><%= slot.description || "説明なし" %></div>
            </div>
          <% } %>
        </div>
      </div>
      <div>
        <h3>任意スロット</h3>
        <div class="slot-list">
          <% if (optionalSlots.length === 0) { %>
            <div class="slot-item muted">必要に応じて内部テンプレートから補完されます。</div>
          <% } %>
          <% for (const slot of optionalSlots) { %>
            <div class="slot-item">
              <strong><%= slot.label %></strong>
              <div class="muted"><%= slot.key %></div>
              <div><%= slot.description || "説明なし" %></div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <%
    const sc = project?.screening_config || {};
    const screeningEnabled = sc.enabled === true;
    const pcState = locals.profileConditionsState || {
      age: { enabled: false, min: null, max: null },
      gender: { enabled: false, allowed: [] },
      occupation: { enabled: false, allowed: [] },
      industry: { enabled: false, allowed: [] },
      marital_status: { enabled: false, allowed: [] },
      has_children: { enabled: false, allowed: [] },
      prefecture: { enabled: false, allowed: [] }
    };
    const sqList = typeof screeningQuestions !== 'undefined' ? screeningQuestions : [];
    const GENDER_OPTIONS = [
      { value: 'male', label: '男性' },
      { value: 'female', label: '女性' },
      { value: 'other', label: 'その他・回答しない' }
    ];
    const OCCUPATION_OPTIONS = [
      '会社員', '公務員', '自営業・経営者', 'フリーランス', '学生',
      '主婦・主夫', 'パート・アルバイト', '無職', 'その他'
    ];
    const INDUSTRY_OPTIONS = [
      'IT・テクノロジー', '医療・福祉', '教育', '金融・保険', '製造業',
      '流通・小売', 'サービス業', '建設・不動産', '農業・漁業', 'その他'
    ];
    const MARITAL_OPTIONS = [
      { value: 'single', label: '未婚' },
      { value: 'married', label: '既婚' },
      { value: 'divorced', label: '離婚・死別' }
    ];
    const PREFECTURES = [
      '北海道','青森県','岩手県','宮城県','秋田県','山形県','福島県',
      '茨城県','栃木県','群馬県','埼玉県','千葉県','東京都','神奈川県',
      '新潟県','富山県','石川県','福井県','山梨県','長野県','岐阜県',
      '静岡県','愛知県','三重県','滋賀県','京都府','大阪府','兵庫県',
      '奈良県','和歌山県','鳥取県','島根県','岡山県','広島県','山口県',
      '徳島県','香川県','愛媛県','高知県','福岡県','佐賀県','長崎県',
      '熊本県','大分県','宮崎県','鹿児島県','沖縄県'
    ];
  %>
  <section class="editor-section stack" id="screening-section">
    <h2>4. スクリーニング設定</h2>
    <p class="helper-text">スクリーニングを使用すると、本編の前に条件判定を行います。マイページ条件とスクリーニング設問の回答結果をもとに、対象者のみ本編へ進めます。</p>

    <label style="display:flex;align-items:center;gap:8px;font-weight:600;cursor:pointer">
      <input type="checkbox" name="screening_enabled" value="1"
        id="screening-enabled-toggle"
        <%= screeningEnabled ? "checked" : "" %>
        onchange="toggleScreeningDetails(this.checked)" />
      このプロジェクトでスクリーニングを使用する
    </label>

    <div id="screening-details" style="<%= screeningEnabled ? '' : 'display:none' %>">

      <h3 style="margin:16px 0 8px">■ マイページ条件</h3>
      <p style="font-size:12px;color:#60726f;margin:0 0 10px">チェックした項目のみ判定に使用されます。条件が1つもない場合は全員通過です。</p>

      <!-- 年齢 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_age_enabled" value="1"
            <%= pcState.age.enabled ? "checked" : "" %>
            onchange="toggleCondFields('age-fields', this.checked)" />
          年齢を条件にする
        </label>
        <div id="age-fields" class="sc-cond-fields" style="<%= pcState.age.enabled ? '' : 'display:none' %>">
          <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center">
            <label style="margin:0;display:flex;align-items:center;gap:6px">
              最小（歳以上）
              <input type="number" name="profile_cond_age_min" min="0" max="120"
                value="<%= pcState.age.min !== null ? pcState.age.min : '' %>"
                placeholder="未設定" style="width:72px" />
            </label>
            <label style="margin:0;display:flex;align-items:center;gap:6px">
              最大（歳以下）
              <input type="number" name="profile_cond_age_max" min="0" max="120"
                value="<%= pcState.age.max !== null ? pcState.age.max : '' %>"
                placeholder="未設定" style="width:72px" />
            </label>
          </div>
        </div>
      </div>

      <!-- 性別 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_gender_enabled" value="1"
            <%= pcState.gender.enabled ? "checked" : "" %>
            onchange="toggleCondFields('gender-fields', this.checked)" />
          性別を条件にする
        </label>
        <div id="gender-fields" class="sc-cond-fields" style="<%= pcState.gender.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of GENDER_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_gender_values" value="<%= opt.value %>"
                  <%= pcState.gender.allowed.includes(opt.value) ? "checked" : "" %> />
                <%= opt.label %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 職業 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_occupation_enabled" value="1"
            <%= pcState.occupation.enabled ? "checked" : "" %>
            onchange="toggleCondFields('occupation-fields', this.checked)" />
          職業を条件にする
        </label>
        <div id="occupation-fields" class="sc-cond-fields" style="<%= pcState.occupation.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of OCCUPATION_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_occupation_values" value="<%= opt %>"
                  <%= pcState.occupation.allowed.includes(opt) ? "checked" : "" %> />
                <%= opt %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 業種 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_industry_enabled" value="1"
            <%= pcState.industry.enabled ? "checked" : "" %>
            onchange="toggleCondFields('industry-fields', this.checked)" />
          業種を条件にする
        </label>
        <div id="industry-fields" class="sc-cond-fields" style="<%= pcState.industry.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of INDUSTRY_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_industry_values" value="<%= opt %>"
                  <%= pcState.industry.allowed.includes(opt) ? "checked" : "" %> />
                <%= opt %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 婚姻状況 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_marital_status_enabled" value="1"
            <%= pcState.marital_status.enabled ? "checked" : "" %>
            onchange="toggleCondFields('marital-fields', this.checked)" />
          婚姻状況を条件にする
        </label>
        <div id="marital-fields" class="sc-cond-fields" style="<%= pcState.marital_status.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <% for (const opt of MARITAL_OPTIONS) { %>
              <label>
                <input type="checkbox" name="profile_cond_marital_status_values" value="<%= opt.value %>"
                  <%= pcState.marital_status.allowed.includes(opt.value) ? "checked" : "" %> />
                <%= opt.label %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 子どもの有無 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_has_children_enabled" value="1"
            <%= pcState.has_children.enabled ? "checked" : "" %>
            onchange="toggleCondFields('children-fields', this.checked)" />
          子どもの有無を条件にする
        </label>
        <div id="children-fields" class="sc-cond-fields" style="<%= pcState.has_children.enabled ? '' : 'display:none' %>">
          <div class="sc-cond-checks">
            <label>
              <input type="checkbox" name="profile_cond_has_children_values" value="true"
                <%= pcState.has_children.allowed.includes('true') ? "checked" : "" %> />
              あり
            </label>
            <label>
              <input type="checkbox" name="profile_cond_has_children_values" value="false"
                <%= pcState.has_children.allowed.includes('false') ? "checked" : "" %> />
              なし
            </label>
          </div>
        </div>
      </div>

      <!-- 都道府県 -->
      <div class="sc-cond-block">
        <label class="sc-cond-label">
          <input type="checkbox" name="profile_cond_prefecture_enabled" value="1"
            <%= pcState.prefecture.enabled ? "checked" : "" %>
            onchange="toggleCondFields('prefecture-fields', this.checked)" />
          都道府県を条件にする
        </label>
        <div id="prefecture-fields" class="sc-cond-fields" style="<%= pcState.prefecture.enabled ? '' : 'display:none' %>">
          <div class="sc-pref-grid">
            <% for (const pref of PREFECTURES) { %>
              <label>
                <input type="checkbox" name="profile_cond_prefecture_values" value="<%= pref %>"
                  <%= pcState.prefecture.allowed.includes(pref) ? "checked" : "" %> />
                <%= pref %>
              </label>
            <% } %>
          </div>
        </div>
      </div>

      <h3 style="margin:16px 0 8px">■ 設問によるスクリーニング</h3>
      <div style="background:#f0faf5;border:1px solid #b2dcc8;border-radius:8px;padding:12px;font-size:13px;color:#444;line-height:1.7">
        各設問の「スクリーニング設問にする」チェックをONにすることで、その設問がスクリーニング設問として扱われます。<br>
        スクリーニング設問への回答後、上記マイページ条件と合わせて pass / fail を判定します。
        <% if (project?.id) { %>
          <br>&rarr; <a href="/admin/projects/<%= project.id %>/questions">設問管理画面で設定する</a>
        <% } %>
        <% if (sqList.length > 0) { %>
          <br><strong>現在のスクリーニング設問: <%= sqList.length %>件</strong>（<%= sqList.map(q => q.question_code).join('、') %>）
        <% } else { %>
          <br><span class="muted">現在スクリーニング設問はありません。</span>
        <% } %>
      </div>

      <h3 style="margin:16px 0 8px">■ メッセージ</h3>
      <label>
        通過時メッセージ
        <textarea name="screening_pass_message" placeholder="省略時：スクリーニングを通過しました。次のステップへお進みください。"><%= sc.pass_message || "" %></textarea>
      </label>
      <label>
        非通過時メッセージ
        <textarea name="screening_fail_message" placeholder="省略時：今回はご参加いただけませんでした。またの機会にご協力をお願いします。"><%= sc.fail_message || "" %></textarea>
      </label>

    </div>
  </section>

  <%
    // ──────────────────────────────────────────────
    // 5. AIプロンプト設定
    // ──────────────────────────────────────────────
    const currentPolicy = (project && project.ai_prompt_policy_json) ? project.ai_prompt_policy_json : {};

    const RESEARCH_TYPE_OPTIONS = [
      { key: "standard_research",    label: "標準リサーチ" },
      { key: "interview_research",   label: "インタビューリサーチ" },
      { key: "survey_interview",     label: "サーベイ+インタビュー" },
      { key: "exploratory_research", label: "探索的リサーチ" }
    ];
    const AUDIENCE_OPTIONS = [
      { key: "general",          label: "一般（指定なし）" },
      { key: "female_friendly",  label: "女性向け（丁寧・共感重視）" },
      { key: "young_casual",     label: "若年層（カジュアル）" },
      { key: "business",         label: "ビジネス層（フォーマル）" },
      { key: "senior_friendly",  label: "シニア向け（わかりやすく）" }
    ];
    const PROBE_STYLE_OPTIONS = [
      { key: "standard",             label: "標準" },
      { key: "reason_and_scene",     label: "理由・場面を引き出す" },
      { key: "comparison",           label: "比較・違いを引き出す" },
      { key: "emotion_and_context",  label: "感情・背景を引き出す" },
      { key: "decision_process",     label: "判断プロセスを引き出す" }
    ];
    const NONE_ANSWER_POLICY_OPTIONS = [
      { key: "default",            label: "デフォルト（既存ルール）" },
      { key: "accept",             label: "そのまま受け入れる" },
      { key: "retry_once_softly",  label: "一度だけやさしく再確認" },
      { key: "ask_for_small_hint", label: "小さなヒントを求める" }
    ];
    const AMBIGUOUS_ANSWER_RULE_OPTIONS = [
      { key: "default",           label: "デフォルト（既存ルール）" },
      { key: "ask_clarification", label: "具体化を求める" },
      { key: "accept_and_note",   label: "受け入れてメモ" },
      { key: "concrete_example",  label: "具体例を引き出す" }
    ];
    const FREE_ANSWER_POLICY_OPTIONS = [
      { key: "default",          label: "デフォルト（既存ルール）" },
      { key: "accept_none",      label: "「特になし」を受け入れる" },
      { key: "include_verbatim", label: "発言をそのまま含める" },
      { key: "summarize_only",   label: "要約のみ記録" }
    ];
    const RESTRICTION_OPTIONS = [
      { key: "no_leading_question",              label: "誘導質問禁止" },
      { key: "one_question_only",                label: "1回につき1質問のみ" },
      { key: "avoid_sensitive_personal_data",    label: "個人情報を引き出さない" },
      { key: "no_medical_legal_financial_claim", label: "医療・法律・金融の断言禁止" },
      { key: "no_internal_codes",                label: "内部コードを表示しない" }
    ];
    const PRIORITY_OPTIONS = [
      { key: "research_quality_first",   label: "調査品質優先" },
      { key: "respondent_comfort_first", label: "回答者の負担軽減優先" },
      { key: "comparability_first",      label: "比較可能性優先" }
    ];
  %>

  <details class="editor-section" id="ai-prompt-section">
    <summary class="summary-toggle">5. AIプロンプト設定</summary>
    <div class="stack" style="margin-top:14px">
      <p class="helper-text">
        プロンプト本文（systemPrompt / userPrompt / テンプレート）の編集は<a href="/admin/prompt-packages" target="_blank">プロンプトパッケージ画面</a>に集約されています。
        この画面では「どのパッケージ・公開バージョンを使うか」と「このプロジェクト固有の方針の上書き」のみを設定します。
      </p>

      <%
        // 新規プロジェクトはパッケージ運用を既定にする（プロンプト本文はパッケージ画面で一元管理）
        const currentPromptMode = project ? (project.ai_prompt_mode || 'custom') : 'package';
        const currentPackageVersionId = (project && project.ai_prompt_package_version_id) ? project.ai_prompt_package_version_id : '';
        // 選択可能（published / archived）バージョンを持つパッケージのみ
        const selectablePackages = (promptPackages || []).filter(p => Array.isArray(p.selectable_versions) && p.selectable_versions.length > 0);
        // 現在選択中のバージョンからパッケージ・バージョンを逆引き
        let currentPkg = null;
        let currentVersion = null;
        for (const p of selectablePackages) {
          const v = p.selectable_versions.find(v => v.id === currentPackageVersionId);
          if (v) { currentPkg = p; currentVersion = v; break; }
        }
        // Phase 6-B: 個別オーバーライド（policy のみ）
        const currentOverridePolicy = (project && project.ai_prompt_overrides_json && project.ai_prompt_overrides_json.policy)
          ? project.ai_prompt_overrides_json.policy : {};
        const overrideRestrictionsEnabled = Array.isArray(currentOverridePolicy.restrictions);
        const currentOverrideRestrictions = overrideRestrictionsEnabled ? currentOverridePolicy.restrictions : [];
      %>

      <!-- Phase 8: 現在適用中のAIプロンプト状態パネル（プロジェクト画面は参照と選択のみ） -->
      <div style="border:1px solid #c8dcd6;border-radius:10px;padding:14px 16px;background:#fff;margin-bottom:12px">
        <h3 style="margin:0 0 10px;font-size:14px;font-weight:700">現在適用中のAIプロンプト</h3>
        <% if (currentPromptMode === 'package' && currentPkg && currentVersion) { %>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;font-size:13px">
            <div><span class="muted">モード</span><br><strong>プロンプトパッケージ</strong></div>
            <div><span class="muted">パッケージ</span><br><strong><%= currentPkg.name %></strong></div>
            <div><span class="muted">バージョン</span><br><strong>v<%= currentVersion.version_no %></strong></div>
            <div><span class="muted">公開状態</span><br>
              <% if (currentVersion.status === 'published') { %>
                <span style="background:#e8f5ef;color:#1a7a5a;padding:1px 8px;border-radius:4px;font-weight:600">公開中</span>
              <% } else { %>
                <span style="background:#fff3e0;color:#b36200;padding:1px 8px;border-radius:4px;font-weight:600">アーカイブ（実行時は公開版へfallback）</span>
              <% } %>
            </div>
            <div><span class="muted">最終更新</span><br><strong><%= currentVersion.updated_at ? new Date(currentVersion.updated_at).toLocaleString('ja-JP') : '—' %></strong></div>
          </div>
        <% } else if (currentPromptMode === 'package') { %>
          <p style="margin:0;font-size:13px;color:#b36200">パッケージ未選択です。下で公開済みパッケージ・バージョンを選択してください。</p>
        <% } else { %>
          <p style="margin:0;font-size:13px;color:#60726f">
            モード: <strong>プロジェクト個別設定（非推奨・後方互換）</strong>。プロンプトパッケージへの移行を推奨します。
          </p>
        <% } %>
        <div style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap">
          <a href="/admin/prompt-packages" target="_blank"
            style="font-size:12px;padding:5px 14px;background:#1a7a5a;color:#fff;border-radius:6px;text-decoration:none">
            プロンプトパッケージ管理へ移動
          </a>
          <a href="#prompt-package-area"
            style="font-size:12px;padding:5px 14px;background:#fff;color:#1a7a5a;border:1px solid #1a7a5a;border-radius:6px;text-decoration:none">
            このプロジェクトに適用するパッケージを変更
          </a>
        </div>
      </div>

      <!-- パッケージ選択 UI -->
      <div style="border:1px solid #c8dcd6;border-radius:10px;padding:16px;background:#f7fbf9;margin-bottom:4px">
        <h3 style="margin:0 0 10px;font-size:14px;font-weight:700">適用するプロンプトパッケージ</h3>

        <%
          // Phase B: プロジェクト編集画面は「適用先選択」のみ。モードはラジオではなく hidden で送る。
          //  - 新規 / 既存 package プロジェクト → package
          //  - 既存 custom（legacy）プロジェクト → custom を維持（パッケージ選択時に JS で package へ昇格）
          const initialPromptMode = currentPromptMode === 'custom' ? 'custom' : 'package';
        %>
        <input type="hidden" name="ai_prompt_mode" id="ai_prompt_mode_hidden"
          data-initial="<%= initialPromptMode %>" value="<%= initialPromptMode %>" />

        <% if (currentPromptMode === 'custom') { %>
          <div style="background:#f4f6f5;border:1px solid #d8e3e0;border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:13px;color:#60726f">
            このプロジェクトは旧「プロジェクト個別設定（custom・非推奨）」で動作しています。プロンプト本文・方針はこの画面では編集できません。
            <strong>公開済みパッケージを選択すると package モードへ移行します。</strong>
            <% if (project && project.id) { %>
              既存の個別設定は<a href="/admin/projects/<%= project.id %>/prompt-package-history" target="_blank" style="color:#1a7a5a">変更履歴</a>から確認できます。
            <% } %>
          </div>
        <% } %>

        <div id="prompt-package-area" style="display:block">
          <% if (locals.packageFallbackWarning !== undefined && packageFallbackWarning !== null) { %>
            <div style="background:#fff8e1;border:1px solid #f9a825;border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:13px">
              <strong style="color:#b36200">⚠ 設定中のパッケージバージョンは archived のため、公開中の最新バージョンを使用しています。</strong>
              <% if (packageFallbackWarning) { %>
                <span style="display:block;margin-top:4px;color:#60726f">
                  現在適用中: v<%= packageFallbackWarning.version_no %>（公開中）
                  <a href="#prompt-package-area" style="margin-left:8px;color:#1a7a5a">↓ パッケージを再選択してください</a>
                </span>
              <% } else { %>
                <span style="display:block;margin-top:4px;color:#c62828">公開中バージョンが存在しないため、AIプロンプトはカスタム設定で動作しています。</span>
              <% } %>
            </div>
          <% } %>
          <% if (selectablePackages.length === 0) { %>
            <p class="helper-text" style="color:#b36200">適用可能なプロンプトパッケージがありません。先に<a href="/admin/prompt-packages">パッケージを作成・公開</a>してください。</p>
          <% } else { %>
            <!-- Phase 6-A: パッケージ → バージョンの2段選択 -->
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;max-width:760px">
              <label style="display:block;font-size:13px">
                1. パッケージを選択
                <select id="pkg-package-select" onchange="onPackageSelectChange()" style="margin-top:4px;width:100%">
                  <option value="">-- パッケージを選択してください --</option>
                  <% for (const pkg of selectablePackages) { %>
                    <option value="<%= pkg.id %>" <%= (currentPkg && currentPkg.id === pkg.id) ? 'selected' : '' %>>
                      <%= pkg.name %><% if (pkg.description) { %> · <%= pkg.description %><% } %>
                    </option>
                  <% } %>
                </select>
              </label>
              <label style="display:block;font-size:13px">
                2. バージョンを選択
                <select name="ai_prompt_package_version_id" id="pkg-version-select" onchange="syncPromptMode()" style="margin-top:4px;width:100%">
                  <% if (currentPkg) { %>
                    <% for (const v of currentPkg.selectable_versions) { %>
                      <option value="<%= v.id %>" <%= (currentPackageVersionId === v.id) ? 'selected' : '' %>>
                        v<%= v.version_no %><%= v.status === 'published' ? '（公開中）' : '（アーカイブ・実行時は公開版へfallback）' %><% if (v.change_note) { %> · <%= v.change_note %><% } %>
                      </option>
                    <% } %>
                  <% } else { %>
                    <option value="">-- 先にパッケージを選択 --</option>
                  <% } %>
                </select>
              </label>
            </div>
            <p style="margin:6px 0 0">
              <a id="pkg-detail-link" href="<%= currentPkg ? '/admin/prompt-packages/' + currentPkg.id : '#' %>" target="_blank"
                style="font-size:12px;color:#1a7a5a;<%= currentPkg ? '' : 'display:none' %>">
                選択中パッケージの詳細を確認 →
              </a>
            </p>

            <!-- Phase 5-A: 適用前プレビュー -->
            <div style="margin-top:10px">
              <button type="button" id="pkg-preview-btn" onclick="loadPackagePreview()"
                style="font-size:12px;padding:4px 12px;border:1px solid #1a7a5a;color:#1a7a5a;background:#fff;border-radius:6px;cursor:pointer">
                選択中バージョンの内容をプレビュー
              </button>
              <span id="pkg-preview-status" style="font-size:12px;color:#60726f;margin-left:8px"></span>
            </div>
            <div id="pkg-preview-area" style="display:none;margin-top:10px;border:1px solid #d8e3e0;border-radius:8px;background:#fff;padding:12px 14px;font-size:12px"></div>

            <label style="display:block;margin-top:10px;font-size:13px">
              変更理由（任意・履歴に記録されます）
              <input type="text" name="package_change_reason" placeholder="例: 女性向け対象に変更" style="margin-top:4px;width:100%;max-width:480px" />
            </label>

            <!-- Phase B: 個別オーバーライド編集UIは撤去（プロジェクト画面は適用先選択のみ）。
                 既存の ai_prompt_overrides_json は保全されるが新規編集は不可。下に read-only 表示のみ残す。 -->
            <% if (Object.keys(currentOverridePolicy).length > 0) { %>
              <div style="margin-top:14px;border:1px solid #f0d8b8;border-radius:10px;padding:10px 14px;background:#fffaf2;font-size:12px;color:#60726f">
                <strong style="color:#b36200">個別オーバーライド（非推奨・読み取り専用）</strong>
                <span style="margin-left:6px">このプロジェクトには過去に設定されたパッケージ上書きが <%= Object.keys(currentOverridePolicy).length %> 項目あります（実行時に適用されますが deprecated）。</span>
                <code style="display:block;margin-top:6px;white-space:pre-wrap;background:#fff;border:1px solid #eadfcb;border-radius:6px;padding:6px 8px"><%= JSON.stringify(currentOverridePolicy) %></code>
              </div>
            <% } %>
          <% } %>
        </div>
        <% if (project && project.id) { %>
          <p style="margin-top:8px;font-size:12px">
            <a href="/admin/projects/<%= project.id %>/prompt-package-history" target="_blank" style="color:#60726f">
              AIプロンプト変更履歴を確認 →
            </a>
          </p>
        <% } %>

      </div>

      <!-- Phase B: プロジェクト個別の policy 編集（旧 Section A）と override 編集は撤去。
           プロンプト方針・本文の真実はパッケージバージョンに集約。既存 custom データは controller 側で保全。 -->

      <!-- Phase 6-A: プロンプト本文の編集UIは撤去（パッケージ画面に集約）。動作確認のみ残す -->
      <% if (project && project.id) { %>
        <details style="border:1px solid #d8e3e0;border-radius:10px;padding:10px 14px;background:#fff">
          <summary style="cursor:pointer;font-weight:600;font-size:13px">プロンプト動作確認（プレビュー / テスト実行）</summary>
          <div style="margin-top:10px">
            <p class="helper-text" style="margin-bottom:8px">
              現在の設定（パッケージ / 個別設定）で実際に使われるプロンプトを確認できます。本文の編集は
              <a href="/admin/prompt-packages" target="_blank">プロンプトパッケージ画面</a>で行ってください。
            </p>

            <!-- 用途フィルタ＋凡例（version-form と同方式の配置可視化） -->
            <div style="background:#f8faf9;border:1px solid #e0e8e4;border-radius:10px;padding:8px 12px;margin-bottom:12px;font-size:12px">
              <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap">
                <label style="font-weight:600;color:#1a4d3a">用途で絞り込み
                  <select id="rf-family-filter" style="margin-left:6px;font-size:12px;padding:2px 6px">
                    <option value="all">すべて表示</option>
                    <option value="conversation">会話系（アンケート・インタビュー）</option>
                    <option value="research_infra">調査基盤系（AI状態・横断分析）</option>
                    <option value="post">投稿系（日記・愚痴・ペルソナ）</option>
                    <option value="admin_tool">管理ツール系（フロー生成・設問候補）</option>
                  </select>
                </label>
                <label style="cursor:pointer;color:#48635c"><input type="checkbox" id="rf-hide-dormant" /> 休眠キーを隠す</label>
                <label style="cursor:pointer;color:#48635c"><input type="checkbox" id="rf-probe-only" /> 🔍 深掘り関連のみ</label>
                <span id="rf-filter-count" style="margin-left:auto;color:#8a9a96"></span>
              </div>
              <div style="margin-top:6px;display:flex;gap:12px;flex-wrap:wrap;color:#60726f">
                <span>凡例:</span>
                <span><span style="background:#fff3e0;color:#b25a00;border:1px solid #f0c98a;border-radius:4px;padding:0 5px">🔍 深掘り影響</span></span>
                <span><span style="background:#eceff1;color:#78909c;border:1px solid #cfd8dc;border-radius:4px;padding:0 5px">💤 休眠</span></span>
                <span><span style="background:#eef4ff;color:#3a5a9a;border:1px solid #cdd9f0;border-radius:4px;padding:0 5px">発火文脈</span></span>
              </div>
            </div>

            <%
              // version-form と同じ系統グルーピング（PROMPT_FAMILY_ORDER 順）。プレビュー/テスト挙動は変えない。
              const RF_FAMILY_ORDER = ['conversation','research_infra','post','admin_tool'];
              const rfGrouped = {};
              for (const d of safePromptKeyDefs) { (rfGrouped[d.family] = rfGrouped[d.family] || []).push(d); }
            %>
            <% for (const fam of RF_FAMILY_ORDER) { if (!rfGrouped[fam] || !rfGrouped[fam].length) continue; %>
              <div data-rf-fam-group="<%= fam %>" style="margin:12px 0 4px;padding:6px 10px;background:#eef4f2;border-left:4px solid #1a7a5a;border-radius:0 6px 6px 0;font-weight:700;font-size:12px;color:#1a4d3a">
                <%= rfGrouped[fam][0].familyLabel %>
                <span style="font-weight:normal;font-size:11px;color:#5a6b80">（<%= rfGrouped[fam].length %>キー）</span>
              </div>
              <% for (const pkDef of rfGrouped[fam]) { %>
              <div data-rf-pk-card data-fam="<%= pkDef.family %>" data-dormant="<%= pkDef.dormant ? '1' : '0' %>" data-probe="<%= pkDef.probeImpact ? '1' : '0' %>"
                style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:6px 0;border-bottom:1px solid #eef4f2;font-size:12px">
                <span style="flex:1;min-width:220px">
                  <strong><%= pkDef.label %></strong>
                  <span class="muted" style="font-weight:normal">(<%= pkDef.key %>)</span>
                  <% if (pkDef.probeImpact) { %>
                    <span title="このプロンプトは深掘りの判定・生成を内包します。編集すると深掘り挙動に影響しうるので注意。" style="font-size:11px;background:#fff3e0;color:#b25a00;border:1px solid #f0c98a;padding:1px 6px;border-radius:4px;margin-left:4px">🔍 深掘り影響</span>
                  <% } %>
                  <% if (pkDef.dormant) { %>
                    <span title="現在このプロンプトを呼び出すコードパスはありません（休眠）。実行時には反映されません。" style="font-size:11px;background:#eceff1;color:#78909c;border:1px solid #cfd8dc;padding:1px 6px;border-radius:4px;margin-left:4px">💤 休眠</span>
                  <% } %>
                  <% for (const ctx of (pkDef.contexts || [])) { %>
                    <span style="font-size:11px;background:#eef4ff;color:#3a5a9a;border:1px solid #cdd9f0;padding:1px 6px;border-radius:4px;margin-left:4px"><%= ctx %></span>
                  <% } %>
                </span>
                <button type="button"
                  onclick="openPromptPreview('<%= project.id %>', '<%= pkDef.key %>')"
                  style="font-size:12px;padding:3px 10px;background:#f0f7f5;border:1px solid #9dbab4;border-radius:6px;cursor:pointer">
                  プレビュー
                </button>
                <button type="button"
                  onclick="openPromptTest('<%= project.id %>', '<%= pkDef.key %>', '<%= pkDef.label %>')"
                  style="font-size:12px;padding:3px 10px;background:#f5f0ff;border:1px solid #b09ddb;border-radius:6px;cursor:pointer">
                  テスト実行
                </button>
              </div>
              <% } %>
            <% } %>
          </div>
        </details>
      <% } %>
    </div>
  </details>

  <button type="submit"><%= project ? "更新する" : "作成する" %></button>
</form>

<!-- ─── プロンプトプレビューモーダル ─── -->
<div id="preview-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;overflow:auto">
  <div style="background:#fff;border-radius:12px;max-width:820px;margin:40px auto;padding:24px;position:relative">
    <button onclick="closeModal('preview-modal')"
      style="position:absolute;top:12px;right:16px;background:none;border:none;font-size:20px;cursor:pointer">×</button>
    <h3 id="preview-title" style="margin:0 0 12px">プロンプトプレビュー</h3>
    <div id="preview-meta" style="font-size:12px;color:#60726f;margin-bottom:10px"></div>
    <div id="preview-tabs" style="display:flex;gap:4px;margin-bottom:10px">
      <button onclick="showPreviewTab('rendered')" id="tab-rendered"
        class="preview-tab active-tab">最終プロンプト</button>
      <button onclick="showPreviewTab('template')" id="tab-template"
        class="preview-tab">テンプレート</button>
      <button onclick="showPreviewTab('policy')" id="tab-policy"
        class="preview-tab">適用ポリシー</button>
    </div>
    <div id="preview-loading" style="display:none;color:#60726f;font-size:13px">読み込み中...</div>
    <pre id="preview-rendered" style="white-space:pre-wrap;background:#f8fbfa;border:1px solid #d8e3e0;border-radius:8px;padding:14px;font-size:12px;max-height:500px;overflow:auto;margin:0"></pre>
    <pre id="preview-template" style="display:none;white-space:pre-wrap;background:#f8fbfa;border:1px solid #d8e3e0;border-radius:8px;padding:14px;font-size:12px;max-height:500px;overflow:auto;margin:0"></pre>
    <pre id="preview-policy" style="display:none;white-space:pre-wrap;background:#f8fbfa;border:1px solid #d8e3e0;border-radius:8px;padding:14px;font-size:12px;max-height:500px;overflow:auto;margin:0"></pre>
  </div>
</div>

<!-- ─── テスト実行モーダル ─── -->
<div id="test-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;overflow:auto">
  <div style="background:#fff;border-radius:12px;max-width:880px;margin:40px auto;padding:24px;position:relative">
    <button onclick="closeModal('test-modal')"
      style="position:absolute;top:12px;right:16px;background:none;border:none;font-size:20px;cursor:pointer">×</button>
    <h3 id="test-title" style="margin:0 0 4px">テスト実行</h3>
    <p style="font-size:12px;color:#60726f;margin:0 0 14px">各プレースホルダーに任意の値を入力して最終プロンプトを確認できます。</p>
    <div id="test-fields" style="display:grid;gap:8px;margin-bottom:12px"></div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
      <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer">
        <input type="checkbox" id="test-call-ai" />
        AIへ送信する（実際にAPIを呼び出します）
      </label>
      <button id="test-run-btn" onclick="runPromptTest()"
        style="padding:6px 16px;background:#3d7a70;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px">
        実行
      </button>
    </div>
    <div id="test-loading" style="display:none;color:#60726f;font-size:13px;margin-bottom:8px">実行中...</div>
    <div id="test-result" style="display:none">
      <div id="test-result-tabs" style="display:flex;gap:4px;margin-bottom:10px">
        <button onclick="showTestTab('rendered')" id="test-tab-rendered" class="preview-tab active-tab">最終プロンプト</button>
        <button onclick="showTestTab('ai')" id="test-tab-ai" class="preview-tab">AIレスポンス</button>
      </div>
      <pre id="test-rendered" style="white-space:pre-wrap;background:#f8fbfa;border:1px solid #d8e3e0;border-radius:8px;padding:14px;font-size:12px;max-height:400px;overflow:auto;margin:0"></pre>
      <pre id="test-ai-response" style="display:none;white-space:pre-wrap;background:#f8fbfa;border:1px solid #d8e3e0;border-radius:8px;padding:14px;font-size:12px;max-height:400px;overflow:auto;margin:0"></pre>
    </div>
  </div>
</div>

<script>
function toggleScreeningDetails(enabled) {
  var el = document.getElementById('screening-details');
  if (el) el.style.display = enabled ? '' : 'none';
}
function toggleCondFields(id, enabled) {
  var el = document.getElementById(id);
  if (el) el.style.display = enabled ? '' : 'none';
}

// Phase B: ai_prompt_mode は hidden で送信する（ラジオ撤去）。
//  - 初期が package（新規 / 既存 package）→ 常に package
//  - 初期が custom（legacy）→ パッケージ未選択なら custom 維持、選択したら package へ昇格
function syncPromptMode() {
  var hidden = document.getElementById('ai_prompt_mode_hidden');
  if (!hidden) return;
  var versionSelect = document.querySelector('[name="ai_prompt_package_version_id"]');
  var hasVersion = !!(versionSelect && (versionSelect.value || '').trim() !== '');
  if (hidden.getAttribute('data-initial') === 'custom' && !hasVersion) {
    hidden.value = 'custom';
  } else {
    hidden.value = 'package';
  }
}

(function() {
  var form = document.querySelector('form.card');
  if (!form) return;
  form.addEventListener('submit', syncPromptMode);
})();

// プロンプト動作確認の用途フィルタ: 系統/休眠/深掘りでカードを畳む（クライアントのみ・送信に影響しない）
function setupResearchPromptFilter() {
  var famSel    = document.getElementById('rf-family-filter');
  var hideDorm  = document.getElementById('rf-hide-dormant');
  var probeOnly = document.getElementById('rf-probe-only');
  var countEl   = document.getElementById('rf-filter-count');
  if (!famSel) return;

  function apply() {
    var fam = famSel.value;
    var cards = document.querySelectorAll('[data-rf-pk-card]');
    var shown = 0;
    cards.forEach(function(c) {
      var ok = true;
      if (fam !== 'all' && c.getAttribute('data-fam') !== fam) ok = false;
      if (hideDorm && hideDorm.checked && c.getAttribute('data-dormant') === '1') ok = false;
      if (probeOnly && probeOnly.checked && c.getAttribute('data-probe') !== '1') ok = false;
      c.style.display = ok ? '' : 'none';
      if (ok) shown++;
    });
    document.querySelectorAll('[data-rf-fam-group]').forEach(function(h) {
      var g = h.getAttribute('data-rf-fam-group');
      var any = Array.prototype.some.call(
        document.querySelectorAll('[data-rf-pk-card][data-fam="' + g + '"]'),
        function(c) { return c.style.display !== 'none'; }
      );
      h.style.display = any ? '' : 'none';
    });
    if (countEl) countEl.textContent = '表示中 ' + shown + ' / ' + cards.length + ' キー';
  }

  famSel.addEventListener('change', apply);
  if (hideDorm)  hideDorm.addEventListener('change', apply);
  if (probeOnly) probeOnly.addEventListener('change', apply);
  apply();
}
setupResearchPromptFilter();

// Phase G/B: package モードでバージョン未選択のまま送信しようとした場合に明確に警告する
function confirmPromptPackageSelection() {
  syncPromptMode();
  var hidden = document.getElementById('ai_prompt_mode_hidden');
  if (!hidden || hidden.value !== 'package') return true;
  var versionSelect = document.querySelector('[name="ai_prompt_package_version_id"]');
  var versionId = versionSelect ? (versionSelect.value || '').trim() : '';
  if (versionId) return true;
  return window.confirm(
    'プロンプトパッケージのバージョンが未選択です。\n' +
    'このまま保存すると、公開済みパッケージを割り当てるまで既定プロンプト（BASE）で動作します。\n\n' +
    'このまま続行しますか？（OK＝続行 / キャンセル＝戻ってパッケージを選択）'
  );
}

// Phase 6-A: パッケージ → バージョンの2段選択
var PKG_DATA = <%- JSON.stringify((promptPackages || [])
  .filter(function(p) { return Array.isArray(p.selectable_versions) && p.selectable_versions.length > 0; })
  .map(function(p) {
    return {
      id: p.id,
      versions: p.selectable_versions,
      publishedVersionId: p.published_version ? p.published_version.id : null
    };
  })) %>;

function onPackageSelectChange() {
  var pkgSelect = document.getElementById('pkg-package-select');
  var versionSelect = document.getElementById('pkg-version-select');
  var detailLink = document.getElementById('pkg-detail-link');
  if (!pkgSelect || !versionSelect) return;

  var pkg = null;
  for (var i = 0; i < PKG_DATA.length; i++) {
    if (PKG_DATA[i].id === pkgSelect.value) { pkg = PKG_DATA[i]; break; }
  }

  versionSelect.innerHTML = '';
  if (!pkg) {
    var emptyOpt = document.createElement('option');
    emptyOpt.value = '';
    emptyOpt.textContent = '-- 先にパッケージを選択 --';
    versionSelect.appendChild(emptyOpt);
    if (detailLink) detailLink.style.display = 'none';
    return;
  }

  pkg.versions.forEach(function(v) {
    var opt = document.createElement('option');
    opt.value = v.id;
    var label = 'v' + v.version_no + (v.status === 'published' ? '（公開中）' : '（アーカイブ・実行時は公開版へfallback）');
    if (v.change_note) label += ' · ' + v.change_note;
    opt.textContent = label;
    if (pkg.publishedVersionId ? v.id === pkg.publishedVersionId : false) opt.selected = true;
    versionSelect.appendChild(opt);
  });

  if (detailLink) {
    detailLink.href = '/admin/prompt-packages/' + pkg.id;
    detailLink.style.display = '';
  }
  syncPromptMode();
}

// Phase 5-A: 選択中パッケージバージョンの適用前プレビュー
function escapeHtmlForPreview(value) {
  return String(value == null ? '' : value)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function loadPackagePreview() {
  var select = document.querySelector('[name="ai_prompt_package_version_id"]');
  var area = document.getElementById('pkg-preview-area');
  var status = document.getElementById('pkg-preview-status');
  if (!select || !area) return;
  if (!select.value) {
    status.textContent = 'パッケージを選択してください。';
    area.style.display = 'none';
    return;
  }
  status.textContent = '読み込み中…';
  fetch('/admin/api/prompt-package-versions/' + encodeURIComponent(select.value) + '/preview')
    .then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    })
    .then(function(p) {
      status.textContent = '';
      var html = '';
      html += '<div style="margin-bottom:8px">'
        + '<strong>' + escapeHtmlForPreview(p.packageName || '') + '</strong> '
        + '<code style="font-size:11px">' + escapeHtmlForPreview(p.packageSlug || '') + '</code> '
        + '— 選択中: v' + escapeHtmlForPreview(p.selectedVersionNo)
        + ' <span style="color:#60726f">(' + escapeHtmlForPreview(p.selectedStatus) + ')</span>'
        + '</div>';

      if (p.customEquivalent) {
        html += '<div style="background:#fdecea;border:1px solid #e57373;border-radius:6px;padding:8px 12px;color:#c62828;margin-bottom:8px">'
          + '✗ fallback 先の公開バージョンがないため、このプロジェクトは<strong>プロジェクト個別設定（custom 相当）</strong>で動作します。'
          + 'パッケージの policy / templates は適用されません。'
          + '</div>';
        area.innerHTML = html;
        area.style.display = 'block';
        return;
      }

      if (p.isFallback) {
        html += '<div style="background:#fff8e1;border:1px solid #f9a825;border-radius:6px;padding:8px 12px;color:#b36200;margin-bottom:8px">'
          + '⚠ 選択中バージョンは archived のため、公開中の <strong>v' + escapeHtmlForPreview(p.fallbackVersionNo) + '</strong> に fallback されます。'
          + '以下は fallback 後（実際に使用される）の内容です。'
          + '</div>';
      }

      html += '<div style="margin-bottom:8px;color:#60726f">'
        + '適用バージョン: <strong>v' + escapeHtmlForPreview(p.effectiveVersionNo) + '</strong>'
        + ' (' + escapeHtmlForPreview(p.effectiveStatus) + ') / fallback: ' + (p.isFallback ? 'あり' : 'なし')
        + '</div>';

      html += '<div style="margin-bottom:10px"><strong>policy_json</strong>'
        + '<pre style="font-size:11px;margin:4px 0 0;background:#f8faf9;border:1px solid #e0e8e4;border-radius:6px;padding:8px;white-space:pre-wrap;max-height:160px;overflow-y:auto">'
        + escapeHtmlForPreview(p.policyJson ? JSON.stringify(p.policyJson, null, 2) : '（未設定 — プロジェクト個別設定を使用）')
        + '</pre></div>';

      html += '<strong>実際に使用されるプロンプトテンプレート</strong>';
      (p.templates || []).forEach(function(t) {
        var badge = t.source === 'package'
          ? '<span style="font-size:10px;background:#e8f5ef;color:#1a7a5a;padding:1px 6px;border-radius:4px">package_template</span>'
          : '<span style="font-size:10px;background:#f0f4f3;color:#60726f;padding:1px 6px;border-radius:4px">base_template' + (t.source === 'disabled' ? '（無効化→デフォルト）' : '') + '</span>';
        html += '<details style="margin-top:6px;border:1px solid #e0e8e4;border-radius:6px;padding:6px 10px">'
          + '<summary style="cursor:pointer;font-size:12px">' + escapeHtmlForPreview(t.label)
          + ' <code style="font-size:10px">' + escapeHtmlForPreview(t.key) + '</code> ' + badge + '</summary>'
          + '<pre style="font-size:11px;margin:6px 0 0;background:#f8faf9;border:1px solid #e0e8e4;border-radius:6px;padding:8px;white-space:pre-wrap;max-height:240px;overflow-y:auto">'
          + escapeHtmlForPreview(t.template) + '</pre>'
          + '</details>';
      });

      area.innerHTML = html;
      area.style.display = 'block';
    })
    .catch(function(err) {
      status.textContent = 'プレビューの取得に失敗しました（' + err.message + '）';
      area.style.display = 'none';
    });
}
</script>

<style>
.preview-tab {
  padding: 4px 12px;
  font-size: 12px;
  border: 1px solid #d8e3e0;
  border-radius: 6px;
  background: #f8fbfa;
  cursor: pointer;
}
.preview-tab.active-tab {
  background: #3d7a70;
  color: #fff;
  border-color: #3d7a70;
}
</style>

<script>
var _previewProjectId = null;
var _previewPromptKey = null;
var _testProjectId = null;
var _testPromptKey = null;
var _testPlaceholders = [];

function closeModal(id) {
  document.getElementById(id).style.display = 'none';
}

// キーボードでモーダルを閉じる
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('[id$="-modal"]').forEach(function(el) {
      el.style.display = 'none';
    });
  }
});

/* ── プレビューモーダル ── */
function showPreviewTab(tab) {
  ['rendered','template','policy'].forEach(function(t) {
    document.getElementById('preview-' + t).style.display = t === tab ? '' : 'none';
    var btn = document.getElementById('tab-' + t);
    if (btn) btn.className = t === tab ? 'preview-tab active-tab' : 'preview-tab';
  });
}

function openPromptPreview(projectId, promptKey) {
  _previewProjectId = projectId;
  _previewPromptKey = promptKey;
  document.getElementById('preview-modal').style.display = '';
  document.getElementById('preview-title').textContent = 'プロンプトプレビュー: ' + promptKey;
  document.getElementById('preview-meta').textContent = '';
  document.getElementById('preview-rendered').textContent = '';
  document.getElementById('preview-template').textContent = '';
  document.getElementById('preview-policy').textContent = '';
  document.getElementById('preview-loading').style.display = '';
  showPreviewTab('rendered');

  fetch('/admin/api/projects/' + projectId + '/prompt-preview', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'prompt_key=' + encodeURIComponent(promptKey)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    document.getElementById('preview-loading').style.display = 'none';
    if (data.error) {
      document.getElementById('preview-rendered').textContent = 'エラー: ' + data.error;
      return;
    }
    document.getElementById('preview-meta').textContent =
      'モード: ' + data.templateMode + '  |  ' + data.label;
    document.getElementById('preview-rendered').textContent = data.rendered;
    document.getElementById('preview-template').textContent = data.template;
    document.getElementById('preview-policy').textContent =
      JSON.stringify(data.policy, null, 2);
  })
  .catch(function(err) {
    document.getElementById('preview-loading').style.display = 'none';
    document.getElementById('preview-rendered').textContent = 'リクエスト失敗: ' + err.message;
  });
}

/* ── テスト実行モーダル ── */
function showTestTab(tab) {
  ['rendered','ai-response'].forEach(function(t) {
    var el = document.getElementById('test-' + t);
    if (el) el.style.display = t === tab ? '' : 'none';
    var tid = t === 'rendered' ? 'test-tab-rendered' : 'test-tab-ai';
    var btn = document.getElementById(tid);
    if (btn) btn.className = t === tab ? 'preview-tab active-tab' : 'preview-tab';
  });
}

function openPromptTest(projectId, promptKey, label) {
  _testProjectId = projectId;
  _testPromptKey = promptKey;
  document.getElementById('test-modal').style.display = '';
  document.getElementById('test-title').textContent = 'テスト実行: ' + label;
  document.getElementById('test-result').style.display = 'none';
  document.getElementById('test-loading').style.display = 'none';
  document.getElementById('test-call-ai').checked = false;

  // プレースホルダー入力欄を生成するためプレビューAPIで定義を取得
  var fields = document.getElementById('test-fields');
  fields.innerHTML = '<span style="font-size:12px;color:#60726f">読み込み中...</span>';

  fetch('/admin/api/projects/' + projectId + '/prompt-preview', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'prompt_key=' + encodeURIComponent(promptKey)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    _testPlaceholders = data.allowedPlaceholders || [];
    fields.innerHTML = '';
    _testPlaceholders.forEach(function(ph) {
      var wrap = document.createElement('label');
      wrap.style.cssText = 'display:grid;gap:2px;font-size:12px;color:#60726f';
      var isLong = ['sessionSummary','answers','collectedSoFar','existingSlots','extractedSlots'].indexOf(ph.key) >= 0;
      wrap.innerHTML =
        '<span>{{' + ph.key + '}} <span style="color:#9ab">' + ph.description + '</span></span>' +
        (isLong
          ? '<textarea id="test-ph-' + ph.key + '" rows="3" style="font-family:monospace;font-size:11px" placeholder="（任意）サンプル値"></textarea>'
          : '<input id="test-ph-' + ph.key + '" type="text" style="font-family:monospace;font-size:11px" placeholder="（任意）サンプル値" />');
      fields.appendChild(wrap);
    });
  })
  .catch(function() {
    fields.innerHTML = '<span style="color:#c0392b;font-size:12px">プレースホルダー情報の取得に失敗しました</span>';
  });
}

function runPromptTest() {
  var sampleValues = {};
  _testPlaceholders.forEach(function(ph) {
    var el = document.getElementById('test-ph-' + ph.key);
    if (el && el.value.trim()) sampleValues[ph.key] = el.value.trim();
  });

  var callAI = document.getElementById('test-call-ai').checked ? '1' : '0';
  document.getElementById('test-loading').style.display = '';
  document.getElementById('test-result').style.display = 'none';
  document.getElementById('test-run-btn').disabled = true;

  fetch('/admin/api/projects/' + _testProjectId + '/prompt-test', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'prompt_key=' + encodeURIComponent(_testPromptKey) +
          '&call_ai=' + callAI +
          '&sample_values=' + encodeURIComponent(JSON.stringify(sampleValues))
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    document.getElementById('test-loading').style.display = 'none';
    document.getElementById('test-run-btn').disabled = false;
    document.getElementById('test-result').style.display = '';

    if (data.error) {
      document.getElementById('test-rendered').textContent = 'エラー: ' + data.error;
      return;
    }

    document.getElementById('test-rendered').textContent = data.rendered;

    var aiEl = document.getElementById('test-ai-response');
    if (data.aiResponse) {
      aiEl.textContent = data.aiResponse;
    } else if (data.aiError) {
      aiEl.textContent = 'AIエラー: ' + data.aiError;
    } else {
      aiEl.textContent = '（AIへの送信は選択されませんでした）';
    }
    showTestTab('rendered');
  })
  .catch(function(err) {
    document.getElementById('test-loading').style.display = 'none';
    document.getElementById('test-run-btn').disabled = false;
    document.getElementById('test-rendered').textContent = 'リクエスト失敗: ' + err.message;
    document.getElementById('test-result').style.display = '';
  });
}
</script>

<%- include("../../partials/footer") %>

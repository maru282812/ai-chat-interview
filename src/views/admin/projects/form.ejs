<%- include("../../partials/header", { title }) %>
<form class="card" method="post" action="<%= action %>">
  <label>
    プロジェクト名
    <input type="text" name="name" value="<%= project?.name || '' %>" required />
  </label>
  <label>
    クライアント名
    <input type="text" name="client_name" value="<%= project?.client_name || '' %>" />
  </label>
  <label>
    調査目的
    <textarea name="objective"><%= project?.objective || '' %></textarea>
  </label>
  <label>
    ステータス
    <select name="status">
      <% for (const status of ["draft", "ready", "published", "paused", "closed", "archived"]) { %>
        <option value="<%= status %>" <%= project?.status === status ? "selected" : "" %>><%= status %></option>
      <% } %>
    </select>
  </label>
  <label>
    完了ポイント
    <input type="number" name="reward_points" value="<%= project?.reward_points || 30 %>" />
  </label>
  <label>
    カテゴリ（LIFF案件一覧のタブ用）
    <select name="category">
      <option value="">未設定</option>
      <% for (const cat of ["生活系","仕事系","子育て","健康","趣味","その他"]) { %>
        <option value="<%= cat %>" <%= project?.category === cat ? "selected" : "" %>><%= cat %></option>
      <% } %>
    </select>
  </label>
  <label>
    所要時間（分）
    <input type="number" name="estimated_minutes" value="<%= project?.estimated_minutes || '' %>" placeholder="例: 10" min="1" />
  </label>
  <label>
    最大応募人数
    <input type="number" name="max_respondents" value="<%= project?.max_respondents || '' %>" placeholder="未設定で無制限" min="1" />
  </label>
  <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
    <input type="checkbox" name="is_discoverable" value="true" <%= project?.is_discoverable ? "checked" : "" %> />
    LIFF案件一覧に公開する（※現在は status=published で自動制御）
  </label>

  <hr style="margin:16px 0" />
  <h3 style="margin:0 0 8px">配信設定</h3>

  <label>
    配信分類
    <select name="delivery_type">
      <option value="">未設定</option>
      <% const deliveryTypeLabels = {
           new_project: '新着案件',
           interview: 'インタビュー',
           survey: 'アンケート',
           daily_survey: 'デイリーアンケート',
           high_point: '高ポイント案件',
           urgent: '緊急募集'
         };
         for (const [val, label] of Object.entries(deliveryTypeLabels)) { %>
        <option value="<%= val %>" <%= project?.delivery_type === val ? "selected" : "" %>><%= label %></option>
      <% } %>
    </select>
  </label>

  <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
    <input type="checkbox" name="delivery_enabled" value="true" <%= project?.delivery_enabled ? "checked" : "" %> />
    自動配信を有効にする（status=ready のときのみ配信テンプレートの対象になります）
  </label>

  <% if (project?.delivered_at) { %>
    <p style="font-size:12px;color:#666;margin:4px 0 0">最終配信日時: <%= new Date(project.delivered_at).toLocaleString('ja-JP') %></p>
  <% } %>

  <button type="submit">保存</button>
</form>
<%- include("../../partials/footer") %>

<%- include("../../partials/header", { title }) %>

<div style="margin-bottom:1rem">
  <a href="/admin/projects/<%= project.id %>/edit#screening-section">&larr; プロジェクト設定に戻る</a>
</div>

<h2>スクリーニング設定: <%= project.name %></h2>

<div style="background:#fffbe6;border:1px solid #f5c842;border-radius:8px;padding:14px 16px;margin-bottom:1.5rem">
  <p style="margin:0;font-size:14px;color:#666">
    スクリーニング設定はプロジェクト編集ページに統合されました。
    <a href="/admin/projects/<%= project.id %>/edit#screening-section"
       style="color:#1a6b4a;font-weight:600">プロジェクト編集ページ（スクリーニング設定）</a>
    から設定・条件の追加削除ができます。
  </p>
</div>

<% if (flash === 'condition_added') { %>
  <div style="color:green;margin-bottom:1rem">条件を追加しました。</div>
<% } else if (flash === 'condition_deleted') { %>
  <div style="color:green;margin-bottom:1rem">条件を削除しました。</div>
<% } else if (flash === 'error_missing_fields') { %>
  <div style="color:red;margin-bottom:1rem">必須項目を入力してください。</div>
<% } %>

<section>
  <h3>現在の条件一覧</h3>
  <p style="font-size:0.9rem;color:#555">
    スクリーニング設問数: <strong><%= screeningQuestions.length %></strong>
  </p>
  <% if (conditions.length === 0) { %>
    <p class="muted">条件が設定されていません（全員通過）。</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>種別</th>
          <th>対象</th>
          <th>演算子</th>
          <th>値 (JSON)</th>
          <th>優先度</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% for (const cond of conditions) { %>
          <tr>
            <td>
              <% if (cond.condition_type === 'profile') { %>
                <span class="tag" style="background:#e3f2fd;color:#1565c0">マイページ</span>
              <% } else { %>
                <span class="tag" style="background:#e8f5e9;color:#2e7d32">回答</span>
              <% } %>
            </td>
            <td><code><%= cond.target_key %></code></td>
            <td><code><%= cond.operator %></code></td>
            <td><code><%= JSON.stringify(cond.value_json) %></code></td>
            <td><%= cond.priority %></td>
            <td>
              <form method="post"
                    action="/admin/projects/<%= project.id %>/screening/conditions/<%= cond.id %>/delete"
                    style="display:inline"
                    onsubmit="return confirm('この条件を削除しますか？')">
                <button type="submit" class="btn-danger">削除</button>
              </form>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</section>

<div style="margin-top:2rem">
  <a href="/admin/projects/<%= project.id %>/edit#screening-section" class="btn-primary">
    プロジェクト編集ページで条件を追加する →
  </a>
</div>

<%- include("../../partials/footer") %>

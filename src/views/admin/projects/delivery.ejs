<%- include("../../partials/header", { title }) %>
<div class="stack">
  <div class="card">
    <h2><%= project.name %></h2>
    <p class="muted">Delivery management for project assignments</p>
    <p>
      <a href="/admin/projects/<%= project.id %>/respondents">Respondents</a> |
      <a href="/admin/projects/<%= project.id %>/questions">Questions</a> |
      <a href="/admin/projects/<%= project.id %>/exports/assignments.csv">Assignments CSV</a> |
      <a href="/admin/projects/<%= project.id %>/exports/unanswered.csv">Unanswered CSV</a> |
      <a href="/admin/projects/<%= project.id %>/exports/expired.csv">Expired CSV</a>
    </p>
  </div>

  <form class="card stack" method="post" action="/admin/projects/<%= project.id %>/delivery/manual">
    <div>
      <h3>Manual Delivery</h3>
      <p class="muted">LINE user id があるユーザーだけ配信対象にできます。</p>
    </div>
    <label>
      回答期限
      <input type="datetime-local" name="due_at" />
    </label>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Select</th>
            <th>Display</th>
            <th>LINE User</th>
            <th>Rank</th>
            <th>Total Points</th>
            <th>Last Participation</th>
            <th>Status</th>
            <th>Assignment</th>
          </tr>
        </thead>
        <tbody>
          <% for (const candidate of candidates) { %>
            <tr>
              <td>
                <input
                  type="checkbox"
                  name="selected_respondent_ids"
                  value="<%= candidate.source_respondent_id %>"
                  <%= candidate.has_line_user_id ? "" : "disabled" %>
                />
              </td>
              <td>
                <strong><%= candidate.display_name || "-" %></strong><br />
                <span class="muted"><code><%= candidate.source_respondent_id %></code></span>
              </td>
              <td>
                <% if (candidate.has_line_user_id) { %>
                  <code><%= candidate.line_user_id %></code>
                <% } else { %>
                  <span class="danger-text">not available</span>
                <% } %>
              </td>
              <td><%= candidate.rank_name || "-" %></td>
              <td><%= candidate.total_points %> pt</td>
              <td><%= candidate.last_participated_at || "-" %></td>
              <td><span class="tag"><%= candidate.status %></span></td>
              <td>
                <% if (candidate.target_assignment_status) { %>
                  <span class="tag"><%= candidate.target_assignment_status %></span><br />
                  <span class="muted"><%= candidate.target_assignment_due_at || "-" %></span>
                <% } else { %>
                  <span class="muted">-</span>
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div>
      <button type="submit">Assign And Push</button>
    </div>
  </form>

  <form class="card stack" method="post" action="/admin/projects/<%= project.id %>/delivery/rules">
    <div>
      <h3>Rule Based Delivery</h3>
      <p class="muted">後から条件を増やしやすいように、条件オブジェクト前提の簡易フォームにしています。</p>
    </div>
    <div class="form-grid">
      <label>
        Rank
        <select name="rank_code">
          <option value="">Any</option>
          <% for (const rank of ranks) { %>
            <option value="<%= rank.rank_code %>"><%= rank.rank_name %></option>
          <% } %>
        </select>
      </label>
      <label>
        Total Points Min
        <input type="number" name="total_points_min" min="0" />
      </label>
      <label>
        Total Points Max
        <input type="number" name="total_points_max" min="0" />
      </label>
      <label>
        Has Participated
        <select name="has_participated">
          <option value="">Any</option>
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </label>
      <label>
        Last Participated Before
        <input type="date" name="last_participated_before" />
      </label>
      <label>
        Unanswered Project
        <select name="unanswered_project_id">
          <option value="">Skip</option>
          <% for (const item of projects) { %>
            <option value="<%= item.id %>"><%= item.name %></option>
          <% } %>
        </select>
      </label>
      <label>
        回答期限
        <input type="datetime-local" name="rule_due_at" />
      </label>
    </div>
    <div>
      <h4>基本情報条件（任意）</h4>
      <p class="muted">未入力の項目は絞り込み対象外になります。複数値はカンマ区切りで入力してください。</p>
    </div>
    <div class="form-grid">
      <label>
        年齢（下限）
        <input type="number" name="age_min" min="0" max="120" />
      </label>
      <label>
        年齢（上限）
        <input type="number" name="age_max" min="0" max="120" />
      </label>
      <label>
        都道府県（カンマ区切り）
        <input type="text" name="prefectures" placeholder="例: 東京都,神奈川県" />
      </label>
      <label>
        職業（カンマ区切り）
        <input type="text" name="occupations" placeholder="例: 会社員（正社員）,自営業・フリーランス" />
      </label>
      <label>
        業種（カンマ区切り）
        <input type="text" name="industries" placeholder="例: IT・通信,製造" />
      </label>
      <label>
        婚姻状況（カンマ区切り）
        <input type="text" name="marital_statuses" placeholder="例: single,married" />
        <span class="muted">値: single / married / divorced / widowed</span>
      </label>
      <label>
        子どもの有無
        <select name="has_children">
          <option value="">条件なし</option>
          <option value="true">いる</option>
          <option value="false">いない</option>
        </select>
      </label>
      <label>
        同居家族構成（カンマ区切り、いずれかを含む）
        <input type="text" name="household_compositions" placeholder="例: spouse,child" />
        <span class="muted">値: self / spouse / child / parent / sibling / other</span>
      </label>
    </div>
    <div>
      <button type="submit">Assign By Rule</button>
    </div>
  </form>

  <div class="card">
    <h3>Assignments</h3>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Respondent</th>
            <th>Status</th>
            <th>Screening</th>
            <th>Type</th>
            <th>Due</th>
            <th>Sent</th>
            <th>Started</th>
            <th>Completed</th>
            <th>Expired</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% for (const item of assignments) { %>
            <tr>
              <td>
                <strong><%= item.assignment.respondent?.display_name || "-" %></strong><br />
                <span class="muted"><code><%= item.assignment.respondent_id %></code></span>
              </td>
              <td><span class="tag"><%= item.assignment.status %></span></td>
              <td>
                <% if (item.assignment.screening_result === "passed") { %>
                  <span class="tag tag-success">通過</span>
                <% } else if (item.assignment.screening_result === "failed") { %>
                  <span class="tag tag-danger">非通過</span>
                <% } else { %>
                  <span class="muted">-</span>
                <% } %>
              </td>
              <td><%= item.assignment.assignment_type %></td>
              <td><%= item.assignment.due_at || "-" %></td>
              <td><%= item.assignment.sent_at || "-" %></td>
              <td><%= item.assignment.started_at || "-" %></td>
              <td><%= item.assignment.completed_at || "-" %></td>
              <td><%= item.isExpired ? "yes" : "no" %></td>
              <td>
                <% if (item.assignment.last_delivery_error) { %>
                  <span class="danger-text"><%= item.assignment.last_delivery_error %></span>
                <% } else { %>
                  <span class="muted">-</span>
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../../partials/footer") %>

<%- include("../../partials/header", { title }) %>
<div class="card" style="margin-bottom: 16px;">
  <h2><%= project.name %></h2>
  <% if (project.user_display_title && project.user_display_title.trim() && project.user_display_title.trim() !== project.name) { %>
  <p class="muted" style="margin-top:4px;font-size:0.85em;">USER表示タイトル: <strong><%= project.user_display_title %></strong></p>
  <% } %>
  <p class="muted">Research mode: <%= project.research_mode %></p>
  <p>
    <a href="/admin/projects/<%= project.id %>/respondents">Respondents</a> |
    <a href="/admin/projects/<%= project.id %>/exports/respondents.csv">Export CSV</a>
  </p>
  <form method="post" action="/admin/projects/<%= project.id %>/analysis" style="margin-top: 12px;">
    <button type="submit">Run AI Analysis</button>
  </form>
</div>

<div class="card" style="margin-bottom:16px;">
  <h2>統計エクスポート（外部集計ソフト向け）</h2>
  <p class="muted" style="font-size:0.85em;">UTF-8 BOM + RFC4180。列は送付時マスター順、多重選択は 0/1 展開、AI深掘りは元設問へ統合。出力主キーは擬似匿名。</p>
  <% const exBase = `/admin/projects/${project.id}/exports/stat`; %>
  <p style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
    <label style="font-size:0.85em;"><input type="checkbox" id="ex-include-test" /> テスト回答を含む</label>
    <label style="font-size:0.85em;"><input type="checkbox" id="ex-consented-only" /> 同意者のみ</label>
  </p>
  <p style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
    <a class="button-link primary" id="ex-bundle" href="<%= exBase %>/bundle.zip">集計アプリ用3点セット（zip）</a>
    <span class="muted" style="font-size:0.8em;">respondents_wide / answers_long / codebook をまとめて取得</span>
  </p>
  <p style="display:flex;flex-wrap:wrap;gap:8px;">
    <a class="button-link" id="ex-wide" href="<%= exBase %>/respondents-wide.csv">respondents_wide.csv</a>
    <a class="button-link" id="ex-long" href="<%= exBase %>/answers-long.csv">answers_long.csv</a>
    <a class="button-link" href="<%= exBase %>/codebook.csv">codebook.csv</a>
    <a class="button-link" href="<%= exBase %>/questionnaire-snapshot.json">questionnaire_snapshot.json</a>
    <a class="button-link" id="ex-rand" href="<%= exBase %>/randomization-log.csv">randomization_log.csv</a>
  </p>

  <h2 style="margin-top:16px;">送付前チェック / 調査票の確定</h2>
  <p class="muted" style="font-size:0.85em;">確定すると現在の設問構成を凍結（スナップショット）します。依存順違反などのエラーがあると確定はブロックされます。</p>
  <p style="display:flex;gap:8px;">
    <button type="button" class="button-link secondary" id="btn-validate">調査票を検証</button>
    <button type="button" class="button-link primary" id="btn-snapshot">調査票を確定（スナップショット作成）</button>
  </p>
  <div id="validate-result" style="margin-top:8px;font-size:0.85em;"></div>
</div>

<script>
(function () {
  const base = "/admin/projects/<%= project.id %>";
  function syncExportLinks() {
    const params = new URLSearchParams();
    if (document.getElementById("ex-include-test").checked) params.set("includeTest", "1");
    if (document.getElementById("ex-consented-only").checked) params.set("consentedOnly", "1");
    const qs = params.toString() ? ("?" + params.toString()) : "";
    for (const [id, path] of [["ex-wide", "/respondents-wide.csv"], ["ex-long", "/answers-long.csv"], ["ex-rand", "/randomization-log.csv"], ["ex-bundle", "/bundle.zip"]]) {
      document.getElementById(id).href = base + "/exports/stat" + path + qs;
    }
  }
  document.getElementById("ex-include-test").addEventListener("change", syncExportLinks);
  document.getElementById("ex-consented-only").addEventListener("change", syncExportLinks);

  function renderReport(report, prefix) {
    const out = document.getElementById("validate-result");
    const findings = (report && report.findings) || [];
    const errors = findings.filter(f => f.level === "error");
    const warnings = findings.filter(f => f.level === "warning");
    let html = prefix + " エラー " + errors.length + " 件 / 警告 " + warnings.length + " 件";
    if (findings.length) {
      html += "<ul style='margin:6px 0;'>" + findings.map(f =>
        "<li style='color:" + (f.level === "error" ? "#b00020" : "#8a5b00") + "'>[" + f.level + "] " +
        (f.question_code ? (f.question_code + ": ") : "") + f.message + "</li>").join("") + "</ul>";
    }
    out.innerHTML = html;
  }

  document.getElementById("btn-validate").addEventListener("click", async () => {
    document.getElementById("validate-result").textContent = "検証中...";
    try {
      const res = await fetch(base + "/validate");
      renderReport(await res.json(), "検証結果:");
    } catch (e) { document.getElementById("validate-result").textContent = "検証に失敗しました: " + e; }
  });

  document.getElementById("btn-snapshot").addEventListener("click", async () => {
    if (!confirm("現在の設問構成を凍結してスナップショットを作成します。よろしいですか？")) return;
    document.getElementById("validate-result").textContent = "確定中...";
    try {
      const res = await fetch(base + "/snapshot", { method: "POST" });
      const data = await res.json();
      if (res.ok && data.ok) {
        renderReport(data.report, "確定しました（version " + data.snapshot_version + "）。");
      } else {
        renderReport(data.report, "エラーのため確定をブロックしました。");
      }
    } catch (e) { document.getElementById("validate-result").textContent = "確定に失敗しました: " + e; }
  });
})();
</script>

<div class="card" style="margin-bottom:16px;">
  <h2>ロウデータ出力（Freeasy水準）</h2>
  <p class="muted" style="font-size:0.85em;">
    Freeasy式列命名（q1 / q1c1 / q1t1 / q1s1 …）＋設問別回答時刻＋属性列（性別/年齢/年代/都道府県/地方/職業/業種/未既婚/世帯年収/子供/ランク）。
    列の意味はレイアウトデータで引けます。含めるステータスは件数を見て手動選択（既定は完了＋未完了＝集計アプリ側でクリーニング裁定するため）。
  </p>
  <div id="rd-counts" style="font-size:0.9em;margin-bottom:8px;">件数を読み込み中...</div>
  <p style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;font-size:0.85em;">
    <span>
      出力タイプ:
      <label><input type="radio" name="rd-mode" value="code" checked /> コード出力</label>
      <label><input type="radio" name="rd-mode" value="label" /> 回答値出力</label>
    </span>
    <label><input type="checkbox" id="rd-include-probe" checked /> AI深掘り列を含む</label>
    <label><input type="checkbox" id="rd-include-test" /> テスト回答を含む</label>
    <label title="個人情報のため、不正検出で必要なときだけONにしてください">
      <input type="checkbox" id="rd-include-pii" /> UserAgent / IP を含む（不正検出用）
    </label>
  </p>
  <p style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
    <a class="button-link" id="rd-csv" href="<%= exBase %>/rawdata.csv">rawdata.csv</a>
    <a class="button-link secondary" id="rd-layout" href="<%= exBase %>/rawdata-layout.csv">rawdata-layout.csv（レイアウトデータ）</a>
    <button type="button" class="button-link secondary" id="rd-history-btn">出力履歴</button>
  </p>
  <div id="rd-history" style="display:none;font-size:0.85em;margin-top:8px;"></div>
</div>

<script>
(function () {
  const base = "/admin/projects/<%= project.id %>/exports/stat";
  const countsEl = document.getElementById("rd-counts");
  const STATUS_LABELS = { completed: "完了", partial: "途中までの回答", abandoned: "離脱", not_started: "未開始" };

  function selectedStatuses() {
    return [...document.querySelectorAll(".rd-status:checked")].map((el) => el.value);
  }

  function syncRawdataLinks() {
    const includePii = document.getElementById("rd-include-pii").checked;
    const params = new URLSearchParams();
    const mode = document.querySelector('input[name="rd-mode"]:checked');
    if (mode && mode.value === "label") params.set("mode", "label");
    const statuses = selectedStatuses();
    if (statuses.length > 0) params.set("statuses", statuses.join(","));
    if (!document.getElementById("rd-include-probe").checked) params.set("includeProbe", "0");
    if (document.getElementById("rd-include-test").checked) params.set("includeTest", "1");
    if (includePii) params.set("includePii", "1");
    document.getElementById("rd-csv").href = base + "/rawdata.csv?" + params.toString();
    // レイアウトは rawdata.csv と同じ列構成を説明する必要があるため includePii を揃える
    const layoutParams = new URLSearchParams();
    if (!document.getElementById("rd-include-probe").checked) layoutParams.set("includeProbe", "0");
    if (includePii) layoutParams.set("includePii", "1");
    document.getElementById("rd-layout").href = base + "/rawdata-layout.csv" + (layoutParams.toString() ? "?" + layoutParams.toString() : "");
  }

  async function loadCounts() {
    try {
      const res = await fetch(base + "/status-counts");
      const data = await res.json();
      const counts = (data && data.counts) || [];
      if (counts.length === 0) {
        countsEl.textContent = "回答がまだありません。";
        return;
      }
      countsEl.innerHTML = counts.map((entry) => {
        const label = STATUS_LABELS[entry.status] || entry.status;
        const checked = entry.status !== "not_started" ? "checked" : "";
        const test = entry.test_count > 0 ? "（別途テスト " + entry.test_count + " 件）" : "";
        return '<label style="margin-right:16px;"><input type="checkbox" class="rd-status" value="' + entry.status + '" ' + checked + " /> " +
          "【" + entry.sta_code + "】" + label + " <strong>" + entry.count + "</strong> 件" + test + "</label>";
      }).join("");
      for (const el of document.querySelectorAll(".rd-status")) {
        el.addEventListener("change", syncRawdataLinks);
      }
      syncRawdataLinks();
    } catch (e) {
      countsEl.textContent = "件数の取得に失敗しました: " + e;
    }
  }

  for (const el of document.querySelectorAll('input[name="rd-mode"], #rd-include-probe, #rd-include-test, #rd-include-pii')) {
    el.addEventListener("change", syncRawdataLinks);
  }
  syncRawdataLinks();
  loadCounts();

  // 出力履歴（export_jobs 監査ログ）
  document.getElementById("rd-history-btn").addEventListener("click", async () => {
    const box = document.getElementById("rd-history");
    if (box.style.display !== "none") {
      box.style.display = "none";
      return;
    }
    box.style.display = "";
    box.textContent = "読み込み中...";
    try {
      const res = await fetch(base + "/history");
      const data = await res.json();
      const jobs = (data && data.jobs) || [];
      if (jobs.length === 0) {
        box.textContent = "出力履歴はまだありません。";
        return;
      }
      box.innerHTML = "<table style='width:100%;'><thead><tr><th>日時</th><th>種類</th><th>実施者</th><th>フィルタ</th></tr></thead><tbody>" +
        jobs.map((job) => "<tr><td>" + new Date(job.exported_at).toLocaleString("ja-JP") + "</td><td>" + job.export_type + "</td><td>" +
          (job.exported_by || "-") + "</td><td style='color:#888;'>" + JSON.stringify(job.filters_json || {}) + "</td></tr>").join("") +
        "</tbody></table>";
    } catch (e) {
      box.textContent = "履歴の取得に失敗しました: " + e;
    }
  });
})();
</script>

<section class="grid">
  <div class="card">
    <h2>Coverage</h2>
    <p>Respondents: <strong><%= dataset.respondent_count %></strong></p>
    <p>Completed sessions: <strong><%= dataset.completed_session_count %></strong></p>
    <p><strong>Primary objectives</strong><br /><%= (project.primary_objectives || []).join(" / ") || "-" %></p>
    <p><strong>Secondary objectives</strong><br /><%= (project.secondary_objectives || []).join(" / ") || "-" %></p>
  </div>
  <div class="card">
    <h2>Free-text Policy</h2>
    <p><%= dataset.freeAnswerPolicy.policy %></p>
    <p class="muted">Target questions: <%= dataset.freeAnswerPolicy.target_question_codes.join(", ") || "-" %></p>
  </div>
</section>

<section class="stack" style="margin-top: 16px;">
  <div class="card">
    <h2>Comparison Units</h2>
    <table>
      <thead>
        <tr>
          <th>Question</th>
          <th>Role</th>
          <th>Type</th>
          <th>Aggregation</th>
          <th>Values</th>
        </tr>
      </thead>
      <tbody>
        <% for (const unit of dataset.comparisonUnits) { %>
          <tr>
            <td><strong><%= unit.question_code %></strong><br /><span class="muted"><%= unit.question_text %></span></td>
            <td><span class="tag"><%= unit.question_role %></span></td>
            <td><%= unit.question_type %></td>
            <td><%= unit.aggregation_type %><br /><span class="muted"><%= unit.note %></span></td>
            <td>
              <% if (unit.values.length > 0) { %>
                <% for (const value of unit.values) { %>
                  <div><%= value.label %>: <%= value.count %></div>
                <% } %>
              <% } else { %>
                <span class="muted">qualitative only</span>
              <% } %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Respondent Summaries</h2>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Session</th>
          <th>Summary</th>
        </tr>
      </thead>
      <tbody>
        <% for (const item of dataset.respondentSummaries) { %>
          <tr>
            <td><strong><%= item.respondent_name %></strong><br /><span class="muted"><%= item.line_user_id %></span></td>
            <td><span class="tag"><%= item.session_status %></span><br /><span class="muted"><%= item.completed_at || "-" %></span></td>
            <td><%= item.summary %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Latest AI Report</h2>
    <% if (latestReport) { %>
      <p class="muted">Generated at: <%= latestReport.created_at %></p>
      <pre class="prelike"><%= JSON.stringify(latestReport.report_json, null, 2) %></pre>
    <% } else { %>
      <p class="muted">No project analysis report yet.</p>
    <% } %>
  </div>
</section>
<%- include("../../partials/footer") %>

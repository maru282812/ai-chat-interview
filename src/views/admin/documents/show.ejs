<%- include("../../partials/header", { title }) %>

<%
const TYPE_LABELS = {
  terms_of_service:        '利用規約',
  privacy_policy:          'プライバシーポリシー',
  survey_participation:    'アンケート参加規約',
  interview_participation: 'インタビュー参加規約',
  point_service:           'ポイント利用規約',
  data_usage:              'データ利用同意書',
  third_party_sharing:     '第三者提供同意書',
  campaign_terms:          'キャンペーン応募規約',
  project_specific:        '案件向け個別同意書',
};
%>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
  <div>
    <a href="/admin/documents" style="color:#60726f;font-size:13px">← 書類一覧</a>
    <h2 style="margin:4px 0 0"><%= document.title %></h2>
    <span style="font-size:12px;background:#f0f4f3;padding:2px 8px;border-radius:4px">
      <%= TYPE_LABELS[document.document_type] || document.document_type %>
    </span>
    <% if (!document.is_active) { %>
      <span style="font-size:12px;background:#fff0f0;color:#c00;padding:2px 8px;border-radius:4px;margin-left:4px">非公開</span>
    <% } %>
    <% if (document.is_required_global) { %>
      <span style="font-size:12px;background:#e8f5ef;color:#1a7a5a;padding:2px 8px;border-radius:4px;margin-left:4px">グローバル必須</span>
    <% } %>
  </div>
  <div style="display:flex;gap:8px">
    <a href="/admin/documents/<%= document.id %>/edit" class="button-link">✏️ 編集</a>
    <a href="/admin/documents/<%= document.id %>/versions/new" class="button-link" style="background:#1a7a5a;color:#fff">＋ 新バージョン</a>
  </div>
</div>

<% if (document.description) { %>
<p style="color:#60726f;margin-bottom:1.5rem"><%= document.description %></p>
<% } %>

<!-- 現在のバージョン本文 -->
<% if (document.current_version) { %>
<div class="card" style="margin-bottom:1.5rem">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <h3 style="margin:0">
      現在の版: <code>v<%= document.current_version.version_no %></code>
    </h3>
    <span style="font-size:12px;color:#60726f">
      <%= new Date(document.current_version.effective_from).toLocaleString('ja-JP') %> 〜
      <% if (document.current_version.effective_to) { %>
        <%= new Date(document.current_version.effective_to).toLocaleString('ja-JP') %>
      <% } else { %>
        現在
      <% } %>
    </span>
  </div>
  <% if (document.current_version.change_reason) { %>
    <p style="font-size:13px;color:#60726f;margin-bottom:12px">改定理由: <%= document.current_version.change_reason %></p>
  <% } %>

  <!-- 目次（見出し抽出） -->
  <%
    const headings = (document.current_version.content.match(/^#{1,3} .+/gm) || [])
      .map(h => {
        const level = h.match(/^#+/)[0].length;
        const text = h.replace(/^#+\s*/, '');
        return { level, text };
      });
  %>
  <% if (headings.length > 0) { %>
  <details style="margin-bottom:12px">
    <summary style="cursor:pointer;font-size:13px;color:#2ca87a;font-weight:600">目次を表示</summary>
    <ul style="margin:8px 0 0;padding-left:1.2em;font-size:13px">
      <% for (const h of headings) { %>
        <li style="margin-left:<%= (h.level - 1) * 1 %>em"><%= h.text %></li>
      <% } %>
    </ul>
  </details>
  <% } %>

  <div style="background:#f8faf9;border-radius:8px;padding:16px;max-height:520px;overflow-y:auto">
    <div id="current-document-render" class="document-markdown"></div>
    <details style="margin-top:14px">
      <summary style="cursor:pointer;font-size:13px;color:#60726f">Markdown原文を表示</summary>
      <pre style="white-space:pre-wrap;font-family:inherit;font-size:13px;line-height:1.7;margin:10px 0 0"><%= document.current_version.content %></pre>
    </details>
  </div>
  <script type="application/json" id="current-document-markdown"><%- JSON.stringify(document.current_version.content).replace(/</g, "\\u003c") %></script>
  <p style="font-size:12px;color:#999;margin-top:8px;text-align:right">
    作成者: <%= document.current_version.created_by %> |
    作成日時: <%= new Date(document.current_version.created_at).toLocaleString('ja-JP') %>
  </p>
</div>
<% } %>

<!-- バージョン履歴 -->
<h3>バージョン履歴</h3>
<table>
  <thead>
    <tr>
      <th>バージョン</th>
      <th>公開開始</th>
      <th>公開終了</th>
      <th>改定理由</th>
      <th>作成者</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% for (const v of versions) { %>
    <tr style="<%= v.id === document.current_version_id ? 'background:#f0faf5' : '' %>">
      <td>
        <code>v<%= v.version_no %></code>
        <% if (v.id === document.current_version_id) { %>
          <span style="font-size:11px;background:#2ca87a;color:#fff;padding:1px 6px;border-radius:4px;margin-left:4px">最新</span>
        <% } %>
      </td>
      <td><%= new Date(v.effective_from).toLocaleString('ja-JP') %></td>
      <td>
        <% if (v.effective_to) { %>
          <%= new Date(v.effective_to).toLocaleString('ja-JP') %>
        <% } else { %>
          <span style="color:#2ca87a">公開中</span>
        <% } %>
      </td>
      <td><%= v.change_reason || '—' %></td>
      <td><%= v.created_by %></td>
      <td>
        <button onclick="toggleContent('<%= v.id %>')" style="font-size:12px">本文を表示</button>
      </td>
    </tr>
    <tr id="content-<%= v.id %>" style="display:none">
      <td colspan="6">
        <div style="background:#f8faf9;padding:12px;border-radius:6px">
          <pre style="white-space:pre-wrap;font-size:12px;margin:0;line-height:1.6"><%= v.content %></pre>
        </div>
      </td>
    </tr>
    <% } %>
    <% if (versions.length === 0) { %>
    <tr><td colspan="6" style="text-align:center;color:#999">バージョンがありません</td></tr>
    <% } %>
  </tbody>
</table>

<div style="margin-top:1.5rem;display:flex;gap:12px">
  <a href="/admin/documents/<%= document.id %>/consent-audit" class="button-link">👥 同意者一覧を確認</a>
  <a href="/admin/documents/exports/consents.csv?document_id=<%= document.id %>" class="button-link" style="background:#555;color:#fff">📄 CSV出力</a>
</div>

<script src="/public/documentMarkdown.js"></script>
<script>
const currentDocumentMarkdown = document.getElementById('current-document-markdown');
const currentDocumentRender = document.getElementById('current-document-render');
if (currentDocumentMarkdown && currentDocumentRender) {
  currentDocumentRender.innerHTML = window.DocumentMarkdown.render(JSON.parse(currentDocumentMarkdown.textContent || '""'));
}

function toggleContent(id) {
  const row = document.getElementById('content-' + id);
  row.style.display = row.style.display === 'none' ? '' : 'none';
}
</script>

<%- include("../../partials/footer") %>

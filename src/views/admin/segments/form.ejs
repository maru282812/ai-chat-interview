<%- include("../../partials/header", { title }) %>
<h2><%= segment ? 'セグメント編集' : 'セグメント作成' %></h2>

<form method="post" action="<%= segment ? `/admin/segments/${segment.id}` : '/admin/segments' %>"
      style="max-width:700px">
  <div class="form-row">
    <label>セグメント名 <span class="required">*</span></label>
    <input type="text" name="name" value="<%= segment?.name ?? '' %>" required placeholder="例: 20代女性 東京在住" />
  </div>
  <div class="form-row">
    <label>説明</label>
    <input type="text" name="description" value="<%= segment?.description ?? '' %>" placeholder="任意のメモ" />
  </div>

  <div class="form-row">
    <label>絞り込み条件 (JSON)</label>
    <p class="muted" style="font-size:12px;margin-bottom:6px">
      {"operator":"AND","conditions":[{"field":"gender","op":"in","value":["female"]},{"field":"prefecture","op":"in","value":["東京都"]}]}
    </p>
    <textarea name="conditions" rows="8" style="font-family:monospace;font-size:12px;width:100%"><%= segment ? JSON.stringify(segment.conditions, null, 2) : JSON.stringify({operator:"AND",conditions:[]}, null, 2) %></textarea>
  </div>

  <div style="margin-top:1rem">
    <p class="muted" style="font-size:12px;margin-bottom:8px">
      対応フィールド: <code>gender</code>（op: in, value: ["male"/"female"]）,
      <code>prefecture</code>（op: in, value: ["東京都",...]）,
      <code>is_blocked</code>（op: eq, value: false）,
      <code>profile_completed</code>（op: eq, value: true）
    </p>
  </div>

  <div style="display:flex;gap:12px;margin-top:1.5rem">
    <button type="submit"><%= segment ? '更新' : '作成' %></button>
    <a href="/admin/segments">キャンセル</a>
  </div>
</form>
<%- include("../../partials/footer") %>

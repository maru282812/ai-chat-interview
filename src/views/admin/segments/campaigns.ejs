<%- include("../../partials/header", { title }) %>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
  <h2>配信キャンペーン</h2>
  <div style="display:flex;gap:8px">
    <a href="/admin/segments/campaigns/new" class="btn">＋ キャンペーン作成</a>
    <a href="/admin/segments" class="btn-secondary">← セグメント管理</a>
  </div>
</div>

<section>
  <table>
    <thead>
      <tr>
        <th>キャンペーン名</th>
        <th>プロジェクト</th>
        <th>セグメント</th>
        <th>ステータス</th>
        <th>配信予定日時</th>
        <th>送信数</th>
        <th style="text-align:center">開封</th>
        <th style="text-align:center">開始</th>
        <th style="text-align:center">完了</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% for (const c of campaigns) { %>
        <tr>
          <td><strong><%= c.name %></strong></td>
          <td><%= c.project?.name ?? '-' %></td>
          <td><%= c.segment?.name ?? '全回答者' %></td>
          <td>
            <% const statusLabel = { draft: '下書き', scheduled: '配信予定', sent: '送信済', cancelled: 'キャンセル' } %>
            <% const statusClass = { draft: '', scheduled: 'tag-blue', sent: 'tag-green', cancelled: 'tag-grey' } %>
            <span class="tag <%= statusClass[c.status] ?? '' %>"><%= statusLabel[c.status] ?? c.status %></span>
          </td>
          <td>
            <% if (c.scheduled_at) { %>
              <span class="muted"><%= new Date(c.scheduled_at).toLocaleString('ja-JP') %></span>
            <% } else { %>
              <span class="muted">-</span>
            <% } %>
          </td>
          <td><%= c.sent_count %></td>
          <td style="text-align:center">
            <%= c.opened_count %>
            <% if (c.sent_count > 0) { %>
              <span class="muted" style="font-size:11px">(<%= Math.round(c.opened_count/c.sent_count*100) %>%)</span>
            <% } %>
          </td>
          <td style="text-align:center">
            <%= c.started_count %>
            <% if (c.sent_count > 0) { %>
              <span class="muted" style="font-size:11px">(<%= Math.round(c.started_count/c.sent_count*100) %>%)</span>
            <% } %>
          </td>
          <td style="text-align:center">
            <%= c.completed_count %>
            <% if (c.sent_count > 0) { %>
              <span class="muted" style="font-size:11px">(<%= Math.round(c.completed_count/c.sent_count*100) %>%)</span>
            <% } %>
          </td>
          <td style="white-space:nowrap">
            <% if (c.status === 'draft' || c.status === 'scheduled') { %>
              <button class="btn-secondary" onclick="executeCampaign('<%= c.id %>', '<%= c.name %>')">今すぐ実行</button>
              <a href="/admin/segments/campaigns/<%= c.id %>/edit">編集</a>
              <form method="post" action="/admin/segments/campaigns/<%= c.id %>/cancel"
                    style="display:inline" onsubmit="return confirm('キャンセルしますか？')">
                <button type="submit" class="btn-danger">取消</button>
              </form>
            <% } else { %>
              <span class="muted">-</span>
            <% } %>
          </td>
        </tr>
      <% } %>
      <% if (campaigns.length === 0) { %>
        <tr><td colspan="10" class="muted" style="text-align:center">キャンペーンがありません</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<script>
async function executeCampaign(campaignId, name) {
  if (!confirm(`「${name}」を今すぐ実行しますか？\n対象者にプロジェクトがアサインされます。`)) return;
  const btn = event.target;
  btn.disabled = true;
  btn.textContent = '実行中...';
  try {
    const res = await fetch(`/admin/api/campaigns/${campaignId}/execute`, { method: 'POST' });
    const json = await res.json();
    if (json.ok) {
      alert(`配信完了: ${json.sent_count}件 アサインしました。`);
      location.reload();
    } else {
      alert('エラー: ' + (json.error ?? '不明なエラー'));
      btn.disabled = false;
      btn.textContent = '今すぐ実行';
    }
  } catch (e) {
    alert('実行に失敗しました');
    btn.disabled = false;
    btn.textContent = '今すぐ実行';
  }
}
</script>
<%- include("../../partials/footer") %>

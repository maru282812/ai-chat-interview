<%- include("../../partials/header", { title }) %>
<section class="grid">
  <div class="card">
    <h2><%= respondent.display_name || respondent.line_user_id %></h2>
    <p class="muted">Project: <%= project.name %></p>
    <p class="muted">Research mode: <%= project.research_mode %></p>
    <p>Status: <span class="tag"><%= respondent.status %></span></p>
    <p>Points: <strong><%= respondent.total_points %> pt</strong></p>
    <p>Rank: <strong><%= respondent.current_rank?.rank_name || "-" %></strong></p>
  </div>
  <form class="card" method="post" action="/admin/respondents/<%= respondent.id %>/points">
    <h2>Adjust Points</h2>
    <label>
      points
      <input type="number" name="points" value="10" />
    </label>
    <label>
      reason
      <input type="text" name="reason" value="manual adjustment" />
    </label>
    <button type="submit">Apply</button>
  </form>
</section>

<section class="stack" style="margin-top: 16px;">
  <div class="card">
    <h2>Sessions</h2>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Status</th>
          <th>Phase</th>
          <th>Started</th>
          <th>Completed</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% for (const session of sessions) { %>
          <tr>
            <td><code><%= session.id %></code></td>
            <td><span class="tag"><%= session.status %></span></td>
            <td><%= session.current_phase %></td>
            <td><%= session.started_at %></td>
            <td><%= session.completed_at || "-" %></td>
            <td><a href="/admin/sessions/<%= session.id %>">Session Detail</a></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Point Transactions</h2>
    <table>
      <thead>
        <tr>
          <th>At</th>
          <th>Type</th>
          <th>Points</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% for (const tx of transactions) { %>
          <tr>
            <td><%= tx.created_at %></td>
            <td><%= tx.transaction_type %></td>
            <td><%= tx.points %></td>
            <td><%= tx.reason %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include("../../partials/footer") %>

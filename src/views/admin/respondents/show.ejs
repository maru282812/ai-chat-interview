<%- include("../../partials/header", { title }) %>
<section class="grid">
  <div class="card">
    <h2><%= respondent.display_name || respondent.line_user_id %></h2>
    <p class="muted">Project: <%= project.name %></p>
    <p class="muted">Research mode: <%= project.research_mode %></p>
    <p>Status: <span class="tag"><%= respondent.status %></span></p>
    <p>Points: <strong><%= respondent.total_points %> pt</strong></p>
    <p>Rank: <strong><%= respondent.current_rank?.rank_name || "-" %></strong></p>
  </div>
  <form class="card" method="post" action="/admin/respondents/<%= respondent.id %>/points">
    <h2>Adjust Points</h2>
    <label>
      points
      <input type="number" name="points" value="10" />
    </label>
    <label>
      reason
      <input type="text" name="reason" value="manual adjustment" />
    </label>
    <button type="submit">Apply</button>
  </form>
</section>

<section class="stack" style="margin-top: 16px;">
  <div class="card">
    <h2>Sessions</h2>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Status</th>
          <th>Phase</th>
          <th>Started</th>
          <th>Completed</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% for (const session of sessions) { %>
          <tr>
            <td><code><%= session.id %></code></td>
            <td><span class="tag"><%= session.status %></span></td>
            <td><%= session.current_phase %></td>
            <td><%= session.started_at %></td>
            <td><%= session.completed_at || "-" %></td>
            <td><a href="/admin/sessions/<%= session.id %>">Session Detail</a></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Point Transactions</h2>
    <table>
      <thead>
        <tr>
          <th>At</th>
          <th>Type</th>
          <th>Points</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% for (const tx of transactions) { %>
          <tr>
            <td><%= tx.created_at %></td>
            <td><%= tx.transaction_type %></td>
            <td><%= tx.points %></td>
            <td><%= tx.reason %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>AI分析 <span class="muted" style="font-size:13px">Phase 2-C</span></h2>
    <p class="muted" style="font-size:13px">このユーザーの投稿履歴からAIタグとペルソナ要約を自動生成します。</p>
    <button id="gen-tags-btn" class="btn" onclick="generateAiTags()">AIタグ生成</button>
    <div id="gen-tags-result" style="margin-top:12px"></div>
  </div>
</section>

<script>
  async function generateAiTags() {
    const btn = document.getElementById("gen-tags-btn");
    const result = document.getElementById("gen-tags-result");
    btn.disabled = true;
    btn.textContent = "生成中...";
    result.innerHTML = "";
    try {
      const resp = await fetch("/admin/api/ai/generate-user-tags/<%= respondent.id %>", {
        method: "POST",
        headers: { "Content-Type": "application/json" }
      });
      const data = await resp.json();
      if (data.ok && data.result) {
        const tags = (data.result.tags || []).map(t => `<span style="background:#e0ede9;border-radius:12px;padding:2px 10px;font-size:13px;margin:2px;display:inline-block">${t}</span>`).join("");
        result.innerHTML = `
          <p style="font-size:13px;color:#2ca87a;font-weight:600">生成完了</p>
          <p style="font-size:13px">${data.result.persona_summary || ""}</p>
          <div style="margin-top:6px">${tags}</div>
        `;
      } else {
        result.innerHTML = `<p style="color:#e53e3e;font-size:13px">生成に失敗しました（投稿データが不足している可能性があります）</p>`;
      }
    } catch (e) {
      result.innerHTML = `<p style="color:#e53e3e;font-size:13px">エラー: ${e.message}</p>`;
    }
    btn.disabled = false;
    btn.textContent = "AIタグ生成";
  }
</script>
<%- include("../../partials/footer") %>

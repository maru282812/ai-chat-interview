<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
        background: #f0f4f3;
        min-height: 100vh;
      }
      .page-header {
        background: #fff;
        padding: 16px;
        border-bottom: 1px solid #e8eeec;
        position: sticky; top: 0; z-index: 10;
      }
      .page-header h1 { font-size: 17px; font-weight: 700; color: #1a2f2a; }

      .tab-bar {
        display: flex; gap: 0;
        background: #fff;
        border-bottom: 1px solid #e8eeec;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .tab-bar::-webkit-scrollbar { display: none; }
      .tab {
        flex-shrink: 0;
        padding: 10px 16px;
        font-size: 13px; font-weight: 600;
        color: #60726f;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        white-space: nowrap;
      }
      .tab.active { color: #2ca87a; border-bottom-color: #2ca87a; }

      .search-bar {
        padding: 10px 16px;
        background: #fff;
      }
      .search-input {
        width: 100%;
        padding: 9px 14px;
        border: 1px solid #d8e3e0; border-radius: 20px;
        font-size: 14px; color: #222;
        background: #f8faf9;
      }
      .search-input:focus { outline: none; border-color: #2ca87a; }

      .sort-bar {
        display: flex; justify-content: flex-end; align-items: center;
        padding: 8px 16px;
        font-size: 12px; color: #60726f; gap: 6px;
      }
      .sort-btn {
        background: none; border: 1px solid #d8e3e0;
        border-radius: 6px; padding: 4px 10px;
        font-size: 12px; cursor: pointer; color: #333;
      }

      .project-list { padding: 8px 16px; }
      .project-card {
        background: #fff;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,.06);
        cursor: pointer;
        position: relative;
      }
      .project-card:active { opacity: 0.85; }

      .card-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        margin-bottom: 8px;
      }
      .card-title {
        font-size: 15px; font-weight: 700; color: #1a2f2a;
        flex: 1; padding-right: 8px; line-height: 1.4;
      }
      .save-btn {
        background: none; border: none; cursor: pointer;
        font-size: 22px; line-height: 1; flex-shrink: 0;
        color: #ccc; padding: 0;
      }
      .save-btn.saved { color: #2ca87a; }

      .card-tags {
        display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;
      }
      .tag {
        font-size: 11px; font-weight: 600;
        padding: 3px 9px; border-radius: 20px;
      }
      .tag-new { background: #fff3e0; color: #c26d00; }
      .tag-cat { background: #e8f5ef; color: #1a7a5a; }
      .tag-type { background: #f0eef8; color: #5a3a9a; }

      .card-meta {
        display: flex; gap: 14px; font-size: 12px; color: #60726f;
      }
      .card-meta-item { display: flex; align-items: center; gap: 3px; }
      .card-reward {
        font-size: 16px; font-weight: 700; color: #2ca87a;
        margin-top: 10px;
      }

      .card-footer {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 10px;
        border-top: 1px solid #f0f4f3; padding-top: 10px;
      }
      .respondents-bar {
        flex: 1; max-width: 140px; margin-right: 12px;
      }
      .respondents-bar-track { background: #e0ede9; border-radius: 4px; height: 5px; }
      .respondents-bar-fill { background: #2ca87a; height: 100%; border-radius: 4px; }
      .respondents-label { font-size: 11px; color: #60726f; margin-top: 3px; }
      .deadline-label { font-size: 11px; color: #999; }

      .empty-state {
        text-align: center; padding: 60px 20px;
        color: #60726f; font-size: 14px;
      }
      .empty-state .icon { font-size: 40px; margin-bottom: 12px; }

      #loading-overlay {
        display: flex; justify-content: center; align-items: center;
        padding: 60px 20px;
      }
      .spinner {
        width: 28px; height: 28px;
        border: 3px solid #e0ede9; border-top-color: #2ca87a;
        border-radius: 50%; animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    <div class="page-header">
      <h1>案件を探す</h1>
    </div>

    <div class="tab-bar" id="tab-bar">
      <div class="tab active" data-cat="">すべて</div>
      <div class="tab" data-cat="生活系">生活系</div>
      <div class="tab" data-cat="仕事系">仕事系</div>
      <div class="tab" data-cat="子育て">子育て</div>
      <div class="tab" data-cat="健康">健康</div>
      <div class="tab" data-cat="趣味">趣味</div>
    </div>

    <div class="search-bar">
      <input class="search-input" type="search" id="search-input" placeholder="案件を検索..." />
    </div>

    <div class="sort-bar">
      <span>並び替え:</span>
      <button class="sort-btn active-sort" id="sort-new">新着順</button>
      <button class="sort-btn" id="sort-reward">謝礼順</button>
    </div>

    <div id="loading-overlay"><div class="spinner"></div></div>
    <div class="project-list" id="project-list" style="display:none"></div>

    <%- include('../partials/liff-bottom-nav', { active: 'projects' }) %>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      const d = JSON.parse(document.getElementById('initial-data').dataset.json || '{}');
      const { liffId, projectsDataUrl, projectDetailBaseUrl } = d;

      let idToken = null;
      let allProjects = [];
      let currentCat = '';
      let sortBy = 'new';
      let searchText = '';

      function esc(v) {
        return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
      }

      function daysAgo(iso) {
        if (!iso) return null;
        const diff = Date.now() - new Date(iso).getTime();
        return Math.floor(diff / 86400000);
      }

      function renderProjects(projects) {
        const listEl = document.getElementById('project-list');
        document.getElementById('loading-overlay').style.display = 'none';
        listEl.style.display = '';

        if (projects.length === 0) {
          listEl.innerHTML = `<div class="empty-state"><div class="icon">🔍</div><p>該当する案件がありません</p></div>`;
          return;
        }

        listEl.innerHTML = projects.map(p => {
          const isNew = (daysAgo(p.created_at) ?? 99) <= 3;
          const fillPct = p.max_respondents ? Math.min(100, Math.round(((p.completed_count ?? 0) / p.max_respondents) * 100)) : null;
          return `
            <div class="project-card" data-id="${esc(p.id)}">
              <div class="card-header">
                <div class="card-title">${esc(p.title)}</div>
                <button class="save-btn ${p.is_saved ? 'saved' : ''}" data-id="${esc(p.id)}" title="${p.is_saved ? '保存済み' : '保存'}">
                  ${p.is_saved ? '🔖' : '🏷️'}
                </button>
              </div>
              <div class="card-tags">
                ${isNew ? '<span class="tag tag-new">NEW</span>' : ''}
                ${p.category ? `<span class="tag tag-cat">${esc(p.category)}</span>` : ''}
              </div>
              <div class="card-meta">
                ${p.estimated_minutes ? `<span class="card-meta-item">⏱ 約${esc(String(p.estimated_minutes))}分</span>` : ''}
              </div>
              ${p.reward_points ? `<div class="card-reward">謝礼 ${p.reward_points.toLocaleString()}pt</div>` : ''}
              ${fillPct !== null ? `
              <div class="card-footer">
                <div class="respondents-bar">
                  <div class="respondents-bar-track"><div class="respondents-bar-fill" style="width:${fillPct}%"></div></div>
                  <div class="respondents-label">${fillPct}% 埋まっています</div>
                </div>
              </div>` : ''}
            </div>`;
        }).join('');

        listEl.querySelectorAll('.project-card').forEach(card => {
          card.addEventListener('click', e => {
            if (e.target.closest('.save-btn')) return;
            window.location.href = `${projectDetailBaseUrl}/${card.dataset.id}`;
          });
        });

        listEl.querySelectorAll('.save-btn').forEach(btn => {
          btn.addEventListener('click', async e => {
            e.stopPropagation();
            const projectId = btn.dataset.id;
            try {
              const res = await fetch(`/liff/projects/${projectId}/favorite`, {
                method: 'POST',
                headers: { Authorization: `Bearer ${idToken}` }
              });
              const json = await res.json();
              const saved = json.saved;
              btn.textContent = saved ? '🔖' : '🏷️';
              btn.className = `save-btn${saved ? ' saved' : ''}`;
              const proj = allProjects.find(p => p.id === projectId);
              if (proj) proj.is_saved = saved;
            } catch (err) {
              console.error('save failed', err);
            }
          });
        });
      }

      function applyFilters() {
        let list = allProjects;
        if (currentCat) list = list.filter(p => p.category === currentCat);
        if (searchText) {
          const q = searchText.toLowerCase();
          list = list.filter(p => p.title.toLowerCase().includes(q));
        }
        if (sortBy === 'reward') {
          list = [...list].sort((a, b) => (b.reward_points ?? 0) - (a.reward_points ?? 0));
        }
        renderProjects(list);
      }

      async function load() {
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return;
          idToken = token;

          const res = await fetch(projectsDataUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          const data = await res.json();
          allProjects = data.projects || [];
          applyFilters();
        } catch (err) {
          document.getElementById('loading-overlay').style.display = 'none';
          document.getElementById('project-list').style.display = '';
          document.getElementById('project-list').innerHTML = `<div class="empty-state"><div class="icon">⚠️</div><p>${esc(err.message || '読み込みに失敗しました')}</p></div>`;
        }
      }

      document.getElementById('tab-bar').addEventListener('click', e => {
        const tab = e.target.closest('.tab');
        if (!tab) return;
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentCat = tab.dataset.cat;
        applyFilters();
      });

      document.getElementById('search-input').addEventListener('input', e => {
        searchText = e.target.value.trim();
        applyFilters();
      });

      document.getElementById('sort-new').addEventListener('click', () => {
        sortBy = 'new';
        document.getElementById('sort-new').classList.add('active-sort');
        document.getElementById('sort-reward').classList.remove('active-sort');
        applyFilters();
      });
      document.getElementById('sort-reward').addEventListener('click', () => {
        sortBy = 'reward';
        document.getElementById('sort-reward').classList.add('active-sort');
        document.getElementById('sort-new').classList.remove('active-sort');
        applyFilters();
      });

      void load();
    })();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <link rel="stylesheet" href="/public/hibi.css" />
    <%# 体験設定（サーバー権威で解決済み・若年層体験パック Phase 0）。演出パーシャルより前に読み込む %>
    <%- include('../partials/experience-inject') %>
    <script src="/public/rank-icons.js"></script>
    <%# 昇格演出（共通パーシャル。rank-icons.js の後に読み込む） %>
    <%- include('../partials/rank-celebration') %>
    <%# 今日の1問（共通パーシャル。answer-ui もこの中で読み込まれる） %>
    <%- include('../partials/daily-today-card') %>
    <%# ついでスワイプ（脇役。AnswerUI は上の daily-today-card が読み込み済み） %>
    <%- include('../partials/pool-swipe-box') %>
    <%# 行動計測（HbTrack）。ナビのタップと案件一覧への到達を実データで取る %>
    <%- include('../partials/behavior-track') %>
    <style>
      /* 進捗ステータス帯（案B）。pt・ランク・今月の応募数を1行に畳む。
         以前は pt カード／今月の応募数／今日の1問が縦に3つ並び、いずれも「あなたの進捗」を
         訴えていたため視線が割れ、案件一覧が初期表示に入らなかった。ここを1行にして
         「回答 → 加算 → 次ランクが近づく」は保ったまま、一覧を画面内へ持ち上げる。 */
      .hb-pt {
        display: flex; align-items: center; gap: 10px;
        margin: 0; padding: 9px 16px;
        background: #fff; border-bottom: 1px solid #e2ece8;
        text-decoration: none; color: inherit;
      }
      .hb-pt .medal { font-size: 19px; flex-shrink: 0; line-height: 1; }
      .hb-pt .meat { flex: 1; min-width: 0; }
      .hb-pt .line1 { display: flex; align-items: baseline; gap: 3px; }
      .hb-pt .val { font-size: 17px; font-weight: 900; color: #14493a; line-height: 1.2; font-variant-numeric: tabular-nums; }
      .hb-pt .unit { font-size: 11px; font-weight: 800; color: #14493a; }
      .hb-pt .togo { margin-left: auto; font-size: 10.5px; color: #4d7a6b; white-space: nowrap; }
      .hb-pt .togo b { color: #1f8f66; font-weight: 800; }
      .hb-pt .bar {
        height: 5px; border-radius: 20px; background: #edf3f1;
        overflow: hidden; margin-top: 4px;
      }
      .hb-pt .bar i {
        display: block; height: 100%; border-radius: 20px;
        background: linear-gradient(90deg, #2ca87a, #1f8f66);
        transition: width .45s ease;
      }
      /* 現在地と行き先は文字でも読めるようにする（メダルの色・絵柄だけに意味を載せない）。 */
      .hb-pt .line2 {
        display: flex; align-items: baseline; gap: 8px;
        margin-top: 3px; font-size: 9.5px; font-weight: 700;
      }
      .hb-pt .line2 .cur { color: #14493a; }
      .hb-pt .line2 .nxt { color: #6b8c81; font-weight: 600; }
      .hb-pt .line2 .mon { margin-left: auto; color: #6b8c81; font-weight: 600; white-space: nowrap; }
      .hb-pt .line2 .mon b { color: #1f8f66; font-weight: 800; }
      .hb-pt .gain {
        display: inline-block; margin-left: 4px; font-size: 11px; font-weight: 800;
        color: #1f8f66; animation: hb-pt-pop 1.6s ease;
      }
      .hb-h .hb-h-ico { align-self: center; color: #1f8f66; flex-shrink: 0; }

      /* すきま時間に（案Q2）。電車の中など短時間で開いた人に、その場で終わる案件だけを
         横スクロールで差し出す。「探す」操作をさせずに目に入ることが狙いなので、
         チップでの絞り込みではなく常設の帯にする。該当0件なら帯ごと出さない。 */
      .hb-quick { padding: 6px 0 2px; }
      .hb-quick .rail {
        display: flex; gap: 10px; overflow-x: auto;
        padding: 6px 12px 12px; scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }
      .hb-quick .rail::-webkit-scrollbar { display: none; }
      .hb-quick .qcard {
        flex-shrink: 0; width: 150px; background: #fff;
        border: 1px solid #e2ece8; border-radius: 14px; padding: 12px;
        box-shadow: 0 2px 8px rgba(20,73,58,.06);
        text-decoration: none; color: inherit;
      }
      .hb-quick .qtop { display: flex; align-items: baseline; gap: 4px; }
      .hb-quick .qpt { font-size: 19px; font-weight: 900; color: var(--hb-teal); font-variant-numeric: tabular-nums; }
      .hb-quick .qunit { font-size: 10.5px; font-weight: 800; color: var(--hb-teal); }
      /* 所要時間は色でなく数字で伝える（色だけに意味を載せない）。 */
      .hb-quick .qmin {
        margin-left: auto; font-size: 10px; font-weight: 800; color: #fff;
        background: var(--hb-teal); padding: 2px 7px; border-radius: 20px; white-space: nowrap;
      }
      .hb-quick .qttl {
        font-size: 12px; font-weight: 700; line-height: 1.45; margin-top: 7px;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
      }

      @keyframes hb-pt-pop {
        0% { opacity: 0; transform: translateY(6px); }
        20% { opacity: 1; transform: translateY(0); }
        80% { opacity: 1; }
        100% { opacity: 0; }
      }
    </style>
  </head>
  <body class="hibi" data-track-page="projects">
    <div class="hb-shell">
      <header class="hb-appbar">
        <span class="hb-logo">Hibi</span>
        <input class="hb-search" id="search-input" placeholder="キーワードで探す" />
      </header>

      <a class="hb-pt" id="point-card" href="#" style="display:none"></a>

      <nav class="hb-chips" id="chip-bar">
        <button class="hb-chip on" data-filter="all">すべて</button>
        <button class="hb-chip" data-filter="cat:生活系" data-category="life">生活系</button>
        <button class="hb-chip" data-filter="cat:仕事系" data-category="work">仕事系</button>
        <button class="hb-chip" data-filter="instant" data-category="urgent">即回答OK</button>
      </nav>

      <div id="daily-area"></div>
      <div id="pool-swipe-area"></div>
      <div id="quick-area"></div>
      <div id="pick-area"></div>
      <div class="hb-h" id="list-head" style="display:none">
        <svg class="hb-h-ico" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v9"/><path d="M8 8l4 4 4-4"/><path d="M3 14v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4h-5l-1.4 2h-5.2L8 14z"/></svg>
        <span>案件一覧</span>
      </div>

      <div class="hb-loading" id="loading-overlay">読み込み中…</div>
      <main class="hb-cards" id="project-list" style="display:none"></main>

      <button class="hb-fab" id="sort-fab">⇅ 新着順</button>

      <%- include('../partials/liff-bottom-nav', { active: 'projects' }) %>
    </div>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      'use strict';
      const d = JSON.parse(document.getElementById('initial-data').dataset.json || '{}');
      const { liffId, projectsDataUrl, projectDetailBaseUrl } = d;

      let idToken = null;
      let allProjects = [];
      let filter = 'all';
      let searchText = '';
      // 直近描画したランク状態。回答確定後に旧→新を比べて昇格演出を出すために保持する。
      let lastPointStatus = null;
      const SORTS = [
        { key: 'new',      label: '⇅ 新着順' },
        { key: 'reward',   label: '⇅ 報酬が高い順' },
        { key: 'deadline', label: '⇅ 締切が近い順' },
      ];
      let sortIdx = 0;

      function esc(v) {
        return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
      }
      function daysAgo(iso) {
        if (!iso) return null;
        return Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
      }
      function daysLeft(iso) {
        if (!iso) return null;
        const dd = Math.ceil((new Date(iso).getTime() - Date.now()) / 86400000);
        return dd < 0 ? null : dd;
      }
      function fmtBadges(p) {
        const isNew = (daysAgo(p.created_at) ?? 99) <= 3;
        const isAuto = p.apply_mode === 'auto';
        const applied = !!p.application_status && p.application_status !== 'withdrawn';
        const badges = [];
        if (applied) badges.push('<span class="hb-badge done">応募済み</span>');
        if (isNew) badges.push('<span class="hb-badge new">新着</span>');
        badges.push(isAuto
          ? '<span class="hb-badge ai">AIインタビュー</span>'
          : '<span class="hb-badge fmt">' + esc(p.interview_format || 'インタビュー（選考あり）') + '</span>');
        (p.tags || []).slice(0, 2).forEach(t => badges.push('<span class="hb-badge fmt">#' + esc(t) + '</span>'));
        return badges.join('');
      }

      function renderPick(p) {
        const area = document.getElementById('pick-area');
        if (!p) { area.innerHTML = ''; return; }
        area.innerHTML = `
          <a class="hb-pick" href="${esc(projectDetailBaseUrl)}/${esc(p.id)}">
            <span class="lbl">✨ 注目の案件</span>
            <h3>${esc(p.title)}</h3>
            <div class="foot">
              <span class="price">${(p.reward_points ?? 0).toLocaleString()}<small>pt${p.estimated_minutes ? '｜' + esc(String(p.estimated_minutes)) + '分' : ''}</small></span>
              <span class="go">見る ›</span>
            </div>
          </a>`;
      }

      // すきま時間枠の抽出規則。src/lib/quickPickSelection.ts と同じ規則をブラウザ側でも持つ
      // （テストは純関数側にある。ここを変えるときは向こうも直す）。
      // ⚠ estimated_minutes が未設定の案件は絶対に入れない。「3分で終わるはずが終わらない」が
      //    最も信頼を損なうため、「短いと分かっているもの」だけを枠に入れる。
      const QUICK_MAX_MIN = 5;
      const QUICK_LIMIT = 8;
      function isQuickPick(p) {
        const m = p.estimated_minutes;
        return typeof m === 'number' && Number.isFinite(m) && m > 0 && m <= QUICK_MAX_MIN;
      }
      function selectQuickPicks(list) {
        return list
          .filter(isQuickPick)
          .sort((a, b) => {
            const d = (a.estimated_minutes ?? 0) - (b.estimated_minutes ?? 0);
            return d !== 0 ? d : (b.reward_points ?? 0) - (a.reward_points ?? 0);
          })
          .slice(0, QUICK_LIMIT);
      }

      /**
       * 「すきま時間に」帯を描く。該当0件なら帯ごと消す
       * （見出しだけ残すと空虚に見えるため、セクションごと空にする）。
       */
      function renderQuickPicks(list) {
        const area = document.getElementById('quick-area');
        if (!area) return;
        const picks = selectQuickPicks(list);
        if (picks.length === 0) { area.innerHTML = ''; return; }

        area.innerHTML = `
          <section class="hb-quick">
            <div class="hb-h">
              <svg class="hb-h-ico" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              <span>すきま時間に</span>
              <span class="why">${QUICK_MAX_MIN}分以内 · ${picks.length}件</span>
            </div>
            <div class="rail">
              ${picks.map(p => `
                <a class="qcard" href="${esc(projectDetailBaseUrl)}/${esc(p.id)}" data-quick-id="${esc(p.id)}">
                  <div class="qtop">
                    <span class="qpt">${(p.reward_points ?? 0).toLocaleString()}</span>
                    <span class="qunit">pt</span>
                    <span class="qmin">${esc(String(p.estimated_minutes))}分</span>
                  </div>
                  <div class="qttl">${esc(p.title)}</div>
                </a>`).join('')}
            </div>
          </section>`;

        // すきま帯からの流入を一覧タップと区別できるよう接頭辞を付けて計測する。
        area.querySelectorAll('[data-quick-id]').forEach(el => {
          el.addEventListener('click', () => {
            if (window.HbTrack) {
              window.HbTrack.push('card_tap', 'quick:' + el.dataset.quickId, null);
              window.HbTrack.flush();
            }
          });
        });
      }

      function renderProjects(list) {
        const listEl = document.getElementById('project-list');
        document.getElementById('loading-overlay').style.display = 'none';
        listEl.style.display = '';
        document.getElementById('list-head').style.display = '';

        if (list.length === 0) {
          listEl.innerHTML = '<div class="hb-empty"><div class="icon">🔍</div><p>該当する案件がありません</p></div>';
          return;
        }

        listEl.innerHTML = list.map(p => {
          const left = daysLeft(p.recruit_deadline);
          const isAuto = p.apply_mode === 'auto';
          return `
            <article class="hb-card" data-id="${esc(p.id)}">
              <div class="pt ${isAuto ? 'hot' : ''}">
                <small>${isAuto ? '⚡即回答' : '謝礼'}</small>
                <b>${(p.reward_points ?? 0).toLocaleString()}<small>pt</small></b>
                ${p.estimated_minutes ? `<div class="min">⏱ ${esc(String(p.estimated_minutes))}分</div>` : ''}
              </div>
              <div class="body">
                <h3>${esc(p.title)}</h3>
                <div class="hb-meta">${fmtBadges(p)}</div>
                <div class="hb-foot">
                  ${left !== null ? `<span class="days">あと<b>${left}</b>日</span>` : ''}
                  <button class="hb-save ${p.is_saved ? 'saved' : ''}" data-id="${esc(p.id)}">${p.is_saved ? '★ 保存済' : '☆ 保存'}</button>
                </div>
              </div>
            </article>`;
        }).join('');

        // 案件一覧の見出しに到達したかを1度だけ記録する。
        // 「進捗ブロックが多すぎて一覧まで届いていないのでは」を実データで検証するための計測
        // （value_num にその時点のスクロール量が入るので、どれだけ下げて着いたかも残る）。
        if (window.HbTrack) {
          window.HbTrack.observeReach(document.getElementById('list-head'), 'list_reach', 'project_list');
        }

        listEl.querySelectorAll('.hb-card').forEach(card => {
          card.addEventListener('click', e => {
            if (e.target.closest('.hb-save')) return;
            if (window.HbTrack) {
              window.HbTrack.push('card_tap', card.dataset.id, null);
              window.HbTrack.flush();
            }
            window.location.href = `${projectDetailBaseUrl}/${card.dataset.id}`;
          });
        });
        listEl.querySelectorAll('.hb-save').forEach(btn => {
          btn.addEventListener('click', async e => {
            e.stopPropagation();
            const projectId = btn.dataset.id;
            try {
              const res = await fetch(`/liff/projects/${projectId}/favorite`, {
                method: 'POST',
                headers: { Authorization: `Bearer ${idToken}` }
              });
              const json = await res.json();
              btn.textContent = json.saved ? '★ 保存済' : '☆ 保存';
              btn.className = `hb-save${json.saved ? ' saved' : ''}`;
              const proj = allProjects.find(p => p.id === projectId);
              if (proj) proj.is_saved = json.saved;
              // 保存が実際に使われているかの実データ。ボトムナビから保存タブを外してよいかの根拠になる
              // （value_num: 1=保存した / 0=解除した）。
              if (window.HbTrack) window.HbTrack.push('save_toggle', projectId, json.saved ? 1 : 0);
            } catch (err) { console.error('save failed', err); }
          });
        });
      }

      function applyFilters() {
        let list = allProjects;
        if (filter.startsWith('cat:')) {
          const cat = filter.slice(4);
          list = list.filter(p => p.category === cat);
        } else if (filter === 'instant') {
          list = list.filter(p => p.apply_mode === 'auto');
        }
        if (searchText) {
          const q = searchText.toLowerCase();
          list = list.filter(p =>
            String(p.title).toLowerCase().includes(q) ||
            (p.tags || []).some(t => String(t).toLowerCase().includes(q)));
        }
        const sort = SORTS[sortIdx].key;
        if (sort === 'reward') list = [...list].sort((a, b) => (b.reward_points ?? 0) - (a.reward_points ?? 0));
        if (sort === 'deadline') list = [...list].sort((a, b) => {
          const at = a.recruit_deadline ? new Date(a.recruit_deadline).getTime() : Infinity;
          const bt = b.recruit_deadline ? new Date(b.recruit_deadline).getTime() : Infinity;
          return at - bt;
        });
        // すきま時間帯は「いま絞り込んでいる結果」の中から出す。
        // 検索・カテゴリを当てた状態で無関係な案件が横帯に残ると、絞り込んだ意味が消えるため。
        renderQuickPicks(list);

        // 先頭1件をヒーローに、残りをリストに（1件しかない場合はヒーローのみ）
        renderPick(list[0] ?? null);
        renderProjects(list.slice(1));
      }

      // ランクを表すメダル。ranks.badge_label は環境で絵文字/英字と不一致なので、
      // 表示用メダルは rank_code / rank_name から決め打ちする（データに依存させない）。
      // 順序: … → プラチナ → エメラルド → ダイヤモンド → マスター（migration 081）
      const RANK_MEDAL = { bronze: '🥉', silver: '🥈', gold: '🥇', platinum: '💠', emerald: '💚', diamond: '💎', master: '👑' };
      const RANK_MEDAL_JP = { 'ブロンズ': '🥉', 'シルバー': '🥈', 'ゴールド': '🥇', 'プラチナ': '💠', 'エメラルド': '💚', 'ダイヤモンド': '💎', 'マスター': '👑' };
      function rankMedal(name, code) {
        return RANK_MEDAL_JP[name] || RANK_MEDAL[String(code || '').toLowerCase()] || '🏅';
      }

      const TIER_ROMAN = { 1: 'I', 2: 'II', 3: 'III' };

      /**
       * 現在の段位 → 次の段位 の「旅路」バー。
       * 左端メダル＝今のランク／右端メダル＝次の目標（同ランク次段位 or 昇格先ランク）。
       * 段位フィールド（Phase 2）が来ていればそれを、無ければ旧ランクベースにフォールバックする。
       * gained を渡すと「+15pt」を一瞬出す（デイリー回答直後の加算を見せるため）。
       */
      function renderPointCard(status, gained) {
        const el = document.getElementById('point-card');
        if (!el || !status) return;
        lastPointStatus = status;

        const rankName = status.rank_name || 'ブロンズ';
        const tier = status.tier || null;
        // SVG アイコン（rank-icons.js）。読み込み前や rank_code 不明時は絵文字にフォールバック。
        const ICON_SIZE = 42;
        const medalOf = (code, name, t) =>
          (window.RankIcons && code) ? RankIcons.badge(code, t || 1, ICON_SIZE) : rankMedal(name, code);
        const curMedal = medalOf(status.rank_code, rankName, tier || 1);
        const curLabel = tier ? `${esc(rankName)} ${TIER_ROMAN[tier]}` : esc(rankName);
        const gainTag = gained > 0 ? `<span class="gain">+${esc(String(gained))}pt</span>` : '';

        let fill, nextMedal, nextName, togo;
        const hasTier = tier != null && status.tier_progress_pct != null;
        if (hasTier) {
          // ── 段位ベース（Phase 2）──
          if (status.points_to_next_tier == null) {
            // 最上位ランクの最上位段位（上限なし）
            fill = 100; nextMedal = '🏆'; nextName = '最上位';
            togo = `<b>最上位に到達しています 🎉</b>`;
          } else {
            const tpct = Math.max(0, Math.min(100, Number(status.tier_progress_pct) || 0));
            fill = tpct > 0 ? Math.max(tpct, 4) : 0;
            if (status.next_tier_promotes && status.next_rank_code) {
              nextMedal = medalOf(status.next_rank_code, status.next_rank_name, 1);
              nextName = `${esc(status.next_rank_name)} I`;
            } else {
              nextMedal = medalOf(status.rank_code, rankName, tier + 1);
              nextName = `${esc(rankName)} ${TIER_ROMAN[tier + 1] || ''}`;
            }
            togo = `次の段位まで <b>あと ${esc(String(status.points_to_next_tier))}pt</b>`;
          }
        } else {
          // ── フォールバック（旧・ランクベース）──
          const pct = Math.max(0, Math.min(100, Number(status.progress_pct) || 0));
          fill = pct > 0 ? Math.max(pct, 4) : 0;
          const hasNext = status.next_rank_name && status.points_to_next != null;
          nextMedal = hasNext ? medalOf(status.next_rank_code, status.next_rank_name, 1) : '🏆';
          nextName = hasNext ? esc(status.next_rank_name) : '最上位';
          togo = hasNext
            ? `次のランクまで <b>あと ${esc(String(status.points_to_next))}pt</b>`
            : `<b>最上位ランクに到達しています 🎉</b>`;
        }

        el.href = d.mypageUrl || '#';
        // 初期 style="display:none" を外す。CSS 側の flex を効かせるため空文字で戻す
        // （'block' を入れると1行レイアウトが崩れる）。
        el.style.display = '';
        // 1行のステータス帯（案B）。以前は pt カードと「今月の応募数」が別々の大きなブロックで、
        // 「あなたの進捗」を訴える要素が3つ縦に並び、案件一覧が初期表示に入らなかった。
        // ここに pt・ランク・今月の応募数を畳んで、一覧を画面内へ持ち上げる。
        el.innerHTML = `
          <span class="medal">${curMedal}</span>
          <div class="meat">
            <div class="line1">
              <span class="val">${esc(String(status.available_points ?? 0))}</span><span class="unit">pt</span>${gainTag}
              <span class="togo">${togo}</span>
            </div>
            <div class="bar"><i style="width:${fill}%"></i></div>
            <div class="line2">
              <span class="cur">${curLabel}</span>
              <span class="nxt">次: ${nextMedal} ${nextName}</span>
              <span class="mon" id="monthly-inline"></span>
            </div>
          </div>`;
        renderMonthlyInline();
      }

      // 今月の応募数。旧 .hb-progress ブロックの中身を1行帯の中に畳んだもの
      // （数字は残すが、独立したブロックとしては主張させない）。
      let monthlyState = { count: 0, reco: 10 };
      function renderMonthlyInline() {
        const el = document.getElementById('monthly-inline');
        if (!el) return;
        el.innerHTML = `今月 <b>${monthlyState.count}</b>/${monthlyState.reco}件`;
      }

      async function load() {
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return;
          idToken = token;

          // 今日の1問は案件一覧の表示をブロックしない（失敗してもカードを出さないだけ）。
          // 回答が確定したら、上のポイントカードを付与後の値に差し替える。
          // 回答確定時にポイントカードを付与後の値へ差し替え＋昇格演出を通す共通処理。
          const onPointGained = (result) => {
            const gained = (result.pointsAwarded ?? 0) + (result.streakBonusAwarded ?? 0);
            // 昇格判定は「回答前の状態(prev)」と「付与後の状態(result.pointStatus)」で行う。
            // renderPointCard が lastPointStatus を上書きするので、その前に prev を退避する。
            const prev = lastPointStatus;
            renderPointCard(result.pointStatus, gained);
            try {
              if (window.RankCelebration) RankCelebration.maybePlay(prev, result.pointStatus);
            } catch (e) { console.error('rank celebration failed', e); }
          };

          // 「回答する」タブのバッジ（いま回答できる件数）。一覧表示はブロックしない。
          if (window.LiffNavBadge) LiffNavBadge.refresh(idToken);

          DailyToday.mount({ idToken, url: d.dailyTodayUrl, onAnswered: onPointGained });

          // ついでスワイプ（脇役）。今日の1問と同じく一覧表示はブロックしない。
          // プール回答でも累計ptは動くので同じ onAnswered を通す。
          if (window.PoolSwipe) {
            PoolSwipe.mount({ idToken, url: d.poolQuestionsTodayUrl, onAnswered: onPointGained });
          }

          const _fetchStart = performance.now();
          const res = await fetch(projectsDataUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          const data = await res.json();
          const _dataMs = performance.now() - _fetchStart;
          allProjects = data.projects || [];

          // 今月の応募数はステータス帯の中に畳んで出すので、描画前に値を入れておく
          // （renderPointCard が帯ごと組み立て直すため、順序が逆だと反映されない）。
          const monthly = data.monthly_applications;
          if (monthly) {
            monthlyState = { count: monthly.count, reco: monthly.recommended };
          }
          renderPointCard(data.point_status, 0);
          const _renderStart = performance.now();
          applyFilters();
          try { LiffAuth.reportPerf('/liff/projects', { dataMs: _dataMs, renderMs: performance.now() - _renderStart }); } catch (_e) {}
        } catch (err) {
          document.getElementById('loading-overlay').style.display = 'none';
          const listEl = document.getElementById('project-list');
          listEl.style.display = '';
          listEl.innerHTML = `<div class="hb-empty"><div class="icon">⚠️</div><p>${esc(err.message || '読み込みに失敗しました')}</p></div>`;
        }
      }

      document.getElementById('chip-bar').addEventListener('click', e => {
        const chip = e.target.closest('.hb-chip');
        if (!chip) return;
        document.querySelectorAll('.hb-chip').forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
        filter = chip.dataset.filter;
        applyFilters();
      });
      document.getElementById('search-input').addEventListener('input', e => {
        searchText = e.target.value.trim();
        applyFilters();
      });
      document.getElementById('sort-fab').addEventListener('click', () => {
        sortIdx = (sortIdx + 1) % SORTS.length;
        document.getElementById('sort-fab').textContent = SORTS[sortIdx].label;
        applyFilters();
      });

      void load();
    })();
    </script>
  </body>
</html>

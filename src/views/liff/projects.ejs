<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <link rel="stylesheet" href="/public/hibi.css" />
    <style>
      /* 今日の1問（案件一覧の最上部・その場で回答して完結する。ページ遷移させない） */
      .hb-daily {
        background: linear-gradient(135deg, #2ca87a, #1f8f66);
        color: #fff; border-radius: 16px;
        padding: 14px 16px; margin: 10px 12px 4px;
        box-shadow: 0 4px 14px rgba(44,168,122,.28);
      }
      .hb-daily .head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
      .hb-daily .lbl { font-size: 12px; font-weight: 800; letter-spacing: .04em; opacity: .95; }
      .hb-daily .pt {
        background: rgba(255,255,255,.22); border-radius: 20px;
        padding: 3px 10px; font-size: 12px; font-weight: 800;
      }
      .hb-daily .q { font-size: 16px; font-weight: 800; line-height: 1.5; margin-bottom: 10px; }
      .hb-daily .opts { display: flex; flex-wrap: wrap; gap: 8px; }
      .hb-daily .opt {
        flex: 1 1 calc(50% - 8px); min-width: 0;
        background: rgba(255,255,255,.96); color: #14493a;
        border: none; border-radius: 12px;
        padding: 13px 10px; font-size: 15px; font-weight: 700;
        cursor: pointer; transition: transform .1s, background .15s;
        -webkit-tap-highlight-color: transparent;
      }
      .hb-daily .opt:active { transform: scale(.96); }
      .hb-daily .opt.on { background: #14493a; color: #fff; box-shadow: inset 0 0 0 2px #fff; }
      /* スケールは横一列に詰める */
      .hb-daily .opts.scale .opt { flex: 1 1 0; padding: 13px 4px; font-size: 16px; }
      .hb-daily textarea {
        width: 100%; border: none; border-radius: 12px;
        padding: 11px 12px; font-size: 15px; color: #14493a;
        min-height: 74px; resize: vertical; font-family: inherit;
      }
      .hb-daily .send {
        width: 100%; margin-top: 8px;
        background: #14493a; color: #fff; border: none; border-radius: 12px;
        padding: 13px; font-size: 15px; font-weight: 800; cursor: pointer;
      }
      .hb-daily .send:disabled { opacity: .5; }
      .hb-daily .step { font-size: 11px; opacity: .8; margin-top: 8px; text-align: right; }
      .hb-daily .msg { font-size: 12px; margin-top: 8px; min-height: 15px; }

      /* 回答後（消さずに実績として見せる） */
      .hb-daily.done {
        background: #eef7f3; color: #14493a;
        box-shadow: none; border: 1px solid #cfe6dc;
        display: flex; align-items: center; gap: 10px;
      }
      .hb-daily.done .icon { font-size: 22px; }
      .hb-daily.done .t { font-size: 14px; font-weight: 800; }
      .hb-daily.done .s { font-size: 12px; color: #4d7a6b; margin-top: 2px; }
      .hb-daily.done .rewards { margin-left: auto; text-align: right; }
      .hb-daily.done .rewards b { font-size: 17px; font-weight: 900; color: #1f8f66; }
    </style>
  </head>
  <body class="hibi">
    <div class="hb-shell">
      <header class="hb-appbar">
        <span class="hb-logo">Hibi</span>
        <input class="hb-search" id="search-input" placeholder="キーワードで探す" />
      </header>

      <nav class="hb-chips" id="chip-bar">
        <button class="hb-chip on" data-filter="all">すべて</button>
        <button class="hb-chip" data-filter="cat:生活系">🍚 生活系</button>
        <button class="hb-chip" data-filter="cat:仕事系">💼 仕事系</button>
        <button class="hb-chip" data-filter="instant">⚡ 即回答OK</button>
      </nav>

      <section class="hb-progress" id="progress" style="display:none">
        <div class="row"><span>💡 今月の応募数</span><span class="num"><b id="monthly-count">0</b><small> /<span id="monthly-reco">10</span>件</small></span></div>
        <div class="bar"><i id="monthly-bar" style="width:0%"></i></div>
      </section>

      <div id="daily-area"></div>
      <div id="pick-area"></div>
      <div class="hb-h" id="list-head" style="display:none">🆕 新着の案件</div>

      <div class="hb-loading" id="loading-overlay">読み込み中…</div>
      <main class="hb-cards" id="project-list" style="display:none"></main>

      <button class="hb-fab" id="sort-fab">⇅ 新着順</button>

      <nav class="hb-bottomnav">
        <a class="on" href="#"><span class="i">🔍</span>探す</a>
        <a id="nav-saved" href="#"><span class="i">☆</span>保存</a>
        <a id="nav-interactions" href="#"><span class="i">📋</span>やりとり</a>
        <a id="nav-mypage" href="#"><span class="i">👤</span>マイページ</a>
      </nav>
    </div>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      'use strict';
      const d = JSON.parse(document.getElementById('initial-data').dataset.json || '{}');
      const { liffId, projectsDataUrl, projectDetailBaseUrl } = d;
      document.getElementById('nav-saved').href = d.savedProjectsUrl || '#';
      document.getElementById('nav-interactions').href = d.interactionsUrl || '#';
      document.getElementById('nav-mypage').href = d.mypageUrl || '#';

      let idToken = null;
      let allProjects = [];
      let filter = 'all';
      let searchText = '';
      const SORTS = [
        { key: 'new',      label: '⇅ 新着順' },
        { key: 'reward',   label: '⇅ 報酬が高い順' },
        { key: 'deadline', label: '⇅ 締切が近い順' },
      ];
      let sortIdx = 0;

      function esc(v) {
        return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
      }
      function daysAgo(iso) {
        if (!iso) return null;
        return Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
      }
      function daysLeft(iso) {
        if (!iso) return null;
        const dd = Math.ceil((new Date(iso).getTime() - Date.now()) / 86400000);
        return dd < 0 ? null : dd;
      }
      function fmtBadges(p) {
        const isNew = (daysAgo(p.created_at) ?? 99) <= 3;
        const isAuto = p.apply_mode === 'auto';
        const applied = !!p.application_status && p.application_status !== 'withdrawn';
        const badges = [];
        if (applied) badges.push('<span class="hb-badge done">応募済み</span>');
        if (isNew) badges.push('<span class="hb-badge new">新着</span>');
        badges.push(isAuto
          ? '<span class="hb-badge ai">AIインタビュー</span>'
          : '<span class="hb-badge fmt">' + esc(p.interview_format || 'インタビュー（選考あり）') + '</span>');
        (p.tags || []).slice(0, 2).forEach(t => badges.push('<span class="hb-badge fmt">#' + esc(t) + '</span>'));
        return badges.join('');
      }

      function renderPick(p) {
        const area = document.getElementById('pick-area');
        if (!p) { area.innerHTML = ''; return; }
        area.innerHTML = `
          <a class="hb-pick" href="${esc(projectDetailBaseUrl)}/${esc(p.id)}">
            <span class="lbl">✨ 注目の案件</span>
            <h3>${esc(p.title)}</h3>
            <div class="foot">
              <span class="price">${(p.reward_points ?? 0).toLocaleString()}<small>pt${p.estimated_minutes ? '｜' + esc(String(p.estimated_minutes)) + '分' : ''}</small></span>
              <span class="go">見る ›</span>
            </div>
          </a>`;
      }

      // ─────────────────────────────────────────────────────────────
      // 今日の1問（その場で回答して完結する。案件詳細へは遷移させない）
      // ─────────────────────────────────────────────────────────────
      const dailyArea = document.getElementById('daily-area');

      function rewardLabel(s) {
        return s.reward_type === 'fixed'
          ? `+${s.reward_points}pt`
          : `+${s.reward_min_points}〜${s.reward_max_points}pt`;
      }

      /** 1件ぶんのカード。設問を1問ずつ進め、最後の回答で送信する。 */
      function mountDailyCard(item, slotEl) {
        const { survey, questions, delivery, answerUrl } = item;
        const answers = {};
        let idx = 0;

        function done(result) {
          const r = result || {};
          const bonus = r.streakBonusAwarded ? ` (+${r.streakBonusAwarded}pt ボーナス)` : '';
          slotEl.className = 'hb-daily done';
          slotEl.innerHTML = `
            <div class="icon">✅</div>
            <div>
              <div class="t">今日の1問に回答しました</div>
              <div class="s">${r.currentStreak ? esc(String(r.currentStreak)) + '日連続' : 'また明日'}${esc(bonus)}</div>
            </div>
            <div class="rewards"><b>+${esc(String(r.pointsAwarded ?? 0))}</b><small>pt</small></div>`;
        }

        async function submit() {
          const msg = slotEl.querySelector('.msg');
          if (msg) msg.textContent = '送信中…';
          try {
            const res = await fetch(answerUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${idToken}` },
              body: JSON.stringify({
                deliveryId: delivery.id,
                answers: Object.entries(answers).map(([questionId, answerValue]) => ({ questionId, answerValue }))
              })
            });
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.error || '送信に失敗しました');
            }
            done(await res.json());
          } catch (err) {
            if (msg) msg.textContent = err.message || '送信に失敗しました';
          }
        }

        /** 1問ぶんの回答が確定したら次へ。最後なら送信。 */
        function commit(value) {
          answers[questions[idx].id] = value;
          if (idx < questions.length - 1) { idx++; render(); }
          else submit();
        }

        function render() {
          const q = questions[idx];
          const opts = (q.answer_options || []).length
            ? q.answer_options
            : (q.question_type === 'scale' ? [1,2,3,4,5].map(n => ({ label: String(n), value: String(n) })) : []);
          const step = questions.length > 1 ? `<div class="step">${idx + 1} / ${questions.length}</div>` : '';

          let body = '';
          if (q.question_type === 'text') {
            body = `<textarea class="txt" placeholder="ひとことどうぞ"></textarea>
                    <button class="send">送信する</button>`;
          } else if (q.question_type === 'multiple_choice') {
            body = `<div class="opts">${opts.map(o =>
                      `<button class="opt" data-val="${esc(o.value)}">${esc(o.label)}</button>`).join('')}</div>
                    <button class="send" disabled>選んで送信</button>`;
          } else {
            // single_choice / scale はタップした瞬間に確定する（確定ボタンを挟まない）
            const scaleClass = q.question_type === 'scale' ? ' scale' : '';
            body = `<div class="opts${scaleClass}">${opts.map(o =>
                      `<button class="opt" data-val="${esc(o.value)}">${esc(o.label)}</button>`).join('')}</div>`;
          }

          slotEl.className = 'hb-daily';
          slotEl.innerHTML = `
            <div class="head">
              <span class="lbl">☀️ 今日の1問</span>
              <span class="pt">${esc(rewardLabel(survey))}</span>
            </div>
            <p class="q">${esc(q.question_text)}</p>
            ${body}
            ${step}
            <p class="msg"></p>`;

          wire(q);
        }

        function wire(q) {
          const optEls = [...slotEl.querySelectorAll('.opt')];
          const sendEl = slotEl.querySelector('.send');
          const txtEl = slotEl.querySelector('.txt');

          if (q.question_type === 'multiple_choice') {
            const picked = new Set();
            optEls.forEach(el => el.addEventListener('click', () => {
              const v = el.dataset.val;
              if (picked.has(v)) { picked.delete(v); el.classList.remove('on'); }
              else { picked.add(v); el.classList.add('on'); }
              sendEl.disabled = picked.size === 0;
              sendEl.textContent = picked.size ? `${picked.size}件で送信` : '選んで送信';
            }));
            sendEl.addEventListener('click', () => {
              if (picked.size === 0) return;
              sendEl.disabled = true;
              commit([...picked]);
            });
            return;
          }

          if (q.question_type === 'text') {
            sendEl.addEventListener('click', () => {
              const v = (txtEl.value || '').trim();
              if (!v) { slotEl.querySelector('.msg').textContent = '入力してください'; return; }
              sendEl.disabled = true;
              commit(v);
            });
            return;
          }

          // single_choice / scale
          optEls.forEach(el => el.addEventListener('click', () => {
            optEls.forEach(o => { o.disabled = true; });
            el.classList.add('on');
            commit(el.dataset.val);
          }));
        }

        render();
      }

      function renderDaily(items) {
        dailyArea.innerHTML = '';
        for (const item of items) {
          const slot = document.createElement('section');
          dailyArea.appendChild(slot);
          mountDailyCard(item, slot);
        }
      }

      function renderProjects(list) {
        const listEl = document.getElementById('project-list');
        document.getElementById('loading-overlay').style.display = 'none';
        listEl.style.display = '';
        document.getElementById('list-head').style.display = '';

        if (list.length === 0) {
          listEl.innerHTML = '<div class="hb-empty"><div class="icon">🔍</div><p>該当する案件がありません</p></div>';
          return;
        }

        listEl.innerHTML = list.map(p => {
          const left = daysLeft(p.recruit_deadline);
          const isAuto = p.apply_mode === 'auto';
          return `
            <article class="hb-card" data-id="${esc(p.id)}">
              <div class="pt ${isAuto ? 'hot' : ''}">
                <small>${isAuto ? '⚡即回答' : '謝礼'}</small>
                <b>${(p.reward_points ?? 0).toLocaleString()}<small>pt</small></b>
                ${p.estimated_minutes ? `<div class="min">⏱ ${esc(String(p.estimated_minutes))}分</div>` : ''}
              </div>
              <div class="body">
                <h3>${esc(p.title)}</h3>
                <div class="hb-meta">${fmtBadges(p)}</div>
                <div class="hb-foot">
                  ${left !== null ? `<span class="days">あと<b>${left}</b>日</span>` : ''}
                  <button class="hb-save ${p.is_saved ? 'saved' : ''}" data-id="${esc(p.id)}">${p.is_saved ? '★ 保存済' : '☆ 保存'}</button>
                </div>
              </div>
            </article>`;
        }).join('');

        listEl.querySelectorAll('.hb-card').forEach(card => {
          card.addEventListener('click', e => {
            if (e.target.closest('.hb-save')) return;
            window.location.href = `${projectDetailBaseUrl}/${card.dataset.id}`;
          });
        });
        listEl.querySelectorAll('.hb-save').forEach(btn => {
          btn.addEventListener('click', async e => {
            e.stopPropagation();
            const projectId = btn.dataset.id;
            try {
              const res = await fetch(`/liff/projects/${projectId}/favorite`, {
                method: 'POST',
                headers: { Authorization: `Bearer ${idToken}` }
              });
              const json = await res.json();
              btn.textContent = json.saved ? '★ 保存済' : '☆ 保存';
              btn.className = `hb-save${json.saved ? ' saved' : ''}`;
              const proj = allProjects.find(p => p.id === projectId);
              if (proj) proj.is_saved = json.saved;
            } catch (err) { console.error('save failed', err); }
          });
        });
      }

      function applyFilters() {
        let list = allProjects;
        if (filter.startsWith('cat:')) {
          const cat = filter.slice(4);
          list = list.filter(p => p.category === cat);
        } else if (filter === 'instant') {
          list = list.filter(p => p.apply_mode === 'auto');
        }
        if (searchText) {
          const q = searchText.toLowerCase();
          list = list.filter(p =>
            String(p.title).toLowerCase().includes(q) ||
            (p.tags || []).some(t => String(t).toLowerCase().includes(q)));
        }
        const sort = SORTS[sortIdx].key;
        if (sort === 'reward') list = [...list].sort((a, b) => (b.reward_points ?? 0) - (a.reward_points ?? 0));
        if (sort === 'deadline') list = [...list].sort((a, b) => {
          const at = a.recruit_deadline ? new Date(a.recruit_deadline).getTime() : Infinity;
          const bt = b.recruit_deadline ? new Date(b.recruit_deadline).getTime() : Infinity;
          return at - bt;
        });
        // 先頭1件をヒーローに、残りをリストに（1件しかない場合はヒーローのみ）
        renderPick(list[0] ?? null);
        renderProjects(list.slice(1));
      }

      async function load() {
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return;
          idToken = token;

          // 今日の1問は案件一覧の表示をブロックしない（失敗してもカードを出さないだけ）。
          if (d.dailyTodayUrl) {
            void fetch(d.dailyTodayUrl, { headers: { Authorization: `Bearer ${idToken}` } })
              .then(r => (r.ok ? r.json() : null))
              .then(json => { if (json?.items?.length) renderDaily(json.items); })
              .catch(err => console.error('daily load failed', err));
          }

          const _fetchStart = performance.now();
          const res = await fetch(projectsDataUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          const data = await res.json();
          const _dataMs = performance.now() - _fetchStart;
          allProjects = data.projects || [];

          const monthly = data.monthly_applications;
          if (monthly) {
            document.getElementById('progress').style.display = '';
            document.getElementById('monthly-count').textContent = monthly.count;
            document.getElementById('monthly-reco').textContent = monthly.recommended;
            document.getElementById('monthly-bar').style.width =
              Math.min(100, Math.round((monthly.count / monthly.recommended) * 100)) + '%';
          }
          const _renderStart = performance.now();
          applyFilters();
          try { LiffAuth.reportPerf('/liff/projects', { dataMs: _dataMs, renderMs: performance.now() - _renderStart }); } catch (_e) {}
        } catch (err) {
          document.getElementById('loading-overlay').style.display = 'none';
          const listEl = document.getElementById('project-list');
          listEl.style.display = '';
          listEl.innerHTML = `<div class="hb-empty"><div class="icon">⚠️</div><p>${esc(err.message || '読み込みに失敗しました')}</p></div>`;
        }
      }

      document.getElementById('chip-bar').addEventListener('click', e => {
        const chip = e.target.closest('.hb-chip');
        if (!chip) return;
        document.querySelectorAll('.hb-chip').forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
        filter = chip.dataset.filter;
        applyFilters();
      });
      document.getElementById('search-input').addEventListener('input', e => {
        searchText = e.target.value.trim();
        applyFilters();
      });
      document.getElementById('sort-fab').addEventListener('click', () => {
        sortIdx = (sortIdx + 1) % SORTS.length;
        document.getElementById('sort-fab').textContent = SORTS[sortIdx].label;
        applyFilters();
      });

      void load();
    })();
    </script>
  </body>
</html>

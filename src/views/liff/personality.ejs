<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/styles.css" />
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <style>
      .type-badge {
        display: inline-block;
        background: linear-gradient(135deg, #2ca87a, #38b2ac);
        color: #fff;
        border-radius: 24px;
        padding: 6px 20px;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
      }
      .bar-wrap {
        background: #e0ede9;
        border-radius: 4px;
        height: 8px;
        overflow: hidden;
        flex: 1;
      }
      .bar-fill { height: 100%; border-radius: 4px; }
      .bar-positive { background: #2ca87a; }
      .bar-negative { background: #e53e3e; }
      .bar-neutral  { background: #a0aec0; }
      .bar-mixed    { background: #ed8936; }
      .tag-chip {
        display: inline-block;
        background: #e0ede9;
        border-radius: 12px;
        padding: 3px 12px;
        font-size: 13px;
        margin: 3px;
      }
      .confidence-bar {
        height: 6px;
        background: #e0ede9;
        border-radius: 3px;
        overflow: hidden;
        margin-top: 4px;
      }
    </style>
  </head>
  <body class="liff-body">
    <main class="liff-main">
      <section class="card liff-card stack">
        <div>
          <h1><%= title %></h1>
          <p class="muted">投稿内容から性格傾向を分析しています。</p>
        </div>
        <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>
        <div id="personality-root" class="stack"></div>
        <p id="status" class="muted">LIFF を初期化しています...</p>
      </section>
    </main>
    <script>
      (() => {
        const initialDataEl = document.getElementById("initial-data");
        const initialData = JSON.parse(initialDataEl.dataset.json || "{}");
        const liffId = initialData.liffId || "";
        const root = document.getElementById("personality-root");
        const statusEl = document.getElementById("status");

        function setStatus(text, isError) {
          statusEl.textContent = text;
          statusEl.className = isError ? "danger-text" : "muted";
        }

        function esc(v) {
          return String(v ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
        }

        function pct(part, total) {
          return total > 0 ? Math.round(part / total * 100) : 0;
        }

        function renderBar(value, max, colorClass) {
          const w = max > 0 ? Math.round(value / max * 100) : 0;
          return `<div class="bar-wrap"><div class="bar-fill ${colorClass}" style="width:${w}%"></div></div>`;
        }

        function renderReady(result) {
          const profile = result.profile || {};
          const raw = profile.raw_json || {};
          const personalityType = result.personalityType || raw.personality_type || "-";
          const summary = profile.summary || result.message || "-";
          const confidence = typeof profile.confidence === "number"
            ? Math.round(profile.confidence * 100)
            : null;
          const traits = Array.isArray(result.features) ? result.features
            : Array.isArray(profile.traits) ? profile.traits : [];
          const behaviorTendencies = Array.isArray(result.behaviorTendencies)
            ? result.behaviorTendencies
            : Array.isArray(raw.behavior_tendencies) ? raw.behavior_tendencies : [];
          const keywords = Array.isArray(result.recurringKeywords) ? result.recurringKeywords
            : Array.isArray(raw.recurring_keywords) ? raw.recurring_keywords : [];
          const tags = Array.isArray(result.recurringTags) ? result.recurringTags
            : Array.isArray(raw.recurring_tags) ? raw.recurring_tags : [];
          const sentDist = raw.sentiment_distribution || {};
          const sentTotal = (sentDist.positive||0) + (sentDist.neutral||0) + (sentDist.negative||0) + (sentDist.mixed||0);
          const postCount = result.postCount || raw.post_count || 0;

          const typeIconMap = { "論理型": "🧩", "感情型": "💬", "課題発見型": "🔍", "ポジティブ表現型": "✨" };
          const typeIcon = typeIconMap[personalityType] || "👤";

          root.innerHTML = `
            <div class="card subtle-card" style="text-align:center">
              <div class="type-badge">${typeIcon} ${esc(personalityType)}</div>
              <p style="margin-top:8px">${esc(summary)}</p>
              ${confidence !== null ? `
                <p class="muted" style="font-size:12px;margin-top:4px">分析信頼度</p>
                <div class="confidence-bar">
                  <div style="height:100%;width:${confidence}%;background:#2ca87a;border-radius:3px"></div>
                </div>
                <p class="muted" style="font-size:11px">${confidence}%</p>
              ` : ""}
              <p class="muted" style="font-size:12px;margin-top:8px">参照投稿数: ${esc(postCount)}件</p>
            </div>

            ${traits.length > 0 ? `
            <div class="card subtle-card">
              <h2>あなたの特徴</h2>
              <ul style="padding-left:1.2rem;line-height:1.8">
                ${traits.map(t => `<li>${esc(t)}</li>`).join("")}
              </ul>
            </div>
            ` : ""}

            ${behaviorTendencies.length > 0 ? `
            <div class="card subtle-card">
              <h2>行動傾向</h2>
              <ul style="padding-left:1.2rem;line-height:1.8">
                ${behaviorTendencies.map(b => `<li>${esc(b)}</li>`).join("")}
              </ul>
            </div>
            ` : ""}

            ${sentTotal > 0 ? `
            <div class="card subtle-card">
              <h2>感情バランス</h2>
              <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px">
                ${[
                  ["ポジティブ", sentDist.positive || 0, "bar-positive"],
                  ["ネガティブ", sentDist.negative || 0, "bar-negative"],
                  ["ニュートラル", sentDist.neutral || 0, "bar-neutral"],
                  ["混在", sentDist.mixed || 0, "bar-mixed"]
                ].map(([label, val, cls]) => `
                  <div style="display:flex;align-items:center;gap:8px">
                    <span style="width:80px;font-size:13px">${esc(label)}</span>
                    ${renderBar(val, 100, cls)}
                    <span class="muted" style="width:32px;font-size:12px;text-align:right">${val}%</span>
                  </div>
                `).join("")}
              </div>
            </div>
            ` : ""}

            ${(keywords.length > 0 || tags.length > 0) ? `
            <div class="card subtle-card">
              <h2>よく出るテーマ</h2>
              <div style="margin-top:8px">
                ${tags.map(t => `<span class="tag-chip">${esc(t)}</span>`).join("")}
                ${keywords.map(k => `<span class="tag-chip" style="background:#f0f4f8">${esc(k)}</span>`).join("")}
              </div>
            </div>
            ` : ""}
          `;
        }

        function renderInsufficient(result) {
          root.innerHTML = `
            <div class="card subtle-card" style="text-align:center">
              <p style="font-size:32px;margin-bottom:8px">📊</p>
              <h2>データ収集中</h2>
              <p>${esc(result.message || "性格分析に必要なデータがまだ十分ではありません。")}</p>
              <p class="muted">現在の投稿数: ${esc(result.postCount || 0)}件</p>
              <p class="muted" style="font-size:12px;margin-top:12px">愚痴・日記・アンケートへの参加でデータが蓄積されます。</p>
            </div>
          `;
        }

        async function load() {
          if (!liffId) {
            setStatus("LIFF IDが設定されていません。管理者にお問い合わせください。", true);
            return;
          }
          try {
            const idToken = await LiffAuth.initLiffOrWebAuth(liffId);
            if (!idToken) return; // LINE Login リダイレクト中

            console.log("profile_guard.check", { path: window.location.pathname, requiresProfile: false, redirecting: false });

            const response = await fetch(initialData.personalityDataUrl, {
              headers: { Authorization: `Bearer ${idToken}` }
            });
            if (!response.ok) throw new Error("性格分析の取得に失敗しました。時間をおいて再度お試しください。");

            const result = await response.json();
            if (result.status === "ready") {
              renderReady(result);
            } else {
              renderInsufficient(result);
            }
            setStatus("最新の分析結果を表示しています。", false);
          } catch (error) {
            setStatus(error.message || "性格分析の取得に失敗しました。", true);
          }
        }

        void load();
      })();
    </script>
  </body>
</html>

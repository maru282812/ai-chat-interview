<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <link rel="stylesheet" href="/public/hibi.css" />
    <style>
      .hb-shell { padding-bottom: 96px; }
    </style>
  </head>
  <body class="hibi">
    <div class="hb-shell">
      <header class="hb-appbar">
        <button class="hb-back" id="back-btn">‹</button>
        <span class="hb-title">案件詳細</span>
        <span style="width:24px"></span>
      </header>

      <div class="hb-loading" id="loading-overlay">読み込み中…</div>
      <div id="content" style="display:none"></div>
      <div id="done" style="display:none"></div>

      <div class="hb-cta" id="cta-bar" style="display:none">
        <button class="hb-save" id="save-btn">☆</button>
        <button class="hb-btn primary" id="apply-btn">応募する</button>
      </div>
    </div>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      'use strict';
      const d = JSON.parse(document.getElementById('initial-data').dataset.json || '{}');

      let idToken = null;
      let project = null;
      let isSaved = false;
      let myApplication = null;
      let myAssignment = null;

      function esc(v) {
        return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
      }
      function daysLeft(iso) {
        if (!iso) return null;
        const dd = Math.ceil((new Date(iso).getTime() - Date.now()) / 86400000);
        return dd < 0 ? null : dd;
      }
      function fmtDeadline(iso) {
        if (!iso) return null;
        const dt = new Date(iso);
        const w = ['日','月','火','水','木','金','土'][dt.getDay()];
        return `${dt.getMonth()+1}月${dt.getDate()}日(${w}) ${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')} 締切`;
      }

      function render() {
        const isAuto = project.apply_mode === 'auto';
        const left = daysLeft(project.recruit_deadline);
        const ngLines = String(project.ng_conditions || '').split('\n').map(s => s.trim()).filter(Boolean);
        const el = document.getElementById('content');

        el.innerHTML = `
          <div class="hb-hero">
            <div class="hb-meta">
              <span class="hb-badge">${isAuto ? 'AIインタビュー' : esc(project.interview_format || 'オンラインインタビュー')}</span>
              <span class="hb-badge">${isAuto ? '⚡ 即回答OK' : '選考あり'}</span>
            </div>
            <h3>${esc(project.title)}</h3>
            <div class="t">${isAuto ? '⚡ 応募後、すぐに回答できます' : '📮 応募 → 選考 → 当選された方のみ実施'}</div>
            <p>${isAuto
              ? '選考・日程調整はありません。応募するとそのまま回答が始まり、完了と同時に謝礼が付与されます。'
              : '応募後に選考を行い、結果はLINEでお知らせします。当選された方に回答のご案内をお送りします。'}</p>
          </div>
          <div class="hb-stats">
            <div class="hb-stat"><div class="k">謝礼</div><div class="v">${(project.reward_points ?? 0).toLocaleString()}<small>pt</small></div></div>
            <div class="hb-stat"><div class="k">所要時間</div><div class="v">${project.estimated_minutes ? '約' + esc(String(project.estimated_minutes)) + '<small>分</small>' : '-'}</div></div>
            <div class="hb-stat"><div class="k">締切</div><div class="v">${left !== null ? 'あと' + left + '<small>日</small>' : 'なし'}</div></div>
          </div>

          ${isAuto ? `
          <div class="hb-panel">
            <div class="hb-note" style="margin-bottom:8px">💬 こんなイメージで進みます</div>
            <div class="hb-bub ai">こんにちは！このテーマについて、いま一番気になっていることを教えてください 😊</div>
            <div class="hb-bub me">〇〇が気になっています</div>
            <div class="hb-bub ai">それはどんな場面で感じることが多いですか？</div>
          </div>` : `
          <div class="hb-panel">
            <div class="hb-sec-title">🚩 実施までの流れ</div>
            <ul class="hb-flow">
              <li><b>1. 応募する</b><small>ボタンひとつで完了します</small></li>
              <li><b>2. 選考</b><small>結果はLINEでお知らせします</small></li>
              <li><b>3. 当選 → 回答のご案内</b><small>届いたURLから回答できます</small></li>
              <li><b>4. 謝礼 ${(project.reward_points ?? 0).toLocaleString()}pt 付与</b><small>回答完了後に付与されます</small></li>
            </ul>
          </div>`}

          ${(project.objective || ngLines.length > 0) ? `
          <div class="hb-panel">
            ${project.objective ? `
              <div class="hb-sec-title">👤 募集内容</div>
              <p style="font-size:14px;line-height:1.8;white-space:pre-wrap">${esc(project.objective)}</p>` : ''}
            ${ngLines.length > 0 ? `
              <div class="hb-ngbox">
                <div class="t">⚠ NG条件</div>
                <ul>${ngLines.map(l => '<li>' + esc(l) + '</li>').join('')}</ul>
              </div>` : ''}
          </div>` : ''}

          ${project.recruit_deadline ? `
          <div class="hb-panel">
            <div class="hb-sec-title">📅 募集期限</div>
            <p style="font-size:15px">${esc(fmtDeadline(project.recruit_deadline))}</p>
          </div>` : ''}
          <div style="height:16px"></div>`;

        el.style.display = '';
        document.getElementById('loading-overlay').style.display = 'none';
        renderCta();
      }

      function renderCta() {
        const bar = document.getElementById('cta-bar');
        const applyBtn = document.getElementById('apply-btn');
        const saveBtn = document.getElementById('save-btn');
        bar.style.display = '';
        saveBtn.textContent = isSaved ? '★' : '☆';
        saveBtn.className = `hb-save${isSaved ? ' saved' : ''}`;
        applyBtn.classList.add('primary');
        applyBtn.classList.remove('sub');

        const isAuto = project.apply_mode === 'auto';
        const appStatus = myApplication ? myApplication.status : null;

        if (myAssignment && myAssignment.status === 'completed') {
          applyBtn.textContent = '回答済みです';
          applyBtn.disabled = true;
        } else if (appStatus === 'accepted' && myApplication.assignment_id) {
          applyBtn.textContent = '回答をはじめる ⚡';
          applyBtn.disabled = false;
          applyBtn.dataset.action = 'answer';
        } else if (appStatus === 'applied') {
          applyBtn.textContent = '選考中です（タップで応募を取り消し）';
          applyBtn.disabled = false;
          applyBtn.dataset.action = 'withdraw';
          applyBtn.classList.remove('primary');
          applyBtn.classList.add('sub');
        } else if (project.recruit_closed) {
          applyBtn.textContent = '募集は終了しました';
          applyBtn.disabled = true;
        } else {
          applyBtn.textContent = isAuto ? '応募してすぐ回答する ⚡' : '応募する';
          applyBtn.disabled = false;
          applyBtn.dataset.action = 'apply';
        }
      }

      function showManualDone() {
        document.getElementById('content').style.display = 'none';
        document.getElementById('cta-bar').style.display = 'none';
        const el = document.getElementById('done');
        el.innerHTML = `
          <div class="hb-done">
            <div class="emoji">📮</div>
            <h2>応募を受け付けました</h2>
            <p>選考のうえ、結果はLINEでお知らせします。<br>当選された場合は回答のご案内が届きます。</p>
            <div class="hb-hint hb-mt16">💡 当選率を上げるには、プロフィールを充実させて、毎月10件以上の応募がおすすめです。</div>
            <a class="hb-btn primary hb-mt16" href="${esc(d.projectsUrl)}">ほかの案件も探す</a>
            <a class="hb-btn ghost hb-mt12" href="${esc(d.interactionsUrl)}">応募状況を確認する</a>
          </div>`;
        el.style.display = '';
        window.scrollTo(0, 0);
      }

      async function ensureConsents() {
        // 未同意のグローバル必須書類があれば同意ページへ（同意後この画面に戻る）
        try {
          const res = await fetch(d.consentCheckUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          const json = await res.json();
          if (json.ok && json.count > 0) {
            const redirect = encodeURIComponent(location.pathname + location.search);
            window.location.href = `${d.consentPageUrl}?mode=initial&redirect=${redirect}`;
            return false;
          }
        } catch (err) { console.warn('consent-check failed', err); }
        return true;
      }

      async function doApply() {
        const applyBtn = document.getElementById('apply-btn');
        applyBtn.disabled = true;
        applyBtn.textContent = '応募しています…';

        if (!(await ensureConsents())) return;

        try {
          const res = await fetch(d.applyUrl, {
            method: 'POST',
            headers: { Authorization: `Bearer ${idToken}` }
          });
          const json = await res.json();
          if (!json.ok) {
            alert(json.error || '応募できませんでした。');
            renderCta();
            return;
          }
          if (json.mode === 'auto' && json.survey_url) {
            // 応募→即回答（選考なし・ワンクッション置かず直行）
            window.location.href = json.survey_url;
            return;
          }
          myApplication = { status: 'applied', assignment_id: null };
          showManualDone();
        } catch (err) {
          alert('通信に失敗しました。時間をおいて再度お試しください。');
          renderCta();
        }
      }

      async function doWithdraw() {
        if (!confirm('応募を取り消しますか？')) { renderCta(); return; }
        try {
          const res = await fetch(d.withdrawUrl, {
            method: 'POST',
            headers: { Authorization: `Bearer ${idToken}` }
          });
          const json = await res.json();
          if (!json.ok) { alert(json.error || '取り消せませんでした。'); return; }
          myApplication = null;
          renderCta();
        } catch (err) { alert('通信に失敗しました。'); }
      }

      async function load() {
        try {
          const token = await LiffAuth.initLiffOrWebAuth(d.liffId);
          if (!token) return;
          idToken = token;

          const res = await fetch(d.dataUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (res.status === 404) throw new Error('この案件は現在公開されていません。');
          const data = await res.json();
          project = data.project;
          isSaved = data.is_saved;
          myApplication = data.my_application;
          myAssignment = data.my_assignment;
          render();
        } catch (err) {
          document.getElementById('loading-overlay').style.display = 'none';
          const el = document.getElementById('content');
          el.style.display = '';
          el.innerHTML = `<div class="hb-empty"><div class="icon">⚠️</div><p>${esc(err.message || '読み込みに失敗しました')}</p><a class="hb-btn ghost hb-mt16" href="${esc(d.projectsUrl)}" style="max-width:280px;margin-left:auto;margin-right:auto">案件一覧へ戻る</a></div>`;
        }
      }

      document.getElementById('back-btn').addEventListener('click', () => {
        if (history.length > 1) history.back(); else window.location.href = d.projectsUrl;
      });
      document.getElementById('save-btn').addEventListener('click', async () => {
        try {
          const res = await fetch(d.favoriteUrl, { method: 'POST', headers: { Authorization: `Bearer ${idToken}` } });
          const json = await res.json();
          isSaved = json.saved;
          renderCta();
        } catch (err) { console.error(err); }
      });
      document.getElementById('apply-btn').addEventListener('click', () => {
        const action = document.getElementById('apply-btn').dataset.action;
        if (action === 'apply') void doApply();
        else if (action === 'withdraw') void doWithdraw();
        else if (action === 'answer' && myApplication && myApplication.assignment_id) {
          window.location.href = `${d.surveyBaseUrl}/${myApplication.assignment_id}`;
        }
      });

      void load();
    })();
    </script>
  </body>
</html>

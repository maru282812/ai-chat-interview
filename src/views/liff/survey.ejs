<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= project?.user_display_title || project?.name || 'アンケート' %></title>
  <% if (locals.liffId) { %>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <% } %>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0; padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', sans-serif;
      background: #f5f7f6;
      min-height: 100vh;
    }

    /* ---- survey_question / survey_page 共通 ---- */
    .survey-container {
      max-width: 480px; margin: 0 auto; padding: 16px;
    }
    .progress-bar-wrap { background: #e0ede9; border-radius: 8px; height: 6px; margin-bottom: 16px; }
    .progress-bar      { background: #2ca87a; height: 100%; border-radius: 8px; transition: width 0.3s; }
    .question-card {
      background: #fff; border-radius: 16px; padding: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,.08); margin-bottom: 12px;
    }
    .question-number   { font-size: 12px; color: #60726f; margin-bottom: 6px; }
    .comment-top       { font-size: 13px; color: #4a6060; margin-bottom: 8px; }
    .question-text     { font-size: 16px; font-weight: 600; line-height: 1.5; margin-bottom: 12px; }
    .comment-bottom    { font-size: 13px; color: #4a6060; margin-bottom: 10px; }
    .choice-list       { display: flex; flex-direction: column; gap: 8px; }
    .choice-list.has-images { flex-direction: row; flex-wrap: wrap; gap: 10px; }
    .choice-item       {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px; border: 1px solid #d8e3e0; border-radius: 10px;
      cursor: pointer; transition: background 0.15s;
      background: #fff;
    }
    .choice-item.has-img {
      flex-direction: column; align-items: stretch; gap: 6px;
      padding: 8px; min-width: 120px; max-width: 160px; flex: 1;
    }
    .choice-item.has-img input { margin: 0 auto; }
    .choice-img {
      width: 100%; height: 90px; object-fit: cover;
      border-radius: 6px; display: block;
    }
    .choice-label { font-size: 14px; line-height: 1.4; }
    .choice-item.has-img .choice-label { text-align: center; font-size: 13px; }
    .choice-item.selected { background: #e8f7f0; border-color: #2ca87a; }
    .choice-item input    { accent-color: #2ca87a; flex-shrink: 0; }
    .free-text-input {
      width: 100%; padding: 10px; border: 1px solid #d8e3e0;
      border-radius: 10px; font-size: 15px; resize: vertical; line-height: 1.5;
    }
    .free-text-input:focus { outline: none; border-color: #2ca87a; }
    .scale-row         { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
    .scale-btn         {
      width: 48px; height: 48px; border-radius: 50%;
      border: 2px solid #d8e3e0; background: #fff; cursor: pointer;
      font-size: 15px; font-weight: 600; transition: all 0.15s;
    }
    .scale-btn.selected { background: #2ca87a; color: #fff; border-color: #2ca87a; }
    .nav-btns          { display: flex; gap: 10px; margin-top: 16px; }
    .btn-next          {
      flex: 1; padding: 14px; background: #2ca87a; color: #fff;
      border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer;
    }
    .btn-next:disabled { background: #b0ccc4; cursor: not-allowed; }
    .btn-back          {
      padding: 14px 20px; background: none; color: #2ca87a;
      border: 2px solid #2ca87a; border-radius: 12px; font-size: 15px; cursor: pointer;
    }
    .required-badge { font-size: 10px; color: #fff; background: #e55; border-radius: 4px; padding: 2px 5px; margin-left: 6px; vertical-align: middle; }
    .free-text-required { border: 1.5px solid #e55 !important; }
    .free-text-error { font-size: 12px; color: #e55; margin-top: 4px; display: none; }
    .matrix-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .matrix-table th, .matrix-table td { padding: 8px 6px; border-bottom: 1px solid #eee; text-align: center; }
    .matrix-table th:first-child, .matrix-table td:first-child { text-align: left; min-width: 100px; }
    .matrix-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .matrix-row-cell { display: flex; flex-direction: column; gap: 4px; }
    .matrix-row-img { width: 80px; height: 60px; object-fit: cover; border-radius: 6px; display: block; }
    .matrix-row-imgs { display: flex; flex-wrap: wrap; gap: 4px; }
    .matrix-row-desc { font-size: 11px; color: #60726f; line-height: 1.3; }
    .matrix-header-vertical th { writing-mode: vertical-rl; text-orientation: mixed; white-space: nowrap; height: 80px; vertical-align: bottom; }
    .matrix-header-rotated th { transform: rotate(-90deg); white-space: nowrap; height: 80px; vertical-align: bottom; }
    .question-text-images { margin: 0 0 12px; display: flex; flex-direction: column; gap: 6px; }
    .question-text-img { max-width: 100%; border-radius: 8px; display: block; }
    .question-text-caption { font-size: 12px; color: #60726f; margin: 2px 0 0; line-height: 1.4; }

    /* ---- 画像カードグリッド ---- */
    .card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
    @media (max-width: 320px) { .card-grid { grid-template-columns: 1fr; } }
    .card-item {
      border: 2px solid #d8e3e0; border-radius: 12px; padding: 10px;
      cursor: pointer; transition: all 0.15s; background: #fff;
      display: flex; flex-direction: column; gap: 6px; align-items: center;
    }
    .card-item.selected { border-color: #2ca87a; background: #e8f7f0; }
    .card-item input { accent-color: #2ca87a; }
    .card-item-img { width: 100%; height: 100px; object-fit: cover; border-radius: 8px; display: block; }
    .card-item-title { font-size: 13px; font-weight: 600; text-align: center; line-height: 1.3; }
    .card-item-desc { font-size: 11px; color: #60726f; text-align: center; line-height: 1.3; }
    .card-extra-imgs { display: flex; flex-wrap: wrap; gap: 4px; justify-content: center; margin-top: 4px; }
    .card-extra-img  { width: calc(50% - 2px); height: 60px; object-fit: cover; border-radius: 4px; }
    .choice-desc { font-size: 12px; color: #60726f; line-height: 1.3; display: block; }
    .choice-extra-imgs { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
    .choice-extra-img  { height: 60px; width: auto; max-width: 100%; object-fit: cover; border-radius: 4px; }

    /* ---- image_upload ---- */
    .upload-area {
      border: 2px dashed #b0ccc4; border-radius: 12px; padding: 20px;
      text-align: center; background: #f8fbfa; cursor: pointer;
    }
    .upload-area:hover { border-color: #2ca87a; }
    .upload-instructions { font-size: 13px; color: #60726f; margin: 6px 0 0 0; }
    .upload-preview-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
    .upload-thumb-wrap {
      position: relative; width: 80px; height: 80px;
    }
    .upload-thumb { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; display: block; }
    .upload-thumb-del {
      position: absolute; top: -6px; right: -6px; width: 20px; height: 20px;
      background: #e55; color: #fff; border: none; border-radius: 50%;
      font-size: 12px; cursor: pointer; line-height: 20px; text-align: center; padding: 0;
    }
    .upload-loading { font-size: 13px; color: #2ca87a; margin-top: 6px; }
    .upload-error { font-size: 12px; color: #e55; margin-top: 4px; }

    /* ---- interview_chat モード ---- */
    .chat-container    { max-width: 480px; margin: 0 auto; padding: 12px; }
    .chat-messages     { display: flex; flex-direction: column; gap: 10px; padding-bottom: 80px; }
    .chat-bubble-wrap  { display: flex; }
    .chat-bubble-wrap.ai   { justify-content: flex-start; }
    .chat-bubble-wrap.user { justify-content: flex-end; }
    .chat-bubble {
      max-width: 85%; padding: 12px 16px; border-radius: 18px; line-height: 1.5; font-size: 15px;
    }
    .chat-bubble.ai   { background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.1); border-radius: 18px 18px 18px 4px; }
    .chat-bubble.user { background: #2ca87a; color: #fff; border-radius: 18px 18px 4px 18px; }
    .chat-input-area {
      position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 100%; max-width: 480px; background: #fff;
      padding: 10px 12px; box-shadow: 0 -2px 8px rgba(0,0,0,.08);
      display: flex; gap: 8px; align-items: flex-end;
    }
    .chat-input {
      flex: 1; padding: 10px 14px; border: 1px solid #d8e3e0;
      border-radius: 20px; font-size: 15px; resize: none; max-height: 120px; overflow-y: auto;
    }
    .chat-send {
      width: 44px; height: 44px; background: #2ca87a; border: none; border-radius: 50%;
      color: #fff; font-size: 18px; cursor: pointer; flex-shrink: 0;
    }
    .chat-send:disabled { background: #b0ccc4; }

    /* ---- interview_chat 回答エリア ---- */
    .chat-answer-area {
      width: 100%; max-height: 50vh; overflow-y: auto;
      padding: 8px 0 8px; border-top: 1px solid #eee; margin-bottom: 4px;
    }
    .chat-question-block {
      margin-bottom: 16px;
    }
    .chat-question-block .chat-bubble-wrap {
      margin-bottom: 8px;
    }
    .chat-answer-inline {
      width: 88%;
      max-width: 420px;
      margin-top: 8px;
      padding-left: 8px;
    }
    .chat-answer-inline .choice-item {
      display: flex;
      width: 100%;
      margin-bottom: 8px;
    }
    .chat-answer-inline .choice-button {
      display: block;
      width: 100%;
      margin-bottom: 8px;
    }
    #chatAnswerArea .choice-item { padding: 8px 12px; }
    .chat-answer-inline .choice-item { padding: 8px 12px; }
    #chatAnswerArea .scale-btn { width: 44px; height: 44px; font-size: 14px; }
    .chat-answer-inline .scale-btn { width: 44px; height: 44px; font-size: 14px; }
    #chatAnswerArea .matrix-table-wrap { max-height: 220px; overflow-y: auto; }
    .chat-answer-inline .matrix-table-wrap { max-height: 220px; overflow-y: auto; }
    #chatAnswerArea .free-text-input { font-size: 14px; }
    .chat-answer-inline .free-text-input { font-size: 14px; }

    /* ---- interview_chat インライン送信ボタン ---- */
    .chat-next-row {
      width: 100%;
      padding-top: 10px;
    }
    .chat-next-btn {
      display: block;
      width: 100%;
      padding: 12px;
      background: #2ca87a;
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
    }
    .chat-next-btn:disabled { background: #b0ccc4; cursor: not-allowed; }
    .chat-selection-error { font-size: 12px; color: #e55; margin-top: 4px; display: none; }

    /* ---- 完了画面 ---- */
    .complete-screen { text-align: center; padding: 40px 20px; }
    .complete-icon   { font-size: 48px; margin-bottom: 16px; }
    .complete-title  { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
    .complete-sub    { font-size: 14px; color: #60726f; }

    /* ---- ページモード ---- */
    .page-header { padding: 12px 0; margin-bottom: 8px; }
    .page-title  { font-size: 17px; font-weight: 700; margin: 0; }

    /* ---- スクリーニング境界画面 ---- */
    .screening-boundary {
      max-width: 480px; margin: 0 auto; padding: 40px 24px; text-align: center;
    }
    .screening-boundary-icon  { font-size: 52px; margin-bottom: 18px; }
    .screening-boundary-title { font-size: 19px; font-weight: 700; margin-bottom: 10px; color: #333; }
    .screening-boundary-sub   { font-size: 14px; color: #555; line-height: 1.7; margin-bottom: 28px; }
    .screening-boundary-btn   {
      display: inline-block; padding: 14px 32px;
      background: #2ca87a; color: #fff; border: none; border-radius: 12px;
      font-size: 16px; font-weight: 600; cursor: pointer; text-decoration: none;
    }
  </style>
</head>
<body>

<%
  const displayMode = project?.display_mode || 'survey_question';
  const isChatMode  = displayMode === 'interview_chat';
  const isPageMode  = displayMode === 'survey_page';
%>

<% if (locals.errorMessage) { %>
  <!-- エラー画面 -->
  <div style="max-width:480px;margin:40px auto;padding:24px;text-align:center;font-family:sans-serif;">
    <div style="font-size:40px;margin-bottom:16px;">⚠️</div>
    <p style="font-size:16px;color:#444;margin-bottom:8px;"><%= errorMessage %></p>
    <p style="font-size:13px;color:#999;">解決しない場合は、運営までお問い合わせください。</p>
  </div>
<% } else if (locals.alreadyCompleted) { %>
  <!-- 回答済み画面 -->
  <div style="max-width:480px;margin:60px auto;padding:24px;text-align:center;font-family:sans-serif;">
    <div style="font-size:48px;margin-bottom:16px;">✅</div>
    <p style="font-size:18px;font-weight:700;margin-bottom:8px;color:#333;">回答が完了しています</p>
    <p style="font-size:14px;color:#666;line-height:1.6;">このアンケートはすでに回答済みです。<br>ご協力ありがとうございました。</p>
  </div>
<% } else if (locals.screeningFailed) { %>
  <!-- スクリーニング対象外画面 -->
  <div style="max-width:480px;margin:60px auto;padding:32px 24px;text-align:center;font-family:sans-serif;">
    <div style="font-size:48px;margin-bottom:16px;">🙏</div>
    <p style="font-size:18px;font-weight:700;margin-bottom:12px;color:#333;">本案件の対象外でした</p>
    <p style="font-size:14px;color:#666;line-height:1.7;margin-bottom:0;">
      <%= locals.screeningFailMessage || "今回はご参加いただけませんでした。またの機会にご協力をお願いします。" %>
    </p>
  </div>
<% } else if (locals.profileIncomplete) { %>
  <!-- プロフィール未設定画面 -->
  <div style="max-width:480px;margin:40px auto;padding:24px;text-align:center;font-family:sans-serif;">
    <div style="font-size:48px;margin-bottom:16px;">📝</div>
    <p style="font-size:18px;font-weight:700;margin-bottom:8px;color:#333;">プロフィール設定が必要です</p>
    <p style="font-size:14px;color:#666;line-height:1.6;margin-bottom:24px;">
      案件に参加するには、まず基本情報を登録してください。<br>約1分で完了します。
    </p>
    <% if (locals.mypageLiffId) { %>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <script>
      (async () => {
        try {
          await liff.init({ liffId: "<%= mypageLiffId %>" });
          document.getElementById("btn-setup").addEventListener("click", () => {
            liff.openWindow({ url: "https://liff.line.me/<%= mypageLiffId %>?mode=initial_setup", external: false });
          });
        } catch {
          document.getElementById("btn-setup").href = "/liff/mypage?mode=initial_setup";
          document.getElementById("btn-setup").tagName === "BUTTON" && (document.getElementById("btn-setup").outerHTML = `<a href="/liff/mypage?mode=initial_setup" id="btn-setup" style="display:block;padding:14px;background:#2ca87a;color:#fff;border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;">プロフィールを設定する</a>`);
        }
      })();
    </script>
    <button id="btn-setup" style="width:100%;padding:14px;background:#2ca87a;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:600;cursor:pointer;">
      プロフィールを設定する
    </button>
    <% } else { %>
    <a href="/liff/mypage?mode=initial_setup" style="display:block;padding:14px;background:#2ca87a;color:#fff;border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;">
      プロフィールを設定する
    </a>
    <% } %>
  </div>
<% } else { %>

<% if (displayMode === 'interview_chat') { %>
  <!-- ============================================================ -->
  <!-- interview_chat モード                                         -->
  <!-- ============================================================ -->
  <div class="chat-container">
    <div id="chatMessages" class="chat-messages">
      <!-- メッセージは JS で動的追加 -->
    </div>
  </div>
  <div class="chat-input-area" id="chatInputArea">
    <div id="chatAnswerArea" class="chat-answer-area" style="display:none"></div>
    <div id="chatTextRow" style="display:flex;gap:8px;align-items:flex-end;width:100%;">
      <textarea id="chatInput" class="chat-input" rows="1" placeholder="返信する..."></textarea>
      <button id="chatSend" class="chat-send" disabled>↑</button>
    </div>
    <div id="chatNextRow" style="display:none;width:100%;padding-top:6px;">
      <button id="chatNext" class="btn-next" style="margin:0;" disabled>次へ →</button>
    </div>
  </div>

<% } else { %>
  <!-- ============================================================ -->
  <!-- survey_question / survey_page モード                          -->
  <!-- ============================================================ -->
  <div class="survey-container">
    <div class="progress-bar-wrap">
      <div class="progress-bar" id="progressBar" style="width: 0%"></div>
    </div>

    <% if (isPageMode) { %>
      <div class="page-header">
        <p class="question-number" id="pageIndicator"></p>
        <h2 class="page-title" id="pageTitle"></h2>
      </div>
    <% } %>

    <div id="questionArea">
      <!-- 質問カードは JS で動的レンダリング -->
    </div>

    <div id="probeArea" style="display:none; margin-bottom:12px;">
      <div class="question-card" style="border:1.5px solid #2ca87a; background:#f0faf5;">
        <div style="font-size:12px;color:#2ca87a;font-weight:600;margin-bottom:8px;">追加質問</div>
        <div class="question-text" id="probeQuestionText" style="font-size:15px;margin-bottom:12px;"></div>
        <textarea id="probeAnswerInput" class="free-text-input" rows="3" placeholder="こちらに入力してください"></textarea>
        <div style="margin-top:10px;">
          <button id="probeSubmitBtn" class="btn-next" disabled>送信</button>
        </div>
      </div>
    </div>

    <div class="nav-btns">
      <button class="btn-back" id="btnBack" style="display:none">← 戻る</button>
      <button class="btn-next" id="btnNext" disabled>次へ →</button>
    </div>

    <div id="completeScreen" class="complete-screen" style="display:none">
      <div class="complete-icon">✅</div>
      <p class="complete-title">回答が完了しました</p>
      <p class="complete-sub">ご協力ありがとうございます。</p>
      <div id="completeActions" style="margin-top:20px;display:none">
        <button id="btnCloseLiff" class="btn-next" style="min-width:160px;">LINEに戻る</button>
        <p id="completeCloseTip" style="display:none;font-size:13px;color:#60726f;margin-top:8px;">アンケートは完了しました。この画面を閉じてください。</p>
      </div>
      <p id="completeError" style="display:none;color:#e53e3e;font-size:14px;margin-top:12px;">完了処理に失敗しました。時間をおいて再度お試しください。</p>
    </div>
  </div>
<% } %>

<script>
// ================================================================
// survey.ejs クライアントサイド質問エンジン
// ================================================================
(function() {
  'use strict';

  // ---- 初期データ（サーバーから受け取る） ----
  const PROJECT_DATA    = <%- JSON.stringify(projectData || {}) %>;
  const QUESTIONS       = <%- JSON.stringify(questions || []) %>;
  const PAGE_GROUPS     = <%- JSON.stringify(pageGroups || []) %>;
  const DISPLAY_MODE    = <%- JSON.stringify(displayMode) %>;
  const SESSION_ID      = <%- JSON.stringify(sessionId || null) %>;
  const ASSIGNMENT_ID   = <%- JSON.stringify(assignmentId || null) %>;
  const LIFF_ID         = <%- JSON.stringify(locals.liffId || null) %>;
  const AUTH_REQUIRED   = <%- JSON.stringify(locals.authRequired === true) %>;
  const LIFF_AUTH_AVAIL = <%- JSON.stringify(locals.liffAuthAvailable === true) %>;
  // ALLOW_LIFF_AUTH_SKIP=false のとき本人確認失敗・スキップを禁止する
  const SKIP_ALLOWED    = <%- JSON.stringify(locals.skipAllowed !== false) %>;
  // 'screening' | 'main'
  const SURVEY_PHASE           = <%- JSON.stringify(locals.surveyPhase || 'main') %>;
  const SCREENING_FAIL_MESSAGE = <%- JSON.stringify(locals.screeningFailMessage || '今回はご参加いただけませんでした。またの機会にご協力をお願いします。') %>;

  console.log("[survey] script loaded");
  console.log("[survey] liffId=", LIFF_ID);
  console.log("[survey] assignmentId=", ASSIGNMENT_ID);
  console.log("[survey] authRequired=", AUTH_REQUIRED, "| liffAuthAvail=", LIFF_AUTH_AVAIL, "| skipAllowed=", SKIP_ALLOWED);
  console.log("[survey] displayMode=", DISPLAY_MODE, "| questions=", QUESTIONS.length);

  // ================================================================
  // LIFF 初期化 + 本人確認
  // ================================================================
  async function initLiffAndVerify() {
    console.info('[survey] LIFF init start', { liffId: LIFF_ID, authRequired: AUTH_REQUIRED, skipAllowed: SKIP_ALLOWED });

    // LIFF 未設定 or auth 不要の場合
    if (!LIFF_ID || !AUTH_REQUIRED || !LIFF_AUTH_AVAIL) {
      console.log('[survey] skipping LIFF auth: LIFF_ID=', LIFF_ID, 'AUTH_REQUIRED=', AUTH_REQUIRED, 'LIFF_AUTH_AVAIL=', LIFF_AUTH_AVAIL);
      if (!LIFF_AUTH_AVAIL && ASSIGNMENT_ID) {
        console.warn('[survey] LIFF auth not configured. assignmentId=' + ASSIGNMENT_ID);
      }
      if (!SKIP_ALLOWED) {
        // スキップ禁止 + LIFF 未設定 → 設定不足エラー
        showAuthError('config_missing');
        return;
      }
      console.log('[survey] before startSurvey (no-auth path)');
      startSurvey();
      console.log('[survey] after startSurvey (no-auth path)');
      return;
    }

    try {
      console.log('[survey] before liff.init');
      await liff.init({ liffId: LIFF_ID });
      console.info('[survey] liff.init success');
      console.log('[survey] isInClient=', liff.isInClient(), '| isLoggedIn=', liff.isLoggedIn());
    } catch (e) {
      console.error('[survey] liff.init failed', e);
      if (!SKIP_ALLOWED) {
        showAuthError('liff_init_failed');
        return;
      }
      startSurvey();
      return;
    }

    // ログイン状態を確認: 未ログインならLINE Loginへリダイレクト
    // isInClient()=false はPCブラウザ・外部ブラウザでも起こりうるため、
    // ログイン状態で判定し、未ログインのみLINE Loginへ誘導する。
    if (!liff.isLoggedIn()) {
      console.warn('[survey] Not logged in – redirecting to LINE Login', {
        isInClient: liff.isInClient(),
        url: location.href,
        ua: navigator.userAgent.slice(0, 150),
      });
      liff.login();
      return;
    }

    // 外部ブラウザだがLINEログイン済みの場合はそのまま続行
    if (!liff.isInClient()) {
      console.info('[survey] External browser with LINE Login, continuing auth.');
    }

    let idToken;
    try {
      idToken = liff.getIDToken();
      if (!idToken) throw new Error('getIDToken returned null');
      console.info('[survey] ID token acquired');
    } catch (e) {
      console.error('[survey] liff.getIDToken failed', e);
      showAuthError('token_failed');
      return;
    }

    // サーバー側で ID token を検証し、本人確認
    try {
      console.info('[survey] verify-identity start', { assignmentId: ASSIGNMENT_ID });
      const res = await fetch('/liff/survey/verify-identity', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id_token: idToken, assignment_id: ASSIGNMENT_ID }),
      });
      const data = await res.json();
      if (!data.ok) {
        if (res.status === 403) {
          console.warn('[survey] verify-identity: IDENTITY_MISMATCH', { assignmentId: ASSIGNMENT_ID });
          showAuthError('identity_mismatch');
        } else if (res.status === 503) {
          console.warn('[survey] verify-identity: LIFF_NOT_CONFIGURED', { skipAllowed: data.skipAllowed });
          // サーバーが skipAllowed=false を返した場合は強制ブロック
          if (!data.skipAllowed || !SKIP_ALLOWED) {
            showAuthError('config_missing');
          } else {
            startSurvey();
          }
        } else {
          console.warn('[survey] verify-identity: unknown error', res.status);
          showAuthError('token_failed');
        }
        return;
      }
      console.info('[survey] verify-identity success');
    } catch (e) {
      console.error('[survey] verify-identity network error', e);
      if (!SKIP_ALLOWED) {
        showAuthError('token_failed');
        return;
      }
      // ネットワークエラー時は開発環境のみスキップ
    }

    startSurvey();
  }

  function showAuthError(code) {
    const BASE_MSG = '本人確認に失敗しました。<br>LINEアプリ内から開き直してください。';
    const messages = {
      config_missing:    BASE_MSG,
      not_in_liff:       BASE_MSG,
      identity_mismatch: 'このアンケートはご本人専用です。<br>配信されたLINEアカウントから開いてください。',
      token_failed:      BASE_MSG,
      liff_init_failed:  BASE_MSG,
    };
    const msg = messages[code] || BASE_MSG;
    console.error('[survey] showAuthError', code);
    document.body.innerHTML = `
      <div style="max-width:480px;margin:60px auto;padding:24px;text-align:center;font-family:sans-serif;">
        <div style="font-size:40px;margin-bottom:16px;">🔒</div>
        <p style="font-size:15px;color:#444;line-height:1.8;">${msg}</p>
        <p style="font-size:13px;color:#999;margin-top:12px;">解決しない場合は、運営までお問い合わせください。</p>
      </div>`;
  }

  // ================================================================
  // メイン: アンケートエンジン
  // ================================================================
  function startSurvey() {

  // ---- 自由記述系タイプ（統一定義） ----
  const FREE_TEXT_TYPES = new Set([
    'free_text_short', 'free_text_long',
    'short_text', 'long_text', 'text',
  ]);
  // 短文扱いになるタイプ（input[type=text] で描画）
  const FREE_TEXT_SHORT_TYPES = new Set(['free_text_short', 'short_text']);

  // ---- 定型文（未入力扱い） ----
  const BOILERPLATE_EXACT = new Set([
    'なし','ない','特になし','特にない','とくになし','不明','わからない','わかりません',
    '該当なし','該当なし','無','なし。','特になし。','ない。',
  ]);

  function isFreeTextValid(text) {
    if (!text) return false;
    const t = text.trim().replace(/[\r\n　]+/g, '').replace(/\s+/g, ' ').trim();
    if (t === '') return false;
    if (BOILERPLATE_EXACT.has(t)) return false;
    return true;
  }

  // ---- 回答コンテキスト ----
  const answerCtx = { answers: {}, imageTexts: {} };

  // ---- 現在位置 ----
  let currentQuestionIndex = 0;    // survey_question 用
  let currentPageIndex = 0;         // survey_page 用
  let questionHistory = [];         // 戻る機能のための履歴

  // ---- survey_page: ページグループ化 ----
  function groupByPage(qs) {
    const pgMap = new Map(PAGE_GROUPS.map(pg => [pg.id, pg]));
    const grouped = new Map();
    for (const pg of PAGE_GROUPS.sort((a,b) => a.sort_order - b.sort_order)) {
      grouped.set(pg.id, { pageGroup: pg, questions: [] });
    }
    grouped.set(null, { pageGroup: null, questions: [] });
    for (const q of qs.sort((a,b) => a.sort_order - b.sort_order)) {
      const key = q.page_group_id ?? null;
      if (!grouped.has(key)) grouped.set(key, { pageGroup: null, questions: [] });
      grouped.get(key).questions.push(q);
    }
    return [...grouped.values()].filter(p => p.questions.length > 0);
  }

  // ---- pipe 条件式の簡易評価 ----
  function evalPipe(expression) {
    try {
      return evalExpr(expression.trim());
    } catch(e) {
      return true; // エラー時は表示
    }
  }

  function evalExpr(expr) {
    expr = expr.trim();
    // 括弧除去
    if (expr.startsWith('(') && expr.endsWith(')')) {
      try { const inner = expr.slice(1,-1); evalExpr(inner); expr = inner.trim(); } catch(e){}
    }
    // OR
    const orParts = splitByKw(expr, ' or ');
    if (orParts.length > 1) return orParts.some(p => evalExpr(p));
    // AND
    const andParts = splitByKw(expr, ' and ');
    if (andParts.length > 1) return andParts.every(p => evalExpr(p));
    // NOT
    if (/^not\s+/i.test(expr)) return !evalExpr(expr.slice(4).trim());
    // 比較
    const m = expr.match(/^(q\d+)\s*(!=|>=|<=|>|<|=)\s*(.+)$/i);
    if (m) {
      const actual = String(answerCtx.answers[m[1].toLowerCase()] ?? '');
      const expected = m[3].trim();
      switch(m[2]) {
        case '=':  return actual === expected;
        case '!=': return actual !== expected;
        case '>':  return parseFloat(actual) > parseFloat(expected);
        case '<':  return parseFloat(actual) < parseFloat(expected);
        case '>=': return parseFloat(actual) >= parseFloat(expected);
        case '<=': return parseFloat(actual) <= parseFloat(expected);
      }
    }
    return false;
  }

  function splitByKw(expr, kw) {
    const parts = []; let depth = 0, last = 0;
    for (let i = 0; i < expr.length; i++) {
      if (expr[i]==='(') depth++; else if (expr[i]===')') depth--;
      else if (depth===0 && expr.slice(i).toLowerCase().startsWith(kw)) {
        parts.push(expr.slice(last,i).trim()); last = i+kw.length; i = last-1;
      }
    }
    parts.push(expr.slice(last).trim());
    return parts.length>1 ? parts : [expr];
  }

  // ---- 設問の表示可否 ----
  function isVisible(q) {
    if (!q.visibility_conditions || q.visibility_conditions.length===0) return true;
    return q.visibility_conditions.every(c =>
      c.type === 'pipe_expression' ? evalPipe(c.expression) : true
    );
  }

  // ---- <ans> 差し込み ----
  function applyAns(text, parsed) {
    if (!parsed || !parsed.answerInsertions) return text;
    let result = text;
    for (const ins of parsed.answerInsertions) {
      const val = answerCtx.answers[ins.source.toLowerCase()];
      const display = Array.isArray(val) ? val.join('、') : String(val ?? '');
      result = result.replace(new RegExp(`<ans\\s+${ins.source}>`, 'gi'), display);
      result = result.replace(new RegExp(`\\{ans:${ins.source}\\}`, 'gi'), display);
    }
    return result;
  }

  // ---- <disable> による選択肢フィルタ ----
  function filterChoices(choices, parsed) {
    if (!parsed || !parsed.disableRules || !parsed.disableRules.length) return choices;
    return choices.filter(c => {
      const rule = parsed.disableRules.find(r => r.targetChoice === c.value);
      return !rule || !evalPipe(rule.condition);
    });
  }

  // ---- 次の質問コード決定 ----
  function resolveNext(q) {
    const rule = q.branch_rule;
    if (!rule) return null;
    if (rule.branches) {
      for (const b of rule.branches) {
        const latestAnswer = answerCtx.answers[q.question_code.toLowerCase()];
        const actual = String(latestAnswer ?? '');
        let matched = false;
        const w = b.when;
        if (w.equals !== undefined) {
          matched = actual === String(w.equals);
        } else if (w.includes !== undefined) {
          // multi_choice は配列で保持されるため配列メンバーシップで判定
          if (Array.isArray(latestAnswer)) {
            matched = latestAnswer.map(String).includes(String(w.includes));
          } else {
            matched = actual.includes(String(w.includes));
          }
        } else if (Array.isArray(w.any_of)) {
          matched = w.any_of.map(String).includes(actual);
        } else if (w.gte !== undefined) {
          matched = parseFloat(actual) >= Number(w.gte);
        } else if (w.lte !== undefined) {
          matched = parseFloat(actual) <= Number(w.lte);
        }
        if (matched) return b.next;
      }
    }
    return rule.default_next || null;
  }

  // ---- 設問文画像 HTML 生成 ----
  function questionTextImageHtml(q) {
    const img = q.question_config && q.question_config.question_text_image;
    if (!img) return '';
    // mainUrl (domain型) と url (シードSQL直書き) の両方に対応
    const mainUrl = img.mainUrl || img.url;
    if (!mainUrl) return '';
    const additionals = (img.additionalUrls || []).filter(u => u && u !== mainUrl);
    return `<div class="question-text-images">
      <img class="question-text-img" src="${esc(mainUrl)}" alt="${esc(img.alt || '')}" loading="lazy" onerror="this.style.display='none'" />
      ${additionals.map(u => `<img class="question-text-img" src="${esc(u)}" alt="" loading="lazy" onerror="this.style.display='none'" />`).join('')}
      ${img.caption ? `<p class="question-text-caption">${esc(img.caption)}</p>` : ''}
    </div>`;
  }

  // ---- 共通回答レイアウト（チャットモードのインライン送信ボタン付き） ----
  function buildAnswerLayout(q, answerHtml, showSubmitButton) {
    if (!showSubmitButton) return answerHtml;
    return `${answerHtml}
      <p class="chat-selection-error" data-sel-err="${esc(q.question_code)}"></p>
      <div class="chat-next-row">
        <button type="button" class="chat-next-btn" disabled>次へ →</button>
      </div>`;
  }

  // ---- 回答 UI HTML 生成（タイプ別、チャットモードからも呼び出す） ----
  function buildAnswerInputHtml(q, showSubmitButton = false) {
    const parsed = q.display_tags_parsed || {};
    const qType = q.question_type;
    console.log('[survey] question_type:', qType, '| code:', q.question_code);
    console.log('[survey] answer_options:', q.question_config?.options);
    let inputHtml = '';

    const cfg = q.question_config || {};
    const rawChoices = (cfg.options || []).map(o => ({
      value: o.value, label: o.label,
      imageUrl: o.imageUrl || '',
      imageUrls: o.imageUrls || [],
      title: o.title || '',
      description: o.description || '',
    }));
    const choices = filterChoices(rawChoices, parsed);

    const displayFormat = cfg.display_format || 'list';
    const gridCols = cfg.grid_cols || 2;
    const hasImages = choices.some(c => c.imageUrl || (c.imageUrls && c.imageUrls.length > 0));
    const choiceClass = hasImages ? 'choice-list has-images' : 'choice-list';

    function choiceImg(c) {
      if (!c.imageUrl) return '';
      return `<img class="choice-img" src="${esc(c.imageUrl)}" alt="" loading="lazy" onerror="this.style.display='none'" />`;
    }

    function choiceAdditionalImgs(c) {
      const additionals = (c.imageUrls || []).filter(u => u && u !== c.imageUrl);
      if (!additionals.length) return '';
      return `<div class="choice-extra-imgs">${additionals.map(u => `<img class="choice-extra-img" src="${esc(u)}" alt="" loading="lazy" onerror="this.style.display='none'" />`).join('')}</div>`;
    }

    function choiceListItem(inputEl, c) {
      return `<label class="choice-item${c.imageUrl ? ' has-img' : ''}">
        ${inputEl}
        ${choiceImg(c)}
        <span class="choice-label">${esc(c.label)}</span>
        ${c.description ? `<span class="choice-desc">${esc(c.description)}</span>` : ''}
        ${choiceAdditionalImgs(c)}
      </label>`;
    }

    if (['single_choice','text_with_image'].includes(qType)) {
      console.log('[survey] render_type: single_choice | choices:', choices.length);
      if (choices.length === 0) {
        console.warn('[survey] single_choice/text_with_image: no choices found, falling back to textarea');
        const ph = cfg.placeholder || '回答を入力してください';
        inputHtml = `<textarea class="free-text-input" data-code="${esc(q.question_code)}" rows="2" placeholder="${esc(ph)}"></textarea>
          <p style="font-size:11px;color:#e55;margin-top:4px;">※選択肢が設定されていません（管理画面で設定してください）</p>`;
      } else if (displayFormat === 'card' && hasImages) {
        const cols = Math.min(gridCols, 4);
        inputHtml = `<div class="card-grid" style="grid-template-columns:repeat(${cols},1fr);" data-type="single">` +
          choices.map(c => {
            const imgSrc = c.imageUrl || (c.imageUrls && c.imageUrls[0]) || '';
            const additionals = (c.imageUrls || []).filter(u => u && u !== imgSrc);
            return `<label class="card-item">
              <input type="radio" name="q_${esc(q.question_code)}" value="${esc(c.value)}" style="display:none" />
              ${imgSrc ? `<img class="card-item-img" src="${esc(imgSrc)}" alt="" loading="lazy" onerror="this.style.display='none'" />` : ''}
              <span class="card-item-title">${esc(c.title || c.label)}</span>
              ${c.description ? `<span class="card-item-desc">${esc(c.description)}</span>` : ''}
              ${additionals.length ? `<div class="card-extra-imgs">${additionals.map(u => `<img class="card-extra-img" src="${esc(u)}" alt="" loading="lazy" onerror="this.style.display='none'" />`).join('')}</div>` : ''}
            </label>`;
          }).join('') + `</div>`;
      } else {
        inputHtml = `<div class="${choiceClass}" data-type="single">` +
          choices.map(c => choiceListItem(`<input type="radio" name="q_${esc(q.question_code)}" value="${esc(c.value)}" />`, c)).join('') + `</div>`;
      }
    } else if (qType === 'multi_choice') {
      console.log('[survey] render_type: multi_choice | choices:', choices.length);
      if (choices.length === 0) {
        console.warn('[survey] multi_choice: no choices found, falling back to textarea');
        const ph = cfg.placeholder || '回答を入力してください';
        inputHtml = `<textarea class="free-text-input" data-code="${esc(q.question_code)}" rows="2" placeholder="${esc(ph)}"></textarea>
          <p style="font-size:11px;color:#e55;margin-top:4px;">※選択肢が設定されていません（管理画面で設定してください）</p>`;
      } else if (displayFormat === 'card' && hasImages) {
        const cols = Math.min(gridCols, 4);
        inputHtml = `<div class="card-grid" style="grid-template-columns:repeat(${cols},1fr);" data-type="multi">` +
          choices.map(c => {
            const imgSrc = c.imageUrl || (c.imageUrls && c.imageUrls[0]) || '';
            const additionals = (c.imageUrls || []).filter(u => u && u !== imgSrc);
            return `<label class="card-item">
              <input type="checkbox" name="q_${esc(q.question_code)}" value="${esc(c.value)}" style="display:none" />
              ${imgSrc ? `<img class="card-item-img" src="${esc(imgSrc)}" alt="" loading="lazy" onerror="this.style.display='none'" />` : ''}
              <span class="card-item-title">${esc(c.title || c.label)}</span>
              ${c.description ? `<span class="card-item-desc">${esc(c.description)}</span>` : ''}
              ${additionals.length ? `<div class="card-extra-imgs">${additionals.map(u => `<img class="card-extra-img" src="${esc(u)}" alt="" loading="lazy" onerror="this.style.display='none'" />`).join('')}</div>` : ''}
            </label>`;
          }).join('') + `</div>`;
      } else {
        inputHtml = `<div class="${choiceClass}" data-type="multi">` +
          choices.map(c => choiceListItem(`<input type="checkbox" name="q_${esc(q.question_code)}" value="${esc(c.value)}" />`, c)).join('') + `</div>`;
      }
    } else if (['numeric', 'sd'].includes(qType)) {
      if (cfg.options && cfg.options.length > 0) {
        inputHtml = `<div class="scale-row">` +
          cfg.options.map(o => `<button type="button" class="scale-btn" data-val="${esc(o.value)}" data-code="${esc(q.question_code)}">${esc(o.label || o.value)}</button>`).join('') +
          `</div>`;
      } else {
        const mn = cfg.min || 1;
        const mx = cfg.max || 5;
        const nums = [];
        for (let i = mn; i <= mx; i++) nums.push(i);
        const minLabel = cfg.min_label ? `<span style="font-size:11px;color:#60726f;">${esc(cfg.min_label)}</span>` : '';
        const maxLabel = cfg.max_label ? `<span style="font-size:11px;color:#60726f;">${esc(cfg.max_label)}</span>` : '';
        inputHtml = `<div class="scale-row">` +
          nums.map(n => `<button type="button" class="scale-btn" data-val="${n}" data-code="${esc(q.question_code)}">${n}</button>`).join('') +
          `</div>` +
          (minLabel || maxLabel ? `<div style="display:flex;justify-content:space-between;margin-top:4px;">${minLabel}${maxLabel}</div>` : '');
      }
    } else if (['matrix_single','matrix_multi','matrix_mixed'].includes(qType)) {
      const matrixRows = (q.question_config?.matrix_rows || q.question_config?.options || []);
      const colObjects = (q.question_config?.matrix_cols || []).map(c => typeof c === 'string' ? { label: c, value: c } : c);
      const cols = colObjects.map(c => c.label || c);
      const headerMode = cfg.matrix_header_mode || 'normal';
      const headerClass = headerMode === 'vertical' ? 'matrix-header-vertical'
                        : headerMode === 'rotated'  ? 'matrix-header-rotated'
                        : '';
      inputHtml = `<div class="matrix-table-wrap"><table class="matrix-table ${headerClass}"><tr><th></th>` +
        colObjects.map(c => {
          const label = c.label || c;
          const imgUrl = c.imageUrl || (c.imageUrls && c.imageUrls[0]) || '';
          const colDesc = c.description || '';
          if (imgUrl || colDesc) {
            return `<th><div style="display:flex;flex-direction:column;align-items:center;gap:4px;">${imgUrl ? `<img src="${esc(imgUrl)}" alt="" style="max-width:60px;max-height:40px;border-radius:4px;" onerror="this.style.display='none'" />` : ''}<span>${esc(label)}</span>${colDesc ? `<span style="font-size:10px;color:#60726f;">${esc(colDesc)}</span>` : ''}</div></th>`;
          }
          return `<th>${esc(label)}</th>`;
        }).join('') + `</tr>` +
        matrixRows.map((row, ri) => {
          const rowLabel = row.label || '';
          const rowDesc = row.description || '';
          const rowImgs = (row.imageUrls && row.imageUrls.length > 0)
            ? row.imageUrls
            : (row.imageUrl ? [row.imageUrl] : []);
          let cellHtml = `<span>${esc(rowLabel)}</span>`;
          if (rowImgs.length > 1) {
            cellHtml = `<div class="matrix-row-cell">
              <span>${esc(rowLabel)}</span>
              <div class="matrix-row-imgs">
                ${rowImgs.map(u => `<img class="matrix-row-img" src="${esc(u)}" alt="" loading="lazy" onerror="this.style.display='none'" />`).join('')}
              </div>
              ${rowDesc ? `<span class="matrix-row-desc">${esc(rowDesc)}</span>` : ''}
            </div>`;
          } else if (rowImgs.length === 1) {
            cellHtml = `<div class="matrix-row-cell">
              <span>${esc(rowLabel)}</span>
              <img class="matrix-row-img" src="${esc(rowImgs[0])}" alt="" loading="lazy" onerror="this.style.display='none'" />
              ${rowDesc ? `<span class="matrix-row-desc">${esc(rowDesc)}</span>` : ''}
            </div>`;
          } else if (rowDesc) {
            cellHtml = `<div class="matrix-row-cell">
              <span>${esc(rowLabel)}</span>
              <span class="matrix-row-desc">${esc(rowDesc)}</span>
            </div>`;
          }
          return `<tr><td>${cellHtml}</td>` +
            cols.map((_c, ci) => `<td><input type="${qType==='matrix_multi'?'checkbox':'radio'}" name="mq_${esc(q.question_code)}_${ri}" value="${ci}" /></td>`).join('') +
            `</tr>`;
        }).join('') + `</table></div>`;
    } else if (FREE_TEXT_TYPES.has(qType)) {
      const ph = cfg.placeholder || '回答を入力してください';
      const maxLen = cfg.max_length || cfg.maxLength || '';
      if (FREE_TEXT_SHORT_TYPES.has(qType)) {
        // 短文自由記述 → input[type=text]
        inputHtml = `<input type="text" class="free-text-input" data-code="${esc(q.question_code)}" placeholder="${esc(ph)}"${maxLen ? ` maxlength="${maxLen}"` : ''} />`;
      } else {
        // 長文自由記述 → textarea
        const rows = parsed.rows || 4;
        inputHtml = `<textarea class="free-text-input" data-code="${esc(q.question_code)}" rows="${rows}" placeholder="${esc(ph)}"${maxLen ? ` maxlength="${maxLen}"` : ''}></textarea>`;
      }
    } else if (qType === 'image_upload') {
      const uploadCfg = cfg.image_upload_config || {};
      const maxCount = uploadCfg.max_count || 1;
      const allowedTypes = (uploadCfg.allowed_types || ['image/jpeg','image/png','image/webp']).join(',');
      const instructions = uploadCfg.instructions || '';
      const maxSizeMb = uploadCfg.max_size_mb || 10;
      const textMode = uploadCfg.text_input_mode || 'optional';
      const textPlaceholder = '画像について補足があれば入力してください';
      const textAreaHtml = textMode !== 'hidden'
        ? `<textarea class="image-text-input" data-img-text-code="${esc(q.question_code)}"
            rows="3" placeholder="${esc(textPlaceholder)}"
            style="width:100%;margin-top:10px;padding:8px;border:1px solid #c8d8d5;border-radius:8px;font-size:14px;resize:vertical;box-sizing:border-box;"></textarea>
           ${textMode === 'required' ? `<p class="image-text-error" data-img-text-err="${esc(q.question_code)}" style="display:none;color:#e53e3e;font-size:13px;margin-top:4px;">補足テキストを入力してください</p>` : ''}`
        : '';
      inputHtml = `<div class="upload-area" data-code="${esc(q.question_code)}"
          data-max-count="${maxCount}" data-max-size-mb="${maxSizeMb}" data-allowed="${esc(allowedTypes)}"
          data-text-mode="${esc(textMode)}">
          <input type="file" class="upload-file-input" accept="${esc(allowedTypes)}"
            ${maxCount > 1 ? 'multiple' : ''} style="display:none" />
          <p style="font-size:28px;margin:0;">📷</p>
          <p style="font-size:14px;font-weight:600;margin:4px 0;">タップして画像を選択</p>
          ${instructions ? `<p class="upload-instructions">${esc(instructions)}</p>` : ''}
          <p class="upload-instructions">最大 ${maxCount} 枚 / 1枚 ${maxSizeMb}MB まで</p>
          <div class="upload-preview-grid"></div>
          <p class="upload-loading" style="display:none">アップロード中...</p>
          <p class="upload-error" style="display:none"></p>
        </div>${textAreaHtml}`;
    } else if (['hidden_single', 'hidden_multi'].includes(qType)) {
      const defVal = qType === 'hidden_multi'
        ? JSON.stringify(cfg.default_values || [])
        : (cfg.default_value || '');
      inputHtml = `<input type="hidden" data-code="${esc(q.question_code)}" value="${esc(defVal)}" />
        <p style="font-size:13px;color:#60726f;margin:4px 0;">（システム設定項目）</p>`;
    } else {
      console.warn('[survey] unknown question_type:', qType);
      const ph = cfg.placeholder || '回答を入力してください';
      inputHtml = `<textarea class="free-text-input" data-code="${esc(q.question_code)}" rows="3" placeholder="${esc(ph)}"></textarea>`;
    }

    // hidden系のみボタン不要（自由記述系はインライン「次へ」ボタンで送信）
    const NO_BUTTON_TYPES = ['hidden_single', 'hidden_multi'];
    return buildAnswerLayout(q, inputHtml, showSubmitButton && !NO_BUTTON_TYPES.includes(qType));
  }

  // ---- 設問カード HTML 生成 ----
  function renderQuestion(q, index, total) {
    const parsed = q.display_tags_parsed || {};
    const qText  = applyAns(q.question_text, parsed);
    const commentTop    = q.comment_top    ? `<p class="comment-top">${esc(q.comment_top)}</p>` : '';
    const commentBottom = q.comment_bottom ? `<p class="comment-bottom">${esc(q.comment_bottom)}</p>` : '';
    const reqBadge = q.is_required ? '<span class="required-badge">必須</span>' : '';
    const inputHtml = buildAnswerInputHtml(q);
    const numLabel = total ? `Q${index+1} / ${total}` : `Q${index+1}`;
    return `<div class="question-card" data-code="${esc(q.question_code)}">
      <p class="question-number">${numLabel}${reqBadge}</p>
      ${commentTop}
      <p class="question-text">${esc(qText)}</p>
      ${questionTextImageHtml(q)}
      ${commentBottom}
      ${inputHtml}
    </div>`;
  }

  // ---- エスケープ ----
  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ---- image_upload 補足テキストの必須チェック ----
  function isImageTextRequired(q) {
    return q.question_config?.image_upload_config?.text_input_mode === 'required';
  }
  function isImageTextAnswered(q) {
    const text = answerCtx.imageTexts[q.question_code.toLowerCase()] || '';
    return text.trim().length > 0;
  }

  // ---- 選択肢・スケール系タイプ（値が入れば OK、定型文チェック不要） ----
  const CHOICE_TYPES = [
    'single_choice', 'multi_choice', 'text_with_image',
    'matrix_single', 'matrix_multi', 'matrix_mixed',
    'numeric', 'sd',
  ];
  // image_upload はファイル添付後に URL 配列を answerCtx に格納
  const IMAGE_UPLOAD_TYPES = ['image_upload'];

  // ---- image_upload ヘルパー ----
  async function uploadImageToServer(file, questionCode) {
    const base64 = await new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result.split(',')[1]);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
    const resp = await fetch('/liff/survey/upload-image', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        session_id: SESSION_ID,
        assignment_id: ASSIGNMENT_ID,
        data: base64,
        filename: file.name,
        mimeType: file.type,
      }),
    });
    const json = await resp.json().catch(() => ({}));
    if (!resp.ok || !json.url) throw new Error(json.error || 'upload failed');
    return json.url;
  }

  function addUploadThumb(container, url, questionCode, errorEl) {
    const wrap = document.createElement('div');
    wrap.className = 'upload-thumb-wrap';
    wrap.innerHTML = `<img class="upload-thumb" src="${url}" alt="" loading="lazy" />
      <button type="button" class="upload-thumb-del" title="削除">✕</button>`;
    wrap.querySelector('.upload-thumb-del').addEventListener('click', (e) => {
      e.stopPropagation();
      wrap.remove();
      const urls = answerCtx.answers[questionCode.toLowerCase()] || [];
      const idx = urls.indexOf(url);
      if (idx >= 0) urls.splice(idx, 1);
      answerCtx.answers[questionCode.toLowerCase()] = urls;
      if (errorEl) hideUploadError(errorEl);
      checkNextEnabled();
    });
    container.appendChild(wrap);
  }

  function showUploadError(el, msg) {
    if (!el) return;
    el.textContent = msg;
    el.style.display = '';
  }
  function hideUploadError(el) {
    if (!el) return;
    el.style.display = 'none';
    el.textContent = '';
  }

  // ---- 回答送信 ----
  async function submitAnswer(questionCode, answerValue) {
    console.log('SUBMIT_START', { questionCode });
    console.log('INPUT_VALUE', answerValue);
    answerCtx.answers[questionCode.toLowerCase()] = answerValue;

    const q = QUESTIONS.find(qq => qq.question_code === questionCode);
    const qType = q ? q.question_type : '';
    const isTextType = q && !CHOICE_TYPES.includes(qType) && !IMAGE_UPLOAD_TYPES.includes(qType);
    const freeText = isTextType ? String(answerValue || '') : '';

    let normalizedAnswer = null;
    let freeTextOverride = null;
    if (IMAGE_UPLOAD_TYPES.includes(qType) && Array.isArray(answerValue)) {
      const supplementText = answerCtx.imageTexts[questionCode.toLowerCase()] || '';
      const textMode = q?.question_config?.image_upload_config?.text_input_mode || 'hidden';
      if (textMode !== 'hidden' && supplementText) {
        normalizedAnswer = { type: 'image_upload', imageUrls: answerValue, text: supplementText };
        freeTextOverride = supplementText;
      } else {
        normalizedAnswer = { type: 'image_upload', imageUrls: answerValue };
      }
    }

    try {
      const response = await fetch('/liff/survey/answer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          session_id: SESSION_ID,
          assignment_id: ASSIGNMENT_ID,
          question_code: questionCode,
          answer_value: Array.isArray(answerValue)
            ? answerValue.join(',')
            : (answerValue !== null && typeof answerValue === 'object'
                ? JSON.stringify(answerValue)
                : answerValue),
          free_text_answer: freeTextOverride !== null ? freeTextOverride : freeText,
          normalized_answer: normalizedAnswer,
        }),
      });
      const data = await response.json().catch(() => ({}));
      console.log('API_RESPONSE', data);
    } catch(e) {
      console.error('answer submit failed', e);
    }
  }

  // ================================================================
  // survey_question / survey_page モード
  // ================================================================
  if (DISPLAY_MODE !== 'interview_chat') {
    const pages = DISPLAY_MODE === 'survey_page'
      ? groupByPage(QUESTIONS)
      : QUESTIONS.filter(isVisible).map(q => ({ pageGroup: null, questions: [q] }));

    const visiblePages = DISPLAY_MODE === 'survey_page'
      ? pages
      : null; // survey_question は再評価する

    let visibleQs = QUESTIONS.filter(isVisible);
    let cursor = 0; // 現在の質問 index (survey_question)
    let pageCursor = 0; // 現在のページ index (survey_page)

    const questionArea = document.getElementById('questionArea');
    const btnNext = document.getElementById('btnNext');
    const btnBack = document.getElementById('btnBack');
    const progressBar = document.getElementById('progressBar');
    const completeScreen = document.getElementById('completeScreen');

    // ---- 次へボタン押下前のバリデーション（表示中の設問のみ検証） ----
    function validateCurrentView() {
      try {
        let qs;
        if (DISPLAY_MODE === 'survey_page') {
          const allPages = groupByPage(QUESTIONS);
          const page = allPages.filter(p => p.questions.filter(isVisible).length > 0)[pageCursor];
          qs = page ? page.questions.filter(isVisible) : [];
        } else {
          qs = (visibleQs && visibleQs[cursor]) ? [visibleQs[cursor]] : [];
        }

        if (!qs || qs.length === 0) {
          console.warn('[survey] validateCurrentView: no visible questions');
          return true;
        }

        let valid = true;
        for (const q of qs) {
          if (!isQuestionAnswered(q)) {
            const inputEl = questionArea.querySelector(`[data-code="${q.question_code}"]`);
            const errEl = questionArea.querySelector(`[data-free-err="${q.question_code}"]`);
            if (inputEl) {
              if (q.question_type === 'image_upload') {
                const urls = answerCtx.answers[q.question_code.toLowerCase()];
                if (!(Array.isArray(urls) && urls.length > 0)) {
                  const errP = inputEl.querySelector('.upload-error');
                  if (errP) { errP.textContent = '画像を1枚以上追加してください。'; errP.style.display = ''; }
                } else if (isImageTextRequired(q) && !isImageTextAnswered(q)) {
                  const textErrEl = questionArea.querySelector(`[data-img-text-err="${q.question_code}"]`);
                  if (textErrEl) textErrEl.style.display = '';
                }
              } else {
                inputEl.classList.add('free-text-required');
              }
            }
            if (errEl) errEl.style.display = 'block';
            valid = false;
          }
        }
        return valid;
      } catch (e) {
        console.error('[survey] validateCurrentView error:', e);
        return true;
      }
    }

    function renderCurrentState() {
      if (DISPLAY_MODE === 'survey_page') {
        renderPageMode();
      } else {
        renderQuestionMode();
      }
    }

    function renderQuestionMode() {
      visibleQs = QUESTIONS.filter(isVisible); // 再評価
      if (cursor >= visibleQs.length) { showComplete(); return; }
      const q = visibleQs[cursor];
      questionArea.innerHTML = renderQuestion(q, cursor, visibleQs.length);
      bindInputEvents(q);
      btnBack.style.display = 'none';
      btnNext.disabled = true;
      progressBar.style.width = (cursor / visibleQs.length * 100) + '%';
      checkNextEnabled(); // 非必須・hidden 設問では即時活性化
    }

    function renderPageMode() {
      const allPages = groupByPage(QUESTIONS);
      const visiblePagesNow = allPages.map(p => ({
        ...p,
        questions: p.questions.filter(isVisible)
      })).filter(p => p.questions.length > 0);

      if (pageCursor >= visiblePagesNow.length) { showComplete(); return; }
      const page = visiblePagesNow[pageCursor];

      const pageIndicator = document.getElementById('pageIndicator');
      const pageTitle     = document.getElementById('pageTitle');
      if (pageIndicator) pageIndicator.textContent = `ページ ${pageCursor+1} / ${visiblePagesNow.length}`;
      if (pageTitle && page.pageGroup?.title) pageTitle.textContent = page.pageGroup.title;

      questionArea.innerHTML = page.questions
        .map((q, i) => renderQuestion(q, i, page.questions.length))
        .join('');
      page.questions.forEach(q => bindInputEvents(q));
      btnBack.style.display = 'none';
      btnNext.disabled = true;
      progressBar.style.width = (pageCursor / visiblePagesNow.length * 100) + '%';
      checkNextEnabled(); // 非必須・hidden 設問では即時活性化
    }

    function bindInputEvents(q) {
      // ---- 画像カードグリッド（click で label 全体を選択） ----
      questionArea.querySelectorAll('.card-item').forEach(card => {
        card.addEventListener('click', (e) => {
          if (e.target.tagName === 'INPUT') return;
          const input = card.querySelector('input');
          if (!input) return;
          if (input.type === 'radio') {
            questionArea.querySelectorAll('.card-item').forEach(c => c.classList.remove('selected'));
            input.checked = true;
            card.classList.add('selected');
          } else {
            input.checked = !input.checked;
            card.classList.toggle('selected', input.checked);
          }
          const qType = q.question_type;
          let val;
          if (qType === 'multi_choice') {
            val = [...questionArea.querySelectorAll(`input[name="q_${q.question_code}"]:checked`)].map(e => e.value);
          } else {
            const checked = questionArea.querySelector(`input[name="q_${q.question_code}"]:checked`);
            val = checked ? checked.value : '';
          }
          answerCtx.answers[q.question_code.toLowerCase()] = val;
          checkNextEnabled();
        });
      });

      // ---- image_upload ----
      const uploadArea = questionArea.querySelector(`.upload-area[data-code="${q.question_code}"]`);
      if (uploadArea) {
        const fileInput = uploadArea.querySelector('.upload-file-input');
        const previewGrid = uploadArea.querySelector('.upload-preview-grid');
        const loadingEl = uploadArea.querySelector('.upload-loading');
        const errorEl = uploadArea.querySelector('.upload-error');
        const maxCount = parseInt(uploadArea.dataset.maxCount || '1', 10);
        const maxSizeMb = parseFloat(uploadArea.dataset.maxSizeMb || '10');
        const allowedTypes = (uploadArea.dataset.allowed || '').split(',').filter(Boolean);

        uploadArea.addEventListener('click', (e) => {
          if (e.target === fileInput || e.target.classList.contains('upload-thumb-del')) return;
          fileInput.click();
        });

        fileInput.addEventListener('change', async () => {
          const files = [...fileInput.files];
          fileInput.value = '';
          if (!files.length) return;

          const currentUrls = answerCtx.answers[q.question_code.toLowerCase()] || [];
          if (currentUrls.length + files.length > maxCount) {
            showUploadError(errorEl, `最大 ${maxCount} 枚までアップロードできます。`);
            return;
          }
          hideUploadError(errorEl);

          for (const file of files) {
            if (allowedTypes.length && !allowedTypes.includes(file.type)) {
              showUploadError(errorEl, `${file.name}: 対応していないファイル形式です。`);
              continue;
            }
            if (file.size > maxSizeMb * 1024 * 1024) {
              showUploadError(errorEl, `${file.name}: ファイルサイズが${maxSizeMb}MBを超えています。`);
              continue;
            }

            loadingEl.style.display = '';
            try {
              const url = await uploadImageToServer(file, q.question_code);
              const urls = answerCtx.answers[q.question_code.toLowerCase()] || [];
              urls.push(url);
              answerCtx.answers[q.question_code.toLowerCase()] = urls;
              addUploadThumb(previewGrid, url, q.question_code, errorEl);
              checkNextEnabled();
            } catch(err) {
              showUploadError(errorEl, `アップロード失敗: ${err.message}`);
            } finally {
              loadingEl.style.display = 'none';
            }
          }
        });

        // image-text-input (補足テキスト)
        const imgTextEl = questionArea.querySelector(`.image-text-input[data-img-text-code="${q.question_code}"]`);
        if (imgTextEl) {
          imgTextEl.addEventListener('input', () => {
            answerCtx.imageTexts[q.question_code.toLowerCase()] = imgTextEl.value;
            const errEl = questionArea.querySelector(`[data-img-text-err="${q.question_code}"]`);
            if (errEl) errEl.style.display = 'none';
            checkNextEnabled();
          });
        }
      }

      // radio/checkbox
      questionArea.querySelectorAll(`input[name="q_${q.question_code}"]`).forEach(el => {
        el.addEventListener('change', () => {
          const qType = q.question_type;
          let val;
          if (qType === 'multi_choice') {
            val = [...questionArea.querySelectorAll(`input[name="q_${q.question_code}"]:checked`)].map(e => e.value);
            // チェックボックスは個別に toggle（全解除してから追加すると他の選択が消える）
            el.closest('label')?.classList.toggle('selected', el.checked);
          } else {
            val = el.value;
            // ラジオは排他選択なので全解除→選択項目のみ追加
            questionArea.querySelectorAll(`label.choice-item`).forEach(l => l.classList.remove('selected'));
            el.closest('label')?.classList.add('selected');
          }
          answerCtx.answers[q.question_code.toLowerCase()] = val;
          checkNextEnabled();
        });
      });
      // scale buttons
      questionArea.querySelectorAll(`.scale-btn[data-code="${q.question_code}"]`).forEach(btn => {
        btn.addEventListener('click', () => {
          questionArea.querySelectorAll(`.scale-btn[data-code="${q.question_code}"]`).forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          answerCtx.answers[q.question_code.toLowerCase()] = btn.dataset.val;
          checkNextEnabled();
        });
      });
      // matrix inputs（mq_<code>_<rowIndex> という name を使う）
      if (['matrix_single','matrix_multi','matrix_mixed'].includes(q.question_type)) {
        const matrixRows = q.question_config?.matrix_rows || q.question_config?.options || [];
        questionArea.querySelectorAll(`input[name^="mq_${q.question_code}_"]`).forEach(input => {
          input.addEventListener('change', () => {
            const answer = {};
            matrixRows.forEach((_, ri) => {
              const checked = [...questionArea.querySelectorAll(`input[name="mq_${q.question_code}_${ri}"]:checked`)];
              if (checked.length > 0) {
                answer[ri] = q.question_type === 'matrix_multi'
                  ? checked.map(i => i.value)
                  : checked[0].value;
              }
            });
            answerCtx.answers[q.question_code.toLowerCase()] = answer;
            checkNextEnabled();
          });
        });
      }
      // hidden_single / hidden_multi: デフォルト値を answerCtx に設定
      if (['hidden_single', 'hidden_multi'].includes(q.question_type)) {
        const hiddenEl = questionArea.querySelector(`input[type="hidden"][data-code="${q.question_code}"]`);
        if (hiddenEl) {
          const raw = hiddenEl.value;
          answerCtx.answers[q.question_code.toLowerCase()] =
            q.question_type === 'hidden_multi'
              ? (raw ? JSON.parse(raw) : [])
              : raw;
        }
      }

      // text inputs
      questionArea.querySelectorAll(`[data-code="${q.question_code}"]`).forEach(el => {
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          if (el.type === 'hidden') return; // hidden は input イベントなし
          el.addEventListener('input', () => {
            answerCtx.answers[q.question_code.toLowerCase()] = el.value;
            el.classList.remove('free-text-required');
            checkNextEnabled();
          });
        }
      });
    }

    function isQuestionAnswered(q) {
      // 非必須・hidden系は常に通過
      if (!q.is_required) return true;
      if (['hidden_single', 'hidden_multi'].includes(q.question_type)) return true;

      const val = answerCtx.answers[q.question_code.toLowerCase()];
      const qType = q.question_type;
      if (IMAGE_UPLOAD_TYPES.includes(qType)) {
        if (!(Array.isArray(val) && val.length > 0)) return false;
        if (isImageTextRequired(q) && !isImageTextAnswered(q)) return false;
        return true;
      }
      // マトリクス: 全行に少なくとも1つの選択が必要
      if (['matrix_single','matrix_multi','matrix_mixed'].includes(qType)) {
        if (!val || typeof val !== 'object' || Array.isArray(val)) return false;
        const rows = q.question_config?.matrix_rows || q.question_config?.options || [];
        if (rows.length === 0) return false;
        return rows.every((_, ri) => {
          const rv = val[ri];
          return rv !== undefined && rv !== null && (!Array.isArray(rv) || rv.length > 0);
        });
      }
      const isChoiceType = CHOICE_TYPES.includes(qType);
      if (isChoiceType) {
        // 選択肢・スケール系は何か選んでいればOK
        return val !== undefined && val !== null && val !== '' && (!Array.isArray(val) || val.length > 0);
      }
      // テキスト系は定型文禁止の入力チェック
      return isFreeTextValid(String(val || ''));
    }

    function checkNextEnabled() {
      if (DISPLAY_MODE === 'survey_page') {
        const allPages = groupByPage(QUESTIONS);
        const page = allPages.filter(p => p.questions.filter(isVisible).length > 0)[pageCursor];
        if (!page) { btnNext.disabled = false; return; }
        btnNext.disabled = !page.questions.filter(isVisible).every(isQuestionAnswered);
      } else {
        const q = visibleQs[cursor];
        if (!q) { btnNext.disabled = false; return; }
        btnNext.disabled = !isQuestionAnswered(q);
      }
    }

    // probe 状態管理（survey_question モード用）
    let probeActiveQ = null;
    let probeNextCursor = null;
    const probeArea     = document.getElementById('probeArea');
    const probeQuestionText = document.getElementById('probeQuestionText');
    const probeAnswerInput  = document.getElementById('probeAnswerInput');
    const probeSubmitBtn    = document.getElementById('probeSubmitBtn');

    probeAnswerInput.addEventListener('input', () => {
      probeSubmitBtn.disabled = probeAnswerInput.value.trim() === '';
    });

    async function checkAndShowProbe(q, val, nextCursor) {
      if (!q.ai_probe_enabled) return false;
      try {
        const res = await fetch('/liff/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ session_id: SESSION_ID, message: String(val || '') })
        });
        const data = await res.json().catch(() => ({}));
        console.log('PROBE_RESPONSE', data);
        if (data.probe_question) {
          probeActiveQ = q;
          probeNextCursor = nextCursor;
          probeQuestionText.textContent = data.probe_question;
          probeAnswerInput.value = '';
          probeSubmitBtn.disabled = true;
          probeArea.style.display = '';
          btnNext.disabled = true;
          btnBack.style.display = 'none';
          return true;
        }
      } catch(e) { console.error('probe check failed', e); }
      return false;
    }

    probeSubmitBtn.addEventListener('click', async () => {
      const probeText = probeAnswerInput.value.trim();
      if (!probeText || !probeActiveQ) return;
      probeSubmitBtn.disabled = true;
      await submitAnswer(probeActiveQ.question_code, probeText);
      probeArea.style.display = 'none';
      probeActiveQ = null;
      cursor = probeNextCursor;
      probeNextCursor = null;
      renderQuestionMode();
    });

    btnNext.addEventListener('click', async () => {
      try {
        if (!validateCurrentView()) return;
      } catch (e) {
        console.error('[survey] Validation error:', e);
        return;
      }

      btnNext.disabled = true;

      if (DISPLAY_MODE === 'survey_page') {
        const allPages = groupByPage(QUESTIONS);
        const page = allPages.filter(p => p.questions.filter(isVisible).length > 0)[pageCursor];
        if (page) {
          for (const q of page.questions.filter(isVisible)) {
            const val = answerCtx.answers[q.question_code.toLowerCase()];
            if (val !== undefined) await submitAnswer(q.question_code, val);
          }
        }
        pageCursor++;
        renderPageMode();
      } else {
        const q = visibleQs[cursor];
        if (q) {
          const val = answerCtx.answers[q.question_code.toLowerCase()];
          await submitAnswer(q.question_code, val);
          const nextCode = resolveNext(q);
          console.log('NEXT_QUESTION_ID', nextCode ?? '(end)');
          let nextCursor;
          if (nextCode) {
            const nextIdx = QUESTIONS.findIndex(qq => qq.question_code === nextCode);
            nextCursor = nextIdx >= 0 ? nextIdx : cursor + 1;
          } else {
            nextCursor = cursor + 1;
          }
          const probeShown = await checkAndShowProbe(q, val, nextCursor);
          if (probeShown) return;
          cursor = nextCursor;
        }
        renderQuestionMode();
      }
    });

    btnBack.addEventListener('click', () => {
      if (DISPLAY_MODE === 'survey_page') {
        if (pageCursor > 0) { pageCursor--; renderPageMode(); }
      } else {
        if (cursor > 0) { cursor--; renderQuestionMode(); }
      }
    });

    async function showComplete() {
      // スクリーニングフェーズ: 判定API → 境界画面を表示
      if (SURVEY_PHASE === 'screening') {
        questionArea.style.display = 'none';
        const navBtns = document.querySelector('.nav-btns');
        if (navBtns) navBtns.style.display = 'none';
        progressBar.style.width = '100%';

        // 確認中インジケータ
        const waitDiv = document.createElement('div');
        waitDiv.style.cssText = 'text-align:center;padding:40px 24px;';
        waitDiv.innerHTML = '<p style="font-size:16px;color:#555;">確認中...</p>';
        document.querySelector('.survey-container').appendChild(waitDiv);

        try {
          const judgeResp = await fetch('/liff/survey/' + ASSIGNMENT_ID + '/judge-screening', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session_id: SESSION_ID }),
          });
          const judgeData = await judgeResp.json();
          if (judgeData.judgement === 'pass') {
            // 通過: 境界画面 → 本アンケートへ進むボタン
            waitDiv.innerHTML = `
              <div class="screening-boundary">
                <div class="screening-boundary-icon">&#x2705;</div>
                <p class="screening-boundary-title">ご協力ありがとうございます。<br>条件確認が完了しました。</p>
                <p class="screening-boundary-sub">これより本アンケートを開始します。</p>
                <button class="screening-boundary-btn" onclick="window.location.reload()">本アンケートへ進む</button>
              </div>`;
          } else {
            // 非通過: 終了メッセージ
            waitDiv.innerHTML = `
              <div class="screening-boundary">
                <div class="screening-boundary-icon">&#x1F64F;</div>
                <p class="screening-boundary-title">ご協力ありがとうございました。</p>
                <p class="screening-boundary-sub">${SCREENING_FAIL_MESSAGE}</p>
              </div>`;
          }
        } catch(e) {
          console.error('judge-screening failed', e);
          waitDiv.innerHTML = '<p style="color:red;text-align:center;padding:24px;">判定に失敗しました。ページを再読み込みしてください。</p>';
        }
        return;
      }

      questionArea.style.display = 'none';
      document.querySelector('.nav-btns').style.display = 'none';
      completeScreen.style.display = 'block';
      progressBar.style.width = '100%';

      const completeActions = document.getElementById('completeActions');
      const completeError = document.getElementById('completeError');
      const btnCloseLiff = document.getElementById('btnCloseLiff');
      const completeCloseTip = document.getElementById('completeCloseTip');

      try {
        const resp = await fetch('/liff/survey/' + ASSIGNMENT_ID + '/complete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ session_id: SESSION_ID }),
        });
        if (!resp.ok) throw new Error('complete API error');

        completeActions.style.display = 'block';
        const inLiff = window.liff && typeof liff.isInClient === 'function' && liff.isInClient();
        if (inLiff) {
          btnCloseLiff.style.display = '';
          btnCloseLiff.addEventListener('click', () => { liff.closeWindow(); });
        } else {
          btnCloseLiff.style.display = 'none';
          completeCloseTip.style.display = '';
        }
      } catch(e) {
        console.error('complete failed', e);
        completeError.style.display = '';
      }
    }

    try {
      console.log('[survey] renderCurrentState start, displayMode=', DISPLAY_MODE, 'questions=', QUESTIONS.length);
      renderCurrentState();
      console.log('[survey] renderCurrentState done');
    } catch(e) {
      console.error('[survey] renderCurrentState error', e);
      throw e;
    }
  }

  // ================================================================
  // interview_chat モード
  // ================================================================
  if (DISPLAY_MODE === 'interview_chat') {
    const chatMessages   = document.getElementById('chatMessages');
    const chatInput      = document.getElementById('chatInput');
    const chatSend       = document.getElementById('chatSend');
    const chatAnswerArea = document.getElementById('chatAnswerArea');
    const chatTextRow    = document.getElementById('chatTextRow');
    const chatNextRow    = document.getElementById('chatNextRow');
    const chatNext       = document.getElementById('chatNext');

    let chatQueueIndex = 0;
    const visibleQs = QUESTIONS.filter(isVisible);

    function scrollToBottom() {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function addBubble(text, role) {
      const wrap = document.createElement('div');
      wrap.className = `chat-bubble-wrap ${role}`;
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble ${role}`;
      bubble.textContent = text;
      wrap.appendChild(bubble);
      chatMessages.appendChild(wrap);
      scrollToBottom();
    }

    // ---- チャットモードで回答済みか判定 ----
    function isChatAnswered(q) {
      if (!q.is_required) return true;
      if (['hidden_single', 'hidden_multi'].includes(q.question_type)) return true;
      const val = answerCtx.answers[q.question_code.toLowerCase()];
      const qType = q.question_type;
      if (IMAGE_UPLOAD_TYPES.includes(qType)) {
        if (!(Array.isArray(val) && val.length > 0)) return false;
        if (isImageTextRequired(q) && !isImageTextAnswered(q)) return false;
        return true;
      }
      if (['matrix_single','matrix_multi','matrix_mixed'].includes(qType)) {
        if (!val || typeof val !== 'object' || Array.isArray(val)) return false;
        const rows = q.question_config?.matrix_rows || q.question_config?.options || [];
        return rows.length > 0 && rows.every((_, ri) => {
          const rv = val[ri];
          return rv !== undefined && rv !== null && (!Array.isArray(rv) || rv.length > 0);
        });
      }
      if (CHOICE_TYPES.includes(qType)) {
        return val !== undefined && val !== null && val !== '' && (!Array.isArray(val) || val.length > 0);
      }
      return isFreeTextValid(String(val || ''));
    }

    function checkChatNextEnabled() {
      const q = visibleQs[chatQueueIndex];
      if (!q) return;
      const answered = isChatAnswered(q);
      chatNext.disabled = !answered;
      // 最新のインラインブロックの送信ボタンも更新
      const blocks = chatMessages.querySelectorAll('.chat-question-block');
      const latestBlock = blocks[blocks.length - 1];
      if (latestBlock) {
        const inlineBtn = latestBlock.querySelector('.chat-next-btn');
        if (inlineBtn) inlineBtn.disabled = !answered;
      }
    }

    // ---- 選択肢 UI イベントをバインド（chatAnswerArea スコープ） ----
    function bindChatAnswerEvents(q, root = chatAnswerArea) {
      const answerRoot = root;
      // image_upload
      const uploadArea = answerRoot.querySelector(`.upload-area[data-code="${q.question_code}"]`);
      if (uploadArea) {
        const fileInput    = uploadArea.querySelector('.upload-file-input');
        const previewGrid  = uploadArea.querySelector('.upload-preview-grid');
        const loadingEl    = uploadArea.querySelector('.upload-loading');
        const errorEl      = uploadArea.querySelector('.upload-error');
        const maxCount     = parseInt(uploadArea.dataset.maxCount || '1', 10);
        const maxSizeMb    = parseFloat(uploadArea.dataset.maxSizeMb || '10');
        const allowedTypes = (uploadArea.dataset.allowed || '').split(',').filter(Boolean);
        uploadArea.addEventListener('click', (e) => {
          if (e.target === fileInput || e.target.classList.contains('upload-thumb-del')) return;
          fileInput.click();
        });
        fileInput.addEventListener('change', async () => {
          const files = [...fileInput.files];
          fileInput.value = '';
          if (!files.length) return;
          const currentUrls = answerCtx.answers[q.question_code.toLowerCase()] || [];
          if (currentUrls.length + files.length > maxCount) {
            showUploadError(errorEl, `最大 ${maxCount} 枚までアップロードできます。`); return;
          }
          hideUploadError(errorEl);
          for (const file of files) {
            if (allowedTypes.length && !allowedTypes.includes(file.type)) {
              showUploadError(errorEl, `${file.name}: 対応していないファイル形式です。`); continue;
            }
            if (file.size > maxSizeMb * 1024 * 1024) {
              showUploadError(errorEl, `${file.name}: ファイルサイズが${maxSizeMb}MBを超えています。`); continue;
            }
            loadingEl.style.display = '';
            try {
              const url = await uploadImageToServer(file, q.question_code);
              const urls = answerCtx.answers[q.question_code.toLowerCase()] || [];
              urls.push(url);
              answerCtx.answers[q.question_code.toLowerCase()] = urls;
              addUploadThumb(previewGrid, url, q.question_code, errorEl);
              checkChatNextEnabled();
            } catch(err) {
              showUploadError(errorEl, `アップロード失敗: ${err.message}`);
            } finally {
              loadingEl.style.display = 'none';
            }
          }
        });

        // image-text-input (補足テキスト) - チャットモード
        const imgTextEl = answerRoot.querySelector(`.image-text-input[data-img-text-code="${q.question_code}"]`);
        if (imgTextEl) {
          imgTextEl.addEventListener('input', () => {
            answerCtx.imageTexts[q.question_code.toLowerCase()] = imgTextEl.value;
            checkChatNextEnabled();
          });
        }
      }

      // card-item (radio/checkbox with image)
      answerRoot.querySelectorAll('.card-item').forEach(card => {
        card.addEventListener('click', (e) => {
          if (e.target.tagName === 'INPUT') return;
          const input = card.querySelector('input');
          if (!input) return;
          if (input.type === 'radio') {
            answerRoot.querySelectorAll('.card-item').forEach(c => c.classList.remove('selected'));
            input.checked = true; card.classList.add('selected');
          } else {
            input.checked = !input.checked;
            card.classList.toggle('selected', input.checked);
          }
          let val;
          if (q.question_type === 'multi_choice') {
            val = [...answerRoot.querySelectorAll(`input[name="q_${q.question_code}"]:checked`)].map(e => e.value);
          } else {
            const checked = answerRoot.querySelector(`input[name="q_${q.question_code}"]:checked`);
            val = checked ? checked.value : '';
          }
          answerCtx.answers[q.question_code.toLowerCase()] = val;
          checkChatNextEnabled();
        });
      });

      // radio / checkbox (list style)
      answerRoot.querySelectorAll(`input[name="q_${q.question_code}"]`).forEach(el => {
        el.addEventListener('change', () => {
          let val;
          if (q.question_type === 'multi_choice') {
            val = [...answerRoot.querySelectorAll(`input[name="q_${q.question_code}"]:checked`)].map(e => e.value);
            el.closest('label')?.classList.toggle('selected', el.checked);
          } else {
            val = el.value;
            answerRoot.querySelectorAll('label.choice-item').forEach(l => l.classList.remove('selected'));
            el.closest('label')?.classList.add('selected');
          }
          answerCtx.answers[q.question_code.toLowerCase()] = val;
          checkChatNextEnabled();
        });
      });

      // scale buttons (numeric / sd)
      answerRoot.querySelectorAll(`.scale-btn[data-code="${q.question_code}"]`).forEach(btn => {
        btn.addEventListener('click', () => {
          answerRoot.querySelectorAll(`.scale-btn[data-code="${q.question_code}"]`).forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          answerCtx.answers[q.question_code.toLowerCase()] = btn.dataset.val;
          checkChatNextEnabled();
        });
      });

      // matrix inputs
      if (['matrix_single','matrix_multi','matrix_mixed'].includes(q.question_type)) {
        const matrixRows = q.question_config?.matrix_rows || q.question_config?.options || [];
        answerRoot.querySelectorAll(`input[name^="mq_${q.question_code}_"]`).forEach(input => {
          input.addEventListener('change', () => {
            const answer = {};
            matrixRows.forEach((_, ri) => {
              const checked = [...answerRoot.querySelectorAll(`input[name="mq_${q.question_code}_${ri}"]:checked`)];
              if (checked.length > 0) {
                answer[ri] = q.question_type === 'matrix_multi' ? checked.map(i => i.value) : checked[0].value;
              }
            });
            answerCtx.answers[q.question_code.toLowerCase()] = answer;
            checkChatNextEnabled();
          });
        });
      }

      // hidden default values
      if (['hidden_single', 'hidden_multi'].includes(q.question_type)) {
        const hiddenEl = answerRoot.querySelector(`input[type="hidden"][data-code="${q.question_code}"]`);
        if (hiddenEl) {
          const raw = hiddenEl.value;
          answerCtx.answers[q.question_code.toLowerCase()] =
            q.question_type === 'hidden_multi' ? (raw ? JSON.parse(raw) : []) : raw;
        }
      }

      // input/textarea（自由記述インライン入力）
      answerRoot.querySelectorAll(`[data-code="${q.question_code}"]`).forEach(el => {
        if ((el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') && el.type !== 'hidden') {
          el.addEventListener('input', () => {
            answerCtx.answers[q.question_code.toLowerCase()] = el.value;
            el.classList.remove('free-text-required');
            checkChatNextEnabled();
          });
          // input[type=text] は Enter キーで送信
          if (el.tagName === 'INPUT' && el.type !== 'hidden') {
            el.addEventListener('keydown', e => {
              if (e.key === 'Enter') {
                e.preventDefault();
                const btn = answerRoot.querySelector('.chat-next-btn');
                if (btn && !btn.disabled) btn.click();
              }
            });
          }
        }
      });

      // ---- インライン送信ボタン（全タイプ共通） ----
      const inlineSubmitBtn = answerRoot.querySelector('.chat-next-btn');
      if (inlineSubmitBtn) {
        inlineSubmitBtn.addEventListener('click', async () => {
          if (!isChatAnswered(q)) {
            const errEl = answerRoot.querySelector(`[data-sel-err="${q.question_code}"]`);
            if (errEl) { errEl.textContent = '選択してください'; errEl.style.display = ''; }
            return;
          }
          inlineSubmitBtn.disabled = true;
          const val = answerCtx.answers[q.question_code.toLowerCase()];
          await submitAnswer(q.question_code, val);
          freezeLatestQuestionBlock();

          // 表示テキスト生成
          const cfg = q.question_config || {};
          const opts = cfg.options || [];
          let displayText;
          if (Array.isArray(val)) {
            displayText = val.map(v => { const o = opts.find(o => o.value === v); return o ? o.label : v; }).join('、');
          } else if (val !== null && typeof val === 'object') {
            displayText = JSON.stringify(val);
          } else {
            const o = opts.find(o => String(o.value) === String(val));
            displayText = o ? o.label : String(val ?? '');
          }

          await advanceAfterAnswer(q, displayText);
        });
      }
    }

    // ---- 回答 UI を chatAnswerArea に描画 ----
    function renderChatAnswerArea(q) {
      chatAnswerArea.innerHTML = questionTextImageHtml(q) + buildAnswerInputHtml(q);
      chatAnswerArea.style.display = '';
      bindChatAnswerEvents(q);

      // hidden 系は即時通過（次へを有効化）
      if (['hidden_single', 'hidden_multi'].includes(q.question_type)) {
        checkChatNextEnabled();
      }
    }

    // ---- 次の質問を表示 ----
    function addQuestionBlock(q) {
      const parsed = q.display_tags_parsed || {};
      const qText = applyAns(q.question_text, parsed);
      const container = document.createElement('div');
      container.className = 'chat-question-block';
      container.innerHTML = `
        <div class="chat-bubble-wrap ai">
          <div class="chat-bubble ai">
            <div>${esc(qText)}</div>
            ${questionTextImageHtml(q)}
          </div>
        </div>
        <div class="chat-answer-inline">
          ${buildAnswerInputHtml(q, true)}
        </div>
      `;
      chatMessages.appendChild(container);
      const answerRoot = container.querySelector('.chat-answer-inline');
      bindChatAnswerEvents(q, answerRoot);
      scrollToBottom();

      if (['hidden_single', 'hidden_multi'].includes(q.question_type)) {
        checkChatNextEnabled();
      }
    }

    function freezeLatestQuestionBlock() {
      const blocks = chatMessages.querySelectorAll('.chat-question-block');
      const latestBlock = blocks[blocks.length - 1];
      if (!latestBlock) return;
      latestBlock.querySelectorAll('input, textarea, button').forEach(el => {
        el.disabled = true;
      });
    }

    function askCurrentQuestion() {
      if (chatQueueIndex >= visibleQs.length) {
        // スクリーニングフェーズ終了: judge-screening を呼んで境界メッセージを表示
        if (SURVEY_PHASE === 'screening') {
          chatAnswerArea.style.display = 'none';
          chatAnswerArea.innerHTML = '';
          chatTextRow.style.display = 'none';
          chatNextRow.style.display = 'none';
          (async () => {
            try {
              const judgeResp = await fetch('/liff/survey/' + ASSIGNMENT_ID + '/judge-screening', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ session_id: SESSION_ID }),
              });
              const judgeData = await judgeResp.json();
              if (judgeData.judgement === 'pass') {
                addBubble('条件確認が完了しました。ここから本アンケートを開始します。', 'ai');
                // ボタンを追加して本案件ページへ遷移
                const btnWrap = document.createElement('div');
                btnWrap.style.cssText = 'text-align:center;margin-top:16px;';
                const btn = document.createElement('button');
                btn.className = 'btn-next';
                btn.style.minWidth = '200px';
                btn.textContent = '本アンケートへ進む';
                btn.addEventListener('click', () => { window.location.reload(); });
                btnWrap.appendChild(btn);
                chatMessages.appendChild(btnWrap);
              } else {
                addBubble('今回は条件に合致しませんでした。ご協力ありがとうございました。', 'ai');
              }
              chatMessages.scrollTop = chatMessages.scrollHeight;
            } catch(e) {
              console.error('judge-screening failed', e);
              addBubble('判定に失敗しました。ページを再読み込みしてください。', 'ai');
            }
          })();
          return;
        }

        addBubble('ご回答ありがとうございました。アンケートが完了しました。', 'ai');
        chatAnswerArea.style.display = 'none';
        chatAnswerArea.innerHTML = '';
        chatTextRow.style.display = 'none';
        chatNextRow.style.display = 'none';
        (async () => {
          try {
            const resp = await fetch('/liff/survey/' + ASSIGNMENT_ID + '/complete', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ session_id: SESSION_ID }),
            });
            if (!resp.ok) throw new Error('complete API error');

            const closeBtnWrap = document.createElement('div');
            closeBtnWrap.style.cssText = 'text-align:center;margin-top:16px;';
            const inLiff = window.liff && typeof liff.isInClient === 'function' && liff.isInClient();
            if (inLiff) {
              const closeBtn = document.createElement('button');
              closeBtn.className = 'btn-next';
              closeBtn.style.minWidth = '160px';
              closeBtn.textContent = 'LINEに戻る';
              closeBtn.addEventListener('click', () => { liff.closeWindow(); });
              closeBtnWrap.appendChild(closeBtn);
            } else {
              const tip = document.createElement('p');
              tip.style.cssText = 'font-size:13px;color:#60726f;';
              tip.textContent = 'アンケートは完了しました。この画面を閉じてください。';
              closeBtnWrap.appendChild(tip);
            }
            chatMessages.appendChild(closeBtnWrap);
            chatMessages.scrollTop = chatMessages.scrollHeight;
          } catch(e) {
            console.error('complete failed', e);
            const errWrap = document.createElement('p');
            errWrap.style.cssText = 'color:#e53e3e;font-size:14px;text-align:center;margin-top:12px;';
            errWrap.textContent = '完了処理に失敗しました。時間をおいて再度お試しください。';
            chatMessages.appendChild(errWrap);
            chatMessages.scrollTop = chatMessages.scrollHeight;
          }
        })();
        return;
      }

      const q = visibleQs[chatQueueIndex];
      // 全タイプをインラインブロックで描画（自由記述もinput/textareaをインライン表示）
      chatAnswerArea.style.display = 'none';
      chatAnswerArea.innerHTML = '';
      chatTextRow.style.display = 'none';
      chatNextRow.style.display = 'none';
      chatNext.disabled = true;
      addQuestionBlock(q);
      checkChatNextEnabled();
    }

    // ---- テキスト入力 → 送信 ----
    chatInput.addEventListener('input', () => {
      chatSend.disabled = chatInput.value.trim() === '';
    });

    async function advanceAfterAnswer(q, displayText) {
      addBubble(displayText, 'user');

      // AI 深掘り
      if (q.ai_probe_enabled) {
        try {
          const res = await fetch('/liff/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session_id: SESSION_ID, assignment_id: ASSIGNMENT_ID, message: displayText }),
          });
          const data = await res.json();
          if (data.probe_question) {
            addBubble(data.probe_question, 'ai');
            // 深掘り中はテキスト入力エリアに戻す
            chatTextRow.style.display = 'flex';
            chatNextRow.style.display = 'none';
            chatAnswerArea.style.display = 'none';
            chatInput.disabled = false;
            chatInput.value = '';
            chatSend.disabled = true;
            return;
          }
        } catch(e) { console.error(e); }
      }

      // 次の質問へ
      const nextCode = resolveNext(q);
      if (nextCode) {
        const nextIdx = QUESTIONS.findIndex(qq => qq.question_code === nextCode);
        chatQueueIndex = nextIdx >= 0 ? nextIdx : chatQueueIndex + 1;
      } else {
        chatQueueIndex++;
      }
      askCurrentQuestion();
    }

    async function sendChatAnswer() {
      const text = chatInput.value.trim();
      if (!text) return;
      chatInput.value = '';
      chatSend.disabled = true;
      chatInput.disabled = true;

      const q = visibleQs[chatQueueIndex];
      if (!q) return;

      answerCtx.answers[q.question_code.toLowerCase()] = text;
      await submitAnswer(q.question_code, text);
      await advanceAfterAnswer(q, text);
    }

    // ---- 次へボタン（選択肢・スケール系） ----
    chatNext.addEventListener('click', async () => {
      const q = visibleQs[chatQueueIndex];
      if (!q || !isChatAnswered(q)) return;
      chatNext.disabled = true;

      const val = answerCtx.answers[q.question_code.toLowerCase()];
      await submitAnswer(q.question_code, val);
      freezeLatestQuestionBlock();

      // 表示用テキストを生成（配列なら結合、オブジェクトなら JSON）
      let displayText;
      if (Array.isArray(val)) {
        const cfg = q.question_config || {};
        const opts = cfg.options || [];
        const labels = val.map(v => {
          const o = opts.find(o => o.value === v);
          return o ? o.label : v;
        });
        displayText = labels.join('、');
      } else if (val !== null && typeof val === 'object') {
        displayText = JSON.stringify(val);
      } else {
        const cfg = q.question_config || {};
        const opts = cfg.options || [];
        const o = opts.find(o => String(o.value) === String(val));
        displayText = o ? o.label : String(val ?? '');
      }

      await advanceAfterAnswer(q, displayText);
    });

    chatSend.addEventListener('click', sendChatAnswer);
    chatInput.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChatAnswer(); }
    });

    try {
      console.log('[survey] askCurrentQuestion start, visibleQs=', visibleQs.length);
      askCurrentQuestion();
      console.log('[survey] askCurrentQuestion returned');
    } catch(e) {
      console.error('[survey] askCurrentQuestion error', e);
      throw e;
    }
  }

  } // end startSurvey()

  // LIFF 初期化 → 本人確認 → アンケート開始
  initLiffAndVerify().catch(function(e) {
    console.error('[survey] fatal init error', e);
    document.body.innerHTML =
      '<pre style="white-space:pre-wrap;padding:16px;font-family:monospace;font-size:14px;color:#c00;">' +
      'Survey初期化エラー:\n' + String(e && e.message ? e.message : e) +
      '\n\n' + (e && e.stack ? e.stack : '') +
      '</pre>';
  });

})();
</script>
<% } %>
</body>
</html>

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
        background: #f0f4f3;
        min-height: 100vh;
      }
      .container { max-width: 480px; margin: 0 auto; padding: 16px; }
      .card {
        background: #fff; border-radius: 16px; padding: 24px 20px;
        margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.07);
        text-align: center;
      }
      #loading-view {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 60px 20px; color: #60726f; font-size: 14px; gap: 12px;
      }
      .spinner {
        width: 32px; height: 32px;
        border: 3px solid #e0ede9; border-top-color: #2ca87a;
        border-radius: 50%; animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      .icon { font-size: 44px; margin-bottom: 12px; }
      h2 { font-size: 18px; font-weight: 700; color: #1a2f2a; margin-bottom: 8px; }
      p { font-size: 14px; color: #60726f; line-height: 1.7; }
      .btn {
        display: block; width: 100%; padding: 14px; border: none;
        border-radius: 12px; font-size: 15px; font-weight: 600;
        cursor: pointer; text-align: center; margin-top: 18px;
      }
      .btn-primary { background: #2ca87a; color: #fff; }
      .btn-secondary { background: #f0f4f3; color: #333; border: 1px solid #d8e3e0; }
      /* 店舗コード手入力フォールバック（A 案の最小フォールバック） */
      .code-input {
        width: 100%; padding: 12px 14px; margin-top: 14px;
        border: 1.5px solid #d8e3e0; border-radius: 10px;
        font-size: 16px; text-align: center; letter-spacing: .05em;
      }
      .code-input:focus { outline: none; border-color: #2ca87a; box-shadow: 0 0 0 3px rgba(44,168,122,.15); }
      .err { color: #c0392b; font-size: 13px; margin-top: 10px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div id="loading-view">
        <div class="spinner"></div>
        <span>お店のアンケートを確認中...</span>
      </div>
      <div id="app-view" style="display:none"></div>
    </div>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      const initialData = JSON.parse(document.getElementById("initial-data").dataset.json || "{}");
      const { liffId, resolveUrl, surveyBaseUrl } = initialData;
      const appView = document.getElementById("app-view");
      const loadingView = document.getElementById("loading-view");
      let idToken = null;

      function esc(v) {
        return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
      }
      function show(html) {
        loadingView.style.display = "none";
        appView.style.display = "";
        appView.innerHTML = html;
      }

      // entry_code は server 埋め込み(initialData) を優先し、無ければ URL から拾う
      function readEntryCode() {
        if (initialData.entryCode) return String(initialData.entryCode).trim();
        try {
          const u = new URL(window.location.href);
          const direct = u.searchParams.get("entry_code");
          if (direct) return direct.trim();
          const state = u.searchParams.get("liff.state");
          if (state) {
            const sp = new URLSearchParams(state.startsWith("?") ? state.slice(1) : state);
            return (sp.get("entry_code") || "").trim();
          }
        } catch { /* noop */ }
        return "";
      }

      async function resolveAndGo(entryCode) {
        const res = await fetch(resolveUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json", Authorization: `Bearer ${idToken}` },
          body: JSON.stringify({ entry_code: entryCode })
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.message || "お店のアンケートが見つかりませんでした。");
        }
        const data = await res.json();
        window.location.href = `${surveyBaseUrl}/${encodeURIComponent(data.assignment_id)}`;
      }

      // 店舗コード手入力フォールバック（QR/URL で来られなかった人向け = C 案）
      function renderCodeForm(message) {
        show(`
          <div class="card">
            <div class="icon">🏪</div>
            <h2>お店のアンケート</h2>
            <p>お店から案内されたコードを入力してください。</p>
            <input id="code-input" class="code-input" placeholder="例: abc" autocapitalize="off" autocomplete="off" />
            <p id="code-err" class="err"></p>
            <button class="btn btn-primary" id="code-go">アンケートへ進む</button>
          </div>
        `);
        if (message) {
          const e = document.getElementById("code-err");
          if (e) e.textContent = message;
        }
        document.getElementById("code-go").onclick = async () => {
          const val = (document.getElementById("code-input").value || "").trim();
          const errEl = document.getElementById("code-err");
          if (!val) { if (errEl) errEl.textContent = "コードを入力してください。"; return; }
          if (errEl) errEl.textContent = "";
          try {
            await resolveAndGo(val);
          } catch (err) {
            if (errEl) errEl.textContent = err.message || "見つかりませんでした。コードをご確認ください。";
          }
        };
      }

      async function load() {
        if (!liffId) { show(`<div class="card"><div class="icon">⚠️</div><p>LIFF IDが設定されていません。</p></div>`); return; }
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return;
          idToken = token;

          const entryCode = readEntryCode();
          if (!entryCode) { renderCodeForm(); return; }

          try {
            await resolveAndGo(entryCode);
          } catch (err) {
            // 専用URLで解決できなかった場合はコード入力にフォールバック
            renderCodeForm(err.message);
          }
        } catch (err) {
          show(`<div class="card"><div class="icon">⚠️</div><p>${esc(err.message || "読み込みに失敗しました。")}</p>
            <button class="btn btn-secondary" onclick="LiffAuth.closeOrBack()">閉じる</button></div>`);
        }
      }

      void load();
    })();
    </script>
  </body>
</html>

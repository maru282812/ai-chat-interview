<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <link rel="stylesheet" href="/public/hibi.css" />
    <%- include('../partials/daily-today-card') %>
    <style>
      .hb-tabs { display: flex; background: #FFFDF6; border-bottom: 2px solid var(--hb-line); position: sticky; top: 49px; z-index: 19; }
      .hb-tab { flex: 1; text-align: center; padding: 12px 4px; font-size: 13px; font-weight: 700; color: var(--hb-sub); border-bottom: 3px solid transparent; margin-bottom: -2px; cursor: pointer; white-space: nowrap; }
      .hb-tab.on { color: var(--hb-brand-text); border-color: var(--hb-brand-strong); }
      .hb-tab .cnt { font-size: 11px; font-weight: 400; margin-left: 2px; }
      .item { margin: 12px 16px 0; background: #fff; border-radius: 14px; padding: 15px; }
      .item.hot { border: 1.5px solid #9DC6BB; background: #F2F9F6; }
      .item h3 { font-size: 14.5px; line-height: 1.5; margin-top: 8px; font-weight: 700; }
      .item .sub { display: flex; align-items: center; gap: 10px; margin-top: 8px; font-size: 12px; color: var(--hb-sub); flex-wrap: wrap; }
      .item .sub .pt { margin-left: auto; color: var(--hb-teal); font-weight: 800; font-size: 13px; }
      .item .act { margin-top: 12px; }
      .item .act .hb-btn { padding: 11px; font-size: 14px; border-radius: 10px; }
    </style>
  </head>
  <body class="hibi">
    <div class="hb-shell">
      <header class="hb-appbar">
        <span class="hb-logo">Hibi</span>
        <span class="hb-title">やりとり</span>
        <span style="width:24px"></span>
      </header>

      <div id="daily-area"></div>

      <nav class="hb-tabs" id="tab-bar">
        <div class="hb-tab on" data-tab="applications">応募中<span class="cnt" id="cnt-applications"></span></div>
        <div class="hb-tab" data-tab="pending">実施予定<span class="cnt" id="cnt-pending"></span></div>
        <div class="hb-tab" data-tab="in_progress">回答中<span class="cnt" id="cnt-in_progress"></span></div>
        <div class="hb-tab" data-tab="completed">完了<span class="cnt" id="cnt-completed"></span></div>
      </nav>

      <div class="hb-loading" id="loading-overlay">読み込み中…</div>
      <div id="tab-applications" class="tab-content" style="display:none"></div>
      <div id="tab-pending"      class="tab-content" style="display:none"></div>
      <div id="tab-in_progress"  class="tab-content" style="display:none"></div>
      <div id="tab-completed"    class="tab-content" style="display:none"></div>
      <div style="height:16px"></div>

      <nav class="hb-bottomnav">
        <a id="nav-projects" href="#"><span class="i">🔍</span>探す</a>
        <a id="nav-saved" href="#"><span class="i">☆</span>保存</a>
        <a class="on" href="#"><span class="i">📋</span>やりとり</a>
        <a id="nav-mypage" href="#"><span class="i">👤</span>マイページ</a>
      </nav>
    </div>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      'use strict';
      const d = JSON.parse(document.getElementById('initial-data').dataset.json || '{}');
      const { liffId, interactionsDataUrl, surveyBaseUrl, projectsUrl } = d;
      document.getElementById('nav-projects').href = projectsUrl || '/liff/projects';
      document.getElementById('nav-saved').href = d.savedProjectsUrl || '/liff/saved-projects';
      document.getElementById('nav-mypage').href = d.mypageUrl || '/liff/mypage';

      let idToken = null;
      let currentTab = 'applications';

      function esc(v) {
        return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
      }
      function fmtDate(iso) {
        if (!iso) return '';
        const date = new Date(iso);
        return `${date.getMonth()+1}/${date.getDate()}`;
      }

      const asgBadge = {
        assigned:  { label: '当選・未回答', cls: 'win' },
        sent:      { label: '当選・未回答', cls: 'win' },
        opened:    { label: '未回答',       cls: 'win' },
        started:   { label: '回答中',       cls: 'doing' },
        completed: { label: '完了',         cls: 'done' },
        expired:   { label: '期限切れ',     cls: 'lose' },
        cancelled: { label: 'キャンセル',   cls: 'lose' },
      };

      function emptyState(msg) {
        return `<div class="hb-empty"><div class="icon">📋</div><p>${esc(msg)}</p><a class="hb-btn ghost hb-mt16" href="${esc(projectsUrl)}" style="max-width:240px;margin-left:auto;margin-right:auto">案件を探す</a></div>`;
      }

      function renderApplications(items) {
        const el = document.getElementById('tab-applications');
        if (!items.length) { el.innerHTML = emptyState('応募中の案件はありません'); return; }
        el.innerHTML = items.map(a => `
          <div class="item">
            <span class="hb-status ${a.status === 'applied' ? 'wait' : 'lose'}">${a.status === 'applied' ? '選考中' : '落選'}</span>
            <h3>${esc(a.title)}</h3>
            <div class="sub">
              <span>${fmtDate(a.applied_at)} 応募</span>
              ${a.reward_points ? `<span class="pt">${a.reward_points.toLocaleString()}pt</span>` : ''}
            </div>
            ${a.status === 'applied' ? `
            <div class="act"><button class="hb-btn sub withdraw-btn" data-project="${esc(a.project_id)}" style="font-size:12.5px;padding:9px">応募を取り消す</button></div>` : ''}
          </div>`).join('');

        el.querySelectorAll('.withdraw-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            if (!confirm('応募を取り消しますか？')) return;
            try {
              const res = await fetch(`/liff/projects/${btn.dataset.project}/withdraw`, {
                method: 'POST', headers: { Authorization: `Bearer ${idToken}` }
              });
              const json = await res.json();
              if (!json.ok) { alert(json.error || '取り消せませんでした。'); return; }
              void load();
            } catch { alert('通信に失敗しました。'); }
          });
        });
      }

      function renderAssignments(name, items, emptyMsg) {
        const el = document.getElementById(`tab-${name}`);
        if (!items.length) { el.innerHTML = emptyState(emptyMsg); return; }
        el.innerHTML = items.map(a => {
          const b = asgBadge[a.status] || { label: a.status, cls: 'done' };
          const answerable = ['assigned', 'sent', 'opened', 'started'].includes(a.status);
          return `
          <div class="item ${answerable ? 'hot' : ''}" ${!answerable ? 'style="opacity:.75"' : ''}>
            <span class="hb-status ${b.cls}">${b.label}</span>
            <h3>${esc(a.title)}</h3>
            <div class="sub">
              ${a.estimated_minutes ? `<span>約${a.estimated_minutes}分</span>` : ''}
              ${a.deadline ? `<span>期限 ${fmtDate(a.deadline)}</span>` : ''}
              ${a.completed_at ? `<span>${fmtDate(a.completed_at)} 完了</span>` : ''}
              ${a.reward_points ? `<span class="pt">${a.status === 'completed' ? '+' : ''}${a.reward_points.toLocaleString()}pt</span>` : ''}
            </div>
            ${answerable ? `
            <div class="act"><a class="hb-btn primary" href="${esc(surveyBaseUrl)}/${esc(a.assignment_id)}" style="display:block;text-align:center;text-decoration:none">${a.status === 'started' ? '続きから回答する' : '回答をはじめる ⚡'}</a></div>` : ''}
          </div>`;
        }).join('');
      }

      function renderAll(data) {
        document.getElementById('loading-overlay').style.display = 'none';
        const apps = data.applications || [];
        renderApplications(apps);
        renderAssignments('pending', data.pending || [], '実施予定の案件はありません');
        renderAssignments('in_progress', data.in_progress || [], '回答中の案件はありません');
        renderAssignments('completed', data.completed || [], '完了した案件はまだありません');
        setCnt('applications', apps.filter(a => a.status === 'applied').length);
        setCnt('pending', (data.pending || []).length);
        setCnt('in_progress', (data.in_progress || []).length);
        setCnt('completed', (data.completed || []).length);
        showTab(currentTab);
      }
      function setCnt(name, n) {
        document.getElementById(`cnt-${name}`).textContent = n > 0 ? String(n) : '';
      }
      function showTab(name) {
        currentTab = name;
        document.querySelectorAll('.hb-tab').forEach(t => t.classList.remove('on'));
        document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
        document.querySelector(`.hb-tab[data-tab="${name}"]`)?.classList.add('on');
        document.getElementById(`tab-${name}`).style.display = 'block';
      }

      document.getElementById('tab-bar').addEventListener('click', e => {
        const tab = e.target.closest('.hb-tab');
        if (tab) showTab(tab.dataset.tab);
      });

      async function load() {
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return;
          idToken = token;

          // 今日の1問はこの画面の表示をブロックしない（失敗してもカードを出さないだけ）。
          DailyToday.mount({ idToken });

          const res = await fetch(interactionsDataUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          const data = await res.json();
          renderAll(data);
        } catch (err) {
          document.getElementById('loading-overlay').style.display = 'none';
          const el = document.getElementById('tab-applications');
          el.style.display = 'block';
          el.innerHTML = `<div class="hb-empty"><div class="icon">⚠️</div><p>${esc(err.message || '読み込みに失敗しました')}</p></div>`;
        }
      }

      void load();
    })();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>プロフィール確認</title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
        background: #f0f4f3;
        min-height: 100vh;
      }
      .container { max-width: 480px; margin: 0 auto; padding: 16px; }

      .card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
      }

      .page-header {
        text-align: center;
        padding: 12px 0 4px;
      }
      .page-header h2 { font-size: 18px; font-weight: 700; color: #1a2f2a; margin-bottom: 6px; }
      .page-header p  { font-size: 13px; color: #60726f; line-height: 1.6; }

      .profile-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f4f3;
        font-size: 14px;
      }
      .profile-row:last-child { border-bottom: none; }
      .profile-label { color: #60726f; font-size: 13px; }
      .profile-value { font-weight: 600; color: #1a2f2a; }
      .profile-value.missing { color: #c0392b; font-size: 12px; font-weight: 400; }

      .btn {
        display: block;
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: opacity 0.15s;
      }
      .btn:active { opacity: 0.8; }
      .btn-primary  { background: #2ca87a; color: #fff; }
      .btn-secondary {
        background: #f0f4f3; color: #2ca87a;
        border: 1.5px solid #2ca87a;
        font-size: 14px;
        padding: 11px;
        margin-top: 8px;
      }

      .form-stack { display: flex; flex-direction: column; gap: 14px; }
      .form-group label {
        display: block;
        font-size: 13px; font-weight: 600; color: #444;
        margin-bottom: 6px;
      }
      .form-group label .required {
        color: #e05555; font-size: 11px; margin-left: 4px;
      }
      .form-control {
        width: 100%; padding: 11px 14px;
        border: 1px solid #d8e3e0; border-radius: 10px;
        font-size: 15px; color: #222;
        background: #fff;
        appearance: none;
      }
      .form-control:focus {
        outline: none; border-color: #2ca87a;
        box-shadow: 0 0 0 3px rgba(44,168,122,.15);
      }
      .radio-group {
        display: flex; flex-wrap: wrap; gap: 8px;
      }
      .radio-group label {
        display: flex; align-items: center; gap: 6px;
        padding: 8px 12px;
        border: 1px solid #d8e3e0; border-radius: 8px;
        font-size: 14px; font-weight: 400; color: #333;
        cursor: pointer;
      }
      .radio-group input { accent-color: #2ca87a; }

      .status-msg { text-align: center; font-size: 13px; color: #60726f; padding: 8px 0; min-height: 20px; }
      .status-msg.error   { color: #c0392b; }
      .status-msg.success { color: #2ca87a; font-weight: 600; }

      #loading-view {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 60px 20px;
        color: #60726f; font-size: 14px; gap: 12px;
      }
      .spinner {
        width: 32px; height: 32px;
        border: 3px solid #e0ede9;
        border-top-color: #2ca87a;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      .section-title {
        font-size: 13px; font-weight: 600; color: #60726f; margin-bottom: 10px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div id="loading-view">
        <div class="spinner"></div>
        <span>読み込み中...</span>
      </div>
      <div id="app-view" style="display:none"></div>
    </div>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      const { liffId, next, sessionId, profileUrl, updateUrl, confirmMypageUrl } =
        JSON.parse(document.getElementById("initial-data").dataset.json || "{}");

      const appView     = document.getElementById("app-view");
      const loadingView = document.getElementById("loading-view");
      let idToken = null;

      function esc(v) {
        return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
      }
      function sel(v, t) { return v === t ? "selected" : ""; }
      function chk(v, t) { return v === t ? "checked" : ""; }

      function show(html) {
        loadingView.style.display = "none";
        appView.style.display = "";
        appView.innerHTML = html;
      }

      function showError(msg) {
        show(`<div class="card" style="text-align:center;padding:40px 20px;">
          <div style="font-size:40px;margin-bottom:12px;">⚠️</div>
          <p style="color:#c0392b;font-size:14px;">${esc(msg)}</p>
        </div>`);
      }

      // セッション確認 → next へ遷移
      async function confirmAndGoToSurvey() {
        if (confirmMypageUrl && sessionId) {
          try {
            await fetch(confirmMypageUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ session_id: sessionId })
            });
          } catch (e) {
            console.warn("confirm-mypage failed", e);
          }
        }
        window.location.href = next || "/";
      }

      // プロフィール確認画面（完了済みユーザー向け）
      function renderConfirmView(profile) {
        const p = profile || {};
        const displayName = p.nickname || "未設定";

        const GENDER_LABEL = { male: "男性", female: "女性", other: "その他", prefer_not_to_say: "答えたくない" };
        const genderLabel = GENDER_LABEL[p.gender] || p.gender || "未設定";

        let ageText = "未設定";
        if (p.birth_date) {
          const birth = new Date(p.birth_date);
          const today = new Date();
          let age = today.getFullYear() - birth.getFullYear();
          const m = today.getMonth() - birth.getMonth();
          if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
          ageText = `${age}歳`;
        }

        show(`
          <div class="card">
            <div class="page-header">
              <h2>プロフィール確認</h2>
              <p>案件回答の前に、プロフィール内容をご確認ください。</p>
            </div>
          </div>

          <div class="card">
            <div class="section-title">現在の登録情報</div>
            <div class="profile-row">
              <span class="profile-label">呼び名</span>
              <span class="profile-value">${esc(displayName)}</span>
            </div>
            <div class="profile-row">
              <span class="profile-label">年齢</span>
              <span class="profile-value">${esc(ageText)}</span>
            </div>
            <div class="profile-row">
              <span class="profile-label">性別</span>
              <span class="profile-value">${esc(genderLabel)}</span>
            </div>
            <div class="profile-row">
              <span class="profile-label">都道府県</span>
              <span class="profile-value">${esc(p.prefecture || "未設定")}</span>
            </div>
            <div class="profile-row">
              <span class="profile-label">職業</span>
              <span class="profile-value">${esc(p.occupation || "未設定")}</span>
            </div>
            <div class="profile-row">
              <span class="profile-label">業種</span>
              <span class="profile-value">${esc(p.industry || "未設定")}</span>
            </div>
          </div>

          <div class="card">
            <button class="btn btn-primary" id="btn-confirm">この内容で回答を開始する</button>
            <button class="btn btn-secondary" id="btn-edit">内容を変更する</button>
          </div>
        `);

        document.getElementById("btn-confirm")?.addEventListener("click", async () => {
          const btn = document.getElementById("btn-confirm");
          if (btn) { btn.disabled = true; btn.textContent = "開始中..."; }
          await confirmAndGoToSurvey();
        });

        document.getElementById("btn-edit")?.addEventListener("click", () => {
          renderEditForm(profile);
        });
      }

      // プロフィール入力フォーム（未完了ユーザー / 変更ボタン押下時）
      function renderEditForm(profile, isFirstTime) {
        const p = profile || {};
        const prefectures = ["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県","茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県","新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県","三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県","鳥取県","島根県","岡山県","広島県","山口県","徳島県","香川県","愛媛県","高知県","福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"];

        const backButtonHtml = isFirstTime
          ? ""
          : `<div class="card" style="display:flex;align-items:center;gap:12px;padding:14px 20px;">
               <button id="btn-back" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;color:#2ca87a;">←</button>
               <span style="font-weight:600;font-size:16px;">プロフィール編集</span>
             </div>`;

        const headerHtml = isFirstTime
          ? `<div class="card">
               <div class="page-header">
                 <h2>プロフィール設定</h2>
                 <p>案件に参加する前に、基本情報を登録してください。<br>所要時間：約2分</p>
               </div>
             </div>`
          : "";

        const termsHtml = isFirstTime
          ? `<div class="form-group" style="margin-top:8px">
               <label style="display:flex;align-items:flex-start;gap:10px;font-weight:400;cursor:pointer">
                 <input type="checkbox" name="terms_agreed" id="terms-check" style="margin-top:3px;accent-color:#2ca87a;flex-shrink:0" required />
                 <span style="font-size:13px;color:#444;line-height:1.6">
                   <a href="https://line.me/terms" target="_blank" style="color:#2ca87a">利用規約</a>および
                   個人情報の取り扱いに同意します<span style="color:#e05555;font-size:11px;margin-left:4px">必須</span>
                 </span>
               </label>
             </div>`
          : "";

        const submitLabel = isFirstTime ? "登録して回答を開始する" : "保存して回答を開始する";

        show(`
          ${backButtonHtml}
          ${headerHtml}
          <div class="card">
            <div class="section-title" style="margin-bottom:4px">必須項目</div>
            <p style="font-size:12px;color:#60726f;margin-bottom:14px">以下の項目は全て入力が必要です。</p>
            <form id="profile-form" class="form-stack">
              <div class="form-group">
                <label>呼び名<span class="required">必須</span></label>
                <input class="form-control" type="text" name="nickname" value="${esc(p.nickname)}" placeholder="例：たろう" required />
              </div>
              <div class="form-group">
                <label>生年月日<span class="required">必須</span></label>
                <input class="form-control" type="date" name="birth_date" value="${esc(p.birth_date)}" required />
              </div>
              <div class="form-group">
                <label>性別<span class="required">必須</span></label>
                <div class="radio-group">
                  ${[["male","男性"],["female","女性"],["other","その他"],["prefer_not_to_say","答えたくない"]].map(([v,l]) =>
                    `<label><input type="radio" name="gender" value="${v}" ${chk(p.gender, v)} required />${l}</label>`
                  ).join("")}
                </div>
              </div>
              <div class="form-group">
                <label>都道府県<span class="required">必須</span></label>
                <select class="form-control" name="prefecture" required>
                  <option value="">選択してください</option>
                  ${prefectures.map(pref => `<option value="${esc(pref)}" ${sel(p.prefecture, pref)}>${esc(pref)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>職業<span class="required">必須</span></label>
                <select class="form-control" name="occupation" required>
                  <option value="">選択してください</option>
                  ${["会社員（正社員）","会社員（契約・派遣）","公務員","自営業・フリーランス","パート・アルバイト","学生","専業主婦・主夫","無職","その他"].map(o => `<option value="${esc(o)}" ${sel(p.occupation, o)}>${esc(o)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>業種<span class="required">必須</span></label>
                <select class="form-control" name="industry" required>
                  <option value="">選択してください</option>
                  ${["IT・通信","製造","金融・保険","医療・福祉","教育","小売・流通","外食・フード","建設・不動産","メディア・広告","公共・行政","その他"].map(i => `<option value="${esc(i)}" ${sel(p.industry, i)}>${esc(i)}</option>`).join("")}
                </select>
              </div>
              ${termsHtml}
              <p id="form-status" class="status-msg"></p>
              <button type="submit" class="btn btn-primary">${esc(submitLabel)}</button>
            </form>
          </div>
        `);

        document.getElementById("btn-back")?.addEventListener("click", () => {
          load();
        });

        document.getElementById("profile-form")?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const fd = new FormData(e.target);
          const statusEl = document.getElementById("form-status");

          if (!fd.get("gender")) {
            statusEl.textContent = "性別を選択してください。";
            statusEl.className = "status-msg error";
            return;
          }
          if (isFirstTime) {
            const termsCheck = document.getElementById("terms-check");
            if (termsCheck && !termsCheck.checked) {
              statusEl.textContent = "利用規約への同意が必要です。";
              statusEl.className = "status-msg error";
              return;
            }
          }

          statusEl.textContent = "保存中...";
          statusEl.className = "status-msg";

          const payload = {
            nickname:   fd.get("nickname") || null,
            birth_date: fd.get("birth_date") || null,
            gender:     fd.get("gender") || null,
            prefecture: fd.get("prefecture") || null,
            occupation: fd.get("occupation") || null,
            industry:   fd.get("industry") || null,
          };

          try {
            const res = await fetch(updateUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json", Authorization: `Bearer ${idToken}` },
              body: JSON.stringify(payload)
            });
            if (!res.ok) {
              let msg = "保存に失敗しました。";
              try {
                const errData = await res.json();
                if (errData.error) msg = errData.error;
                else if (errData.message) msg = errData.message;
              } catch (_) { /* ignore */ }
              throw new Error(msg);
            }

            statusEl.textContent = "保存しました。回答画面へ移動します...";
            statusEl.className = "status-msg success";
            setTimeout(() => confirmAndGoToSurvey(), 800);
          } catch (err) {
            console.error("[ProfileCheck] save error", err);
            statusEl.textContent = err.message || "保存に失敗しました。";
            statusEl.className = "status-msg error";
          }
        });
      }

      async function load() {
        if (!liffId) {
          showError("LIFF IDが設定されていません。管理者にお問い合わせください。");
          return;
        }
        console.log("[ProfileCheck] load start", { liffId, next, sessionId });
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return; // LINE Login リダイレクト中
          idToken = token;
          console.log("[ProfileCheck] LIFF auth ok, fetching profile from", profileUrl);

          const res = await fetch(profileUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) {
            let msg = "情報の取得に失敗しました。ページを開き直してください。";
            try {
              const errData = await res.json();
              const code = errData.code || "";
              if (code === "NO_TOKEN" || code === "AUTH_FAILED") {
                msg = "LINE認証に失敗しました。LINEアプリ内から開き直してください。";
              } else if (code === "DB_ERROR") {
                msg = "サーバーエラーが発生しました。しばらくしてから再度お試しください。";
              } else if (errData.message) {
                msg = errData.message;
              }
              console.error("[ProfileCheck] profile fetch error", { status: res.status, code, message: errData.message });
            } catch (_) {
              console.error("[ProfileCheck] profile fetch error (non-json)", { status: res.status });
            }
            throw new Error(msg);
          }

          const data = await res.json();
          console.log("[ProfileCheck] profile loaded", {
            exists: !!data.profile,
            profileCompleted: data.profile?.profile_completed ?? false,
          });

          if (!data.profile?.profile_completed) {
            renderEditForm(data.profile, /* isFirstTime= */ !data.profile);
          } else {
            renderConfirmView(data.profile);
          }
        } catch (err) {
          console.error("[ProfileCheck] load error", err);
          showError(err.message || "読み込みに失敗しました。");
        }
      }

      void load();
    })();
    </script>
  </body>
</html>

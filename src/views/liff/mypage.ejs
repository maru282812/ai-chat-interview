<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
        background: #f0f4f3;
        min-height: 100vh;
      }
      .container { max-width: 480px; margin: 0 auto; padding: 16px; }

      /* ---- カード共通 ---- */
      .card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
      }

      /* ---- ダッシュボード ---- */
      .profile-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 4px;
      }
      .avatar {
        width: 56px; height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2ca87a, #1a7a5a);
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 22px; font-weight: 700;
        flex-shrink: 0;
      }
      .profile-name { font-size: 18px; font-weight: 700; color: #1a2f2a; }
      .rank-badge {
        display: inline-block;
        font-size: 12px; font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        background: #e8f5ef; color: #1a7a5a;
        margin-top: 4px;
      }
      .rank-badge.silver { background: #f0f0f5; color: #556080; }
      .rank-badge.gold   { background: #fdf5e0; color: #9a6800; }
      .rank-badge.platinum { background: #f0eef8; color: #5a3a9a; }

      .stats-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 10px;
        margin-bottom: 12px;
      }
      .stat-box {
        background: #f8faf9;
        border-radius: 12px;
        padding: 14px 16px;
        text-align: center;
      }
      .stat-value { font-size: 24px; font-weight: 700; color: #1a2f2a; }
      .stat-unit  { font-size: 12px; color: #2ca87a; font-weight: 600; }
      .stat-label { font-size: 11px; color: #60726f; margin-top: 2px; }

      .progress-section { margin-bottom: 4px; }
      .progress-label {
        display: flex; justify-content: space-between;
        font-size: 12px; color: #60726f; margin-bottom: 6px;
      }
      .progress-bar-wrap { background: #e0ede9; border-radius: 6px; height: 8px; }
      .progress-bar { background: #2ca87a; height: 100%; border-radius: 6px; transition: width 0.4s; }

      .section-title { font-size: 13px; font-weight: 600; color: #60726f; margin-bottom: 10px; }

      .tx-list { list-style: none; }
      .tx-item {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f4f3;
        font-size: 13px;
      }
      .tx-item:last-child { border-bottom: none; }
      .tx-reason { color: #333; flex: 1; }
      .tx-points { font-weight: 700; color: #2ca87a; white-space: nowrap; padding-left: 8px; }
      .tx-date   { font-size: 11px; color: #999; white-space: nowrap; padding-left: 8px; }

      .btn {
        display: block;
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.15s;
      }
      .btn:active { opacity: 0.8; }
      .btn-primary { background: #2ca87a; color: #fff; }
      .btn-secondary {
        background: #f0f4f3; color: #333;
        border: 1px solid #d8e3e0;
      }
      .btn-sm {
        padding: 10px 14px;
        font-size: 13px;
        border-radius: 10px;
      }

      /* ---- フォーム ---- */
      .form-stack { display: flex; flex-direction: column; gap: 14px; }
      .form-group label {
        display: block;
        font-size: 13px; font-weight: 600; color: #444;
        margin-bottom: 6px;
      }
      .form-group label .required {
        color: #e05555; font-size: 11px; margin-left: 4px;
      }
      .form-control {
        width: 100%; padding: 11px 14px;
        border: 1px solid #d8e3e0; border-radius: 10px;
        font-size: 15px; color: #222;
        background: #fff;
        appearance: none;
      }
      .form-control:focus {
        outline: none; border-color: #2ca87a;
        box-shadow: 0 0 0 3px rgba(44,168,122,.15);
      }
      .radio-group, .checkbox-group {
        display: flex; flex-wrap: wrap; gap: 8px;
      }
      .radio-group label, .checkbox-group label {
        display: flex; align-items: center; gap: 6px;
        padding: 8px 12px;
        border: 1px solid #d8e3e0; border-radius: 8px;
        font-size: 14px; font-weight: 400; color: #333;
        cursor: pointer;
      }
      .radio-group input, .checkbox-group input { accent-color: #2ca87a; }

      .setup-header {
        text-align: center; padding: 20px 0 8px;
      }
      .setup-header .icon { font-size: 40px; margin-bottom: 8px; }
      .setup-header h2 { font-size: 18px; color: #1a2f2a; margin-bottom: 6px; }
      .setup-header p { font-size: 13px; color: #60726f; line-height: 1.6; }

      .status-msg { text-align: center; font-size: 13px; color: #60726f; padding: 8px 0; min-height: 20px; }
      .status-msg.error { color: #c0392b; }
      .status-msg.success { color: #2ca87a; font-weight: 600; }

      /* ---- ローディング ---- */
      #loading-view {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 60px 20px;
        color: #60726f; font-size: 14px; gap: 12px;
      }
      .spinner {
        width: 32px; height: 32px;
        border: 3px solid #e0ede9;
        border-top-color: #2ca87a;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* ---- 今月の応募状況 ---- */
      .monthly-card {
        background: #fff; border-radius: 16px; padding: 18px 20px;
        margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.07);
      }
      .monthly-title { font-size: 13px; font-weight: 600; color: #60726f; margin-bottom: 12px; }
      .monthly-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .monthly-item { background: #f8faf9; border-radius: 10px; padding: 12px; text-align: center; }
      .monthly-value { font-size: 22px; font-weight: 700; color: #1a2f2a; }
      .monthly-unit  { font-size: 12px; color: #2ca87a; margin-left: 2px; }
      .monthly-label { font-size: 11px; color: #60726f; margin-top: 3px; }

      /* ---- ポイント交換 ---- */
      .balance-card {
        background: linear-gradient(135deg, #1a7a5a, #2ca87a);
        border-radius: 16px;
        padding: 22px 20px 18px;
        margin-bottom: 12px;
        color: #fff;
        box-shadow: 0 4px 12px rgba(44,168,122,.35);
      }
      .balance-label { font-size: 12px; opacity: .85; margin-bottom: 4px; }
      .balance-main { font-size: 42px; font-weight: 700; line-height: 1; letter-spacing: -1px; }
      .balance-unit  { font-size: 18px; font-weight: 600; margin-left: 3px; opacity: .9; }
      .balance-sub-row {
        display: flex; gap: 16px; margin-top: 14px;
        border-top: 1px solid rgba(255,255,255,.25); padding-top: 12px;
      }
      .balance-sub-item { flex: 1; text-align: center; }
      .balance-sub-val { font-size: 18px; font-weight: 700; }
      .balance-sub-lbl { font-size: 10px; opacity: .8; margin-top: 2px; }

      .exchange-progress-wrap {
        background: rgba(255,255,255,.25); border-radius: 6px; height: 6px; margin-top: 14px;
      }
      .exchange-progress-bar {
        background: #fff; height: 100%; border-radius: 6px; transition: width .4s;
      }
      .exchange-progress-label {
        font-size: 11px; opacity: .85; margin-top: 5px; text-align: right;
      }

      .btn-exchange {
        background: #fff; color: #1a7a5a; font-weight: 700; font-size: 16px;
        border: none; border-radius: 12px; padding: 15px; width: 100%; cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,.12); transition: opacity .15s;
      }
      .btn-exchange:active { opacity: .8; }
      .btn-exchange:disabled {
        background: rgba(255,255,255,.4); color: rgba(26,122,90,.6); cursor: not-allowed;
      }
      .btn-exchange-pending {
        background: rgba(255,255,255,.2); color: #fff;
        font-size: 14px; font-weight: 600; border-radius: 12px; padding: 13px; width: 100%;
        border: 1.5px solid rgba(255,255,255,.5); cursor: default; text-align: center;
      }

      .exchange-status-badge {
        display: inline-block; font-size: 11px; font-weight: 700;
        padding: 3px 9px; border-radius: 20px; white-space: nowrap;
      }
      .badge-pending   { background: #fff3cd; color: #856404; }
      .badge-approved  { background: #cce5ff; color: #004085; }
      .badge-fulfilled { background: #d4edda; color: #155724; }
      .badge-rejected  { background: #f8d7da; color: #721c24; }
      .badge-canceled  { background: #e9ecef; color: #495057; }

      .gift-url-box {
        background: #f0faf6; border: 1.5px solid #2ca87a; border-radius: 10px;
        padding: 12px 14px; margin-top: 8px;
      }
      .gift-url-box a {
        color: #1a7a5a; font-weight: 700; font-size: 14px; word-break: break-all;
      }
      .gift-url-label { font-size: 11px; color: #60726f; margin-bottom: 4px; }

      .tab-bar {
        display: flex; border-bottom: 2px solid #e0ede9; margin-bottom: 14px;
      }
      .tab-btn {
        flex: 1; padding: 10px; font-size: 13px; font-weight: 600;
        border: none; background: none; color: #60726f; cursor: pointer;
        border-bottom: 3px solid transparent; margin-bottom: -2px; transition: color .15s;
      }
      .tab-btn.active { color: #1a7a5a; border-bottom-color: #2ca87a; }

      .confirm-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.5);
        display: flex; align-items: flex-end; z-index: 100;
      }
      .confirm-sheet {
        background: #fff; border-radius: 20px 20px 0 0;
        padding: 24px 20px 32px; width: 100%; max-width: 480px; margin: 0 auto;
      }
      .confirm-title { font-size: 17px; font-weight: 700; color: #1a2f2a; margin-bottom: 6px; }
      .confirm-body  { font-size: 14px; color: #60726f; line-height: 1.7; margin-bottom: 20px; }
      .confirm-btns  { display: flex; gap: 10px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div id="loading-view">
        <div class="spinner"></div>
        <span>読み込み中...</span>
      </div>
      <div id="app-view" style="display:none"></div>
    </div>

    <%- include('../partials/liff-bottom-nav', { active: 'mypage' }) %>

    <div id="initial-data" hidden data-json='<%= JSON.stringify(initialData) %>'></div>

    <script>
    (() => {
      const initialData = JSON.parse(document.getElementById("initial-data").dataset.json || "{}");
      const { liffId, mode, next, sessionId, profileUrl, updateUrl, confirmMypageUrl, historyUrl, pointsUrl, exchangeRequestUrl, consentStatusUrl, consentPageUrl, documentBaseUrl, interactionsUrl } = initialData;
      const appView   = document.getElementById("app-view");
      const loadingView = document.getElementById("loading-view");
      let idToken = null;

      // ---- ユーティリティ ----
      function esc(v) {
        return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
      }
      function sel(v, t) { return v === t ? "selected" : ""; }
      function chk(v, t) { return v === t ? "checked" : ""; }
      function inArr(arr, v) { return (arr||[]).includes(v) ? "checked" : ""; }

      function show(html) {
        loadingView.style.display = "none";
        appView.style.display = "";
        appView.innerHTML = html;
      }

      function showError(msg) {
        show(`<div class="card" style="text-align:center;padding:40px 20px;">
          <div style="font-size:40px;margin-bottom:12px;">⚠️</div>
          <p style="color:#c0392b;font-size:14px;">${esc(msg)}</p>
        </div>`);
      }

      // ---- ランクバッジクラス ----
      function rankClass(code) {
        if (!code) return "";
        const c = code.toLowerCase();
        if (c.includes("silver"))   return "silver";
        if (c.includes("gold"))     return "gold";
        if (c.includes("platinum")) return "platinum";
        return "";
      }

      // ---- ポイントバーの幅 ----
      function progressWidth(current, next) {
        if (!next || next <= 0) return 100;
        const pct = Math.min(100, Math.round((current / next) * 100));
        return pct;
      }

      // ---- 日付フォーマット ----
      function fmtDate(iso) {
        if (!iso) return "";
        try {
          const d = new Date(iso);
          return `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,"0")}/${String(d.getDate()).padStart(2,"0")}`;
        } catch { return ""; }
      }

      // ---- ダッシュボード描画 ----
      function renderDashboard(data) {
        const p      = data.profile || {};
        const s      = data.stats   || {};
        const txs    = data.recent_transactions || [];
        const badges = data.awarded_badges || [];
        const name   = p.nickname || data.display_name || "ゲスト";
        const initial = name.charAt(0).toUpperCase();
        const pct    = progressWidth(s.total_points, s.next_rank_min_points);
        const streak = s.current_streak ?? 0;

        const txHtml = txs.length === 0
          ? `<li class="tx-item"><span class="tx-reason" style="color:#999">まだ履歴がありません</span></li>`
          : txs.map(tx => `
            <li class="tx-item">
              <span class="tx-reason">${esc(tx.reason)}</span>
              <span class="tx-date">${fmtDate(tx.created_at)}</span>
              <span class="tx-points">+${tx.points}pt</span>
            </li>`).join("");

        const nextRankInfo = s.next_rank_name
          ? `次のランク: ${esc(s.next_rank_name)}（あと ${s.next_rank_min_points - s.total_points}pt）`
          : `最高ランク達成！`;

        const badgeHtml = badges.length === 0
          ? `<p style="font-size:12px;color:#999;text-align:center;padding:8px 0">まだバッジがありません</p>`
          : badges.slice(0, 6).map(b => `
              <div style="text-align:center;font-size:11px;color:#60726f;flex:1;min-width:60px;max-width:80px;">
                <div style="font-size:28px;margin-bottom:2px;">${esc(b.badge_icon || "🏅")}</div>
                <div style="word-break:break-all;line-height:1.3">${esc(b.badge_name || b.badge_code)}</div>
              </div>`).join("");

        show(`
          <div class="card">
            <div class="profile-header">
              <div class="avatar">${esc(initial)}</div>
              <div>
                <div class="profile-name">${esc(name)}</div>
                <div class="rank-badge ${rankClass(s.rank_code)}">${esc(s.badge_label || s.rank_name || "Bronze")}</div>
              </div>
            </div>
          </div>

          <div class="stats-row">
            <div class="stat-box">
              <div class="stat-value">${s.total_points ?? 0}<span class="stat-unit">pt</span></div>
              <div class="stat-label">現在のポイント</div>
            </div>
            <div class="stat-box">
              <div class="stat-value">${s.completed_count ?? 0}<span class="stat-unit" style="font-size:14px">件</span></div>
              <div class="stat-label">回答済み案件</div>
            </div>
            <div class="stat-box">
              <div class="stat-value">${streak}<span class="stat-unit" style="font-size:14px">日</span></div>
              <div class="stat-label">連続回答</div>
            </div>
          </div>

          <div class="card">
            <div class="progress-section">
              <div class="progress-label">
                <span>ランク進捗</span>
                <span>${nextRankInfo}</span>
              </div>
              <div class="progress-bar-wrap">
                <div class="progress-bar" style="width:${pct}%"></div>
              </div>
            </div>
          </div>

          <div class="monthly-card" id="monthly-stats-card" style="display:none">
            <div class="monthly-title">今月の応募状況</div>
            <div class="monthly-grid" id="monthly-grid"></div>
            <div style="text-align:right;margin-top:10px">
              <a href="${interactionsUrl || '/liff/interactions'}" style="font-size:12px;color:#2ca87a;font-weight:600;text-decoration:none">やりとりを見る →</a>
            </div>
          </div>

          <div class="card">
            <div class="section-title" style="margin-bottom:10px">獲得バッジ</div>
            <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:flex-start">
              ${badgeHtml}
            </div>
            ${badges.length > 6 ? `<p style="font-size:12px;color:#2ca87a;text-align:center;margin-top:10px">他 ${badges.length - 6} 個</p>` : ""}
          </div>

          <div class="card">
            <div class="section-title">最近のポイント履歴</div>
            <ul class="tx-list">${txHtml}</ul>
          </div>

          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;">
            <button class="btn btn-secondary btn-sm" id="btn-history">回答履歴を見る</button>
            <button class="btn btn-secondary btn-sm" id="btn-points-detail">ポイント明細を見る</button>
            <button class="btn btn-secondary btn-sm" id="btn-edit-profile">プロフィールを編集</button>
            <button class="btn btn-secondary btn-sm" id="btn-consent">規約・同意状況</button>
          </div>
        `);

        // 今月の応募状況を非同期ロード
        loadMonthlyStats();

        document.getElementById("btn-history")?.addEventListener("click", () => {
          renderHistory();
        });
        document.getElementById("btn-points-detail")?.addEventListener("click", () => {
          renderPointsDetail();
        });
        document.getElementById("btn-edit-profile")?.addEventListener("click", () => {
          renderEditForm(data.profile);
        });
        document.getElementById("btn-consent")?.addEventListener("click", () => {
          renderConsentPage();
        });
      }

      // ---- 初回セットアップ描画 ----
      function renderSetupForm(profile) {
        const p = profile || {};
        const prefectures = ["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県","茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県","新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県","三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県","鳥取県","島根県","岡山県","広島県","山口県","徳島県","香川県","愛媛県","高知県","福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"];
        show(`
          <div class="card">
            <div class="setup-header">
              <div class="icon">📝</div>
              <h2>プロフィール設定</h2>
              <p>案件に参加する前に、基本情報を登録してください。<br>所要時間：約2分</p>
            </div>
          </div>
          <div class="card">
            <div class="section-title" style="margin-bottom:4px">必須項目</div>
            <p style="font-size:12px;color:#60726f;margin-bottom:14px">以下の項目は全て入力が必要です。</p>
            <form id="setup-form" class="form-stack">
              <div class="form-group">
                <label>呼び名<span class="required">必須</span></label>
                <input class="form-control" type="text" name="nickname" value="${esc(p.nickname)}" placeholder="例：たろう" required />
              </div>
              <div class="form-group">
                <label>生年月日<span class="required">必須</span></label>
                <input class="form-control" type="date" name="birth_date" value="${esc(p.birth_date)}" required />
              </div>
              <div class="form-group">
                <label>性別<span class="required">必須</span></label>
                <div class="radio-group">
                  ${[["male","男性"],["female","女性"],["other","その他"],["prefer_not_to_say","答えたくない"]].map(([v,l]) =>
                    `<label><input type="radio" name="gender" value="${v}" ${chk(p.gender, v)} required />${l}</label>`
                  ).join("")}
                </div>
              </div>
              <div class="form-group">
                <label>都道府県<span class="required">必須</span></label>
                <select class="form-control" name="prefecture" required>
                  <option value="">選択してください</option>
                  ${prefectures.map(pref => `<option value="${esc(pref)}" ${sel(p.prefecture, pref)}>${esc(pref)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>職業<span class="required">必須</span></label>
                <select class="form-control" name="occupation" required>
                  <option value="">選択してください</option>
                  ${["会社員（正社員）","会社員（契約・派遣）","公務員","自営業・フリーランス","パート・アルバイト","学生","専業主婦・主夫","無職","その他"].map(o => `<option value="${esc(o)}" ${sel(p.occupation, o)}>${esc(o)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>業種<span class="required">必須</span></label>
                <select class="form-control" name="industry" required>
                  <option value="">選択してください</option>
                  ${["IT・通信","製造","金融・保険","医療・福祉","教育","小売・流通","外食・フード","建設・不動産","メディア・広告","公共・行政","その他"].map(i => `<option value="${esc(i)}" ${sel(p.industry, i)}>${esc(i)}</option>`).join("")}
                </select>
              </div>

              <div class="card" style="background:#f8faf9;border-radius:12px;padding:14px;margin-top:4px">
                <div class="section-title" style="margin-bottom:8px">推奨項目（任意）</div>
                <p style="font-size:12px;color:#60726f;margin-bottom:12px">入力するとあなたに合ったアンケートが届きやすくなります。</p>
                <div class="form-stack">
                  <div class="form-group">
                    <label>婚姻状況</label>
                    <div class="radio-group">
                      ${[["single","未婚"],["married","既婚"],["divorced","離婚"],["widowed","死別"]].map(([v,l]) =>
                        `<label><input type="radio" name="marital_status" value="${v}" ${chk(p.marital_status, v)} />${l}</label>`
                      ).join("")}
                    </div>
                  </div>
                  <div class="form-group">
                    <label>子どもの有無</label>
                    <div class="radio-group">
                      <label><input type="radio" name="has_children" value="true"  ${p.has_children === true  ? "checked" : ""} />いる</label>
                      <label><input type="radio" name="has_children" value="false" ${p.has_children === false ? "checked" : ""} />いない</label>
                    </div>
                  </div>
                </div>
              </div>

              <p style="font-size:12px;color:#60726f;line-height:1.6;margin-top:4px">
                利用規約・プライバシーポリシーへの同意は確認済みです。内容は「マイページ」からいつでも再確認できます。
              </p>
              <p id="setup-status" class="status-msg"></p>
              <button type="submit" class="btn btn-primary">登録して始める</button>
            </form>
          </div>
        `);

        document.getElementById("setup-form")?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const form = e.target;
          const fd = new FormData(form);
          const statusEl = document.getElementById("setup-status");

          // 性別は radio なので HTML required が効かないブラウザ向けに JS バリデーション
          if (!fd.get("gender")) {
            statusEl.textContent = "性別を選択してください。";
            statusEl.className = "status-msg error";
            return;
          }

          statusEl.textContent = "保存中...";
          statusEl.className = "status-msg";

          const payload = {
            nickname:       fd.get("nickname") || null,
            birth_date:     fd.get("birth_date") || null,
            gender:         fd.get("gender") || null,
            prefecture:     fd.get("prefecture") || null,
            occupation:     fd.get("occupation") || null,
            industry:       fd.get("industry") || null,
            marital_status: fd.get("marital_status") || null,
            has_children:   fd.get("has_children") === "true" ? true : fd.get("has_children") === "false" ? false : null,
          };

          try {
            const res = await fetch(updateUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json", Authorization: `Bearer ${idToken}` },
              body: JSON.stringify(payload)
            });
            if (!res.ok) throw new Error("保存に失敗しました。");
            const json = await res.json();

            // マイページ確認完了をセッションに記録してからnextへ遷移
            async function confirmAndNavigate(destination) {
              if (confirmMypageUrl && sessionId) {
                try {
                  await fetch(confirmMypageUrl, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ session_id: sessionId })
                  });
                } catch(e) {
                  console.warn("confirm-mypage failed", e);
                }
              }
              window.location.href = destination;
            }

            if (json.profile_just_completed) {
              statusEl.textContent = "登録完了！";
              statusEl.className = "status-msg success";
              if (next) {
                setTimeout(() => confirmAndNavigate(next), 800);
              } else {
                setTimeout(() => load(), 800);
              }
            } else {
              statusEl.textContent = "保存しました。";
              statusEl.className = "status-msg success";
              if (next) {
                setTimeout(() => confirmAndNavigate(next), 800);
              }
            }
          } catch (err) {
            statusEl.textContent = err.message || "保存に失敗しました。";
            statusEl.className = "status-msg error";
          }
        });
      }

      // ---- 回答履歴描画 ----
      async function renderHistory() {
        show(`<div id="loading-inner" style="text-align:center;padding:40px;color:#60726f">読み込み中...</div>`);
        try {
          const res = await fetch(historyUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) throw new Error("取得に失敗しました");
          const data = await res.json();
          const history = data.history || [];

          const statusLabel = {
            assigned: "未開始", sent: "送付済", opened: "開封済",
            started: "回答中", completed: "完了", expired: "期限切れ", cancelled: "キャンセル"
          };
          const statusColor = { completed: "#2ca87a", expired: "#999", cancelled: "#999" };

          const rows = history.length === 0
            ? `<div style="text-align:center;color:#999;padding:24px">回答履歴がありません</div>`
            : history.map(h => `
              <div class="tx-item" style="flex-direction:column;align-items:flex-start;gap:4px;padding:12px 0">
                <div style="display:flex;justify-content:space-between;width:100%">
                  <span style="font-weight:600;font-size:14px">${esc(h.project_name)}</span>
                  <span style="font-size:12px;font-weight:600;color:${statusColor[h.status]||'#333'}">${statusLabel[h.status]||h.status}</span>
                </div>
                <div style="display:flex;justify-content:space-between;width:100%">
                  <span style="font-size:12px;color:#60726f">${fmtDate(h.assigned_at)}</span>
                  ${h.status === 'completed' && h.reward_points ? `<span style="font-size:12px;color:#2ca87a;font-weight:600">+${h.reward_points}pt</span>` : ''}
                </div>
              </div>`).join("");

          show(`
            <div class="card" style="display:flex;align-items:center;gap:12px;padding:14px 20px;">
              <button id="btn-back" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;">←</button>
              <span style="font-weight:600;font-size:16px;">回答履歴</span>
            </div>
            <div class="card">
              <div class="section-title" style="margin-bottom:8px">全${history.length}件</div>
              <ul class="tx-list">${rows}</ul>
            </div>
          `);
          document.getElementById("btn-back")?.addEventListener("click", () => load());
        } catch (err) {
          showError(err.message || "読み込みに失敗しました");
        }
      }

      // ---- ポイント画面 ----
      async function renderPointsDetail() {
        show(`<div style="text-align:center;padding:40px;color:#60726f">読み込み中...</div>`);
        try {
          const res = await fetch(pointsUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) throw new Error("取得に失敗しました");
          const data = await res.json();
          renderPointsView(data);
        } catch (err) {
          showError(err.message || "読み込みに失敗しました");
        }
      }

      function renderPointsView(data, activeTab = "exchange") {
        const bal      = data.balance  || {};
        const histories = data.histories || [];
        const exchanges = data.exchanges || [];

        const available = bal.available_points ?? 0;
        const pending   = bal.pending_points   ?? 0;
        const lifetime  = bal.lifetime_points  ?? 0;

        // 交換進捗
        const UNIT = 500;
        const remainder    = available % UNIT;
        const shortfall    = remainder === 0 && available > 0 ? 0 : UNIT - remainder;
        const progressPct  = Math.min(100, Math.round((remainder === 0 && available >= UNIT ? UNIT : remainder) / UNIT * 100));
        const canExchange  = available >= UNIT;
        const hasPending   = exchanges.some(e => e.status === "pending");
        const exchangeCount = Math.floor(available / UNIT);

        // バランスカード
        const progressHtml = `
          <div class="exchange-progress-wrap">
            <div class="exchange-progress-bar" style="width:${canExchange ? 100 : progressPct}%"></div>
          </div>
          <div class="exchange-progress-label">
            ${canExchange
              ? `${exchangeCount}口（${available}pt）交換可能`
              : `次の交換まであと ${shortfall}pt`}
          </div>`;

        const exchangeBtnHtml = hasPending
          ? `<div class="btn-exchange-pending">申請中（承認をお待ちください）</div>`
          : canExchange
            ? `<button id="btn-do-exchange" class="btn-exchange">500pt を交換申請する</button>`
            : `<button class="btn-exchange" disabled>500pt に達したら交換できます</button>`;

        // 交換履歴
        const exchangeStatusLabel = {
          pending: "申請中", approved: "承認済", fulfilled: "送付済", rejected: "却下", canceled: "キャンセル"
        };
        const exchangeStatusClass = {
          pending: "badge-pending", approved: "badge-approved", fulfilled: "badge-fulfilled",
          rejected: "badge-rejected", canceled: "badge-canceled"
        };

        const exchangeRows = exchanges.length === 0
          ? `<div style="text-align:center;color:#999;padding:16px;font-size:13px">交換申請はまだありません</div>`
          : exchanges.map(e => {
            const giftHtml = e.status === "fulfilled" && e.gift_url
              ? `<div class="gift-url-box">
                   <div class="gift-url-label">ギフトURL（有効期限内にご使用ください）</div>
                   <a href="${esc(e.gift_url)}" target="_blank">${esc(e.gift_url)}</a>
                 </div>`
              : "";
            const cancelBtn = e.status === "pending"
              ? `<button class="btn-cancel-exchange btn btn-secondary btn-sm" data-id="${esc(e.id)}"
                   style="margin-top:8px;font-size:12px;padding:7px 12px;width:auto">申請をキャンセル</button>`
              : "";
            const failedNote = e.status === "rejected" && e.failed_reason
              ? `<div style="font-size:12px;color:#c0392b;margin-top:4px">却下理由: ${esc(e.failed_reason)}</div>`
              : "";
            return `
              <div style="padding:14px 0;border-bottom:1px solid #f0f4f3">
                <div style="display:flex;justify-content:space-between;align-items:center">
                  <span style="font-size:15px;font-weight:700;color:#1a2f2a">${e.requested_points}pt</span>
                  <span class="exchange-status-badge ${exchangeStatusClass[e.status] || ''}">${exchangeStatusLabel[e.status] || e.status}</span>
                </div>
                <div style="font-size:12px;color:#60726f;margin-top:3px">${fmtDate(e.requested_at)} 申請</div>
                ${failedNote}
                ${giftHtml}
                ${cancelBtn}
              </div>`;
          }).join("");

        // ポイント履歴
        const typeLabel = {
          project_completion: "案件完了", first_bonus: "初回ボーナス",
          continuity_bonus: "継続ボーナス", project_bonus: "案件ボーナス",
          daily_survey: "デイリー回答", interview_complete: "インタビュー完了",
          streak_bonus: "ストリークボーナス", birthday_bonus: "誕生日ボーナス",
          campaign_bonus: "キャンペーン", attribute_update: "プロフィール更新",
          manual_adjustment: "手動調整", redemption: "交換",
          exchange_request: "交換申請（仮押さえ）", exchange_cancel: "申請キャンセル（返還）",
          exchange_refund: "申請却下（返還）"
        };

        const historyRows = histories.length === 0
          ? `<li class="tx-item"><span class="tx-reason" style="color:#999">ポイント履歴がありません</span></li>`
          : histories.map(t => `
            <li class="tx-item">
              <span class="tx-reason">${esc(t.reason || typeLabel[t.type] || t.type)}</span>
              <span class="tx-date">${fmtDate(t.created_at)}</span>
              <span class="tx-points" style="color:${t.points >= 0 ? '#2ca87a' : '#c0392b'}">
                ${t.points >= 0 ? '+' : ''}${t.points}pt
              </span>
            </li>`).join("");

        show(`
          <div class="card" style="display:flex;align-items:center;gap:12px;padding:14px 20px;">
            <button id="btn-back" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;">←</button>
            <span style="font-weight:600;font-size:16px;">ポイント</span>
          </div>

          <div class="balance-card">
            <div class="balance-label">保有ポイント</div>
            <div>
              <span class="balance-main">${available}</span>
              <span class="balance-unit">pt</span>
            </div>
            <div class="balance-sub-row">
              <div class="balance-sub-item">
                <div class="balance-sub-val">${pending}<span style="font-size:12px;margin-left:2px">pt</span></div>
                <div class="balance-sub-lbl">申請中</div>
              </div>
              <div class="balance-sub-item">
                <div class="balance-sub-val">${lifetime - available - pending}<span style="font-size:12px;margin-left:2px">pt</span></div>
                <div class="balance-sub-lbl">累計交換</div>
              </div>
              <div class="balance-sub-item">
                <div class="balance-sub-val">${lifetime}<span style="font-size:12px;margin-left:2px">pt</span></div>
                <div class="balance-sub-lbl">累計獲得</div>
              </div>
            </div>
            ${progressHtml}
            <div style="margin-top:14px">${exchangeBtnHtml}</div>
          </div>

          <div class="card">
            <div class="tab-bar">
              <button class="tab-btn ${activeTab === 'exchange' ? 'active' : ''}" id="tab-exchange">交換申請履歴</button>
              <button class="tab-btn ${activeTab === 'history'  ? 'active' : ''}" id="tab-history">ポイント履歴</button>
            </div>
            <div id="pane-exchange" style="display:${activeTab === 'exchange' ? '' : 'none'}">
              ${exchangeRows}
            </div>
            <div id="pane-history" style="display:${activeTab === 'history' ? '' : 'none'}">
              <ul class="tx-list">${historyRows}</ul>
            </div>
          </div>
        `);

        // ---- イベント ----
        document.getElementById("btn-back")?.addEventListener("click", () => load());

        // タブ切替
        document.getElementById("tab-exchange")?.addEventListener("click", () => {
          document.getElementById("pane-exchange").style.display = "";
          document.getElementById("pane-history").style.display  = "none";
          document.getElementById("tab-exchange").classList.add("active");
          document.getElementById("tab-history").classList.remove("active");
        });
        document.getElementById("tab-history")?.addEventListener("click", () => {
          document.getElementById("pane-history").style.display  = "";
          document.getElementById("pane-exchange").style.display = "none";
          document.getElementById("tab-history").classList.add("active");
          document.getElementById("tab-exchange").classList.remove("active");
        });

        // 交換申請
        document.getElementById("btn-do-exchange")?.addEventListener("click", () => {
          showExchangeConfirm(available, data);
        });

        // 申請キャンセル
        document.querySelectorAll(".btn-cancel-exchange").forEach(btn => {
          btn.addEventListener("click", async () => {
            const requestId = btn.dataset.id;
            if (!requestId) return;
            if (!confirm("交換申請をキャンセルしますか？ポイントは返還されます。")) return;
            btn.disabled = true;
            try {
              const r = await fetch(`${exchangeRequestUrl}/${requestId}/cancel`, {
                method: "POST",
                headers: { Authorization: `Bearer ${idToken}` }
              });
              const j = await r.json();
              if (!r.ok) throw new Error(j.error || "キャンセルに失敗しました");
              await reloadPointsView();
            } catch (e) {
              alert(e.message || "エラーが発生しました");
              btn.disabled = false;
            }
          });
        });
      }

      function showExchangeConfirm(available, cachedData) {
        const UNIT = 500;
        const count = Math.floor(available / UNIT);
        // 申請口数は常に1口（1度に500ptのみ）
        const pts = UNIT;
        const overlay = document.createElement("div");
        overlay.className = "confirm-overlay";
        overlay.innerHTML = `
          <div class="confirm-sheet">
            <div class="confirm-title">500pt を交換申請する</div>
            <div class="confirm-body">
              500pt を <strong>Amazonギフト等</strong> と交換申請します。<br>
              申請後、管理者が確認・承認後にギフトURLをLINEでお送りします。<br><br>
              <strong>申請後はキャンセル可能</strong>ですが、承認後はキャンセルできません。
            </div>
            <p id="confirm-status" class="status-msg"></p>
            <div class="confirm-btns">
              <button id="confirm-cancel" class="btn btn-secondary" style="flex:1">閉じる</button>
              <button id="confirm-ok"     class="btn btn-primary"   style="flex:2">申請する（500pt）</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);

        overlay.querySelector("#confirm-cancel").addEventListener("click", () => overlay.remove());
        overlay.addEventListener("click", e => { if (e.target === overlay) overlay.remove(); });

        overlay.querySelector("#confirm-ok").addEventListener("click", async () => {
          const okBtn  = overlay.querySelector("#confirm-ok");
          const stEl   = overlay.querySelector("#confirm-status");
          okBtn.disabled = true;
          stEl.textContent = "申請中...";
          stEl.className = "status-msg";
          try {
            const r = await fetch(exchangeRequestUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json", Authorization: `Bearer ${idToken}` },
              body: JSON.stringify({ requested_points: pts })
            });
            const j = await r.json();
            if (!r.ok) throw new Error(j.error || "申請に失敗しました");
            overlay.remove();
            await reloadPointsView();
          } catch (e) {
            stEl.textContent = e.message || "エラーが発生しました";
            stEl.className = "status-msg error";
            okBtn.disabled = false;
          }
        });
      }

      async function reloadPointsView() {
        try {
          const res = await fetch(pointsUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) throw new Error("再取得に失敗しました");
          renderPointsView(await res.json());
        } catch (err) {
          showError(err.message || "読み込みに失敗しました");
        }
      }

      // ---- 規約・同意状況 ----
      // バージョン管理された書類（利用規約・PP等）の実際の同意状況を表示し、本文を再確認できる。
      async function renderConsentPage() {
        show(`<div style="text-align:center;padding:40px;color:#60726f">読み込み中...</div>`);
        try {
          const res = await fetch(consentStatusUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) throw new Error("取得に失敗しました");
          const data = await res.json();
          const statuses = data.statuses || [];

          const rows = statuses.length === 0
            ? `<p style="font-size:13px;color:#60726f;padding:8px 0">現在、同意が必要な書類はありません。</p>`
            : statuses.map(s => {
              let badge;
              if (!s.consented) {
                badge = `<span style="font-size:12px;font-weight:600;color:#c0392b;background:#fdecea;padding:3px 10px;border-radius:12px">未同意</span>`;
              } else if (!s.isLatestVersion) {
                badge = `<span style="font-size:12px;font-weight:600;color:#b45309;background:#fbf0e0;padding:3px 10px;border-radius:12px">要再同意</span>`;
              } else {
                badge = `<span style="font-size:12px;font-weight:600;color:#1a7a5a;background:#e8f5ef;padding:3px 10px;border-radius:12px">同意済み</span>`;
              }
              const detail = s.consented
                ? `v${esc(s.consentedVersionNo || "")}${s.consentedAt ? "・" + fmtDate(s.consentedAt) : ""}${!s.isLatestVersion && s.currentVersionNo ? `（最新 v${esc(s.currentVersionNo)}）` : ""}`
                : (s.currentVersionNo ? `最新 v${esc(s.currentVersionNo)}` : "");
              return `
                <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;padding:14px 0;border-bottom:1px solid #f0f4f3">
                  <div style="flex:1">
                    <div style="font-size:14px;font-weight:600;color:#1a2f2a">${esc(s.title)}</div>
                    <div style="font-size:12px;color:#60726f;margin-top:3px">${detail}</div>
                  </div>
                  ${badge}
                  <button class="doc-read-btn" data-id="${esc(s.documentId)}" data-title="${esc(s.title)}"
                    style="background:none;border:1px solid #cfe0db;border-radius:8px;padding:6px 12px;font-size:12px;color:#2ca87a;cursor:pointer;white-space:nowrap">読む</button>
                </div>`;
            }).join("");

          const reconsentBtn = data.has_unsigned
            ? `<button id="btn-reconsent" class="btn btn-primary" style="margin-top:16px">未同意・改定された書類を確認する</button>`
            : "";

          show(`
            <div class="card" style="display:flex;align-items:center;gap:12px;padding:14px 20px;">
              <button id="btn-back" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;">←</button>
              <span style="font-weight:600;font-size:16px;">規約・同意状況</span>
            </div>
            <div class="card">
              <div style="font-size:12px;color:#60726f;margin-bottom:8px;line-height:1.6">
                ご利用にあたって同意いただいた書類の状況です。本文は「読む」からいつでも再確認できます。
              </div>
              ${rows}
              ${reconsentBtn}
            </div>
          `);

          document.getElementById("btn-back")?.addEventListener("click", () => load());

          document.getElementById("btn-reconsent")?.addEventListener("click", () => {
            const redirect = encodeURIComponent(location.pathname + location.search);
            location.href = `${consentPageUrl}?mode=update&redirect=${redirect}`;
          });

          document.querySelectorAll(".doc-read-btn").forEach(btn => {
            btn.addEventListener("click", () => openDocumentOverlay(btn.dataset.id, btn.dataset.title));
          });
        } catch (err) {
          showError(err.message || "読み込みに失敗しました");
        }
      }

      // ---- 書類本文オーバーレイ（再確認用） ----
      async function openDocumentOverlay(docId, title) {
        const overlay = document.createElement("div");
        overlay.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:flex-end;justify-content:center";
        overlay.innerHTML = `
          <div style="background:#fff;width:100%;max-width:560px;max-height:85vh;border-radius:16px 16px 0 0;display:flex;flex-direction:column">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid #f0f4f3">
              <span style="font-weight:600;font-size:15px">${esc(title || "書類")}</span>
              <button class="ov-close" style="background:none;border:none;font-size:22px;cursor:pointer;color:#999">×</button>
            </div>
            <div class="ov-body" style="overflow-y:auto;padding:16px;font-size:13px;line-height:1.8;color:#333;white-space:pre-wrap">読み込み中...</div>
          </div>`;
        document.body.appendChild(overlay);
        const close = () => overlay.remove();
        overlay.querySelector(".ov-close")?.addEventListener("click", close);
        overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); });
        try {
          const res = await fetch(`${documentBaseUrl}/${docId}`, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) throw new Error("本文の取得に失敗しました");
          const data = await res.json();
          overlay.querySelector(".ov-body").textContent = data.version?.content || "(本文がありません)";
        } catch (e) {
          overlay.querySelector(".ov-body").textContent = e.message || "本文の取得に失敗しました";
        }
      }

      // ---- 全項目編集フォーム描画 ----
      function renderEditForm(profile) {
        const p = profile || {};
        const prefectures = ["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県","茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県","新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県","三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県","鳥取県","島根県","岡山県","広島県","山口県","徳島県","香川県","愛媛県","高知県","福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"];

        show(`
          <div class="card" style="display:flex;align-items:center;gap:12px;padding:14px 20px;">
            <button id="btn-back" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;">←</button>
            <span style="font-weight:600;font-size:16px;">プロフィール編集</span>
          </div>
          <div class="card">
            <form id="edit-form" class="form-stack">
              <div class="form-group">
                <label>呼び名</label>
                <input class="form-control" type="text" name="nickname" value="${esc(p.nickname)}" placeholder="例：たろう" />
              </div>
              <div class="form-group">
                <label>生年月日</label>
                <input class="form-control" type="date" name="birth_date" value="${esc(p.birth_date)}" />
              </div>
              <div class="form-group">
                <label>都道府県</label>
                <select class="form-control" name="prefecture">
                  <option value="">選択してください</option>
                  ${prefectures.map(pref => `<option value="${esc(pref)}" ${sel(p.prefecture, pref)}>${esc(pref)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>住所詳細</label>
                <div class="radio-group" style="margin-bottom:8px;">
                  <label><input type="radio" name="address_declined" value="false" ${p.address_declined ? "" : "checked"} />詳細も登録する</label>
                  <label><input type="radio" name="address_declined" value="true" ${p.address_declined ? "checked" : ""} />都道府県のみ</label>
                </div>
                <div id="address-detail-wrap">
                  <input class="form-control" type="text" name="address_detail" value="${esc(p.address_detail)}" placeholder="例：渋谷区..." />
                </div>
              </div>
              <div class="form-group">
                <label>職業</label>
                <select class="form-control" name="occupation">
                  <option value="">選択してください</option>
                  ${["会社員（正社員）","会社員（契約・派遣）","公務員","自営業・フリーランス","パート・アルバイト","学生","専業主婦・主夫","無職","その他"].map(o => `<option value="${esc(o)}" ${sel(p.occupation, o)}>${esc(o)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>業種</label>
                <select class="form-control" name="industry">
                  <option value="">選択してください</option>
                  ${["IT・通信","製造","金融・保険","医療・福祉","教育","小売・流通","外食・フード","建設・不動産","メディア・広告","公共・行政","その他"].map(i => `<option value="${esc(i)}" ${sel(p.industry, i)}>${esc(i)}</option>`).join("")}
                </select>
              </div>
              <div class="form-group">
                <label>婚姻状況</label>
                <div class="radio-group">
                  ${[["single","未婚"],["married","既婚"],["divorced","離婚"],["widowed","死別"]].map(([v,l]) =>
                    `<label><input type="radio" name="marital_status" value="${v}" ${chk(p.marital_status, v)} />${l}</label>`
                  ).join("")}
                </div>
              </div>
              <div class="form-group">
                <label>子どもの有無</label>
                <div class="radio-group">
                  <label><input type="radio" name="has_children" value="true"  ${p.has_children === true  ? "checked" : ""} />いる</label>
                  <label><input type="radio" name="has_children" value="false" ${p.has_children === false ? "checked" : ""} />いない</label>
                </div>
              </div>
              <div class="form-group">
                <label>子どもの年齢（カンマ区切り）</label>
                <input class="form-control" type="text" name="children_ages_text" value="${esc((p.children_ages||[]).join(","))}" placeholder="例：3,7,12" />
              </div>
              <div class="form-group">
                <label>同居家族構成（複数選択可）</label>
                <div class="checkbox-group">
                  ${[["self","本人のみ"],["spouse","配偶者"],["child","子ども"],["parent","親"],["sibling","兄弟姉妹"],["other","その他"]].map(([v,l]) =>
                    `<label><input type="checkbox" name="household_composition" value="${v}" ${inArr(p.household_composition, v)} />${l}</label>`
                  ).join("")}
                </div>
              </div>
              <p id="edit-status" class="status-msg"></p>
              <button type="submit" class="btn btn-primary">保存する</button>
            </form>
          </div>
        `);

        document.getElementById("btn-back")?.addEventListener("click", () => load());

        // 住所詳細表示切替
        const declineRadios = document.querySelectorAll('input[name="address_declined"]');
        function toggleAddr() {
          const declined = document.querySelector('input[name="address_declined"]:checked')?.value === "true";
          const wrap = document.getElementById("address-detail-wrap");
          if (wrap) wrap.style.display = declined ? "none" : "";
        }
        declineRadios.forEach(r => r.addEventListener("change", toggleAddr));
        toggleAddr();

        document.getElementById("edit-form")?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const form = e.target;
          const fd = new FormData(form);
          const statusEl = document.getElementById("edit-status");
          statusEl.textContent = "保存中...";
          statusEl.className = "status-msg";

          const childAges = (fd.get("children_ages_text")||"").toString().split(",").map(s => parseInt(s.trim(),10)).filter(n => !isNaN(n));
          const payload = {
            nickname:             fd.get("nickname") || null,
            birth_date:           fd.get("birth_date") || null,
            prefecture:           fd.get("prefecture") || null,
            address_declined:     fd.get("address_declined") === "true",
            address_detail:       fd.get("address_declined") === "true" ? null : (fd.get("address_detail") || null),
            occupation:           fd.get("occupation") || null,
            industry:             fd.get("industry") || null,
            marital_status:       fd.get("marital_status") || null,
            has_children:         fd.get("has_children") === "true" ? true : fd.get("has_children") === "false" ? false : null,
            children_ages:        childAges,
            household_composition: fd.getAll("household_composition").map(String).filter(Boolean),
          };

          try {
            const res = await fetch(updateUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json", Authorization: `Bearer ${idToken}` },
              body: JSON.stringify(payload)
            });
            if (!res.ok) throw new Error("保存に失敗しました。");
            statusEl.textContent = "保存しました。";
            statusEl.className = "status-msg success";
          } catch (err) {
            statusEl.textContent = err.message || "保存に失敗しました。";
            statusEl.className = "status-msg error";
          }
        });
      }

      // ---- 今月の応募状況 ----
      async function loadMonthlyStats() {
        if (!historyUrl) return;
        try {
          const res = await fetch(historyUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) return;
          const data = await res.json();
          const history = data.history || [];
          const now = new Date();
          const thisMonth = history.filter(h => {
            const d = new Date(h.assigned_at || '');
            return d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth();
          });
          const completedThisMonth = thisMonth.filter(h => h.status === 'completed');
          const earnedThisMonth = completedThisMonth.reduce((sum, h) => sum + (h.reward_points || 0), 0);

          const card = document.getElementById('monthly-stats-card');
          const grid = document.getElementById('monthly-grid');
          if (!card || !grid) return;

          grid.innerHTML = `
            <div class="monthly-item">
              <div class="monthly-value">${thisMonth.length}<span class="monthly-unit">件</span></div>
              <div class="monthly-label">今月の応募数</div>
            </div>
            <div class="monthly-item">
              <div class="monthly-value">${earnedThisMonth}<span class="monthly-unit">pt</span></div>
              <div class="monthly-label">今月の獲得ポイント</div>
            </div>`;
          card.style.display = '';
        } catch (_) {}
      }

      // ---- 同意ゲート ----
      // バージョン管理されたグローバル必須書類（利用規約・PP）の最新版に未同意なら
      // 同意画面 /liff/consent へ誘導する。プロフィール登録より前に同意を取得する。
      // 戻り先として現在のURLを渡し、同意後はこのページに復帰する。
      async function ensureGlobalConsent() {
        try {
          // 同意画面 consent.ejs と同一エンドポイントで判定する（基準を揃えてループを防ぐ）。
          // count>0 = 未同意 or 改定による要再同意。
          const res = await fetch('/liff/consent-check', { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) return false; // 同意基盤の障害で登録自体を止めない（フェイルオープン）
          const data = await res.json();
          if (!data.count) return false;
          const redirect = encodeURIComponent(location.pathname + location.search);
          location.href = `/liff/consent?mode=initial&redirect=${redirect}`;
          return true;
        } catch {
          return false;
        }
      }

      // ---- メインロード ----
      async function load() {
        if (!liffId) {
          showError("LIFF IDが設定されていません。管理者にお問い合わせください。");
          return;
        }
        try {
          const token = await LiffAuth.initLiffOrWebAuth(liffId);
          if (!token) return; // LINE Login リダイレクト中
          idToken = token;

          // プロフィール表示・登録の前に規約同意を確認（未同意なら同意画面へ離脱）
          if (await ensureGlobalConsent()) return;

          const res = await fetch(profileUrl, { headers: { Authorization: `Bearer ${idToken}` } });
          if (!res.ok) {
            let detail = "";
            try { detail = (await res.json()).detail || ""; } catch (_e) {}
            throw new Error("情報の取得に失敗しました。" + (detail ? "（" + detail + "）" : "") + `[${res.status}]`);
          }
          const data = await res.json();

          const forceSetup = mode === "initial_setup";
          const profileIncomplete = !data.profile?.profile_completed;

          if (forceSetup || profileIncomplete) {
            renderSetupForm(data.profile);
          } else if (mode === "edit") {
            renderEditForm(data.profile);
          } else {
            renderDashboard(data);
          }
        } catch (err) {
          showError(err.message || "読み込みに失敗しました。");
        }
      }

      void load();
    })();
    </script>
  </body>
</html>

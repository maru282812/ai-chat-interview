<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <%- include('../partials/liff-auth') %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
        background: #f0f4f3;
        min-height: 100vh;
      }
      .container { max-width: 480px; margin: 0 auto; padding: 16px 16px 80px; }

      .page-header {
        text-align: center;
        padding: 24px 0 20px;
      }
      .page-header h1 { font-size: 20px; font-weight: 700; color: #1a2f2a; }
      .page-header p  { font-size: 13px; color: #60726f; margin-top: 8px; line-height: 1.6; }

      .doc-card {
        background: #fff;
        border-radius: 16px;
        margin-bottom: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        overflow: hidden;
      }
      .doc-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        cursor: pointer;
        user-select: none;
      }
      .doc-header:active { background: #f8faf9; }
      .doc-check {
        width: 24px; height: 24px;
        border-radius: 50%;
        border: 2px solid #ccc;
        flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
      }
      .doc-check.checked {
        background: #2ca87a;
        border-color: #2ca87a;
        color: #fff;
      }
      .doc-check svg { width: 14px; height: 14px; }
      .doc-title    { font-size: 15px; font-weight: 600; color: #1a2f2a; flex: 1; }
      .doc-version  { font-size: 11px; color: #999; }
      .required-tag {
        font-size: 10px; font-weight: 600;
        background: #fff0e0; color: #c06000;
        padding: 2px 6px; border-radius: 4px;
      }
      .expand-icon {
        font-size: 18px; color: #999;
        transition: transform 0.2s;
      }
      .expand-icon.open { transform: rotate(180deg); }

      .doc-content {
        display: none;
        border-top: 1px solid #f0f4f3;
        padding: 0 16px;
      }
      .doc-content.open { display: block; }

      /* 目次 */
      .toc {
        background: #f8faf9;
        border-radius: 8px;
        padding: 10px 14px;
        margin: 12px 0;
      }
      .toc-title { font-size: 12px; font-weight: 600; color: #60726f; margin-bottom: 6px; }
      .toc ul { padding-left: 1.2em; margin: 0; }
      .toc li { font-size: 12px; color: #1a7a5a; line-height: 1.8; cursor: pointer; }
      .toc li:hover { text-decoration: underline; }

      /* 本文 */
      .doc-body {
        max-height: 320px;
        overflow-y: auto;
        font-size: 13px;
        line-height: 1.8;
        color: #333;
        padding: 12px 0;
        scroll-behavior: smooth;
      }
      .doc-body h1, .doc-body h2, .doc-body h3 {
        font-size: 14px; font-weight: 700; margin: 16px 0 6px; color: #1a2f2a;
      }
      .doc-body h1 { font-size: 15px; }
      .doc-body p  { margin: 6px 0; }
      .doc-body ul, .doc-body ol { padding-left: 1.4em; margin: 6px 0; }
      .doc-body li { margin: 3px 0; }

      .scroll-note {
        font-size: 11px; color: #999;
        text-align: center;
        padding: 8px 0 14px;
      }

      /* 同意ボタンエリア */
      .consent-btn-wrap {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 16px;
        border-top: 1px solid #f0f4f3;
        background: #f8faf9;
      }
      .consent-btn-wrap label {
        display: flex; align-items: center; gap: 8px;
        font-size: 14px; font-weight: 500; color: #1a2f2a;
        cursor: pointer; flex: 1;
      }
      .consent-btn-wrap input[type="checkbox"] {
        width: 18px; height: 18px; cursor: pointer;
        accent-color: #2ca87a;
      }

      /* 一括チェック */
      .check-all-row {
        display: flex; align-items: center; gap: 10px;
        background: #e8f5ef;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 16px;
        cursor: pointer;
      }
      .check-all-row input[type="checkbox"] {
        width: 20px; height: 20px;
        accent-color: #2ca87a;
      }
      .check-all-label { font-size: 14px; font-weight: 600; color: #1a7a5a; }

      /* 送信ボタン */
      .submit-area {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        background: #fff;
        padding: 12px 16px;
        box-shadow: 0 -2px 8px rgba(0,0,0,.1);
      }
      .submit-btn {
        display: block; width: 100%;
        background: #2ca87a;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 16px; font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
      }
      .submit-btn:disabled { background: #b0cfc3; cursor: not-allowed; }
      .submit-btn:not(:disabled):active { background: #1a7a5a; }

      #loading, #error-msg { padding: 40px; text-align: center; color: #60726f; }
      #error-msg { color: #c00; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="page-header">
        <% if (mode === 'initial') { %>
          <h1>ご利用前の確認</h1>
          <p>サービスをご利用いただくには、<br>以下の書類をご確認の上、同意してください。</p>
        <% } else if (mode === 'update') { %>
          <h1>規約の更新があります</h1>
          <p>一部の規約が改定されました。<br>引き続きご利用いただくには再度のご同意が必要です。</p>
        <% } else { %>
          <h1>同意の確認</h1>
          <p>以下の書類をご確認の上、同意してください。</p>
        <% } %>
      </div>

      <div id="loading">読み込み中...</div>
      <div id="error-msg" style="display:none"></div>
      <div id="docs-container" style="display:none"></div>
    </div>

    <div class="submit-area">
      <button class="submit-btn" id="submit-btn" disabled onclick="submitConsents()">
        同意して利用を開始する
      </button>
    </div>

    <script>
      const LIFF_ID    = '<%= liffId %>';
      const MODE       = '<%= mode %>';
      const PROJECT_ID = '<%= projectId || '' %>';
      const REDIRECT   = '<%= redirectTo || '/liff/mypage' %>';

      let authToken = null;
      let pendingDocs = [];  // [{ documentId, versionId, versionNo, title, content, isRequired }]
      let checkedIds  = new Set();

      // ── 初期化 ──────────────────────────────────────────────────────────
      (async () => {
        try {
          authToken = await LiffAuth.initLiffOrWebAuth(LIFF_ID);
          if (!authToken) return;
          await loadPendingDocs();
        } catch (e) {
          showError(e.message);
        }
      })();

      async function loadPendingDocs() {
        const url = PROJECT_ID
          ? `/liff/consent-check?project_id=${PROJECT_ID}`
          : '/liff/consent-check';
        const res = await fetch(url, {
          headers: { Authorization: 'Bearer ' + authToken },
        });
        const json = await res.json();
        if (!json.ok) throw new Error(json.error || '読み込みに失敗しました');

        pendingDocs = json.pending;

        document.getElementById('loading').style.display = 'none';

        if (pendingDocs.length === 0) {
          // 同意不要 → リダイレクト
          location.href = REDIRECT;
          return;
        }

        document.getElementById('docs-container').style.display = 'block';
        renderDocs();
      }

      // ── レンダリング ─────────────────────────────────────────────────────
      function renderDocs() {
        const container = document.getElementById('docs-container');
        let html = '';

        if (pendingDocs.length > 1) {
          html += `<label class="check-all-row" onclick="toggleAll()">
            <input type="checkbox" id="check-all" />
            <span class="check-all-label">すべての書類に同意する</span>
          </label>`;
        }

        for (const doc of pendingDocs) {
          const toc = extractToc(doc.content);
          const bodyHtml = renderMarkdown(doc.content);
          html += `
<div class="doc-card" id="card-${doc.documentId}">
  <div class="doc-header" onclick="toggleExpand('${doc.documentId}')">
    <div class="doc-check" id="check-circle-${doc.documentId}">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="3,8 7,12 13,4"/>
      </svg>
    </div>
    <div style="flex:1">
      <div style="display:flex;align-items:center;gap:6px">
        <span class="doc-title">${escHtml(doc.title)}</span>
        ${doc.isRequired ? '<span class="required-tag">必須</span>' : ''}
      </div>
      <span class="doc-version">v${escHtml(doc.versionNo)}</span>
    </div>
    <span class="expand-icon" id="expand-icon-${doc.documentId}">▼</span>
  </div>

  <div class="doc-content" id="content-${doc.documentId}">
    ${toc.length > 0 ? renderToc(toc, doc.documentId) : ''}
    <div class="doc-body" id="body-${doc.documentId}">${bodyHtml}</div>
    <div class="scroll-note">▲ スクロールして全文をご確認ください</div>
    <div class="consent-btn-wrap">
      <label>
        <input type="checkbox" id="cb-${doc.documentId}"
          onchange="onCheck('${doc.documentId}', this.checked)" />
        「${escHtml(doc.title)}」を確認しました
      </label>
    </div>
  </div>
</div>`;
        }

        container.innerHTML = html;
        updateSubmitButton();
      }

      function toggleExpand(docId) {
        const content = document.getElementById('content-' + docId);
        const icon    = document.getElementById('expand-icon-' + docId);
        const isOpen  = content.classList.contains('open');
        content.classList.toggle('open', !isOpen);
        icon.classList.toggle('open', !isOpen);
      }

      function toggleAll() {
        const ca = document.getElementById('check-all');
        for (const doc of pendingDocs) {
          const cb = document.getElementById('cb-' + doc.documentId);
          if (cb) {
            cb.checked = ca.checked;
            onCheck(doc.documentId, ca.checked, false);
          }
        }
        updateSubmitButton();
      }

      function onCheck(docId, checked, updateAll = true) {
        if (checked) {
          checkedIds.add(docId);
        } else {
          checkedIds.delete(docId);
        }
        const circle = document.getElementById('check-circle-' + docId);
        if (circle) circle.classList.toggle('checked', checked);
        if (updateAll) {
          const ca = document.getElementById('check-all');
          if (ca) ca.checked = checkedIds.size === pendingDocs.length;
        }
        updateSubmitButton();
      }

      function updateSubmitButton() {
        const required = pendingDocs.filter(d => d.isRequired);
        const allRequiredChecked = required.every(d => checkedIds.has(d.documentId));
        const btn = document.getElementById('submit-btn');
        btn.disabled = !allRequiredChecked;
        btn.textContent = allRequiredChecked
          ? '同意して' + (MODE === 'initial' ? '利用を開始する' : '続ける')
          : '必須書類を確認してください';
      }

      // ── 同意送信 ─────────────────────────────────────────────────────────
      async function submitConsents() {
        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.textContent = '送信中...';

        try {
          const items = pendingDocs
            .filter(d => checkedIds.has(d.documentId))
            .map(d => ({ documentId: d.documentId, versionId: d.versionId, projectId: PROJECT_ID || null }));

          const res = await fetch('/liff/consent-submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: 'Bearer ' + authToken,
            },
            body: JSON.stringify({ items }),
          });
          const json = await res.json();
          if (!json.ok) throw new Error(json.error || '送信に失敗しました');
          location.href = REDIRECT;
        } catch (e) {
          btn.disabled = false;
          btn.textContent = '同意して' + (MODE === 'initial' ? '利用を開始する' : '続ける');
          showError(e.message);
        }
      }

      // ── ユーティリティ ─────────────────────────────────────────────────────
      function showError(msg) {
        document.getElementById('loading').style.display = 'none';
        const el = document.getElementById('error-msg');
        el.textContent = 'エラー: ' + msg;
        el.style.display = 'block';
      }

      function escHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function extractToc(md) {
        const lines = md.split('\n');
        const headings = [];
        for (const line of lines) {
          const m = line.match(/^(#{1,3})\s+(.+)/);
          if (m) headings.push({ level: m[1].length, text: m[2].trim() });
        }
        return headings;
      }

      function renderToc(headings, docId) {
        const items = headings.map(h =>
          `<li style="margin-left:${(h.level - 1) * 12}px" onclick="scrollToSection('${docId}','${escHtml(h.text)}')">${escHtml(h.text)}</li>`
        ).join('');
        return `<div class="toc"><div class="toc-title">目次</div><ul>${items}</ul></div>`;
      }

      function scrollToSection(docId, text) {
        const body = document.getElementById('body-' + docId);
        if (!body) return;
        const els = body.querySelectorAll('h1,h2,h3');
        for (const el of els) {
          if (el.textContent.trim() === text) {
            el.scrollIntoView({ behavior: 'smooth' });
            break;
          }
        }
      }

      // 最小限のMarkdownレンダー
      function renderMarkdown(md) {
        return md
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/^### (.+)$/gm, '<h3>$1</h3>')
          .replace(/^## (.+)$/gm, '<h2>$1</h2>')
          .replace(/^# (.+)$/gm, '<h1>$1</h1>')
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/^- (.+)$/gm, '<li>$1</li>')
          .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
          .replace(/^\d+\. (.+)$/gm, '<li>$1</li>')
          .replace(/\n{2,}/g, '</p><p>')
          .replace(/^(?!<[hul])/gm, '')
          .replace(/\n/g, '<br>')
          || '<p>' + md + '</p>';
      }
    </script>
  </body>
</html>

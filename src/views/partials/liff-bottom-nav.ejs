<%#
  LIFF共通下部ナビゲーション
  使い方: <%- include('../partials/liff-bottom-nav', { active: 'projects' }) %>
  active: 'projects' | 'saved' | 'interactions' | 'mypage'
%>
<nav class="bottom-nav" id="liff-bottom-nav">
  <a class="bottom-nav__item <%= active === 'projects' ? 'bottom-nav__item--active' : '' %>" href="/liff/projects">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span>探す</span>
  </a>
  <a class="bottom-nav__item <%= active === 'saved' ? 'bottom-nav__item--active' : '' %>" href="/liff/saved-projects">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
    <span>保存</span>
  </a>
  <a class="bottom-nav__item <%= active === 'interactions' ? 'bottom-nav__item--active' : '' %>" href="/liff/interactions">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span>やりとり</span>
  </a>
  <a class="bottom-nav__item <%= active === 'mypage' ? 'bottom-nav__item--active' : '' %>" href="/liff/mypage">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <span>マイページ</span>
  </a>
</nav>
<style>
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 60px;
  background: #fff;
  border-top: 1px solid #e8eeec;
  display: flex;
  z-index: 100;
  box-shadow: 0 -2px 8px rgba(0,0,0,.06);
}
.bottom-nav__item {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 2px;
  color: #aaa;
  text-decoration: none;
  font-size: 10px;
  font-weight: 600;
  transition: color 0.15s;
}
.bottom-nav__item--active { color: #2ca87a; }
.bottom-nav__item svg { stroke: currentColor; }
/* ナビ分の余白 */
body { padding-bottom: 68px; }
</style>

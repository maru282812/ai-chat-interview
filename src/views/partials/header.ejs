    <script>
      // 申請中の交換申請件数をヘッダーの「交換申請」に通知バッジとして表示する
      (function () {
        fetch("/admin/exchange-requests/pending-count")
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (j) {
            if (!j || !j.count) return;
            var badge = document.getElementById("nav-exchange-badge");
            if (!badge) return;
            badge.textContent = j.count > 99 ? "99+" : String(j.count);
            badge.style.display = "";
          })
          .catch(function () { /* バッジは補助表示なので失敗しても無視 */ });
      })();
    </script>

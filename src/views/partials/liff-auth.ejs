<%# LIFF共通認証ユーティリティ - 全LIFF画面で LIFF SDK読み込み直後にincludeして使う
    window.LiffAuth を提供し、各画面は個別にliff.init()を書かない。

    使い方:
      const token = await LiffAuth.initLiffOrWebAuth(liffId);
      if (!token) return; // LINE Loginリダイレクト中
      // token を Authorization: Bearer として使う
%>
<script>
(function () {
  'use strict';

  var _initialized = false;

  function _log(msg, data) {
    try { console.log('[LiffAuth] ' + msg, data || {}); } catch (_e) {}
  }

  // LINE Login の戻りで付与される OAuth パラメータ。redirectUri に残したまま
  // 再ログインすると戻りURLに code/state が二重に付き、SDK の検証が失敗し続けて
  // LINE⇄サイトの無限リダイレクトループになるため、ログイン前に必ず除去する。
  var OAUTH_RESPONSE_PARAMS = ['code', 'state', 'error', 'error_description', 'liffClientId', 'liffRedirectUri'];
  // ログイン試行回数を URL で持ち回るパラメータ。WebView がストレージを保持しない
  // 環境（QR流入の in-app ブラウザ等）でもループガードが機能するよう、storage ではなく
  // redirectUri 自体に埋め込む。
  var RETRY_PARAM = 'liff_retry';
  var MAX_LOGIN_ATTEMPTS = 2;

  function _sanitizedUrl() {
    try {
      var u = new URL(location.href);
      for (var i = 0; i < OAUTH_RESPONSE_PARAMS.length; i++) {
        u.searchParams.delete(OAUTH_RESPONSE_PARAMS[i]);
      }
      return u;
    } catch (_e) {
      return null;
    }
  }

  function _loginAttemptCount() {
    try {
      return parseInt(new URL(location.href).searchParams.get(RETRY_PARAM) || '0', 10) || 0;
    } catch (_e) {
      return 0;
    }
  }

  /**
   * ループガード付き LINE Login リダイレクト。
   * redirectUri から前回の OAuth 残渣を除去し、試行回数を URL パラメータで持ち回る。
   * @returns {boolean} true = リダイレクト開始 / false = 試行上限（呼び出し側でエラー表示）
   */
  function loginWithGuard() {
    var attempt = _loginAttemptCount();
    if (attempt >= MAX_LOGIN_ATTEMPTS) {
      _log('login loop guard tripped', { attempt: attempt });
      return false;
    }
    var redirectUri = location.href;
    var u = _sanitizedUrl();
    if (u) {
      u.searchParams.set(RETRY_PARAM, String(attempt + 1));
      redirectUri = u.toString();
    }
    _log('redirecting to LINE Login', { attempt: attempt + 1, redirectUri: redirectUri });
    liff.login({ redirectUri: redirectUri });
    return true;
  }

  /** 認証成功後にアドレスバーから OAuth 残渣とリトライカウンタを消す */
  function _clearLoginResidue() {
    try {
      var u = _sanitizedUrl();
      if (!u) return;
      u.searchParams.delete(RETRY_PARAM);
      var next = u.toString();
      if (next !== location.href) history.replaceState(null, '', next);
    } catch (_e) { /* noop */ }
  }

  /**
   * LIFF初期化 + 未ログイン時はLINE Loginへリダイレクト。
   * スマホLINE内: LIFF認証 → IDトークン取得
   * PCブラウザ等: LINE Login OAuth → リダイレクト後に再実行 → IDトークン取得
   * @param {string} liffId
   * @returns {Promise<string|null>} IDトークン（リダイレクトが起きた場合はnull）
   */
  async function initLiffOrWebAuth(liffId) {
    _log('init start', {
      liffId: liffId,
      sdkLoaded: typeof liff !== 'undefined',
      url: location.href,
      ua: navigator.userAgent.slice(0, 150),
    });

    if (typeof liff === 'undefined') {
      throw new Error('LIFF SDKを読み込めませんでした。ページを再読み込みしてください。');
    }
    if (!liffId) {
      throw new Error('LIFF IDが設定されていません。管理者にお問い合わせください。');
    }

    if (!_initialized) {
      await liff.init({ liffId: liffId });
      _initialized = true;
    }

    var isInClient = liff.isInClient();
    var isLoggedIn = liff.isLoggedIn();
    var hasIdToken = Boolean(liff.getIDToken());

    _log('liff state', {
      hasIdToken: hasIdToken,
      isLoggedIn: isLoggedIn,
      isInClient: isInClient,
      currentPath: location.pathname,
    });

    if (!isLoggedIn) {
      if (!loginWithGuard()) {
        throw new Error('LINEログインを完了できませんでした。LINEアプリでQRコードを読み取り直すか、しばらくしてからもう一度お試しください。');
      }
      return null;
    }

    var token = liff.getIDToken();
    if (!token) {
      throw new Error('認証トークンを取得できませんでした。もう一度お試しください。');
    }

    // IDトークン失効対策。
    // LIFF は getIDToken() を自動更新しないため、ログインセッション(isLoggedIn)は
    // 残ったまま IDトークンだけ失効すると、上の未ログイン分岐に入らず失効トークンを
    // 使い続けてしまう（サーバー検証が 401 TOKEN_EXPIRED になり、LINEから開き直しても
    // セッションが生きているため直らない）。ここで exp を検査し、失効（間近）なら
    // 一度だけ再ログインして新しい IDトークンを取得する。
    try {
      var decoded = liff.getDecodedIDToken();
      var nowSec = Math.floor(Date.now() / 1000);
      if (decoded && decoded.exp && decoded.exp <= nowSec + 30) {
        _log('id token expired – recovering via re-login', { exp: decoded.exp, now: nowSec });
        if (handleTokenExpired()) return null; // logout+login でリダイレクト中
        // リトライ上限に達した場合は失効トークンのまま送信し、サーバー判定に委ねる
      } else {
        // 有効なトークンを取得できたので失効リトライガードを解除（次回の失効時に再回復可能に）
        try { sessionStorage.removeItem('liff_token_expired_retry'); } catch (_e) {}
      }
    } catch (_e) { /* decode 失敗時はそのまま送信しサーバー判定に委ねる */ }

    _log('auth ok', { isInClient: isInClient });
    _clearLoginResidue();
    return token;
  }

  /** 最新のIDトークンを返す（initLiffOrWebAuth呼び出し後のみ有効） */
  function getCurrentAuthToken() {
    if (typeof liff === 'undefined' || !liff.isLoggedIn()) return null;
    return liff.getIDToken();
  }

  /**
   * 未認証ならLINE Loginへリダイレクト（画面ロード時の先行呼び出し用）。
   * initLiffOrWebAuth と同じ動作。
   */
  async function requireLoginIfNeeded(liffId) {
    return initLiffOrWebAuth(liffId);
  }

  /**
   * IdToken expired 時のリカバリー。
   * sessionStorage で 1 回まで制限（無限ループ防止）。
   * @returns {boolean} true = リダイレクト中, false = リトライ上限に達したため中断
   */
  function handleTokenExpired() {
    var KEY = 'liff_token_expired_retry';
    if (sessionStorage.getItem(KEY)) {
      return false;
    }
    sessionStorage.setItem(KEY, '1');
    try { liff.logout(); } catch (_e) {}
    // OAuth 残渣を除去した redirectUri ＋ 試行上限つきで再ログイン（無限ループ防止）
    return loginWithGuard();
  }

  /**
   * LIFFクライアント内なら closeWindow()、外なら history.back()。
   * 閉じるボタンの共通処理。
   */
  function closeOrBack() {
    try {
      if (typeof liff !== 'undefined' &&
          typeof liff.isInClient === 'function' &&
          liff.isInClient()) {
        liff.closeWindow();
        return;
      }
    } catch (_e) {}
    window.history.back();
  }

  window.LiffAuth = {
    initLiffOrWebAuth:    initLiffOrWebAuth,
    getCurrentAuthToken:  getCurrentAuthToken,
    requireLoginIfNeeded: requireLoginIfNeeded,
    handleTokenExpired:   handleTokenExpired,
    loginWithGuard:       loginWithGuard,
    closeOrBack:          closeOrBack,
  };
}());
</script>

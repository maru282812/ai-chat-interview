<%#
  ランク昇格演出（共通パーシャル）

  段位アップ … バッジが遠くから着弾（スラム）＋紙吹雪・星・グレア・オーラ・凱旋2音。
  階級アップ … 「前の位のバッジが砕けて中から新バッジが出る」。旧バッジ登場→震えて発光チャージ→
               破砕（破片が放射状に飛散）＋白フラッシュ＋ショックウェーブ→中から新バッジが着弾。
               紙吹雪・星・ストリーマー増量、凱旋アルペジオ。
  マスター昇格(epic) … 上記に加え、光の柱・放射ズーム・破片＆紙吹雪増量・金×紫パレット・
               画面隅からの紙吹雪・ファンファーレ増強で最大化。

  依存: rank-icons.js（先に読み込むこと）。外部リクエストゼロ・CSP安全。

  使い方:
    RankCelebration.maybePlay(prevStatus, nextStatus)  … 昇格していれば演出。
    RankCelebration.play(prevStatus, nextStatus)        … 強制的に演出（デモ用）。
  status は pointStatusService の PointStatus（rank_code / rank_name / tier）。
%>
<style>
  .rkc-root { position: fixed; inset: 0; z-index: 2147483000; display: none;
    align-items: center; justify-content: center; overflow: hidden; --rkc-glow: #7ff0cf; }
  .rkc-root.on { display: flex; }

  .rkc-dim { position: absolute; inset: 0; opacity: 0; transition: opacity .3s ease;
    background: radial-gradient(circle at 50% 44%, rgba(12,36,28,.86), rgba(3,9,7,.97)); }
  .rkc-root.show .rkc-dim { opacity: 1; }
  .rkc-root.epic .rkc-dim { background: radial-gradient(circle at 50% 44%, rgba(30,16,52,.86), rgba(6,4,12,.98)); }

  /* 着弾時の白フラッシュ */
  .rkc-white { position: absolute; inset: 0; background: #fff; opacity: 0; pointer-events: none; z-index: 4; }
  .rkc-root.reveal .rkc-white { animation: rkc-white .5s ease-out; }
  @keyframes rkc-white { 0% { opacity: 0; } 10% { opacity: .85; } 100% { opacity: 0; } }

  /* 光条（ゴッドレイ）。show で早めに立ち上げ、雰囲気を作る */
  .rkc-rays, .rkc-rays2 { position: absolute; top: 50%; left: 50%; width: 160vmax; height: 160vmax;
    margin: -80vmax 0 0 -80vmax; opacity: 0; will-change: transform; pointer-events: none; z-index: 1; }
  .rkc-rays { background: conic-gradient(from 0deg,
      transparent 0 5deg, rgba(255,255,255,.10) 5deg 7deg, transparent 7deg 22deg,
      rgba(127,240,207,.10) 22deg 25deg, transparent 25deg 45deg); }
  .rkc-rays2 { background: conic-gradient(from 12deg,
      transparent 0 8deg, rgba(242,181,68,.12) 8deg 11deg, transparent 11deg 30deg); }
  .rkc-root.show .rkc-rays { animation: rkc-rayin .6s ease-out both, rkc-spin 26s linear infinite; }
  .rkc-root.show .rkc-rays2 { animation: rkc-rayin .7s ease-out .1s both, rkc-spin-r 34s linear infinite; }
  @keyframes rkc-rayin { 0% { opacity: 0; transform: scale(.35); } 100% { opacity: 1; transform: scale(1); } }
  @keyframes rkc-spin { to { transform: rotate(360deg); } }
  @keyframes rkc-spin-r { to { transform: rotate(-360deg); } }
  .rkc-root.classup .rkc-rays { filter: brightness(1.7) saturate(1.2); }
  .rkc-root.epic .rkc-rays { filter: brightness(2.1) saturate(1.35); }
  .rkc-root.epic .rkc-rays2 { filter: brightness(1.8); }

  /* 多重ショックウェーブ（着弾＝reveal 起点） */
  .rkc-shock { position: absolute; top: 50%; left: 50%; width: 40px; height: 40px; margin: -20px 0 0 -20px;
    border-radius: 50%; border: 4px solid rgba(255,255,255,.9); opacity: 0; pointer-events: none; z-index: 2; }
  .rkc-root.reveal .rkc-shock.s1 { animation: rkc-shock 1s ease-out .02s; }
  .rkc-root.reveal .rkc-shock.s2 { animation: rkc-shock 1.15s ease-out .14s; border-color: rgba(127,240,207,.85); }
  .rkc-root.reveal .rkc-shock.s3 { animation: rkc-shock 1.3s ease-out .28s; border-color: rgba(242,181,68,.8); }
  .rkc-root:not(.classup) .rkc-shock.s3 { display: none; }
  @keyframes rkc-shock {
    0% { opacity: .9; width: 40px; height: 40px; margin: -20px 0 0 -20px; border-width: 5px; }
    100% { opacity: 0; width: 96vmin; height: 96vmin; margin: -48vmin 0 0 -48vmin; border-width: 1px; }
  }

  /* epic 専用：光の柱（多層）＋放射ズーム */
  /* 外周ハロー（金→白→紫）。開いた瞬間に一気に立ち上がる（スラム）→ シマー → 減衰 */
  .rkc-pillar { position: absolute; top: 0; bottom: 0; left: 50%; width: 220px; margin-left: -110px;
    opacity: 0; z-index: 1; pointer-events: none; mix-blend-mode: screen; filter: blur(11px);
    transform: scaleY(0) scaleX(.4); transform-origin: center 44%;
    background: linear-gradient(to top, transparent, rgba(242,181,68,.42) 16%, rgba(255,255,255,.82) 45%, rgba(200,150,255,.55) 74%, transparent); }
  /* 高輝度の白コア */
  .rkc-pillar::before { content: ""; position: absolute; top: 0; bottom: 0; left: 50%; width: 78px; margin-left: -39px; filter: blur(3px);
    background: linear-gradient(to top, transparent, rgba(255,255,255,.98) 44%, rgba(255,255,255,.62) 72%, transparent); }
  /* 根元のブルーム（バッジの位置） */
  .rkc-pillar::after { content: ""; position: absolute; left: 50%; top: 44%; width: 380px; height: 240px; margin: -120px 0 0 -190px; filter: blur(12px);
    background: radial-gradient(ellipse, rgba(255,242,208,.92), rgba(210,160,255,.34) 44%, transparent 70%); }
  .rkc-root.epic.reveal .rkc-pillar { animation: rkc-pillar 2.6s cubic-bezier(.14,.9,.2,1) both; }
  @keyframes rkc-pillar {
    0% { opacity: 0; transform: scaleY(0) scaleX(.35); }
    7% { opacity: 1; transform: scaleY(1.12) scaleX(1.4); }
    18% { transform: scaleY(1) scaleX(1); }
    46% { opacity: .95; } 74% { opacity: .55; }
    100% { opacity: 0; transform: scaleY(1) scaleX(1.4); }
  }
  .rkc-root.epic.reveal .rkc-pillar::before { animation: rkc-pillarcore 2.6s ease-in-out both; }
  @keyframes rkc-pillarcore { 0% { opacity: .2; } 10% { opacity: 1; } 34% { opacity: .6; } 52% { opacity: 1; } 72% { opacity: .45; } 100% { opacity: 0; } }
  /* 立ち上がりの瞬間、根元から強い閃光 */
  .rkc-root.epic.reveal .rkc-pillar::after { animation: rkc-pillarbase 1.4s ease-out both; }
  @keyframes rkc-pillarbase { 0% { opacity: 0; transform: scale(.4); } 14% { opacity: 1; transform: scale(1.15); } 100% { opacity: 0; transform: scale(1.5); } }
  .rkc-zoom { position: absolute; top: 44%; left: 50%; width: 40px; height: 40px; margin: -20px 0 0 -20px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,.95), rgba(255,220,150,.4) 40%, transparent 70%); opacity: 0; z-index: 2; pointer-events: none; }
  .rkc-root.epic.reveal .rkc-zoom { animation: rkc-zoom .95s ease-out both; }
  @keyframes rkc-zoom { 0% { opacity: .95; transform: scale(.3); } 100% { opacity: 0; transform: scale(40); } }
  /* 立ち上がりの一撃：根元から一瞬だけ極細・高輝度のビーム */
  .rkc-beam { position: absolute; top: 0; bottom: 0; left: 50%; width: 46px; margin-left: -23px; opacity: 0; z-index: 2;
    pointer-events: none; mix-blend-mode: screen; filter: blur(2px); transform: scaleY(0); transform-origin: center 44%;
    background: linear-gradient(to top, transparent, rgba(255,255,255,1) 42%, rgba(255,255,255,.82) 70%, transparent); }
  .rkc-root.epic.reveal .rkc-beam { animation: rkc-beam .55s cubic-bezier(.1,.9,.2,1) both; }
  @keyframes rkc-beam { 0% { opacity: 0; transform: scaleY(0) scaleX(1.7); } 12% { opacity: 1; transform: scaleY(1.15) scaleX(1); } 45% { opacity: .7; } 100% { opacity: 0; transform: scaleY(1) scaleX(.6); } }

  .rkc-card { position: relative; z-index: 3; text-align: center; color: #fff; padding: 24px; }
  .rkc-shake { display: inline-block; }
  .rkc-root.reveal .rkc-shake { animation: rkc-shake .55s ease; }
  .rkc-root.epic.reveal .rkc-shake { animation: rkc-shake .75s ease; }
  @keyframes rkc-shake {
    0%,100% { transform: translate(0,0); } 12% { transform: translate(-10px,6px); }
    26% { transform: translate(9px,-5px); } 40% { transform: translate(-7px,4px); }
    56% { transform: translate(6px,-3px); } 72% { transform: translate(-4px,2px); } 86% { transform: translate(2px,-1px); }
  }

  .rkc-badgewrap { position: relative; width: 208px; height: 208px; margin: 0 auto 8px; display: grid; place-items: center; }
  .rkc-aura { position: absolute; inset: 0; margin: auto; width: 208px; height: 208px; border-radius: 50%;
    background: radial-gradient(circle, var(--rkc-glow) 0%, transparent 62%); opacity: 0; filter: blur(8px); z-index: 1; }
  .rkc-root.reveal .rkc-aura { animation: rkc-aurain .5s ease both, rkc-aurapulse 2.4s ease-in-out .6s infinite; }
  @keyframes rkc-aurain { from { opacity: 0; } to { opacity: .5; } }
  @keyframes rkc-aurapulse { 0%,100% { opacity: .38; transform: scale(1); } 50% { opacity: .7; transform: scale(1.1); } }
  .rkc-root.epic.reveal .rkc-aura { animation: rkc-aurain .5s ease both, rkc-aurapulse 2.2s ease-in-out .6s infinite; filter: blur(10px); }

  /* 旧バッジ（階級アップの前段：登場→震えて発光チャージ） */
  .rkc-oldbadge { position: absolute; inset: 0; margin: auto; width: 176px; height: 176px; display: none; place-items: center; z-index: 2; line-height: 0; }
  .rkc-oldbadge .rk-badge svg { width: 176px; height: 176px; }
  .rkc-root.show.classup:not(.reveal) .rkc-oldbadge { display: grid; animation: rkc-charge .8s ease-in both; }
  .rkc-root.reveal .rkc-oldbadge { display: none; }
  @keyframes rkc-charge {
    0% { transform: scale(.4); opacity: 0; } 28% { transform: scale(1); opacity: 1; filter: none; }
    50% { transform: scale(1.02) translate(-2px,1px); } 58% { transform: scale(1.03) translate(3px,-1px); }
    66% { transform: scale(1.04) translate(-3px,1px); } 74% { transform: scale(1.05) translate(2px,-2px); }
    85% { transform: scale(1.08); filter: brightness(1.7) drop-shadow(0 0 14px #fff); }
    100% { transform: scale(1.14); filter: brightness(2.4) drop-shadow(0 0 24px #fff); }
  }

  /* 破片（JSで生成。旧バッジのコピーを扇形に切って放射状に飛散） */
  .rkc-shatter { position: absolute; inset: 0; z-index: 3; pointer-events: none; }
  .rkc-shard { position: absolute; inset: 0; display: grid; place-items: center; opacity: 1;
    transition: transform .62s cubic-bezier(.2,.6,.3,1), opacity .62s ease; will-change: transform, opacity; }
  .rkc-shard .rk-badge svg { width: 176px; height: 176px; }

  /* 新バッジ（着弾＝reveal） */
  .rkc-badge { position: relative; z-index: 2; line-height: 0; opacity: 0; }
  .rkc-badge .rk-badge svg { width: 176px; height: 176px; }
  .rkc-root.reveal .rkc-badge { opacity: 1; animation: rkc-slam .72s cubic-bezier(.2,.9,.25,1) both, rkc-float 4s ease-in-out 1s infinite; }
  .rkc-root.epic.reveal .rkc-badge { animation: rkc-slam .85s cubic-bezier(.2,.9,.25,1) both, rkc-float 4s ease-in-out 1.1s infinite; }
  @keyframes rkc-slam {
    0% { transform: scale(2.7); opacity: 0; filter: blur(7px); }
    42% { opacity: 1; } 62% { transform: scale(.9); filter: blur(0); }
    80% { transform: scale(1.06); } 100% { transform: scale(1); }
  }
  @keyframes rkc-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  /* バッジ表面を走るグレア */
  .rkc-glare { position: absolute; inset: 0; z-index: 4; pointer-events: none;
    -webkit-mask: radial-gradient(circle at 50% 48%, #000 56%, transparent 62%);
    mask: radial-gradient(circle at 50% 48%, #000 56%, transparent 62%); overflow: hidden; opacity: 0; }
  .rkc-root.reveal .rkc-glare { opacity: 1; }
  .rkc-glare::after { content: ""; position: absolute; top: -40%; bottom: -40%; width: 34%; left: -60%;
    background: linear-gradient(100deg, transparent, rgba(255,255,255,.8), transparent); transform: skewX(-18deg); }
  .rkc-root.reveal .rkc-glare::after { animation: rkc-glare 2.8s ease-in-out .9s infinite; }
  @keyframes rkc-glare { 0%,52% { left: -60%; } 78%,100% { left: 150%; } }

  .rkc-kicker { font-size: 13px; font-weight: 800; letter-spacing: .22em; text-transform: uppercase;
    color: #ffe6b0; opacity: 0; text-shadow: 0 0 14px rgba(242,181,68,.6); }
  .rkc-root.reveal .rkc-kicker { animation: rkc-rise .5s ease .42s both; }
  .rkc-root.epic .rkc-kicker { color: #f0d8ff; text-shadow: 0 0 16px rgba(200,150,255,.7); }
  .rkc-title { font-size: 40px; font-weight: 900; margin-top: 4px; letter-spacing: -.01em; opacity: 0;
    background: linear-gradient(180deg,#ffffff,#ffe6b0); -webkit-background-clip: text; background-clip: text;
    color: transparent; filter: drop-shadow(0 3px 18px rgba(0,0,0,.5)); }
  .rkc-root.classup .rkc-title { font-size: 46px; }
  .rkc-root.epic .rkc-title { font-size: 52px; background: linear-gradient(180deg,#ffffff,#f0d8ff); -webkit-background-clip: text; background-clip: text; }
  .rkc-title .tier { -webkit-text-fill-color: #7ff0cf; }
  .rkc-root.reveal .rkc-title { animation: rkc-titlein .6s cubic-bezier(.34,1.56,.5,1) .52s both; }
  @keyframes rkc-titlein { 0% { opacity: 0; transform: scale(.55); } 70% { transform: scale(1.09); } 100% { opacity: 1; transform: scale(1); } }
  .rkc-sub { font-size: 13px; font-weight: 700; color: rgba(255,255,255,.78); margin-top: 10px; opacity: 0; }
  .rkc-sub .arw { color: #7ff0cf; margin: 0 7px; }
  .rkc-root.reveal .rkc-sub { animation: rkc-rise .5s ease .72s both; }
  .rkc-btn { margin-top: 24px; background: #fff; color: #0f3a2c; border: 0; border-radius: 999px;
    padding: 13px 32px; font-size: 15px; font-weight: 850; cursor: pointer; opacity: 0;
    box-shadow: 0 12px 30px -8px rgba(0,0,0,.55); }
  .rkc-root.reveal .rkc-btn { animation: rkc-rise .5s ease .92s both; }
  .rkc-btn:active { transform: scale(.97); }
  @keyframes rkc-rise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

  .rkc-fx { position: absolute; inset: 0; z-index: 2; pointer-events: none; }

  @media (prefers-reduced-motion: reduce) {
    .rkc-root.show .rkc-rays, .rkc-root.show .rkc-rays2, .rkc-root.reveal .rkc-white, .rkc-root.reveal .rkc-shock,
    .rkc-root.reveal .rkc-shake, .rkc-root.reveal .rkc-aura, .rkc-root.reveal .rkc-badge, .rkc-root.reveal .rkc-glare::after,
    .rkc-root.reveal .rkc-kicker, .rkc-root.reveal .rkc-title, .rkc-root.reveal .rkc-sub, .rkc-root.reveal .rkc-btn,
    .rkc-root.epic.reveal .rkc-pillar, .rkc-root.epic.reveal .rkc-pillar::before, .rkc-root.epic.reveal .rkc-pillar::after,
    .rkc-root.epic.reveal .rkc-beam, .rkc-root.epic.reveal .rkc-zoom { animation: none; }
    .rkc-badge, .rkc-kicker, .rkc-title, .rkc-sub, .rkc-btn { opacity: 1; }
    .rkc-aura { opacity: .4; }
  }
</style>
<script>
  (() => {
    'use strict';

    const ORDER = ['bronze', 'silver', 'gold', 'platinum', 'emerald', 'diamond', 'master', 'grandmaster'];
    const ROMAN = { 1: 'I', 2: 'II', 3: 'III' };

    function esc(v) {
      return String(v ?? '').replace(/[&<>"']/g, (c) => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
      ));
    }
    function rankIndex(code) { return ORDER.indexOf(String(code || '').toLowerCase()); }
    function isPromotion(prev, next) {
      if (!prev || !next) return false;
      const pi = rankIndex(prev.rank_code), ni = rankIndex(next.rank_code);
      if (pi < 0 || ni < 0) return false;
      if (ni > pi) return true;
      if (ni === pi) return (Number(next.tier) || 0) > (Number(prev.tier) || 0);
      return false;
    }
    function isClassUp(prev, next) { return rankIndex(next.rank_code) > rankIndex(prev.rank_code); }
    function label(status) {
      return esc(status.rank_name || '') + (status.tier ? ' <span class="tier">' + ROMAN[status.tier] + '</span>' : '');
    }
    function plainLabel(status) { return (status.rank_name || '') + (status.tier ? ' ' + ROMAN[status.tier] : ''); }
    function rankColor(code, key) {
      const c = (window.RankIcons && RankIcons.colors && RankIcons.colors[code]);
      return (c && c[key || 'base']) || '#7ff0cf';
    }

    let root = null, canvas = null, ctx = null, parts = [], raf = null, dismissT = null, breakT = null, active = false;
    let dpr = 1, lastMote = 0, ambient = false, w = 0, h = 0;
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    function ensureRoot() {
      if (root) return;
      root = document.createElement('div');
      root.className = 'rkc-root';
      root.innerHTML =
        '<div class="rkc-dim"></div>' +
        '<canvas class="rkc-fx"></canvas>' +
        '<div class="rkc-rays"></div><div class="rkc-rays2"></div>' +
        '<div class="rkc-pillar"></div><div class="rkc-beam"></div><div class="rkc-zoom"></div>' +
        '<div class="rkc-shock s1"></div><div class="rkc-shock s2"></div><div class="rkc-shock s3"></div>' +
        '<div class="rkc-white"></div>' +
        '<div class="rkc-card">' +
          '<div class="rkc-shake"><div class="rkc-badgewrap">' +
            '<span class="rkc-aura"></span>' +
            '<span class="rkc-oldbadge"></span>' +
            '<div class="rkc-shatter"></div>' +
            '<span class="rkc-badge"></span>' +
            '<span class="rkc-glare"></span>' +
          '</div></div>' +
          '<div class="rkc-kicker"></div>' +
          '<div class="rkc-title"></div>' +
          '<div class="rkc-sub"></div>' +
          '<button class="rkc-btn" type="button">つづける</button>' +
        '</div>';
      document.body.appendChild(root);
      canvas = root.querySelector('.rkc-fx');
      ctx = canvas.getContext('2d');
      root.querySelector('.rkc-dim').addEventListener('click', dismiss);
      root.querySelector('.rkc-btn').addEventListener('click', dismiss);
    }

    // ── 破砕：旧バッジのコピーを扇形に切り出し、放射状へ飛散させる ──
    function shatter(oldHTML, epic) {
      if (reduce) return;
      const cont = root.querySelector('.rkc-shatter');
      cont.innerHTML = '';
      const N = epic ? 14 : 12, step = 360 / N, R = 150, rad = Math.PI / 180;
      for (let i = 0; i < N; i++) {
        const a0 = i * step, a1 = (i + 1) * step, mid = (a0 + step / 2) * rad;
        const p0 = [50 + Math.cos(a0 * rad) * R, 50 + Math.sin(a0 * rad) * R];
        const p1 = [50 + Math.cos(a1 * rad) * R, 50 + Math.sin(a1 * rad) * R];
        const sh = document.createElement('div');
        sh.className = 'rkc-shard';
        const clip = 'polygon(50% 50%, ' + p0[0].toFixed(1) + '% ' + p0[1].toFixed(1) + '%, ' + p1[0].toFixed(1) + '% ' + p1[1].toFixed(1) + '%)';
        sh.style.clipPath = clip; sh.style.webkitClipPath = clip;
        sh.innerHTML = oldHTML;
        cont.appendChild(sh);
        const dist = (epic ? 150 : 110) + Math.random() * 130, rot = (Math.random() - 0.5) * 180;
        requestAnimationFrame(() => requestAnimationFrame(() => {
          sh.style.transform = 'translate(' + (Math.cos(mid) * dist).toFixed(1) + 'px,' + (Math.sin(mid) * dist + 34).toFixed(1) + 'px) rotate(' + rot.toFixed(1) + 'deg) scale(.68)';
          sh.style.opacity = '0';
        }));
      }
      setTimeout(() => { cont.innerHTML = ''; }, 950);
    }

    // ── パーティクル ──
    function sizeCanvas() {
      const rect = canvas.getBoundingClientRect();
      w = rect.width; h = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function ensureRaf() { if (!raf) raf = requestAnimationFrame(tick); }
    function addConfetti(cx, cy, n, colors, spread) {
      for (let i = 0; i < n; i++) {
        const a = Math.random() * Math.PI * 2, sp = 3 + Math.random() * spread;
        parts.push({ k: 'c', x: cx, y: cy, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp - 3,
          g: 0.14 + Math.random() * 0.1, s: 3 + Math.random() * 4.5, rot: Math.random() * 6,
          vr: (Math.random() - 0.5) * 0.5, c: colors[i % colors.length], life: 1, dl: 0.008 + Math.random() * 0.006, shape: Math.random() < 0.5 ? 0 : 1 });
      }
    }
    function addStars(cx, cy, n) {
      for (let i = 0; i < n; i++) {
        const a = Math.random() * Math.PI * 2, sp = 1 + Math.random() * 8;
        parts.push({ k: 's', x: cx, y: cy, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp - 1.5,
          g: 0.05, s: 5 + Math.random() * 7, rot: Math.random() * 6, vr: (Math.random() - 0.5) * 0.2,
          c: i % 3 ? '#fff' : '#ffe6b0', life: 1, dl: 0.006 + Math.random() * 0.006, tw: Math.random() * 6 });
      }
    }
    function addStreamers(cx, cy, n, colors) {
      for (let i = 0; i < n; i++) {
        const a = -Math.PI / 2 + (Math.random() - 0.5) * 2.4, sp = 6 + Math.random() * 9;
        parts.push({ k: 't', x: cx + (Math.random() - 0.5) * 40, y: cy, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp,
          g: 0.16, len: 16 + Math.random() * 20, wdt: 3 + Math.random() * 2, rot: a + Math.PI / 2,
          vr: (Math.random() - 0.5) * 0.1, sway: Math.random() * 6, swaySp: 0.08 + Math.random() * 0.06,
          c: colors[i % colors.length], life: 1, dl: 0.006 + Math.random() * 0.004, t0: 0 });
      }
    }
    function edgeCannon(colors) { // 画面下隅から内側上向きへ（epic）
      const origins = [[10, h - 6, -Math.PI / 3.2], [w - 10, h - 6, -Math.PI + Math.PI / 3.2]];
      for (const [ox, oy, base] of origins) {
        for (let i = 0; i < 60; i++) {
          const a = base + (Math.random() - 0.5) * 0.7, sp = 12 + Math.random() * 12;
          parts.push({ k: 'c', x: ox, y: oy, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp,
            g: 0.16 + Math.random() * 0.08, s: 3 + Math.random() * 4, rot: Math.random() * 6,
            vr: (Math.random() - 0.5) * 0.5, c: colors[i % colors.length], life: 1, dl: 0.006 + Math.random() * 0.004, shape: Math.random() < 0.5 ? 0 : 1 });
        }
      }
    }
    function pillarColumn() { // 柱の中を上昇する光の粒（epic）
      const cx = w / 2, band = 60;
      for (let i = 0; i < 130; i++) {
        parts.push({ k: 'up', x: cx + (Math.random() - 0.5) * band * (0.4 + Math.random()),
          y: h * (0.45 + Math.random() * 0.55), vx: (Math.random() - 0.5) * 0.6, vy: -(2.5 + Math.random() * 6),
          s: 1.4 + Math.random() * 3, c: Math.random() < 0.5 ? '#ffffff' : (Math.random() < 0.6 ? '#ffe6b0' : '#e6c7ff'),
          life: 0.7 + Math.random() * 0.6, dl: 0.004 + Math.random() * 0.004, ph: Math.random() * 6 });
      }
    }
    function climbRings() { // 柱を駆け上がる光のリング（epic）
      const cx = w / 2, cy = h * 0.42;
      for (let i = 0; i < 6; i++) {
        parts.push({ k: 'ring', x: cx, y: cy + 46, r: 14, vr: 1.5, vy: -(3 + i * 0.5),
          life: 1, dl: 0.012, delay: i * 7, t: 0, c: i % 2 ? '#ffe6b0' : '#e6c7ff' });
      }
    }
    function addDebris(cx, cy, base) { // 旧バッジの破片ダスト
      const cols = [base, '#dddddd', '#ffffff', '#999999'];
      for (let i = 0; i < 60; i++) {
        const a = Math.random() * Math.PI * 2, sp = 4 + Math.random() * 11;
        parts.push({ k: 'c', x: cx, y: cy, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp - 2,
          g: 0.2 + Math.random() * 0.12, s: 2 + Math.random() * 3.5, rot: Math.random() * 6,
          vr: (Math.random() - 0.5) * 0.6, c: cols[i % cols.length], life: 1, dl: 0.012 + Math.random() * 0.008, shape: 0 });
      }
    }
    function fireMain(mode) { // 'tier' | 'class' | 'epic'
      if (reduce) return;
      sizeCanvas();
      const cx = w / 2, cy = h * 0.42;
      if (mode === 'tier') {
        addConfetti(cx, cy, 120, ['#7ff0cf', '#42c896', '#ffffff', '#f2b544'], 8);
        addStars(cx, cy, 22);
      } else {
        const pal = mode === 'epic'
          ? ['#ffffff', '#f2b544', '#ffd98a', '#c9a2ff', '#9a63e6', '#7ff0cf']
          : ['#ffffff', '#f2b544', '#ffd98a', '#7ff0cf', '#42c896', '#c9a2ff', '#ff8fb0'];
        addConfetti(cx, cy, mode === 'epic' ? 340 : 240, pal, 12);
        addStars(cx, cy, mode === 'epic' ? 64 : 48);
        addStreamers(cx, cy, mode === 'epic' ? 36 : 26, pal);
        if (mode === 'epic') { edgeCannon(pal); pillarColumn(); climbRings(); }
      }
      ambient = true; lastMote = 0; ensureRaf();
    }
    function tick(now) {
      ctx.clearRect(0, 0, w, h);
      if (ambient && now - lastMote > 90) { lastMote = now; if (parts.length < 340) parts.push(mote()); }
      const glow = (getComputedStyle(root).getPropertyValue('--rkc-glow') || '#7ff0cf').trim();
      let alive = false;
      for (const p of parts) {
        if (p.life <= 0) continue;
        alive = true;
        if (p.k === 'c') {
          p.vy += p.g; p.vx *= 0.99; p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.life -= p.dl;
          ctx.save(); ctx.globalAlpha = Math.max(0, p.life); ctx.translate(p.x, p.y); ctx.rotate(p.rot); ctx.fillStyle = p.c;
          if (p.shape === 0) ctx.fillRect(-p.s / 2, -p.s / 2, p.s, p.s * 1.7);
          else { ctx.beginPath(); ctx.arc(0, 0, p.s / 1.5, 0, 7); ctx.fill(); }
          ctx.restore();
        } else if (p.k === 's') {
          p.vy += p.g; p.vx *= 0.98; p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.tw += 0.3; p.life -= p.dl;
          const tw = 0.55 + 0.45 * Math.sin(p.tw);
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = Math.max(0, p.life) * tw;
          ctx.translate(p.x, p.y); ctx.rotate(p.rot); ctx.fillStyle = p.c; ctx.shadowColor = p.c; ctx.shadowBlur = 8;
          star4(ctx, p.s); ctx.fill(); ctx.restore();
        } else if (p.k === 't') {
          p.t0 += 1; p.vy += p.g; p.vx *= 0.98; p.x += p.vx + Math.sin(p.t0 * p.swaySp) * p.sway * 0.15;
          p.y += p.vy; p.rot += p.vr + Math.sin(p.t0 * p.swaySp) * 0.03; p.life -= p.dl;
          ctx.save(); ctx.globalAlpha = Math.max(0, p.life); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
          ctx.fillStyle = p.c; roundRect(ctx, -p.wdt / 2, -p.len / 2, p.wdt, p.len, p.wdt / 2); ctx.fill(); ctx.restore();
        } else if (p.k === 'm') {
          p.y += p.vy; p.x += p.vx; p.ph += 0.05; p.life -= p.dl;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = Math.max(0, p.life) * (0.4 + 0.3 * Math.sin(p.ph));
          ctx.fillStyle = p.c === 'var' ? glow : p.c; ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, 7); ctx.fill(); ctx.restore();
        } else if (p.k === 'up') {
          p.y += p.vy; p.x += p.vx; p.ph += 0.2; p.life -= p.dl;
          if (p.y < h * 0.08) p.life = 0;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = Math.max(0, p.life) * (0.5 + 0.4 * Math.sin(p.ph));
          ctx.fillStyle = p.c; ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, 7); ctx.fill(); ctx.restore();
        } else if (p.k === 'ring') {
          if (p.t < p.delay) { p.t++; }
          else {
            p.y += p.vy; p.r += p.vr; p.life -= p.dl;
            ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = Math.max(0, p.life) * 0.7;
            ctx.strokeStyle = p.c; ctx.lineWidth = 2.4; ctx.beginPath();
            ctx.ellipse(p.x, p.y, p.r, p.r * 0.34, 0, 0, 7); ctx.stroke(); ctx.restore();
          }
        }
      }
      parts = parts.filter((p) => p.life > 0 && p.y < h + 40);
      if (alive || ambient) raf = requestAnimationFrame(tick);
      else { ctx.clearRect(0, 0, w, h); parts = []; raf = null; }
    }
    function mote() {
      return { k: 'm', x: Math.random() * w, y: h + 10, vx: (Math.random() - 0.5) * 0.4,
        vy: -(0.5 + Math.random() * 1.1), s: 1.5 + Math.random() * 2.5,
        c: Math.random() < 0.5 ? '#fff' : 'var', life: 1, dl: 0.004 + Math.random() * 0.003, ph: Math.random() * 6 };
    }
    function star4(c, r) {
      c.beginPath();
      for (let i = 0; i < 8; i++) { const a = i * Math.PI / 4, rr = i % 2 ? r * 0.34 : r;
        c[i ? 'lineTo' : 'moveTo'](Math.cos(a) * rr, Math.sin(a) * rr); }
      c.closePath();
    }
    function roundRect(c, x, y, ww, hh, r) {
      c.beginPath(); c.moveTo(x + r, y); c.arcTo(x + ww, y, x + ww, y + hh, r); c.arcTo(x + ww, y + hh, x, y + hh, r);
      c.arcTo(x, y + hh, x, y, r); c.arcTo(x, y, x + ww, y, r); c.closePath();
    }

    // ── ファンファーレ ──
    function fanfare(mode) {
      if (reduce) return;
      try {
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return;
        const ac = new AC();
        const out = ac.createGain(); out.gain.value = 0.9; out.connect(ac.destination);
        const beep = (f, t, d, type, vol) => {
          const osc = ac.createOscillator(), g = ac.createGain();
          osc.type = type || 'triangle'; osc.frequency.value = f;
          g.gain.setValueAtTime(0.0001, t);
          g.gain.exponentialRampToValueAtTime(vol || 0.16, t + 0.02);
          g.gain.exponentialRampToValueAtTime(0.0001, t + d);
          osc.connect(g); g.connect(out); osc.start(t); osc.stop(t + d + 0.02);
        };
        const t0 = ac.currentTime;
        if (mode === 'tier') {
          beep(659.25, t0, 0.22, 'triangle', 0.14);
          beep(987.77, t0 + 0.11, 0.5, 'triangle', 0.15);
        } else {
          const arp = [523.25, 659.25, 783.99, 1046.5, 1318.5, 1567.98];
          arp.forEach((f, i) => beep(f, t0 + i * 0.085, 0.4, 'triangle', 0.15));
          [523.25, 659.25, 783.99, 1046.5].forEach((f) => beep(f, t0 + 0.52, 0.95, 'sawtooth', 0.06));
          beep(2093, t0 + 0.6, 0.5, 'sine', 0.05);
          beep(2637, t0 + 0.72, 0.6, 'sine', 0.04);
          if (mode === 'epic') {
            beep(130.81, t0 + 0.5, 1.4, 'sawtooth', 0.09); // 低音の土台
            beep(196.0, t0 + 0.5, 1.4, 'sawtooth', 0.07);
            [1046.5, 1318.5, 1567.98, 2093].forEach((f, i) => beep(f, t0 + 0.95 + i * 0.08, 0.6, 'sine', 0.05)); // 高音の鐘
            beep(1046.5, t0 + 1.5, 1.3, 'sawtooth', 0.09); // 締めの大和音
            beep(1318.5, t0 + 1.5, 1.3, 'sawtooth', 0.08);
            beep(1567.98, t0 + 1.5, 1.3, 'sawtooth', 0.07);
          }
        }
        setTimeout(() => { try { ac.close(); } catch (e) {} }, mode === 'epic' ? 3200 : (mode === 'class' ? 1800 : 900));
      } catch (e) { /* 自動再生ブロック等は無視 */ }
    }

    function dismiss() {
      if (!active) return;
      active = false; ambient = false;
      clearTimeout(dismissT); clearTimeout(breakT);
      root.classList.remove('show', 'reveal');
      setTimeout(() => {
        root.classList.remove('on', 'classup', 'epic');
        root.querySelector('.rkc-shatter').innerHTML = '';
        parts = []; if (ctx) ctx.clearRect(0, 0, w, h);
        if (raf) { cancelAnimationFrame(raf); raf = null; }
      }, 400);
    }

    function play(prev, next) {
      if (!window.RankIcons || !next) return;
      ensureRoot();
      clearTimeout(dismissT); clearTimeout(breakT);
      root.classList.remove('show', 'reveal', 'classup', 'epic');
      root.querySelector('.rkc-shatter').innerHTML = '';
      active = true;

      const classUp = prev ? isClassUp(prev, next) : false;
      const epic = String(next.rank_code).toLowerCase() === 'master';
      const mode = epic ? 'epic' : (classUp ? 'class' : 'tier');
      const staged = classUp && !reduce; // 破砕演出を挟むか

      root.style.setProperty('--rkc-glow', rankColor(next.rank_code, 'base'));
      root.querySelector('.rkc-badge').innerHTML = RankIcons.badge(next.rank_code, next.tier || 1, 176);
      root.querySelector('.rkc-oldbadge').innerHTML = (prev && staged) ? RankIcons.badge(prev.rank_code, prev.tier || 1, 176) : '';
      root.querySelector('.rkc-kicker').textContent = epic ? '◆ 頂点到達 ◆' : (classUp ? '★ ランクアップ ★' : '段位アップ');
      root.querySelector('.rkc-title').innerHTML = label(next);
      root.querySelector('.rkc-sub').innerHTML = prev
        ? esc(plainLabel(prev)) + '<span class="arw">→</span>' + esc(plainLabel(next)) : '';

      root.classList.add('on');
      root.classList.toggle('classup', classUp);
      root.classList.toggle('epic', epic);
      void root.offsetWidth;

      requestAnimationFrame(() => requestAnimationFrame(() => {
        root.classList.add('show'); // dim・光条・（階級アップは旧バッジのチャージ）
        if (staged) {
          const oldBadgeHTML = root.querySelector('.rkc-oldbadge').innerHTML;
          breakT = setTimeout(() => {
            shatter(oldBadgeHTML, epic);
            if (!reduce) sizeCanvas(); // 破片ダストの前に寸法確定
            addDebris(w / 2, h * 0.42, rankColor(prev.rank_code, 'light'));
            root.classList.add('reveal'); // 新バッジ着弾・白フラッシュ・ショックウェーブ・タイトル
            fireMain(mode);
            fanfare(mode);
          }, 820);
        } else {
          setTimeout(() => {
            root.classList.add('reveal');
            fireMain(mode);
            fanfare(mode);
          }, reduce ? 0 : 150);
        }
      }));

      dismissT = setTimeout(dismiss, epic ? 7000 : (classUp ? 5800 : 3600));
    }

    function maybePlay(prev, next) { if (isPromotion(prev, next)) play(prev, next); }

    window.RankCelebration = { play, maybePlay, isPromotion };
  })();
</script>
